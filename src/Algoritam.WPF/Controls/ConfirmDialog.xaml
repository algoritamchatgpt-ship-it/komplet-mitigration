<Window x:Class="Algoritam.WPF.Controls.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potvrda"
        Width="420" Height="Auto" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F0F0F0">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Padding="16,10">
            <TextBlock x:Name="TxtNaslov"
                       FontFamily="Tahoma" FontSize="13" FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- Body -->
        <StackPanel Margin="24,20,24,10">
            <TextBlock x:Name="TxtPoruka"
                       FontFamily="Tahoma" FontSize="12"
                       Foreground="#37474F"
                       TextWrapping="Wrap"
                       LineHeight="20"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,10">
                <Button x:Name="BtnDa" Content="Da"
                        Width="80" Height="30" Margin="0,0,8,0"
                        FontFamily="Tahoma" FontSize="12" FontWeight="SemiBold"
                        Foreground="White" Background="#1565C0"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnDa_Click"/>
                <Button x:Name="BtnNe" Content="Ne"
                        Width="80" Height="30"
                        FontFamily="Tahoma" FontSize="12"
                        Foreground="White" Background="#546E7A"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnNe_Click"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
