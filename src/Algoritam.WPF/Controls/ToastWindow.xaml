<Window x:Class="Algoritam.WPF.Controls.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Focusable="False"
        IsHitTestVisible="False">

    <Window.Resources>
        <DoubleAnimation x:Key="FadeIn" From="0" To="1" Duration="0:0:0.2"/>
        <DoubleAnimation x:Key="FadeOut" From="1" To="0" Duration="0:0:0.3"/>
    </Window.Resources>

    <Border x:Name="ToastBorder"
            CornerRadius="6"
            Padding="14,10,14,10"
            MinWidth="180"
            MaxWidth="360"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.35" ShadowDepth="2" Direction="270"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="IkonicaText"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="PorukaText"
                       FontFamily="Tahoma"
                       FontSize="12"
                       Foreground="White"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="300"/>
        </StackPanel>
    </Border>
</Window>
