<UserControl x:Class="Algoritam.WPF.Views.Teh.TehMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="TehButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Width" Value="148"/>
            <Setter Property="Margin" Value="3,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap"
                                       TextAlignment="Center" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" Padding="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GrupaHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#455A64"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>
        <Style x:Key="SectionWrapPanelStyle" TargetType="WrapPanel">
            <Setter Property="Width" Value="924"/>
            <Setter Property="ItemWidth" Value="154"/>
            <Setter Property="ItemHeight" Value="58"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <SolidColorBrush x:Key="BojaGlavna"  Color="#00695C"/>
        <SolidColorBrush x:Key="BojaAdresni" Color="#00897B"/>
        <SolidColorBrush x:Key="BojaVirman"  Color="#37474F"/>
        <SolidColorBrush x:Key="BojaIzlaz"   Color="#C62828"/>
    </UserControl.Resources>

    <DockPanel Background="#F0F0F0">
        <Border DockPanel.Dock="Top" Background="#00695C" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GLAVNI MENI — REGISTAR VOZILA (TEH)"
                           FontFamily="Tahoma" FontSize="15" FontWeight="Bold" Foreground="White"/>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding FirmaNaziv}"
                               FontFamily="Tahoma" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" TextAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                        <TextBlock Text="{Binding FirmaMesto}"
                                   FontFamily="Tahoma" FontSize="10" Foreground="#80CBC4" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding FirmaPib}"
                                   FontFamily="Tahoma" FontSize="10" Foreground="#80CBC4"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="20,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Izlaz" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaIzlaz}"
                            Width="100" Height="38"
                            Command="{Binding IzlazCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="#E0F2F1"
                BorderThickness="0,0,0,1" BorderBrush="#B2DFDB" Padding="20,6"
                Visibility="{Binding ImaBrzoUlaz, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Poslednje otvoreno:"
                           FontFamily="Tahoma" FontSize="10" Foreground="#757575"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ItemsControl ItemsSource="{Binding BrzoUlazLista}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Naziv}"
                                    Command="{Binding DataContext.OtvoriBrzoUlazCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Height="26" Padding="10,0" Margin="0,0,6,0"
                                    FontFamily="Tahoma" FontSize="11"
                                    Foreground="White" Background="#00695C"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="20,12">
            <StackPanel HorizontalAlignment="Left">

                <TextBlock Text="Registar vozila" Style="{StaticResource GrupaHeaderStyle}"/>
                <WrapPanel Style="{StaticResource SectionWrapPanelStyle}">
                    <Button Content="REGISTRACIJA&#10;VOZILA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaGlavna}"
                            ToolTip="Glavna evidencija registrovanih vozila"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_REGISTAR"/>
                    <Button Content="GODIŠNJA&#10;EVIDENCIJA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaGlavna}"
                            ToolTip="Godišnja evidencija registracije/markica po vozilu"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_GODEVID"/>
                    <Button Content="NAPOMENE&#10;UZ VOZILO" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaGlavna}"
                            ToolTip="Dodatne napomene uz vozilo"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_NAPOMENE"/>
                </WrapPanel>

                <TextBlock Text="Šifarnici vozila" Style="{StaticResource GrupaHeaderStyle}"/>
                <WrapPanel Style="{StaticResource SectionWrapPanelStyle}">
                    <Button Content="BOJA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_BOJA"/>
                    <Button Content="GORIVO" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_GORIVO"/>
                    <Button Content="TIP / MODEL&#10;VOZILA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_TIP"/>
                    <Button Content="VRSTA&#10;VOZILA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_VRSTA"/>
                    <Button Content="ZEMLJA&#10;POREKLA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_ZEMLJA"/>
                    <Button Content="NOSIVOST" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_NOS"/>
                    <Button Content="ISPRAVNOST" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_ISPRAVNO"/>
                    <Button Content="VRSTA TEH.&#10;PREGLEDA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_VRPREG"/>
                    <Button Content="RAZLOG&#10;ODJAVE" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_RAZLOG"/>
                </WrapPanel>

                <TextBlock Text="Adresni šifarnici" Style="{StaticResource GrupaHeaderStyle}"/>
                <WrapPanel Style="{StaticResource SectionWrapPanelStyle}">
                    <Button Content="GRADOVI" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_GRAD"/>
                    <Button Content="OPŠTINE" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_OPST"/>
                    <Button Content="POŠTANSKI&#10;BROJEVI" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaAdresni}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_POSTA"/>
                </WrapPanel>

                <TextBlock Text="Virman nalozi za plaćanje" Style="{StaticResource GrupaHeaderStyle}"/>
                <WrapPanel Style="{StaticResource SectionWrapPanelStyle}">
                    <Button Content="VIRMAN&#10;NALOZI" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaVirman}"
                            ToolTip="Nalozi za plaćanje (npr. registracija, takse)"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_VIRMAN"/>
                    <Button Content="STAVKE&#10;VIRMANA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaVirman}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_VIRMSTAV"/>
                    <Button Content="SERIJE&#10;VIRMANA" Style="{StaticResource TehButtonStyle}"
                            Background="{StaticResource BojaVirman}"
                            Command="{Binding AkcijaCommand}" CommandParameter="TEH_VIRMSER"/>
                </WrapPanel>

                <Border Height="16"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
