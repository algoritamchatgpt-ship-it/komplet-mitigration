<Window x:Class="Algoritam.WPF.Views.Pdv.PdvKnjizenjeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1380" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#880E4F" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#F48FB1" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#FCE4EC" Padding="12,6"
                BorderThickness="0,0,0,1" BorderBrush="#F8BBD0">
            <WrapPanel>
                <TextBlock Text="Od:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumOd}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="Do:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumDo}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,16,0"/>
                <TextBlock Text="Konto:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterKonto, UpdateSourceTrigger=PropertyChanged}"
                         Width="90" Height="26" Padding="4,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <TextBlock Text="VPDV:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterVpdv, UpdateSourceTrigger=PropertyChanged}"
                         Width="50" Height="26" Padding="4,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#880E4F" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#F8BBD0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#FCE4EC"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FCE4EC"/>
                        <Setter Property="Foreground" Value="#880E4F"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#F8BBD0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Br. naloga" Binding="{Binding [BRNAL]}"  Width="90"/>
                    <DataGridTextColumn Header="Dat.PDV"
                                        Binding="{Binding [DATPDV], StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Dat.dok"
                                        Binding="{Binding [DATDOK], StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Konto"    Binding="{Binding [KONTO]}"   Width="90"/>
                    <DataGridTextColumn Header="Šifra"    Binding="{Binding [SIFRA]}"   Width="80"/>
                    <DataGridTextColumn Header="Br.računa" Binding="{Binding [BRRAC]}"  Width="110"/>
                    <DataGridTextColumn Header="Duguje" Binding="{Binding [DUG], StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Potražuje" Binding="{Binding [POT], StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="VPDV"   Binding="{Binding [VPDV]}"   Width="55"/>
                    <DataGridTextColumn Header="POPDV"  Binding="{Binding [POPDV]}"  Width="60"/>
                    <DataGridTextColumn Header="Dok"    Binding="{Binding [DOK]}"    Width="70"/>
                    <DataGridTextColumn Header="Opis"   Binding="{Binding [OPIS]}"   Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#FCE4EC" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#F8BBD0" Margin="0,4,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Ukupno dug:" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding UkupnoDug, StringFormat=N2}"
                               FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                               Foreground="#880E4F" VerticalAlignment="Center" MinWidth="120" TextAlignment="Right"
                               Margin="0,0,20,0"/>
                    <TextBlock Text="Ukupno pot:" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding UkupnoPot, StringFormat=N2}"
                               FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                               Foreground="#880E4F" VerticalAlignment="Center" MinWidth="120" TextAlignment="Right"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Osveži" Width="80" Height="28" Margin="0,0,6,0"
                            Command="{Binding OsveziCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Zatvori" Width="80" Height="28"
                            Command="{Binding ZatvoriCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
