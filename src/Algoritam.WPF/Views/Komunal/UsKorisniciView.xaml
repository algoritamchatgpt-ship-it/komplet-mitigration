<Window x:Class="Algoritam.WPF.Views.Komunal.UsKorisniciView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1200" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#37474F" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#B0BEC5" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#ECEFF1" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#CFD8DC">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Pretraga (ime / adresa / šifra):"
                           FontFamily="Tahoma" FontSize="11"
                           Foreground="#37474F" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                         Width="340" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#B0BEC5" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Korisnici}"
                      SelectedItem="{Binding IzabraniKorisnik}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#ECEFF1"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#ECEFF1"/>
                        <Setter Property="Foreground" Value="#37474F"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#B0BEC5"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Šifra"    Binding="{Binding [SIFRA]}"   Width="70"/>
                    <DataGridTextColumn Header="Ime"      Binding="{Binding [IME]}"     Width="180"/>
                    <DataGridTextColumn Header="Naziv"    Binding="{Binding [NAZIV]}"   Width="180"/>
                    <DataGridTextColumn Header="Adresa"   Binding="{Binding [ADRESA]}"  Width="180"/>
                    <DataGridTextColumn Header="Mesto"    Binding="{Binding [MESTO]}"   Width="100"/>
                    <DataGridTextColumn Header="Telefon"  Binding="{Binding [TELEFON]}" Width="110"/>
                    <DataGridTextColumn Header="JMBG/PIB" Binding="{Binding [JMBG]}"    Width="100"/>
                    <DataGridTextColumn Header="PIB"      Binding="{Binding [PIB]}"     Width="90"/>
                    <DataGridTextColumn Header="Konto"    Binding="{Binding [KONTO]}"   Width="90"/>
                    <DataGridTextColumn Header="Aktivan"  Binding="{Binding [AKTIVAN]}" Width="60"/>
                    <DataGridTextColumn Header="Stanje"   Binding="{Binding [STANJE], StringFormat=N2}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Opis"     Binding="{Binding [OPIS]}"    Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#F5F5F5" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Margin="0,6,0,0">
            <DockPanel>
                <Button Content="Osveži" DockPanel.Dock="Left"
                        Width="90" Height="30" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#37474F" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OsveziCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Zatvori" DockPanel.Dock="Right"
                        Width="90" Height="30" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#C62828" BorderThickness="0" Cursor="Hand"
                        Command="{Binding ZatvoriCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</Window>
