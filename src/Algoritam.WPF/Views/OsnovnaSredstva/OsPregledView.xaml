<Window x:Class="Algoritam.WPF.Views.OsnovnaSredstva.OsPregledView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1200" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <!-- Otpis panel -->
            <RowDefinition Height="Auto"/>
            <!-- Prenos panel -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#4527A0" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#CE93D8" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#EDE7F6" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#D1C4E9">
            <WrapPanel>
                <TextBlock Text="Naziv / šifra:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#4527A0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterNaziv, UpdateSourceTrigger=PropertyChanged}"
                         Width="260" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <TextBlock Text="Grupa:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#4527A0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterGrupa, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#4527A0" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#D1C4E9" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Sredstva}"
                      SelectedItem="{Binding IzabranoSredstvo}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#EDE7F6"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#EDE7F6"/>
                        <Setter Property="Foreground" Value="#4527A0"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#D1C4E9"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Inv.br"  Binding="{Binding [SIFOS]}"   Width="80"/>
                    <DataGridTextColumn Header="ID br"   Binding="{Binding [IDBR]}"    Width="60"/>
                    <DataGridTextColumn Header="Naziv"   Binding="{Binding [NAZIV]}"   Width="*"/>
                    <DataGridTextColumn Header="Grupa"   Binding="{Binding [GRBROJ]}"  Width="60"/>
                    <DataGridTextColumn Header="Dat.unos" Binding="{Binding [DATULAG], StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Nab.vred." Binding="{Binding [IZNOSULAG], StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Sad.vred." Binding="{Binding [SADASNJA], StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Pr.am."   Binding="{Binding [PAM], StringFormat=N2}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Način ob." Binding="{Binding [NACINOB]}" Width="80"/>
                    <DataGridTextColumn Header="Start am." Binding="{Binding [DATSTARTAM], StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Otpis"    Binding="{Binding [OTPIS]}"   Width="50"/>
                    <DataGridTextColumn Header="Dat.otpis" Binding="{Binding [DATOTPIS], StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Prenos"   Binding="{Binding [PRENOS]}"  Width="55"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Otpis panel — vidljiv samo u OsRezim.Otpis -->
        <Border Grid.Row="3" Background="#FFF8E1" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#FFE082"
                Visibility="{Binding JeOtpisRezim,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <WrapPanel>
                <TextBlock Text="Datum otpisa:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#E65100" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding DatumOtpisa}"
                            Height="26" Width="140" FontFamily="Tahoma" FontSize="11"
                            Margin="0,0,16,0"/>
                <Button Content="Otpiši selektovano"
                        Height="30" Padding="14,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#E65100" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OtpisiSelektovanoCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#9E9E9E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="← Izaberite OS iz liste"
                           FontFamily="Tahoma" FontSize="10" Foreground="#9E6A00"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Visibility="{Binding IzabranoSredstvo,
                               Converter={StaticResource NullToVisibilityConverter}}"/>
            </WrapPanel>
        </Border>

        <!-- Prenos panel — vidljiv samo u OsRezim.Prenos -->
        <Border Grid.Row="4" Background="#E8F5E9" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#A5D6A7"
                Visibility="{Binding JePrenosRezim,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <WrapPanel>
                <TextBlock Text="Nova grupa:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1B5E20" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding NovaGrupa, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <Button Content="Prenesi selektovano"
                        Height="30" Padding="14,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#2E7D32" BorderThickness="0" Cursor="Hand"
                        Command="{Binding PrenesSredstvoCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#9E9E9E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="← Izaberite OS iz liste"
                           FontFamily="Tahoma" FontSize="10" Foreground="#2E7D32"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Visibility="{Binding IzabranoSredstvo,
                               Converter={StaticResource NullToVisibilityConverter}}"/>
            </WrapPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="5" Background="#F5F5F5" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Margin="0,6,0,0">
            <DockPanel>
                <Button Content="Osveži" DockPanel.Dock="Left"
                        Width="90" Height="30" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#4527A0" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OsveziCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Izmeni" DockPanel.Dock="Left" Margin="6,0,0,0"
                        Width="90" Height="30" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#1565C0" BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding JePregledRezim, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding IzmeniCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Zatvori" DockPanel.Dock="Right"
                        Width="90" Height="30" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#C62828" BorderThickness="0" Cursor="Hand"
                        Command="{Binding ZatvoriCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</Window>
