<Window x:Class="Algoritam.WPF.Views.PocetniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ALGORITAM FIN"
        Width="760" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" ClipToBounds="True">
        <Grid>

            <!-- Pozadina -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1B2A" Offset="0"/>
                        <GradientStop Color="#1B3A5C" Offset="0.5"/>
                        <GradientStop Color="#0D1B2A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Dekorativni okvir (kao shapes iz FoxPro) -->
            <Rectangle VerticalAlignment="Top"    Height="6" Fill="#C62828"/>
            <Rectangle VerticalAlignment="Bottom" Height="6" Fill="#C62828"/>
            <Rectangle HorizontalAlignment="Left"  Width="6" Fill="#C62828" Margin="0,6,0,6"/>
            <Rectangle HorizontalAlignment="Right" Width="6" Fill="#C62828" Margin="0,6,0,6"/>

            <!-- X dugme -->
            <Button x:Name="BtnZatvori"
                    Width="28" Height="28"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,16,0"
                    Cursor="Hand" FontSize="13" FontWeight="Bold"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <TextBlock x:Name="Txt" Text="✕" Foreground="#90A4AE"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="Bold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C62828"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Sadrzaj -->
            <Grid Margin="36,20,36,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Naslov -->
                    <RowDefinition Height="*"/>     <!-- Centar / ULAZ -->
                    <RowDefinition Height="Auto"/>  <!-- FIN putanja zona -->
                    <RowDefinition Height="Auto"/>  <!-- Arhiva putanja zona -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- ═══ NASLOV ═══ -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,4,0,0">

                    <!-- Ikonica programa -->
                    <Border HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Border.Effect>
                            <DropShadowEffect Color="#C62828" BlurRadius="28"
                                             Opacity="0.55" ShadowDepth="0"/>
                        </Border.Effect>
                        <Image Source="/Assets/app-icon-zarade.png"
                               Width="82" Height="82"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <TextBlock Text="ALGORITAM FIN"
                               FontFamily="Tahoma" FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#EF9A9A" Offset="0"/>
                                <GradientStop Color="White"   Offset="0.5"/>
                                <GradientStop Color="#EF9A9A" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Finansijski informacioni sistem"
                               FontFamily="Tahoma" FontSize="11"
                               Foreground="#90A4AE"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- ═══ CENTAR: dugme ULAZ ═══ -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                    <Rectangle Height="1" Width="180" Margin="0,0,0,28" HorizontalAlignment="Center">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#C62828"     Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Button x:Name="BtnUlaz" Width="180" Height="50" Cursor="Hand" IsDefault="True"
                            IsEnabled="{Binding PutanjaPostavljena}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#C62828" CornerRadius="25"
                                        BorderThickness="2" BorderBrush="#EF9A9A">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="▶" FontSize="13" Foreground="White"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="ULAZ" FontFamily="Tahoma" FontSize="16"
                                                   FontWeight="Bold" Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E53935"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Hint kada putanja nije postavljena -->
                    <TextBlock Text="Najpre postavite putanju do FIN-a"
                               FontFamily="Tahoma" FontSize="10"
                               Foreground="#EF9A9A"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Visibility="{Binding PutanjaPostavljena,
                                   Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <Rectangle Height="1" Width="180" Margin="0,28,0,0" HorizontalAlignment="Center">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#C62828"     Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </StackPanel>

                <!-- ═══ PUTANJA ZONA ═══ -->
                <Border Grid.Row="2"
                        Background="#0A1520" CornerRadius="6"
                        Padding="14,10" Margin="0,0,0,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Label -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Putanja:"
                                   FontFamily="Tahoma" FontSize="10"
                                   Foreground="#546E7A" Margin="0,0,0,3"/>

                        <!-- Putanja + status ikonica -->
                        <StackPanel Grid.Row="1" Grid.Column="0"
                                    Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9"
                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <Binding Path="PutanjaBoja"/>
                                </Border.Background>
                                <TextBlock Text="{Binding PutanjaIkonica}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#1B3A5C"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding PutanjaPrikazana}"
                                       FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Foreground>
                                    <Binding Path="PutanjaBoja"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>

                        <!-- Dugme Postavi putanju -->
                        <Button Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="2"
                                x:Name="BtnPostavi"
                                Content="Postavi putanju..."
                                FontFamily="Tahoma" FontSize="11"
                                Foreground="#90A4AE"
                                Background="Transparent"
                                BorderBrush="#37474F"
                                BorderThickness="1"
                                Padding="10,6"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Command="{Binding PostaviPutanjuCommand}"/>

                        <!-- Status / greška -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding StatusPoruka}"
                                   FontFamily="Tahoma" FontSize="10"
                                   Foreground="#EF9A9A"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding StatusPoruka,
                                        Converter={StaticResource StringToVisibilityConverter}}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="Kliknite ovde ako nemate FIN instalaciju"
                                   FontFamily="Tahoma"
                                   FontSize="10"
                                   Foreground="#90CAF9"
                                   Margin="0,6,0,0"
                                   TextDecorations="Underline"
                                   Cursor="Hand">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding KreirajLokalnuFinInstalacijuCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- ═══ ARHIVA PUTANJA ═══ -->
                <Border Grid.Row="3"
                        Background="#0A1520" CornerRadius="6"
                        Padding="14,10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Folder za arhiviranje:"
                                   FontFamily="Tahoma" FontSize="10"
                                   Foreground="#546E7A" Margin="0,0,0,3"/>

                        <StackPanel Grid.Row="1" Grid.Column="0"
                                    Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9"
                                    Margin="0,0,8,0" VerticalAlignment="Center"
                                    Background="{Binding ArhivaPutanjaBoja}">
                                <TextBlock Text="{Binding ArhivaPutanjaIkonica}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#1B3A5C"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding ArhivaPutanjaPrikazana}"
                                       FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{Binding ArhivaPutanjaBoja}"/>
                        </StackPanel>

                        <Button Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="2"
                                Content="Postavi arhivu..."
                                FontFamily="Tahoma" FontSize="11"
                                Foreground="#90A4AE"
                                Background="Transparent"
                                BorderBrush="#37474F"
                                BorderThickness="1"
                                Padding="10,6"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Command="{Binding PostaviArhivaPutanjuCommand}"/>
                    </Grid>
                </Border>

                <!-- ═══ FOOTER ═══ -->
                <Grid Grid.Row="4">
                    <TextBlock Text="Agencija Kocka  ·  Paraćin  ·  063/601-025"
                               FontFamily="Tahoma" FontSize="10"
                               Foreground="#37474F" HorizontalAlignment="Center"/>
                    <TextBlock Text="Verzija 2025.1"
                               FontFamily="Tahoma" FontSize="10"
                               Foreground="#37474F" HorizontalAlignment="Right"/>
                </Grid>

            </Grid>
        <!-- ═══ LOADING OVERLAY ═══ -->
        <Border CornerRadius="8"
                Background="#CC0D1B2A"
                Panel.ZIndex="20"
                Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="280" Height="4"
                             Foreground="#C62828"
                             Background="#1B3A5C"
                             BorderThickness="0"
                             Margin="0,0,0,16"/>
                <TextBlock Text="{Binding StatusPoruka}"
                           FontFamily="Tahoma" FontSize="12"
                           Foreground="#EF9A9A"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="300"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        </Grid>
    </Border>
</Window>
