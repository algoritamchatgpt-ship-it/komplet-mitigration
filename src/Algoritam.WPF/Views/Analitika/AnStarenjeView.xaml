<Window x:Class="Algoritam.WPF.Views.Analitika.AnStarenjeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1340" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#006064" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#80DEEA" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#E0F7FA" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#80DEEA">
            <WrapPanel>
                <TextBlock Text="Konto:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#006064" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterKonto, UpdateSourceTrigger=PropertyChanged}"
                         Width="110" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <TextBlock Text="Partner:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#006064" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterPartner, UpdateSourceTrigger=PropertyChanged}"
                         Width="220" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#006064" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#CFD8DC" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#E0F7FA"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0F7FA"/>
                        <Setter Property="Foreground" Value="#006064"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#80DEEA"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Konto"    Binding="{Binding [KONTO]}"   Width="80"/>
                    <DataGridTextColumn Header="Šifra"    Binding="{Binding [SIFRA]}"   Width="70"/>
                    <DataGridTextColumn Header="Naziv"    Binding="{Binding [NAZIV]}"   Width="160"/>
                    <DataGridTextColumn Header="Br.rac."  Binding="{Binding [BRRAC]}"   Width="110"/>
                    <DataGridTextColumn Header="Dat.dok"  Binding="{Binding [DATDOK], StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Dat.val"  Binding="{Binding [DATVRED], StringFormat='dd.MM.yyyy'}" Width="90"/>
                    <DataGridTextColumn Header="Saldo" Binding="{Binding [SALDO], StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Dani"     Binding="{Binding [DANI]}"    Width="55"/>
                    <DataGridTextColumn Header="Razred"   Binding="{Binding [RAZRED]}"  Width="60"/>
                    <DataGridTextColumn Header="0-30"   Binding="{Binding [S30],  StringFormat=N2}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="31-60"  Binding="{Binding [S60],  StringFormat=N2}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="61-90"  Binding="{Binding [S90],  StringFormat=N2}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="91-120" Binding="{Binding [S120], StringFormat=N2}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="120+"   Binding="{Binding [S120P], StringFormat=N2}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#E0F7FA" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#80DEEA" Margin="0,4,0,0">
            <DockPanel>
                <TextBlock Text="{Binding Stavke.Count, StringFormat='Zapisa: {0}'}"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"
                           Foreground="#006064" Margin="0,0,20,0"/>
                <Button Content="Osveži" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding OsveziCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="80" Height="28"
                        Command="{Binding ZatvoriCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
