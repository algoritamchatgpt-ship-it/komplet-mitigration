<Window x:Class="Algoritam.WPF.Views.GlavnaKnjiga.GkKontniPlanView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KONTNI PLAN"
        Width="1280" Height="740"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#004D40" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="KONTNI PLAN"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#80CBC4" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="#E0F2F1" Padding="12,6"
                BorderThickness="0,0,0,1" BorderBrush="#B2DFDB">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Konto:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#546E7A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterKonto, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"/>
                <TextBlock Text="Naziv:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#546E7A" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <TextBox Text="{Binding FilterNaziv, UpdateSourceTrigger=PropertyChanged}"
                         Width="280" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Data grid -->
        <DataGrid x:Name="MainDataGrid"
                  Grid.Row="2"
                  Margin="8,8,8,0"
                  ItemsSource="{Binding Konta}"
                  SelectedItem="{Binding IzabranoKonto, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F5F5F5"
                  RowBackground="White"
                  BorderThickness="1" BorderBrush="#CFD8DC"
                  FontFamily="Tahoma" FontSize="12"
                  SelectionMode="Single"
                  EnableRowVirtualization="True">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0F2F1"/>
                    <Setter Property="Foreground" Value="#004D40"/>
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#B2DFDB"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Konto"  Binding="{Binding Konto}"  Width="80"/>
                <DataGridTextColumn Header="Naziv"  Binding="{Binding Naziv}"  Width="200"/>
                <DataGridTextColumn Header="Nivo 1" Binding="{Binding Kn1}"    Width="220"/>
                <DataGridTextColumn Header="Nivo 2" Binding="{Binding Kn2}"    Width="220"/>
                <DataGridTextColumn Header="Nivo 3" Binding="{Binding Kn3}"    Width="220"/>
                <DataGridTextColumn Header="Nivo 4" Binding="{Binding Kn4}"    Width="220"/>
                <DataGridTextColumn Header="Nivo 5" Binding="{Binding Kn5}"    Width="200"/>
                <DataGridTextColumn Header="Nivo 6" Binding="{Binding Kn6}"    Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom bar -->
        <Border Grid.Row="3" Background="#E0F2F1" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#B2DFDB" Margin="0,6,0,0">
            <DockPanel>
                <!-- Navigation left -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,16,0">
                    <Button Content="◀◀ Prvo"  Width="84" Height="28" Margin="0,0,4,0"
                            Command="{Binding PrvoCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="▲ Gore"   Width="84" Height="28" Margin="0,0,4,0"
                            Command="{Binding GoreCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="▼ Dole"   Width="84" Height="28" Margin="0,0,4,0"
                            Command="{Binding DoleCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Zadnje ▶▶" Width="90" Height="28"
                            Command="{Binding ZadnjeCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <!-- Osveži + Izlaz right -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Osveži" Width="80" Height="28" Margin="0,0,6,0"
                            Command="{Binding OsveziCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Izlaz" Width="80" Height="28"
                            Command="{Binding ZatvoriCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
