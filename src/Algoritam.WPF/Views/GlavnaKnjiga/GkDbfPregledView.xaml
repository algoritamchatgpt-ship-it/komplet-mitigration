<Window x:Class="Algoritam.WPF.Views.GlavnaKnjiga.GkDbfPregledView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1100" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{Binding BojaHeaderBrush}" Padding="16,10">
            <TextBlock Text="{Binding Naslov}"
                       FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Filter traka -->
        <Border Grid.Row="1" Background="{Binding BojaLightBrush}" Padding="12,6"
                BorderThickness="0,0,0,1" BorderBrush="#C5CAE9">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Pretraga:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#546E7A" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                         Width="300" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12"
                         VerticalContentAlignment="Center"/>
                <TextBlock Text="{Binding StatusPoruka}" FontFamily="Tahoma" FontSize="11"
                           Foreground="#546E7A" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0">
            <Grid>
                <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Top"
                             Foreground="{Binding BojaHeaderBrush}" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <DataGrid x:Name="MainDataGrid"
                          ItemsSource="{Binding Stavke}"
                          SelectedItem="{Binding IzabranaStavka}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F5F5F5"
                          RowBackground="White"
                          BorderThickness="1" BorderBrush="#CFD8DC"
                          FontFamily="Tahoma" FontSize="12"
                          SelectionMode="Single"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{Binding DataContext.BojaLightBrush,
                                RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="Foreground" Value="{Binding DataContext.BojaHeaderBrush,
                                RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="FontFamily" Value="Tahoma"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#C5CAE9"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#F5F5F5" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Margin="0,6,0,0">
            <DockPanel>
                <Button Content="Osveži"
                        DockPanel.Dock="Left"
                        Width="90" Height="30"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="{Binding BojaHeaderBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding OsveziCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Dodaj"
                        DockPanel.Dock="Left" Margin="6,0,0,0"
                        Width="90" Height="30"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#2E7D32"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding DozvoljenaIzmena, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding DodajCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Izmeni"
                        DockPanel.Dock="Left" Margin="6,0,0,0"
                        Width="90" Height="30"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#1565C0"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding DozvoljenaIzmena, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding IzmeniCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Obriši"
                        DockPanel.Dock="Left" Margin="6,0,0,0"
                        Width="90" Height="30"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#E65100"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding DozvoljenaIzmena, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding ObrisiCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Zatvori"
                        DockPanel.Dock="Right"
                        Width="90" Height="30"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#C62828"
                        BorderThickness="0" Cursor="Hand"
                        IsCancel="True"
                        Command="{Binding ZatvoriCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</Window>
