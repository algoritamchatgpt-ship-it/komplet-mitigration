<Window x:Class="Algoritam.WPF.Views.GlavnaKnjiga.GkZakljucakView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1300" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#37474F" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#B0BEC5" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#ECEFF1" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#CFD8DC">
            <WrapPanel>
                <TextBlock Text="Konto:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#37474F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterKonto, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <TextBlock Text="Naziv:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#37474F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterNaziv, UpdateSourceTrigger=PropertyChanged}"
                         Width="240" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#37474F" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#CFD8DC" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#ECEFF1"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#ECEFF1"/>
                        <Setter Property="Foreground" Value="#37474F"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#B0BEC5"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Konto"    Binding="{Binding [KONTO]}"    Width="90"/>
                    <DataGridTextColumn Header="Naziv"    Binding="{Binding [NAZIV]}"    Width="*"/>
                    <DataGridTextColumn Header="Poc.dug" Binding="{Binding [POC_DUG], StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Poc.pot" Binding="{Binding [POC_POT], StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Prom.dug" Binding="{Binding [PROM_DUG], StringFormat=N2}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Prom.pot" Binding="{Binding [PROM_POT], StringFormat=N2}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Zak.dug" Binding="{Binding [ZAK_DUG], StringFormat=N2}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Zak.pot" Binding="{Binding [ZAK_POT], StringFormat=N2}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MTR"   Binding="{Binding [MTR]}"   Width="50"/>
                    <DataGridTextColumn Header="Obj."  Binding="{Binding [OBJEKAT]}" Width="50"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#ECEFF1" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#CFD8DC" Margin="0,4,0,0">
            <DockPanel>
                <TextBlock Text="{Binding Stavke.Count, StringFormat='Konta: {0}'}"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"
                           Foreground="#37474F" Margin="0,0,20,0"/>
                <Button Content="Osveži" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding OsveziCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="80" Height="28"
                        Command="{Binding ZatvoriCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
