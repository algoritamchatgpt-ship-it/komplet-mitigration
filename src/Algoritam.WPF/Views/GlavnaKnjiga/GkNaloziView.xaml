<Window x:Class="Algoritam.WPF.Views.GlavnaKnjiga.GkNaloziView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1380" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A237E" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="PREGLED NALOGA"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#9FA8DA" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="#E8EAF6" Padding="12,6"
                BorderThickness="0,0,0,1" BorderBrush="#C5CAE9">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Pretraga:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#546E7A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                         Width="260" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"/>
                <TextBlock Text="(br. naloga, vrsta, opis)"
                           FontFamily="Tahoma" FontSize="10" Foreground="#9E9E9E"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Zaglavlja naloga -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#C5CAE9" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#E8EAF6" Padding="8,4">
                    <TextBlock Text="ZAGLAVLJA NALOGA"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold" Foreground="#1A237E"/>
                </Border>
                <DataGrid x:Name="NaloziGrid"
                          Grid.Row="1"
                          ItemsSource="{Binding Nalozi}"
                          SelectedItem="{Binding IzabraniNalog, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F5F5F5"
                          RowBackground="White"
                          BorderThickness="0"
                          FontFamily="Tahoma" FontSize="12"
                          SelectionMode="Single"
                          EnableRowVirtualization="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#E8EAF6"/>
                            <Setter Property="Foreground" Value="#1A237E"/>
                            <Setter Property="FontFamily" Value="Tahoma"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#C5CAE9"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Br. naloga" Binding="{Binding BrNal}"  Width="90"/>
                        <DataGridTextColumn Header="Datum"  Binding="{Binding Datum, StringFormat='dd.MM.yyyy'}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Vrsta"  Binding="{Binding VrNal}"  Width="70"/>
                        <DataGridTextColumn Header="Opis"   Binding="{Binding Opis}"   Width="*"/>
                        <DataGridTextColumn Header="Duguje" Binding="{Binding Dug, StringFormat=N2}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Potražuje" Binding="{Binding Pot, StringFormat=N2}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Dat. knjiz." Binding="{Binding DatKnji, StringFormat='dd.MM.yyyy'}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Pren." Binding="{Binding Preneto}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                      Background="#C5CAE9" ResizeDirection="Rows"/>

        <!-- Stavke naloga -->
        <Border Grid.Row="4" Margin="8,0,8,0" BorderBrush="#CFD8DC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="#FFF3E0" Padding="8,4">
                    <TextBlock Text="STAVKE NALOGA"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold" Foreground="#E65100"/>
                </Border>
                <DataGrid x:Name="StavkeGrid"
                          Grid.Row="1"
                          ItemsSource="{Binding Stavke}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#FFF8E1"
                          RowBackground="White"
                          BorderThickness="0"
                          FontFamily="Tahoma" FontSize="12"
                          SelectionMode="Single"
                          EnableRowVirtualization="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFF3E0"/>
                            <Setter Property="Foreground" Value="#E65100"/>
                            <Setter Property="FontFamily" Value="Tahoma"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#FFCC80"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Konto" Binding="{Binding Konto}" Width="90"/>
                        <DataGridTextColumn Header="Duguje" Binding="{Binding Dug, StringFormat=N2}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Potražuje" Binding="{Binding Pot, StringFormat=N2}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DodDug" Binding="{Binding DodDug, StringFormat=N2}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DodPot" Binding="{Binding DodPot, StringFormat=N2}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Opis"    Binding="{Binding Opis}"   Width="*"/>
                        <DataGridTextColumn Header="Dat.dok" Binding="{Binding DatDok, StringFormat='dd.MM.yyyy'}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Dok"   Binding="{Binding Dok}"   Width="60"/>
                        <DataGridTextColumn Header="Br.dok" Binding="{Binding BrDok}" Width="90"/>
                        <DataGridTextColumn Header="MP"    Binding="{Binding Mp}"    Width="50"/>
                        <DataGridTextColumn Header="Dev"   Binding="{Binding Dev}"   Width="50"/>
                        <DataGridTextColumn Header="Kurs"  Binding="{Binding DevKurs, StringFormat=N4}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
                <!-- Stavke totals -->
                <Border Grid.Row="2" Background="#FFF3E0" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Ukupno dug:" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding UkupnoDug, StringFormat=N2}"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#E65100" VerticalAlignment="Center" MinWidth="100"
                                   TextAlignment="Right" Margin="0,0,20,0"/>
                        <TextBlock Text="Ukupno pot:" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding UkupnoPot, StringFormat=N2}"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#E65100" VerticalAlignment="Center" MinWidth="100"
                                   TextAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="5" Background="#E8EAF6" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#C5CAE9" Margin="0,4,0,0">
            <DockPanel>
                <Button Content="Osveži" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding OsveziCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Izmeni" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding IzmeniCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="80" Height="28"
                        Command="{Binding ZatvoriCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
