<Window x:Class="Algoritam.WPF.Views.GlavnaKnjiga.GkZnBilansView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1180" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A237E" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#9FA8DA" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#E8EAF6" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#C5CAE9">
            <WrapPanel>
                <TextBlock Text="Pretraga:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#3949AB" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                         Width="300" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#3949AB" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#CFD8DC" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Pozicije}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#E8EAF6"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E8EAF6"/>
                        <Setter Property="Foreground" Value="#1A237E"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#C5CAE9"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="AOP"    Binding="{Binding [AOP]}"    Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1A237E"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Pozicija"  Binding="{Binding [NAZIV]}"   Width="*"/>
                    <DataGridTextColumn Header="Tekuća" Binding="{Binding [TEKUCA], StringFormat=N2}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Prethodna" Binding="{Binding [PRETHODNA], StringFormat=N2}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="KONTO"  Binding="{Binding [KONTO]}"   Width="90"/>
                    <DataGridTextColumn Header="Nivo"   Binding="{Binding [NIVO]}"    Width="45"/>
                    <DataGridTextColumn Header="Bilans" Binding="{Binding [BILANS]}"  Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#E8EAF6" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#C5CAE9" Margin="0,4,0,0">
            <DockPanel>
                <TextBlock Text="{Binding Pozicije.Count, StringFormat='Pozicija: {0}'}"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1A237E" Margin="0,0,20,0"/>
                <Button Content="Osveži" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding OsveziCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="80" Height="28"
                        Command="{Binding ZatvoriCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
