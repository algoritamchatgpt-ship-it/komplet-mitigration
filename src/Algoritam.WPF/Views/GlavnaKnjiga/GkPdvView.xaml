<Window x:Class="Algoritam.WPF.Views.GlavnaKnjiga.GkPdvView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1500" Height="740"
        WindowStartupLocation="CenterScreen"
        Background="#FDF8FF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#880E4F" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#F48FB1" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#FCE4EC" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#F8BBD0">
            <WrapPanel>
                <TextBlock Text="Od:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumOd}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="Do:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumDo}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,16,0"/>
                <TextBlock Text="Šifra:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterSifra, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" Height="26" Padding="4,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,12,0"/>
                <TextBlock Text="Dok:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterDok, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" Height="26" Padding="4,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,12,0"/>
                <TextBlock Text="Vrsta PDV:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterVpdv, UpdateSourceTrigger=PropertyChanged}"
                         Width="60" Height="26" Padding="4,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#880E4F" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#F8BBD0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Stavke}"
                      SelectedItem="{Binding IzabranaStavka}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#FCE4EC"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FCE4EC"/>
                        <Setter Property="Foreground" Value="#880E4F"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#F8BBD0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <!-- Identifikacija -->
                    <DataGridTextColumn Header="Br.nal"    Binding="{Binding [BRNAL]}"   Width="80"/>
                    <DataGridTextColumn Header="Dat.dok"   Binding="{Binding [DATDOK], StringFormat='dd.MM.yyyy'}"  Width="90"/>
                    <DataGridTextColumn Header="Dat.PDV"   Binding="{Binding [DATPDV], StringFormat='dd.MM.yyyy'}"  Width="90"/>
                    <DataGridTextColumn Header="Dat.pri"   Binding="{Binding [DATPRI], StringFormat='dd.MM.yyyy'}"  Width="90"/>
                    <DataGridTextColumn Header="Šifra"     Binding="{Binding [SIFRA]}"   Width="70"/>
                    <DataGridTextColumn Header="Br.računa" Binding="{Binding [BRRAC]}"   Width="120"/>
                    <DataGridTextColumn Header="Dok"       Binding="{Binding [DOK]}"     Width="60"/>
                    <DataGridTextColumn Header="Vr.PDV"    Binding="{Binding [VPDV]}"    Width="60"/>
                    <DataGridTextColumn Header="Pos.PDV"   Binding="{Binding [POPDV]}"   Width="70"/>
                    <!-- Iznosi izlazni (pdvi) -->
                    <DataGridTextColumn Header="Osn.20%"   Binding="{Binding [OSN20], StringFormat=N2}"    Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PDV 20%"   Binding="{Binding [PDV20], StringFormat=N2}"   Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Osn.10%"   Binding="{Binding [OSN10], StringFormat=N2}"   Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PDV 10%"   Binding="{Binding [PDV10], StringFormat=N2}"   Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Osn.0%"    Binding="{Binding [OSN0], StringFormat=N2}"    Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <!-- Iznosi ulazni (pdvu) -->
                    <DataGridTextColumn Header="Vred.polj"  Binding="{Binding [PLVREDPOLJ], StringFormat=N2}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PDV polj"   Binding="{Binding [PLPDVPOLJ], StringFormat=N2}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PDV nem.18" Binding="{Binding [PDVNEM18], StringFormat=N2}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PDV nem.8"  Binding="{Binding [PDVNEM8], StringFormat=N2}"  Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#FCE4EC" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#F8BBD0" Margin="0,4,0,0">
            <DockPanel>
                <TextBlock Text="{Binding Stavke.Count, StringFormat='Stavki: {0}'}"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"
                           Foreground="#880E4F" Margin="0,0,20,0"/>
                <Button Content="Osveži" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding OsveziCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="80" Height="28"
                        Command="{Binding ZatvoriCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
