<Window x:Class="Algoritam.WPF.Views.GlavnaKnjiga.GkNalBrojView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1100" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A237E" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#9FA8DA" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#E8EAF6" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#C5CAE9">
            <WrapPanel>
                <TextBlock Text="Tip:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1A237E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterTip, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,16,0"/>
                <TextBlock Text="Opis:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1A237E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterOpis, UpdateSourceTrigger=PropertyChanged}"
                         Width="260" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#1A237E" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#C5CAE9" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Nalozi}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#E8EAF6"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding [ZATVOREN]}" Value="True">
                                <Setter Property="Foreground" Value="#78909C"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E8EAF6"/>
                        <Setter Property="Foreground" Value="#1A237E"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#C5CAE9"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Br. naloga" Binding="{Binding [BRNAL]}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1A237E"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Tip"       Binding="{Binding [TIP]}"    Width="70"/>
                    <DataGridTextColumn Header="Opis"      Binding="{Binding [OPIS]}"   Width="*"/>
                    <DataGridTextColumn Header="Od"
                                        Binding="{Binding [DATOD], StringFormat='dd.MM.yyyy'}" Width="100"/>
                    <DataGridTextColumn Header="Do"
                                        Binding="{Binding [DATDO], StringFormat='dd.MM.yyyy'}" Width="100"/>
                    <DataGridTextColumn Header="Br. stavki" Binding="{Binding [BRST]}"  Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Zatvoren"  Binding="{Binding [ZATVOREN]}" Width="80"/>
                    <DataGridTextColumn Header="MTR"       Binding="{Binding [MTR]}"    Width="55"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#E8EAF6" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#C5CAE9" Margin="0,4,0,0">
            <DockPanel>
                <TextBlock Text="{Binding Nalozi.Count, StringFormat='Naloga: {0}'}"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1A237E" Margin="0,0,20,0" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Osveži" Width="80" Height="28" Margin="0,0,6,0"
                            Command="{Binding OsveziCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Zatvori" Width="80" Height="28"
                            Command="{Binding ZatvoriCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
