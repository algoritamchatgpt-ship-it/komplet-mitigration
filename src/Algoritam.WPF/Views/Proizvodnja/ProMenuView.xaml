<UserControl x:Class="Algoritam.WPF.Views.Proizvodnja.ProMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ProButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Width" Value="148"/>
            <Setter Property="Margin" Value="3,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap"
                                       TextAlignment="Center" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" Padding="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GrupaHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#455A64"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>
        <Style x:Key="SectionWrapPanelStyle" TargetType="WrapPanel">
            <Setter Property="Width" Value="924"/>
            <Setter Property="ItemWidth" Value="154"/>
            <Setter Property="ItemHeight" Value="58"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <SolidColorBrush x:Key="BojaGlavna"  Color="#33691E"/>
        <SolidColorBrush x:Key="BojaSif"     Color="#558B2F"/>
        <SolidColorBrush x:Key="BojaKalk"    Color="#37474F"/>
        <SolidColorBrush x:Key="BojaIzlaz"   Color="#C62828"/>
    </UserControl.Resources>

    <DockPanel Background="#F0F0F0">
        <Border DockPanel.Dock="Top" Background="#33691E" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GLAVNI MENI — PROIZVODNJA"
                           FontFamily="Tahoma" FontSize="15" FontWeight="Bold" Foreground="White"/>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding FirmaNaziv}"
                               FontFamily="Tahoma" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" TextAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                        <TextBlock Text="{Binding FirmaMesto}"
                                   FontFamily="Tahoma" FontSize="10" Foreground="#AED581" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding FirmaPib}"
                                   FontFamily="Tahoma" FontSize="10" Foreground="#AED581"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="20,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Izlaz" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaIzlaz}"
                            Width="100" Height="38"
                            Command="{Binding IzlazCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="#E8F5E9"
                BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Padding="20,6"
                Visibility="{Binding ImaBrzoUlaz, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Poslednje otvoreno:"
                           FontFamily="Tahoma" FontSize="10" Foreground="#757575"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ItemsControl ItemsSource="{Binding BrzoUlazLista}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Naziv}"
                                    Command="{Binding DataContext.OtvoriBrzoUlazCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Height="26" Padding="10,0" Margin="0,0,6,0"
                                    FontFamily="Tahoma" FontSize="11"
                                    Foreground="White" Background="#33691E"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="20,12">
            <StackPanel HorizontalAlignment="Left">

                <TextBlock Text="Proizvodni nalozi" Style="{StaticResource GrupaHeaderStyle}"/>
                <WrapPanel Style="{StaticResource SectionWrapPanelStyle}">
                    <Button Content="PROIZVODNI&#10;NALOZI" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaGlavna}"
                            ToolTip="Zaglavlja i stavke proizvodnih naloga"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_NALOZI"/>
                    <Button Content="NORME /&#10;RECEPTURE" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaGlavna}"
                            ToolTip="Recepture / BOM po gotovom proizvodu"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_NORMA"/>
                    <Button Content="ZAHTEVI ZA&#10;MATERIJAL" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaGlavna}"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_ZAH"/>
                </WrapPanel>

                <TextBlock Text="Šifarnici proizvodnje" Style="{StaticResource GrupaHeaderStyle}"/>
                <WrapPanel Style="{StaticResource SectionWrapPanelStyle}">
                    <Button Content="ŠIFARNIK&#10;RADA" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaSif}"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_RAD"/>
                    <Button Content="ŠIFARNIK&#10;OPREME" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaSif}"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_OPS"/>
                    <Button Content="RADNE&#10;CENE" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaSif}"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_ROB"/>
                </WrapPanel>

                <TextBlock Text="Kalkulacije i obračuni" Style="{StaticResource GrupaHeaderStyle}"/>
                <WrapPanel Style="{StaticResource SectionWrapPanelStyle}">
                    <Button Content="KALKULACIJA&#10;PROIZVODA" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaKalk}"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_CK"/>
                    <Button Content="KALKULACIJA&#10;PO NALOGU" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaKalk}"
                            ToolTip="Troškovni razrez po proizvodnom nalogu — materijal/poluproizvod/ambalaža/rad"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_CKNAL"/>
                    <Button Content="CENOVNA&#10;VARIJANTA" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaKalk}"
                            ToolTip="Profitabilnost po recepturi"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_NORA"/>
                    <Button Content="VERIFIKACIJA&#10;MATERIJALA" Style="{StaticResource ProButtonStyle}"
                            Background="{StaticResource BojaKalk}"
                            ToolTip="Plan vs. stvarna potrošnja materijala"
                            Command="{Binding AkcijaCommand}" CommandParameter="PRO_VMAT"/>
                </WrapPanel>

                <Border Height="16"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
