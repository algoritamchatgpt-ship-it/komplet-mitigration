<Window x:Class="Algoritam.WPF.Views.Blagajna.BlIzvestajView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="820" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B5E20" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#A5D6A7" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#E8F5E9" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#C8E6C9">
            <WrapPanel>
                <TextBlock Text="Period od:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1B5E20" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumOd}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="do:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1B5E20" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumDo}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,16,0"/>
                <Button Content="Osveži" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#388E3C" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OsveziCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#C8E6C9" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#E8F5E9"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E8F5E9"/>
                        <Setter Property="Foreground" Value="#1B5E20"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#A5D6A7"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Konto" Binding="{Binding Konto}" Width="140"/>
                    <DataGridTextColumn Header="Br. stavki" Binding="{Binding BrojStavki}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Duguje" Binding="{Binding UkupnoDuguje, StringFormat=N2}" Width="170">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Potražuje" Binding="{Binding UkupnoPotrazuje, StringFormat=N2}" Width="170">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, StringFormat=N2}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Totals row -->
        <Border Grid.Row="3" Background="#C8E6C9" Padding="12,7"
                Margin="8,4,8,0"
                BorderThickness="1,1,1,0" BorderBrush="#A5D6A7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="UKUPNO:"
                           FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                           Foreground="#1B5E20" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Stavke.Count, StringFormat='{}{0} konta'}"
                           FontFamily="Tahoma" FontSize="11" Foreground="#1B5E20"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding UkupnoDuguje, StringFormat=N2}"
                           FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                           Foreground="#1B5E20" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Padding="4,0"/>
                <TextBlock Grid.Column="3"
                           Text="{Binding UkupnoPotrazuje, StringFormat=N2}"
                           FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                           Foreground="#1B5E20" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Padding="4,0"/>
                <TextBlock Grid.Column="4"
                           Text="{Binding Saldo, StringFormat=N2}"
                           FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                           Foreground="#1B5E20" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Padding="4,0"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Background="#E8F5E9" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9" Margin="0,4,0,0">
            <DockPanel>
                <Button Content="Osveži" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding OsveziCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="80" Height="28"
                        Command="{Binding ZatvoriCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
