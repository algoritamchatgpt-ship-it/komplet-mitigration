<Window x:Class="Algoritam.WPF.Views.Zarade.LdPorpotReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potvrda — kretanje zarada"
        Width="1380"
        Height="760"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Tahoma"
        FontSize="11">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#607D8B" Padding="12,8" CornerRadius="4">
            <DockPanel>
                <TextBlock Text="POTVRDA - KRETANJE ZARADA"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="Bold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="96"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="StampajClick"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Content="STAMPAJ"/>
                    <Button Width="90"
                            Height="28"
                            Click="ZatvoriClick"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Content="ZATVORI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="PrintRoot"
                Grid.Row="1"
                Margin="0,10,0,10"
                Background="White"
                BorderBrush="#C8E6C9"
                BorderThickness="1"
                Padding="10">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#E8F0FE">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Broj" Binding="{Binding Broj}" Width="80"/>
                    <DataGridTextColumn Header="Ime_prez" Binding="{Binding ImePrez}" Width="270"/>
                    <DataGridTextColumn Header="Mes" Binding="{Binding Mes}" Width="70"/>
                    <DataGridTextColumn Header="Mesec" Binding="{Binding Mesec}" Width="180"/>
                    <DataGridTextColumn Header="Raddin" Binding="{Binding Raddin, StringFormat=N2}" Width="110"/>
                    <DataGridTextColumn Header="Radkoef" Binding="{Binding Radkoef, StringFormat=N2}" Width="110"/>
                    <DataGridTextColumn Header="Firdin" Binding="{Binding Firdin, StringFormat=N2}" Width="110"/>
                    <DataGridTextColumn Header="Firkoef" Binding="{Binding Firkoef, StringFormat=N2}" Width="110"/>
                    <DataGridTextColumn Header="Maticnibr" Binding="{Binding Maticnibr}" Width="170"/>
                    <DataGridTextColumn Header="Lbobroj" Binding="{Binding Lbobroj}" Width="120"/>
                    <DataGridTextColumn Header="Zkbroj" Binding="{Binding Zkbroj}" Width="120"/>
                    <DataGridTextColumn Header="Nfirma" Binding="{Binding Nfirma}" Width="110"/>
                    <DataGridTextColumn Header="Nredni" Binding="{Binding Nredni}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="LDPORPOT"
                           FontFamily="Tahoma" FontSize="9" Foreground="#C8E6C9"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" Text="{Binding InfoTekst}"
                           FontFamily="Tahoma" FontSize="11" Foreground="#37474F"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
