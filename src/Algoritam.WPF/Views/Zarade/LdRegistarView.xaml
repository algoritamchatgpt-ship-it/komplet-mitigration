<Window x:Class="Algoritam.WPF.Views.Zarade.LdRegistarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registar zarada — pregled prenesenih zarada"
        Width="1020" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Tahoma" FontSize="11">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding UcitajCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ZatvoriCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Padding="16,10">
            <DockPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="REGISTAR ZARADA" FontSize="15" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding NaslovPerioda}" FontSize="10" Foreground="#A5D6A7" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                           Foreground="#A5D6A7" FontSize="10"
                           Text="Pregled prenesenih zarada za Centralni registar (samo budžetski korisnici)"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9" Padding="12,6">
            <TextBlock Text="{Binding Poruka}" Foreground="#2E7D32" FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9" Padding="10,7">
            <DockPanel>
                <Button Content="ZATVORI [Esc]" DockPanel.Dock="Right"
                        Width="110" Height="28"
                        Background="#455A64" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Command="{Binding ZatvoriCommand}"/>
                <Button Content="F5 OSVEŽI" DockPanel.Dock="Right"
                        Width="90" Height="28" Margin="0,0,8,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Command="{Binding UcitajCommand}"/>

                <WrapPanel VerticalAlignment="Center">
                    <Button Content="IZVOZ EXCEL / CSV" Width="140" Height="28" Margin="0,0,6,0"
                            Background="#1565C0" Foreground="White" BorderThickness="0"
                            FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Izvoz u Excel (.xlsx) ili CSV za Centralni registar"
                            Command="{Binding IzvozExcelCommand}"/>

                    <!-- Filter -->
                    <TextBlock Text="Pretraga:" VerticalAlignment="Center" Margin="16,0,6,0" Foreground="#455A64"/>
                    <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Height="26" VerticalContentAlignment="Center"
                             Padding="4,0"
                             FontFamily="Tahoma" FontSize="11"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Grid -->
        <DataGrid ItemsSource="{Binding Redovi}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="White"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  AlternatingRowBackground="#F1F8E9"
                  FontFamily="Tahoma" FontSize="11"
                  RowHeight="26"
                  Margin="4,4,4,0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1B5E20"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush" Value="#2E7D32"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="R.B." Binding="{Binding Rb}" Width="40" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Br" Binding="{Binding Broj}" Width="46" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez}" Width="210" IsReadOnly="True"/>
                <DataGridTextColumn Header="JMBG / Mat.br." Binding="{Binding Jmbg}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Bruto" Binding="{Binding Bruto, StringFormat=N2}" Width="100" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,6,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Porez" Binding="{Binding Porez, StringFormat=N2}" Width="88" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,6,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Dop.radnik" Binding="{Binding DopRadnik, StringFormat=N2}" Width="96" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,6,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Dop.firma" Binding="{Binding DopFirma, StringFormat=N2}" Width="88" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,6,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Neto" Binding="{Binding Neto, StringFormat=N2}" Width="90" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,6,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Za isplatu" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.Binding>
                        <Binding Path="ZaIsplatu" StringFormat="N2"/>
                    </DataGridTextColumn.Binding>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,6,0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
