<Window x:Class="Algoritam.WPF.Views.Zarade.PppUputstvoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uputstvo za prenos zarada u registar — PPP-PD"
        Width="800" Height="720"
        MinWidth="640" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Stil za naslov grupe šifara -->
        <Style x:Key="GrupaNaslov" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- Stil za red šifre -->
        <Style x:Key="SifraRed" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1A3A6B" Padding="20,14">
            <StackPanel>
                <TextBlock Text="UPUTSTVO ZA PRENOS ZARADA U REGISTAR"
                           FontFamily="Tahoma" FontSize="14" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="PPP-PD — korak po korak i katalog šifara prihoda"
                           FontFamily="Tahoma" FontSize="11"
                           Foreground="#90B4E0" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#EEEEEE"
                BorderBrush="#D0D8E4" BorderThickness="0,1,0,0" Padding="16,10">
            <Button Content="Zatvori" Width="90" Height="32"
                    HorizontalAlignment="Right"
                    FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                    Foreground="White" Background="#1A3A6B" BorderThickness="0"
                    Cursor="Hand" Click="ZatvoriClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>

        <!-- Sadržaj -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  DEO 1: UPUTSTVO ZA PRENOS (korak po korak)       -->
                <!-- ══════════════════════════════════════════════════ -->

                <!-- Uvod -->
                <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="12"
                           Foreground="#333333" Margin="0,0,0,14">
                    Nakon završenog obračuna zarada <Bold>BRUTO ILI NETO</Bold>, u okviru
                    <Bold>PLATNOG SPISKA</Bold>, kliknite na dugme <Bold>PRENOSI</Bold>,
                    pa na dugme <Bold>PRENOS ZA REGISTAR</Bold> i potvrdite klikom na
                    <Bold>ŽELIM PRENOS</Bold> i <Bold>IZLAZ</Bold>. Time ste pripremili
                    obračun za prenos u registar.
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="12"
                           Foreground="#333333" Margin="0,0,0,16">
                    Sada pređite u <Bold>GLAVNI MENI</Bold> i kliknite na dugme
                    <Bold>OBRAZAC PPP</Bold>.
                </TextBlock>

                <!-- Korak 1 — PARAMETRI -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="1.  PARAMETRI PRENOSA"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#333333">
                            U ovoj formi <Bold>OBAVEZNO</Bold> popunite sledeća polja:
                        </TextBlock>
                        <ItemsControl Margin="10,6,0,0" FontFamily="Tahoma" FontSize="11" Foreground="#333333">
                            <ItemsControl.Items>
                                <TextBlock Text="• Jedinstveni broj korisnika" Margin="0,1"/>
                                <TextBlock Text="• Isplata u mesecu — mesec u kome realizujete isplatu zarade" Margin="0,1" TextWrapping="Wrap"/>
                                <TextBlock Text="• Godina — godina u kojoj realizujete isplatu zarade" Margin="0,1" TextWrapping="Wrap"/>
                                <TextBlock Text="• Datum slanja" Margin="0,1"/>
                                <TextBlock Text="• Funkcionalna klasifikacija" Margin="0,1"/>
                                <TextBlock Text="• Izvor finansiranja" Margin="0,1"/>
                                <TextBlock Text="• Isplata za mesec — mesec za koji je urađen obračun" Margin="0,1" TextWrapping="Wrap"/>
                                <TextBlock Text="• Isplata za godinu — godina za koju je urađen obračun" Margin="0,1" TextWrapping="Wrap"/>
                                <TextBlock Text="• Šifra organizacione jedinice" Margin="0,1"/>
                            </ItemsControl.Items>
                        </ItemsControl>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#666666" Margin="0,8,0,0">
                            Polja Program, Projekat možete ostaviti nepopunjena.
                            Koeficijent preračuna sa NETA na BRUTO — u prvom unosu ostavite nulu;
                            program će ga automatski popuniti.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Korak 2 — ŠEMA ZARADA -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="2.  ŠEMA ZARADA"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#333333">
                            Prvi put kliknite na <Bold>DODAJ SVE</Bold> i pređite na sledeću formu.
                            Ova tabela sadrži deo propisanih šifara osnova primanja. Ukoliko vam
                            nedostaje šifra osnova, dodajte je ručno.
                            Jednom unete šifre prihoda program pamti — nema potrebe za ponovnim unosom.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Korak 3 — PREUZMI ZARADE -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="3.  ZARADE — ŠEMA PRENOSA PLATA"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#333333" Margin="0,0,0,6">
                            Uvek kliknite prvo na <Bold>BRIŠI SVE</Bold>, zatim na
                            <Bold>PARAMETRE PRENOSA</Bold>.
                            Ukoliko je tabela prazna, kliknite na <Bold>DODAJ SVE</Bold>
                            pa unesite MESEC, Izvorfin i Redispl.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#333333">
                            Za <Bold>BRUTO</Bold> obračun kliknite:
                            <Bold>PREUZMI ZARADE BRUTO OBRAČUN</Bold> →
                            <Bold>SUMIRANJE ISTIH ŠIFRI OSNOVA KOD ISTOG MATIČNOG BROJA</Bold>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#333333" Margin="0,4,0,0">
                            Za <Bold>NETO</Bold> obračun kliknite:
                            <Bold>PREUZMI ZARADE NETO NA BRUTO</Bold> →
                            <Bold>SUMIRANJE ISTIH ŠIFRI OSNOVA KOD ISTOG MATIČNOG BROJA</Bold>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Korak 4 — XML -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="4.  ŠEMA XML — NAPRAVI XML"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#333333">
                            Uvek kliknite prvo na <Bold>BRIŠI SVE</Bold> pa na <Bold>DODAJ SVE</Bold>,
                            a zatim na <Bold>NAPRAVI XML</Bold> — čime ste formirali XML koji treba
                            da učitate u <Bold>CROSSO aplikaciju</Bold> Centralnog registra.
                            Fajl se nalazi u: Glavni meni → Uvoz datoteka → dugme XML.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- PPP-PO napomena -->
                <Border Background="#FFF8E1" CornerRadius="4" Padding="14,10"
                        BorderBrush="#FFD54F" BorderThickness="1" Margin="0,4,0,24">
                    <StackPanel>
                        <TextBlock Text="PPP-PO POTVRDA"
                                   FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                                   Foreground="#7B4F00" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11"
                                   Foreground="#5D3A00">
                            PPP-PO štampate iz: <Bold>Zarade → Glavni meni → Zarade → Arhiva zarada</Bold> —
                            proverite da li ste arhivirali sve zarade i izađite iz arhive.
                            Zatim kliknite na <Bold>OBRAZAC PPP</Bold>, ispod prazne tabele kliknite na
                            <Bold>PREUZMI ZARADE → POPUNI OPŠTE PODATKE → PPP-PO</Bold>.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════════════ -->
                <!--  DEO 2: ŠIFRE PRIHODA — KATALOG ZA PPP-PD        -->
                <!-- ══════════════════════════════════════════════════ -->

                <!-- Razdvajač -->
                <Border Background="#1A3A6B" CornerRadius="4" Padding="16,10" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="ŠIFRE PRIHODA — KATALOG ZA PPP-PD"
                                   FontFamily="Tahoma" FontSize="13" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock FontFamily="Tahoma" FontSize="10" Foreground="#90B4E0" Margin="0,3,0,0"
                                   TextWrapping="Wrap">
                            Podaci za popunjavanje polja šifara prihoda — od 2014. godine sa dopunama zaključno sa 30.11.2020.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Struktura šifre prihoda -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="STRUKTURA ŠIFRE PRIHODA"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11" Foreground="#333333" Margin="0,0,0,6">
                            <Bold>ŠIFRA PRIHODA = KATALOG + VRSTAPRIM + OZNVRPRIH + OZNOLAKS + OZNBEN</Bold>
                        </TextBlock>
                        <Border Background="White" CornerRadius="3" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 1:  zarada zaposlenog           →  1 01 101 00 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 2:  lična zarada preduzetnika   →  1 03 106 00 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 3:  bolovanje do 30 dana        →  1 01 202 00 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 4:  bolovanje preko 30 dana     →  1 01 204 00 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 5:  porodiljsko bolovanje       →  1 01 206 00 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 6:  olakšica mlađi od 30 god.  →  1 01 101 01 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 7:  subvencija Z1 (stara)       →  1 01 101 06 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 8:  subvencija Z1 (2020)        →  1 01 101 26 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 9:  subvencija Z1 (2021)        →  1 01 101 27 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 10: subvencija Z1 (2022)        →  1 01 101 28 0"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#222" Margin="0,1" TextWrapping="Wrap"
                                           Text="Primer 11: troškovi prevoza/dnevnice/smeštaja/solidarna pomoć/jubilarna nagrada (preko neoporezivog)  →  1 01 110 00 0"/>
                            </StackPanel>
                        </Border>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11" Foreground="#555" Margin="0,4,0,0">
                            <Bold>Napomena:</Bold> Ako zaposleni ima bolovanje do 30 dana, možete odlučiti da otvorite novu šifru
                            radnika sa šifrom prihoda 202, ili da taj prihod unesete kroz redovan rad (šifra 101).
                            Poreska uprava dozvoljava oba načina — morate biti dosledni u narednom periodu.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- VRSTAID i PREBIVAL -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="KATALOG (VRSTAID) i PREBIVAL"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11" Foreground="#333" Margin="0,0,0,6">
                            <Bold>VRSTAID</Bold> — oznaka vrste dokumenta koji PU koristi za identifikaciju primaoca prihoda:
                        </TextBlock>
                        <Border Background="White" CornerRadius="3" Padding="10,6" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  1  =  JMBG"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  2  =  Izbeglička legitimacija"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  3  =  Pasoš"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  4  =  Posebna oznaka za slučajeve odobrene od PU"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  9  =  Ostalo"/>
                            </StackPanel>
                        </Border>
                        <TextBlock TextWrapping="Wrap" FontFamily="Tahoma" FontSize="11" Foreground="#333">
                            <Bold>PREBIVAL</Bold> — šifra opštine prebivališta, odnosno boravišta primaoca prihoda.
                            Ako je u VRSTAID upisano 1, a u matični broj upisan JMBG, ne upisuje se PREBIVAL
                            — osim kod gradova koji imaju gradske opštine. Ukoliko ste u evidenciji zaposlenih
                            uneli slovnu oznaku opštine (kartica F7), samo kliknite na dugme <Bold>Podesi za 2014</Bold>.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- VRSTAPRIM -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="VRSTAPRIM — Vrsta primaoca"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,8"/>
                        <Border Background="White" CornerRadius="3" Padding="10,6">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  01  Zaposleni"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  02  Osnivač zaposlen u društvu"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  03  Samostalna delatnost"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  04  Poljoprivreda"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  05  Lice koje nije osigurano po drugom osnovu"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  06  Nerezident"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  07  Invalidno lice"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  08  Vojni osiguranik"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  09  Lice penzioner po osnovu zaposlenosti"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  10  Lice penzioner po osnovu samostalne delatnosti"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  11  Lice kome se isplaćuju prihodi van radnog odnosa na koje se ne obračunavaju doprinosi za soc. osiguranje" TextWrapping="Wrap"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  12  Vojni penzioner"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  13  Poljoprivredni penzioner"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- OZNOLAKS -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="OZNOLAKS — Oznaka olakšice"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,8"/>
                        <Border Background="White" CornerRadius="3" Padding="10,6">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  00  Bez poreske olakšice"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  01  Por. olaks. pripravnika mlađeg od 30 godina — nije više u upotrebi"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  02  Por. olaks. lice mlađe od 30 godina — nije više u upotrebi"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  03  Por. olaks. zaposleni invalidi"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  04  Por. olaks. starije od 45 a mlađe od 50 godina — nije više u upotrebi"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  05  Por. olaks. starije od 50 godina — nije više u upotrebi"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  06  Subvencija mlađi od 30 i stariji od 45 godina — nije više u upotrebi"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  07  Subvencija stariji od 30 i mlađi od 45 godina — nije više u upotrebi"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  08  Pravo na povraćaj 65% plaćenog poreza i plaćenih doprinosa, po čl. 21v Zakona i čl. 45 Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  09  Pravo na povraćaj 70% plaćenog poreza i plaćenih doprinosa, po čl. 21v Zakona i čl. 45 Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  10  Pravo na povraćaj 75% plaćenog poreza i plaćenih doprinosa, po čl. 21v Zakona i čl. 45. Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  11  Pravo na povraćaj 75% plaćenog poreza i plaćenih doprinosa, po čl. 21d Zakona i čl. 45v Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  18  Pravo na povraćaj 65% plaćenog poreza na zaradu i plaćenih doprinosa, za novozaposleno lice po čl. 21v i čl. 45. Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  19  Pravo na povraćaj 70% plaćenog poreza na zaradu i plaćenih doprinosa, za novozaposleno lice po čl. 21v i čl. 45. Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  20  Pravo na povraćaj 75% plaćenog poreza na zaradu i plaćenih doprinosa, za novozaposleno lice po čl. 21v i čl. 45. Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  21  Pravo na povraćaj 75% plaćenog poreza na zaradu i plaćenih doprinosa, za novozaposleno lice po čl. 21d i čl. 45v Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  22  Pravo na poresko oslobođenje u skladu sa čl. 21dj Zakona i čl. 45g Zakona o doprinosima, za isplate zaključno sa 16. decembrom 2019. godine"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  23  Pravo na oslobođenje u skladu sa čl. 21dj i čl. 45g Zakona o doprinosima, u primeni od 1. januara 2019. — nije više u upotrebi"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  24  Pravo na umanjenje za 70% osnovice poreza na zaradu i doprinosa, po čl. 15v Zakona i čl. 15a Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" TextWrapping="Wrap" Text="  25  Zarada osnivača novoosnovanog privrednog društva koje obavlja inovacionu delatnost, olakšica po čl. 21e Zakona i čl. 45d Zakona o doprinosima"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  26  70% poreza i 100% doprinosa za PIO za period 01.01.–31.12.2020. godine"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  27  65% poreza i 95% doprinosa za PIO za period 01.01.–31.12.2021. godine"/>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  28  60% poreza i 85% doprinosa za PIO za period 01.01.–31.12.2022. godine"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- OZNBEN -->
                <Border Background="#E8EFF8" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="OZNBEN — Oznaka beneficije"
                                   FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                   Foreground="#1A3A6B" Margin="0,0,0,8"/>
                        <Border Background="White" CornerRadius="3" Padding="10,6">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SifraRed}" Text="  0  Bez beneficiranog staža"/>
