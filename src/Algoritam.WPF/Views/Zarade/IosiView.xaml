<Window x:Class="Algoritam.WPF.Views.Zarade.IosiView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obrazac IOSI" Width="1200" Height="550"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1B5E20" Padding="16,10">
            <TextBlock Text="{Binding Naslov}" Foreground="White" FontSize="16" FontWeight="Bold" FontFamily="Tahoma"/>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <DataGrid ItemsSource="{Binding Stavke}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      Background="White" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1B5E20"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mesec" Binding="{Binding Mesec, StringFormat=N0}" Width="55"/>
                    <DataGridTextColumn Header="Naziv mes." Binding="{Binding NazMes}" Width="80"/>
                    <DataGridTextColumn Header="Datum" Binding="{Binding DatDok, StringFormat=dd.MM.yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Uk. zaposl." Binding="{Binding UkZapos, StringFormat=N0}" Width="85"/>
                    <DataGridTextColumn Header="Br. invalida" Binding="{Binding BrojInval, StringFormat=N0}" Width="85"/>
                    <DataGridTextColumn Header="Uk. invalidi" Binding="{Binding UkInval, StringFormat=N0}" Width="85"/>
                    <DataGridTextColumn Header="Br. finans." Binding="{Binding BrojFinans, StringFormat=N0}" Width="85"/>
                    <DataGridTextColumn Header="Din. finans." Binding="{Binding DinFinans, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Br. inv. ugov." Binding="{Binding BrojInvalU, StringFormat=N0}" Width="90"/>
                    <DataGridTextColumn Header="Din. ugov." Binding="{Binding DinUgov, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Br. inv. penal" Binding="{Binding BrojInvalP, StringFormat=N0}" Width="90"/>
                    <DataGridTextColumn Header="Din. penal" Binding="{Binding DinPenal, StringFormat=N2}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="2" Background="#E8F5E9" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="#C8E6C9">
            <DockPanel>
                <Button Content="F5 OSVEZI" DockPanel.Dock="Right"
                        Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <Button Content="ZATVORI" DockPanel.Dock="Right" Width="100" Height="28"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Background="#C62828" Foreground="White" Cursor="Hand" Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
