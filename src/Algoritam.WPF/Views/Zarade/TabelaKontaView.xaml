<Window x:Class="Algoritam.WPF.Views.Zarade.TabelaKontaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sifarnik konta za knjizenje zarada"
        Width="980" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <TextBlock Text="ŠIFARNIK KONTA ZA KNJIŽENJE ZARADA"
                       FontFamily="Tahoma" FontSize="16" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" Margin="16,0"/>
        </Border>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="TabelaKontaGrid"
                  Grid.Row="0"
                  Margin="0,0,0,8"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  CurrentCellChanged="TabelaKontaGridCurrentCellChanged"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#F5F5F5"
                  AlternatingRowBackground="#EDEDED"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vrsta" Binding="{Binding Vrsta, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Kod"   Binding="{Binding Kod, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Opis"  Binding="{Binding Opis, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Konto" Binding="{Binding Konto, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                <DataGridTextColumn Header="Kontop" Binding="{Binding KontoP, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Height="28" Margin="0,0,8,0"
                    Content="PRENOS IZ PRIMERA"
                    FontFamily="Tahoma" FontSize="11"
                    Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Command="{Binding PrenosIzBaznihKontaCommand}"/>
            <Button Grid.Column="1" Height="28"
                    Content="DODAVANJE"
                    FontFamily="Tahoma" FontSize="11"
                    Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Command="{Binding DodajCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Height="28" Margin="0,0,8,0"
                    Content="BRISANJE REDA"
                    FontFamily="Tahoma" FontSize="11"
                    Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Command="{Binding ObrisiCommand}"/>
            <Button Grid.Column="1" Height="28" Margin="0,0,8,0"
                    Content="BRIŠI SVE"
                    FontFamily="Tahoma" FontSize="11"
                    Background="#E65100" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Command="{Binding BrisiSveCommand}"/>
            <Button Grid.Column="2" Height="28"
                    Content="IZLAZ"
                    FontFamily="Tahoma" FontSize="11"
                    Background="#455A64" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="ZatvoriClick"/>
        </Grid>
    </Grid>
    </DockPanel>
</Window>
