<Window x:Class="Algoritam.WPF.Views.Zarade.PutarinePregledView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pregled putarina za period"
        Width="860" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="44">
            <TextBlock Text="PREGLED PUTARINA ZA PERIOD"
                       Margin="14,0" VerticalAlignment="Center"
                       Foreground="White" FontFamily="Tahoma" FontSize="14" FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="STAMPA" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#1565C0" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11"
                            Cursor="Hand" Command="{Binding StampaCommand}"/>
                    <Button Content="IZLAZ" Width="90" Height="28"
                            Background="#455A64" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11"
                            Cursor="Hand" Click="ZatvoriClick"/>
                </StackPanel>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#B0BEC5"
                BorderThickness="0,0,0,1" Padding="10,8">
            <WrapPanel>
                <TextBlock Text="OD:" VerticalAlignment="Center" Margin="0,0,5,0"
                           FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
                <TextBox Width="100" Height="26" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11" Margin="0,0,12,0"
                         Text="{Binding DatumOd, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>
                <TextBlock Text="DO:" VerticalAlignment="Center" Margin="0,0,5,0"
                           FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
                <TextBox Width="100" Height="26" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11" Margin="0,0,12,0"
                         Text="{Binding DatumDo, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>
                <TextBlock Text="GRUPA:" VerticalAlignment="Center" Margin="0,0,5,0"
                           FontFamily="Tahoma" FontSize="11"/>
                <TextBox Width="60" Height="26" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11" Margin="0,0,12,0" MaxLength="3"
                         Text="{Binding GrupaFilter, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="PREGLED" Width="90" Height="28" Margin="0,0,6,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Command="{Binding PregledCommand}"/>
                <Button Content="SALDO RELACIJA" Width="120" Height="28"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Command="{Binding SaldoRelacijaCommand}"/>
            </WrapPanel>
        </Border>

        <Border Margin="10,6,10,6" BorderBrush="#B0BEC5" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Rezultati}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#FAFAFA"
                      FontFamily="Tahoma" FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Red." Binding="{Binding Redbr}" Width="60"/>
                    <DataGridTextColumn Header="Putnal" Binding="{Binding Putnal}" Width="80"/>
                    <DataGridTextColumn Header="Datum" Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="95"/>
                    <DataGridTextColumn Header="Relacija" Binding="{Binding Relacija}" Width="*"/>
                    <DataGridTextColumn Header="Iznos" Binding="{Binding Iznos, StringFormat=N2}" Width="110"/>
                    <DataGridTextColumn Header="Grupa" Binding="{Binding Grupa}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
