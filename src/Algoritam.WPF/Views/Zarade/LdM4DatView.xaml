<Window x:Class="Algoritam.WPF.Views.Zarade.LdM4DatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Datumi isplata — M4" Width="520" Height="420"
        WindowStartupLocation="CenterOwner" Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B5E20" Padding="14,8">
            <TextBlock Text="DATUMI ISPLATA M4 (ldm4dat.dbf)"
                       Foreground="White" FontSize="13" FontWeight="Bold" FontFamily="Tahoma"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#E8F5E9" Padding="6,5"
                BorderThickness="0,0,0,1" BorderBrush="#C8E6C9">
            <WrapPanel>
                <Button Content="DODAJ RED" Width="100" Height="26" Margin="2,0"
                        Background="#388E3C" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding DodajCommand}"/>
                <Button Content="BRIŠI RED" Width="96" Height="26" Margin="2,0"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding BrisiRedCommand}"/>
                <Separator Width="10" Background="Transparent"/>
                <Button Content="SAČUVAJ" Width="90" Height="26" Margin="2,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding SacuvajCommand}"/>
                <Button Content="ZATVORI" Width="80" Height="26" Margin="2,0"
                        Background="#455A64" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding ZatvoriCommand}"/>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  Background="White" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  SelectionMode="Single" Margin="0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1B5E20"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="6,4"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mesec" Binding="{Binding Mes, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding Dat, StringFormat='dd.MM.yyyy', UpdateSourceTrigger=PropertyChanged}"
                                    Width="120"/>
                <DataGridTextColumn Header="Čas" Binding="{Binding Cas, UpdateSourceTrigger=PropertyChanged}"
                                    Width="70"/>
                <DataGridCheckBoxColumn Header="Preneto" Binding="{Binding Preneto, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <Border Grid.Row="3" Background="#E8F5E9" Padding="10,5"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9">
            <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
