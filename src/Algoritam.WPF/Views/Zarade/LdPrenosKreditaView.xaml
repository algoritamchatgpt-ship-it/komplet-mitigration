<Window x:Class="Algoritam.WPF.Views.Zarade.LdPrenosKreditaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="760"
        Height="240"
        MinWidth="760"
        MinHeight="240"
        MaxWidth="760"
        MaxHeight="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10,8"
                Background="#E8F5E9"
                BorderBrush="#9CA3DE"
                BorderThickness="1">
            <TextBlock Text="{Binding StatusPoruka}"
                       FontWeight="Bold"
                       Foreground="#7A0000"
                       TextWrapping="Wrap"/>
        </Border>

        <UniformGrid Grid.Row="1"
                     Margin="0,12,0,10"
                     Rows="2"
                     Columns="2">
            <Button Content="_ZELIM PRENOS KREDITA"
                    Margin="0,0,8,8"
                    Height="28"
                    Command="{Binding ZelimPrenosKreditaCommand}"/>
            <Button Content="_ZELIM PRENOS AKONTACIJE"
                    Margin="8,0,0,8"
                    Height="28"
                    Command="{Binding ZelimPrenosAkontacijeCommand}"/>
            <Button Content="_ODUSTAJEM"
                    Margin="0,8,8,0"
                    Height="28"
                    Command="{Binding OdustajemCommand}"/>
            <Button Content="_IZLAZ"
                    Margin="8,8,0,0"
                    Height="28"
                    Background="#C62828"
                    Foreground="White"
                    BorderThickness="0"
                    Command="{Binding IzlazCommand}"/>
        </UniformGrid>

        <TextBlock Grid.Row="2"
                   Text="Fox 1:1: sabira AKTIVRATA ili AKONTRATA iz LDKRED po BROJ i upisuje u LD.KREDITI / LD.KREDITIA."
                   TextWrapping="Wrap"/>
    </Grid>
</Window>
