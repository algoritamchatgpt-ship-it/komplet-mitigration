<Window x:Class="Algoritam.WPF.Views.Zarade.PutarKarticaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kartica putarine"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="44">
            <TextBlock Text="KARTICA PUTARINE"
                       Margin="14,0" VerticalAlignment="Center"
                       Foreground="White" FontFamily="Tahoma" FontSize="14" FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="SAČUVAJ" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11"
                            Cursor="Hand" Command="{Binding SacuvajCommand}"/>
                    <Button Content="IZLAZ" Width="90" Height="28"
                            Background="#455A64" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11"
                            Cursor="Hand" Click="ZatvoriClick"/>
                </StackPanel>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11"/>
            </DockPanel>
        </Border>

        <Grid Margin="20,12,20,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="RED. BR.:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="0" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11" IsReadOnly="True" Background="#F5F5F5"
                     Text="{Binding Redbr}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="PUTNI NALOG:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="1" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Putnal, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="DATUM:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="2" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Datdok, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="VREME:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="3" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11" MaxLength="10"
                     Text="{Binding Vreme, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="ŠIFRA RELACIJE:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="4" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11" MaxLength="6"
                     Text="{Binding Sifrel, UpdateSourceTrigger=LostFocus}"/>
            <Button Grid.Row="4" Grid.Column="2" Content="F4 RELACIJE" Height="24"
                    Background="#1B5E20" Foreground="White" BorderThickness="0"
                    FontFamily="Tahoma" FontSize="10" FontWeight="SemiBold"
                    Cursor="Hand" Command="{Binding IzaberiRelacijuCommand}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="RELACIJA:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Height="24"
                     VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                     IsReadOnly="True" Background="#F5F5F5"
                     Text="{Binding Relacija}"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="IZNOS:" VerticalAlignment="Center"
                       FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
            <TextBox Grid.Row="6" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="12" FontWeight="SemiBold"
                     Text="{Binding Iznos, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="GRUPA:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="7" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11" MaxLength="3"
                     Text="{Binding Grupa, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
    </DockPanel>
</Window>
