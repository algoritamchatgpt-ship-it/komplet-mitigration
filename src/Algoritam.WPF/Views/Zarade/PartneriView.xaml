<Window x:Class="Algoritam.WPF.Views.Zarade.PartneriView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:util="clr-namespace:Algoritam.WPF.Utilities"
        Title="Šifarnik partnera"
        Width="1360" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        Loaded="PartneriView_Loaded">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
        <KeyBinding Key="F7" Command="{Binding IzmeniCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ══ Header ════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ŠIFARNIK POSLOVNIH PARTNERA"
                               FontFamily="Tahoma" FontSize="16" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding Poruka}"
                               FontFamily="Tahoma" FontSize="10"
                               Foreground="#A5D6A7"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="AN0.DBF"
                           FontFamily="Tahoma" FontSize="10"
                           Foreground="#A5D6A7" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ Status bar ════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom" Background="#2E7D32" Height="30">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontFamily="Tahoma" FontSize="11" Foreground="White"
                           VerticalAlignment="Center">
                    <Run Text="Partnera: " FontWeight="Bold"/>
                    <Run Text="{Binding UkupnoStavki, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Grid.Column="1"
                           Text="{Binding Naslov}"
                           FontFamily="Tahoma" FontSize="10"
                           Foreground="#A5D6A7" VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="ZATVORI"
                        Width="90" Height="24"
                        Background="#455A64" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Tahoma" FontSize="11"
                        Click="ZatvoriClick"/>
            </Grid>
        </Border>

        <!-- ══ Toolbar ═══════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#E8F5E9"
                BorderThickness="0,0,0,1" BorderBrush="#C8E6C9"
                Padding="10,8">
            <Border.Resources>
                <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
                    <Setter Property="BorderBrush" Value="#B0BEC5"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="Margin" Value="0,0,8,0"/>
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="Foreground" Value="#37474F"/>
                </Style>
                <Style x:Key="Btn" TargetType="Button">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Height" Value="28"/>
                    <Setter Property="Padding" Value="10,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Margin" Value="0,0,4,0"/>
                    <Setter Property="Background" Value="#1565C0"/>
                </Style>
            </Border.Resources>

            <WrapPanel>
                <!-- ── Izmene ──────────────────────────────── -->
                <GroupBox Header=" IZMENE " Style="{StaticResource GroupBoxStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="DODAJ +"      Style="{StaticResource Btn}" Background="#1565C0" MinWidth="80"
                                Command="{Binding DodajCommand}"/>
                        <Button Content="IZMENI F7"    Style="{StaticResource Btn}" Background="#1565C0" MinWidth="90"
                                Command="{Binding IzmeniCommand}"/>
                        <Button Content="KOPIRAJ"      Style="{StaticResource Btn}" Background="#1565C0" MinWidth="80"
                                Command="{Binding KopirajRedCommand}"
                                ToolTip="Kopiraj selektovanog partnera kao polaznu tačku za novog"/>
                        <Button Content="OBRIŠI"       Style="{StaticResource Btn}" Background="#C62828" MinWidth="75"
                                Command="{Binding ObrisiCommand}"/>
                        <Button Content="SAČUVAJ"      Style="{StaticResource Btn}" Background="#2E7D32" MinWidth="80"
                                Command="{Binding SacuvajCommand}"/>
                        <Button Content="OSVEZI F5"    Style="{StaticResource Btn}" Background="#607D8B" MinWidth="85" Margin="0"
                                Command="{Binding OsveziCommand}"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Pretraga ────────────────────────────── -->
                <GroupBox Header=" PRETRAGA " Style="{StaticResource GroupBoxStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="200" Height="26"
                                 VerticalContentAlignment="Center" Padding="4,0"
                                 FontFamily="Tahoma" FontSize="11"
                                 Text="{Binding Pretraga, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,4,0"
                                 ToolTip="Tekst pretrage za TRAŽI ŠIFRU / TRAŽI NAZIV"/>
                        <Button Content="TRAŽI ŠIFRU"  Style="{StaticResource Btn}" MinWidth="100"
                                Command="{Binding TraziSifruCommand}"/>
                        <Button Content="TRAŽI NAZIV"  Style="{StaticResource Btn}" MinWidth="100" Margin="0"
                                Command="{Binding TraziNazivCommand}"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Export ──────────────────────────────── -->
                <GroupBox Header=" EXPORT " Style="{StaticResource GroupBoxStyle}" Margin="0">
                    <Button Content="EXPORT U EXCEL"  Style="{StaticResource Btn}" MinWidth="120" Margin="0"
                            Background="#00695C"
                            Command="{Binding ExportUExcelCommand}"
                            ToolTip="Exportuj listu partnera u CSV"/>
                </GroupBox>
            </WrapPanel>
        </Border>

        <!-- ══ Filter bar ════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5"
                BorderThickness="0,0,0,1" BorderBrush="#E0E0E0"
                Padding="8,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#757575"/>
                <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                         Width="240" Height="24"
                         VerticalContentAlignment="Center" Padding="4,0"
                         FontFamily="Tahoma" FontSize="11"
                         ToolTip="Filter po šifri, nazivu, mestu, PIB-u ili e-mailu"/>
                <TextBlock Text="  ×" FontSize="14" Foreground="#9E9E9E"
                           VerticalAlignment="Center" Cursor="Hand"
                           Visibility="{Binding FilterTekst, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OcistiFilterCommand}"/>
                    </TextBlock.InputBindings>
                </TextBlock>
                <TextBlock Margin="14,0,0,0" FontFamily="Tahoma" FontSize="11"
                           Foreground="#757575" VerticalAlignment="Center"
                           Text="{Binding UkupnoStavki, StringFormat='od {0} partnera'}"
                           Visibility="{Binding FilterTekst, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- ══ DataGrid ══════════════════════════════════════════════════ -->
        <Grid Margin="8,4,8,8">

            <DataGrid x:Name="GridPartneri"
                      ItemsSource="{Binding StavkeView}"
                      SelectedItem="{Binding Selektovani, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0E0E0"
                      RowBackground="White"
                      AlternatingRowBackground="#E3F2FD"
                      FrozenColumnCount="2"
                      FontFamily="Tahoma" FontSize="11"
                      RowHeight="24"
                      ColumnHeaderHeight="28"
                      MouseDoubleClick="DataGrid_MouseDoubleClick">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1B5E20"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="Padding" Value="5,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="BorderBrush" Value="#2E7D32"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C8E6C9"/>
                                <Setter Property="Foreground" Value="#1B5E20"/>
                            </Trigger>
                        </Style.Triggers>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu FontFamily="Tahoma" FontSize="12">
                                    <MenuItem Header="Izmeni partnera F7"
                                              Command="{Binding DataContext.IzmeniCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              FontWeight="Bold"/>
                                    <MenuItem Header="Kopiraj kao novi"
                                              Command="{Binding DataContext.KopirajRedCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                    <Separator/>
                                    <MenuItem Header="Obriši partnera"
                                              Command="{Binding DataContext.ObrisiCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              Foreground="#C62828"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Šifra"       Binding="{Binding Sifra}"   Width="80"/>
                    <DataGridTextColumn Header="Naziv"       Binding="{Binding Naziv}"   Width="260"/>
                    <DataGridTextColumn Header="Naziv 2"     Binding="{Binding Naziv2}"  Width="180"/>
                    <DataGridTextColumn Header="Pošta"       Binding="{Binding Posta}"   Width="75"/>
                    <DataGridTextColumn Header="Mesto"       Binding="{Binding Mesto}"   Width="155"/>
                    <DataGridTextColumn Header="Ulica"       Binding="{Binding Ulica}"   Width="190"/>
                    <DataGridTextColumn Header="Br."         Binding="{Binding Ulbroj}"  Width="55"/>
                    <DataGridTextColumn Header="Telefon"     Binding="{Binding Telefon}" Width="125"/>
                    <DataGridTextColumn Header="Kontakt"     Binding="{Binding Lice1}"   Width="165"/>
                    <DataGridTextColumn Header="PIB"         Binding="{Binding Pib}"     Width="110"/>
                    <DataGridTextColumn Header="Mat. broj"   Binding="{Binding Maticni}" Width="110"/>
                    <DataGridTextColumn Header="E-mail"      Binding="{Binding Email}"   Width="210"/>
                    <DataGridTextColumn Header="Žiro račun"  Binding="{Binding ZiroRac}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state -->
            <Border Background="#F0F0F0"
                    Visibility="{Binding IsListaPrazan, Converter={StaticResource BoolToVisibilityConverter}}"
                    Panel.ZIndex="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🏢" FontSize="32" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="Nema partnera u šifarnik"
                               FontFamily="Tahoma" FontSize="13" Foreground="#9E9E9E"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="Koristite DODAJ + da unesete novog partnera"
                               FontFamily="Tahoma" FontSize="11" Foreground="#BDBDBD"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Busy overlay -->
            <Border Background="#CC1B5E20" Panel.ZIndex="100"
                    Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="220" Height="6"
                                 Foreground="White" Background="#2E7D32"/>
                    <TextBlock Text="{Binding BusyPoruka}"
                               FontFamily="Tahoma" FontSize="13" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               Margin="0,14,0,0"/>
                </StackPanel>
            </Border>

        </Grid>

    </DockPanel>
</Window>
