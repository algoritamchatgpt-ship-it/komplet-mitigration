<Window x:Class="Algoritam.WPF.Views.Zarade.PutarineView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Evidencija putarina"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
        <KeyBinding Key="F4" Command="{Binding RelacijeF4Command}"/>
        <KeyBinding Key="F7" Command="{Binding KarticaF7Command}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <TextBlock Text="{Binding Naslov}"
                       Margin="14,0" VerticalAlignment="Center"
                       Foreground="White" FontFamily="Tahoma" FontSize="16" FontWeight="Bold"/>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="OSVEZI" Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <Button DockPanel.Dock="Right" Content="IZLAZ" Width="110" Height="28" Margin="8,0,0,0"
                        Background="#455A64" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Margin="10,8,10,0">
            <WrapPanel Margin="0,0,0,5">
                <Button Content="PRVI" Width="78" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrviCommand}"/>
                <Button Content="GORE" Width="78" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrethodniCommand}"/>
                <Button Content="DOLE" Width="78" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding SledeciCommand}"/>
                <Button Content="ZADNJI" Width="80" Height="28" Margin="0,0,10,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PoslednjiCommand}"/>

                <Button Content="DODAJ" Width="90" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding DodajCommand}"/>
                <Button Content="BRISANJE ZADNJEG" Width="138" Height="28" Margin="0,0,4,0"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding BrisanjeZadnjegCommand}"/>
                <Button Content="SAČUVAJ" Width="90" Height="28" Margin="0,0,10,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding SacuvajCommand}"/>

                <Button Content="KARTICA F7" Width="100" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding KarticaF7Command}"/>
                <Button Content="RELACIJE F4" Width="110" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding RelacijeF4Command}"/>
                <Button Content="PREGLED ZA PERIOD" Width="148" Height="28"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PregledZaPeriodCommand}"/>
            </WrapPanel>

            <WrapPanel Margin="0,0,0,8">
                <TextBox Width="260" Height="28" Margin="0,0,4,0"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding PretragaTekst, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="TRAZI" Width="80" Height="28"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding TraziCommand}"/>
            </WrapPanel>
        </StackPanel>

        <!-- Grid -->
        <Border Margin="10,0,10,10" BorderBrush="#B0BEC5" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Stavke}"
                      SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#FAFAFA"
                      FontFamily="Tahoma" FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Red.br." Binding="{Binding Redbr}" Width="72"/>
                    <DataGridTextColumn Header="Putnal" Binding="{Binding Putnal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                    <DataGridTextColumn Header="Datum" Binding="{Binding Datdok, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="95"/>
                    <DataGridTextColumn Header="Vreme" Binding="{Binding Vreme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridTextColumn Header="Šifra" Binding="{Binding Sifrel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                    <DataGridTextColumn Header="Relacija / Naziv" Binding="{Binding Relacija, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="Iznos" Binding="{Binding Iznos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                    <DataGridTextColumn Header="Grupa" Binding="{Binding Grupa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                    <DataGridTextColumn Header="Kol." Binding="{Binding Kol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
