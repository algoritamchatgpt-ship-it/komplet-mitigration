<Window x:Class="Algoritam.WPF.Views.Zarade.KreditiOtplataView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1380" Height="760"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <TextBlock Text="{Binding Naslov}"
                       Margin="14,0"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontFamily="Tahoma"
                       FontSize="16"
                       FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="OSVEZI"
                        Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="OTKAZI"
                            Width="96"
                            Height="28"
                            Margin="0,0,8,0"
                            Background="#455A64"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                            Command="{Binding OtkaziCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="SAČUVAJ"
                            Width="96"
                            Height="28"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                            Command="{Binding SacuvajCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
                <TextBlock Text="{Binding Poruka}"
                           VerticalAlignment="Center"
                           FontFamily="Tahoma"
                           FontSize="11"/>
            </DockPanel>
        </Border>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,8,10,0">
            <Border BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="5,3">
                <StackPanel>
                    <TextBlock Text="NAVIGACIJA" FontFamily="Tahoma" FontSize="9" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="PRVI" Width="82" Height="28" Margin="0,0,4,0" Command="{Binding PrviCommand}" Style="{StaticResource NavBtnStyle}"/>
                        <Button Content="GORE" Width="82" Height="28" Margin="0,0,4,0" Command="{Binding PrethodniCommand}" Style="{StaticResource NavBtnStyle}"/>
                        <Button Content="DOLE" Width="82" Height="28" Margin="0,0,4,0" Command="{Binding SledeciCommand}" Style="{StaticResource NavBtnStyle}"/>
                        <Button Content="ZADNJI" Width="82" Height="28" Command="{Binding PoslednjiCommand}" Style="{StaticResource NavBtnStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="3" Padding="5,3">
                <StackPanel>
                    <TextBlock Text="OPERACIJE" FontFamily="Tahoma" FontSize="9" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="DODAJ +" Width="96" Height="28" Margin="0,0,4,0" Command="{Binding DodajCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="BRISANJE" Width="96" Height="28" Margin="0,0,4,0" Command="{Binding BrisanjeCommand}" Style="{StaticResource DangerButtonStyle}"/>
                        <Button Content="JEDAN KREDIT" Width="118" Height="28" Margin="0,0,4,0" Command="{Binding JedanKreditCommand}"
                                Background="#1565C0" Foreground="White" BorderThickness="0" FontFamily="Tahoma" FontSize="11" Cursor="Hand"/>
                        <Button Content="SORT" Width="82" Height="28" Command="{Binding SortirajCommand}"
                                Background="#607D8B" Foreground="White" BorderThickness="0" FontFamily="Tahoma" FontSize="11" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Margin="10,8,10,10" BorderBrush="#B0BEC5" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Stavke}"
                      SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      FontFamily="Tahoma"
                      FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kredit" Binding="{Binding Kredit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    <DataGridTextColumn Header="Broj" Binding="{Binding Broj, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="65"/>
                    <DataGridTextColumn Header="Sifra" Binding="{Binding Sifra, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    <DataGridTextColumn Header="Datdok" Binding="{Binding DatDok, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="95"/>
                    <DataGridTextColumn Header="Dug" Binding="{Binding Dug, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="95"/>
                    <DataGridTextColumn Header="Iznos" Binding="{Binding Iznos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="95"/>
                    <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="95"/>
                    <DataGridTextColumn Header="Brnal" Binding="{Binding BrNal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                    <DataGridTextColumn Header="Dev" Binding="{Binding Dev, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Devkurs" Binding="{Binding DevKurs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" Width="95"/>
                    <DataGridTextColumn Header="Devdug" Binding="{Binding DevDug, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" Width="95"/>
                    <DataGridTextColumn Header="Devpot" Binding="{Binding DevPot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" Width="95"/>
                    <DataGridTextColumn Header="Devsaldo" Binding="{Binding DevSaldo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" Width="95"/>
                    <DataGridTextColumn Header="Mesec" Binding="{Binding Mesec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Arhiva" Binding="{Binding Arhiva, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Arhiva2" Binding="{Binding Arhiva2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Preneto" Binding="{Binding Preneto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Idbr" Binding="{Binding IdBr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
