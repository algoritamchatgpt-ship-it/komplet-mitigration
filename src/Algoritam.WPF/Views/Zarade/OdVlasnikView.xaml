<Window x:Class="Algoritam.WPF.Views.Zarade.OdVlasnikView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obrazac OD — Vlasnik" Width="1200" Height="550"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1B5E20" Padding="16,10">
            <TextBlock Text="{Binding Naslov}" Foreground="White" FontSize="16" FontWeight="Bold" FontFamily="Tahoma"/>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <DataGrid ItemsSource="{Binding Stavke}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      Background="White" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1B5E20"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kod" Binding="{Binding Kod}" Width="70"/>
                    <DataGridTextColumn Header="Opis" Binding="{Binding Opis}" Width="180"/>
                    <DataGridTextColumn Header="AOP" Binding="{Binding Aop}" Width="50"/>
                    <DataGridTextColumn Header="SK1" Binding="{Binding Sk1, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK2" Binding="{Binding Sk2, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK3" Binding="{Binding Sk3, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK4" Binding="{Binding Sk4, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK5" Binding="{Binding Sk5, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK6" Binding="{Binding Sk6, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK7" Binding="{Binding Sk7, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK8" Binding="{Binding Sk8, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="SK0" Binding="{Binding Sk0, StringFormat=N2}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="2" Background="#E8F5E9" Padding="16,8" BorderThickness="0,1,0,0" BorderBrush="#C8E6C9">
            <DockPanel>
                <Button Content="F5 OSVEZI" DockPanel.Dock="Right"
                        Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <Button Content="ZATVORI" DockPanel.Dock="Right" Width="100" Height="28"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Background="#C62828" Foreground="White" Cursor="Hand" Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
