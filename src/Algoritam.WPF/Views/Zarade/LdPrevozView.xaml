<Window x:Class="Algoritam.WPF.Views.Zarade.LdPrevozView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1400" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <TextBlock Text="{Binding Naslov}"
                       Margin="14,0"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontFamily="Tahoma"
                       FontSize="16"
                       FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="OSVEZI"
                        Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <Button DockPanel.Dock="Right"
                        Content="IZLAZ"
                        Width="110"
                        Height="28"
                        Margin="8,0,0,0"
                        Background="#455A64"
                        Foreground="White"
                        BorderThickness="0"
                        FontFamily="Tahoma"
                        FontSize="11"
                        Cursor="Hand"
                        Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}"
                           VerticalAlignment="Center"
                           FontFamily="Tahoma"
                           FontSize="11"/>
            </DockPanel>
        </Border>

        <StackPanel DockPanel.Dock="Top" Margin="10,8,10,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <Border BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="5,3">
                    <StackPanel>
                        <TextBlock Text="NAVIGACIJA" FontFamily="Tahoma" FontSize="9" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="PRVI" Width="82" Height="28" Margin="0,0,4,0" Command="{Binding PrviCommand}" Style="{StaticResource NavBtnStyle}"/>
                            <Button Content="GORE" Width="82" Height="28" Margin="0,0,4,0" Command="{Binding PrethodniCommand}" Style="{StaticResource NavBtnStyle}"/>
                            <Button Content="DOLE" Width="82" Height="28" Margin="0,0,4,0" Command="{Binding SledeciCommand}" Style="{StaticResource NavBtnStyle}"/>
                            <Button Content="ZADNJI" Width="82" Height="28" Command="{Binding PoslednjiCommand}" Style="{StaticResource NavBtnStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="5,3">
                    <StackPanel>
                        <TextBlock Text="UREĐIVANJE" FontFamily="Tahoma" FontSize="9" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="DODAJ" Width="96" Height="28" Margin="0,0,4,0" Command="{Binding DodajCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Content="BRISANJE JEDNOG" Width="130" Height="28" Margin="0,0,4,0" Command="{Binding BrisanjeJednogCommand}" Style="{StaticResource DangerButtonStyle}"/>
                            <Button Content="BRIŠI SVE" Width="98" Height="28" Margin="0,0,4,0" Command="{Binding BrisiSveCommand}" Style="{StaticResource DangerButtonStyle}"/>
                            <Button Content="SAČUVAJ" Width="98" Height="28" Command="{Binding SacuvajCommand}" Style="{StaticResource SaveButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="3" Padding="5,3">
                    <StackPanel>
                        <TextBlock Text="PREGLED / ARHIVA" FontFamily="Tahoma" FontSize="9" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="EXPORT U EXCEL" Width="130" Height="28" Margin="0,0,4,0" Command="{Binding ExportExcelCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Content="PREGLED SVE" Width="110" Height="28" Margin="0,0,4,0" Command="{Binding PregledSveCommand}"/>
                            <Button Content="ARHIVA/DEARHIVA" Width="132" Height="28" Command="{Binding ArhivaDearhivaCommand}" Style="{StaticResource WarnButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <WrapPanel Margin="0,0,0,8">
                <TextBox Width="230" Height="28"
                         Margin="0,0,4,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Tahoma"
                         FontSize="11"
                         Text="{Binding PretragaIme, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="TRAŽI IME F4" Width="112" Height="28" Margin="0,0,10,0" Command="{Binding TraziImeCommand}"/>

                <TextBox Width="150" Height="28"
                         Margin="0,0,4,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Tahoma"
                         FontSize="11"
                         Text="{Binding PretragaSifra, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="TRAŽI ŠIFRU F6" Width="112" Height="28" Margin="0,0,10,0" Command="{Binding TraziSifruCommand}"/>

                <Button Content="POPUNJAVANJE" Width="115" Height="28" Margin="0,0,4,0" Command="{Binding PopunjavanjeCommand}"/>
                <Button Content="PREUZMI IZ SPISKA" Width="130" Height="28" Margin="0,0,4,0" Command="{Binding PreuzmiIzSpiskaCommand}"/>
                <Button Content="SIFRA PRIHODA" Width="115" Height="28" Command="{Binding SifraPrihodaCommand}"/>
            </WrapPanel>
        </StackPanel>

        <Border Margin="10,0,10,10" BorderBrush="#B0BEC5" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Stavke}"
                      SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      FontFamily="Tahoma"
                      FontSize="11">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Broj" Binding="{Binding Broj, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="210"/>
                    <DataGridTextColumn Header="Dana" Binding="{Binding Dana, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N1}" Width="70"/>
                    <DataGridTextColumn Header="Karta" Binding="{Binding Karta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                    <DataGridTextColumn Header="Prevoz" Binding="{Binding Prevoz, StringFormat=N2}" IsReadOnly="True" Width="80"/>
                    <DataGridTextColumn Header="Neoporez" Binding="{Binding Neoporez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="Oporez" Binding="{Binding Oporez, StringFormat=N2}" IsReadOnly="True" Width="80"/>
                    <DataGridTextColumn Header="Stopa" Binding="{Binding Stopa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="70"/>
                    <DataGridTextColumn Header="Porez" Binding="{Binding Porez, StringFormat=N2}" IsReadOnly="True" Width="80"/>
                    <DataGridTextColumn Header="Ukupprev" Binding="{Binding Ukupprev, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                    <DataGridTextColumn Header="Datum" Binding="{Binding Datum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="95"/>
                    <DataGridTextColumn Header="Grupa" Binding="{Binding Grupa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Mesec" Binding="{Binding Mesec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Isplata" Binding="{Binding Isplata, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Vrsta" Binding="{Binding Vrsta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Nazmes" Binding="{Binding Nazmes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                    <DataGridTextColumn Header="Sifraprih" Binding="{Binding Sifraprih, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                    <DataGridTextColumn Header="Arhiva" Binding="{Binding Arhiva, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                    <DataGridTextColumn Header="Arhiva2" Binding="{Binding Arhiva2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Preneto" Binding="{Binding Preneto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Numred" Binding="{Binding Numred}" IsReadOnly="True" Width="70"/>
                    <DataGridTextColumn Header="Idbr" Binding="{Binding Idbr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
