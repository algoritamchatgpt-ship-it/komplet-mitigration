<Window x:Class="Algoritam.WPF.Views.Zarade.LdPutnal2View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pregled putnih naloga za period"
        Width="900" Height="560"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="44">
            <TextBlock Text="PREGLED PUTNIH NALOGA ZA PERIOD"
                       Margin="14,0" VerticalAlignment="Center"
                       Foreground="White" FontFamily="Tahoma" FontSize="13" FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="ŠTAMPA" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#1B5E20" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand" Command="{Binding StampaCommand}"/>
                    <Button Content="IZLAZ" Width="90" Height="28"
                            Background="#C62828" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand" Click="ZatvoriClick"/>
                </StackPanel>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- Filter row -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#B0BEC5"
                BorderThickness="0,0,0,1" Padding="10,8">
            <WrapPanel>
                <TextBlock Text="OD:" VerticalAlignment="Center" Margin="0,0,6,0"
                           FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
                <TextBox Width="100" Height="26" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11" Margin="0,0,14,0"
                         Text="{Binding DatumOd, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>
                <TextBlock Text="DO:" VerticalAlignment="Center" Margin="0,0,6,0"
                           FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
                <TextBox Width="100" Height="26" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11" Margin="0,0,14,0"
                         Text="{Binding DatumDo, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>
                <Button Content="PREGLED" Width="90" Height="28"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Command="{Binding PregledCommand}"/>
            </WrapPanel>
        </Border>

        <Border Margin="10,6,10,0" BorderBrush="#B0BEC5" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Rezultati}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      FontFamily="Tahoma" FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Putnal" Binding="{Binding Putnal}" Width="70"/>
                    <DataGridTextColumn Header="Datum" Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="95"/>
                    <DataGridTextColumn Header="Radnik" Binding="{Binding ImeRadnika}" Width="200"/>
                    <DataGridTextColumn Header="Cilj" Binding="{Binding Cilj}" Width="180"/>
                    <DataGridTextColumn Header="Svega" Binding="{Binding Svega, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Za isplatu" Binding="{Binding Zaisplat, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Napomena" Binding="{Binding Napomena}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
