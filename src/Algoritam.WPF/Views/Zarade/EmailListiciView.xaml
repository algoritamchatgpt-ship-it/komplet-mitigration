<Window x:Class="Algoritam.WPF.Views.Zarade.EmailListiciView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Algoritam.WPF.ViewModels"
        Title="Email isplatnih listića"
        Width="820" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Tahoma" FontSize="11">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Padding="16,10">
            <DockPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="EMAIL ISPLATNIH LISTIĆA"
                               FontSize="15" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding MesecGodina}"
                               FontSize="10" Foreground="#A5D6A7" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                           Foreground="#A5D6A7" FontSize="10"
                           Text="Generiše PDF listić i otvara email klijent za svakog radnika"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9" Padding="12,6">
            <TextBlock Text="{Binding Poruka}" Foreground="#2E7D32" FontSize="11"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Output folder bar -->
        <Border DockPanel.Dock="Bottom" Background="#FFF8E1"
                BorderThickness="0,1,0,0" BorderBrush="#FFE082" Padding="12,7">
            <DockPanel>
                <TextBlock Text="Folder za PDF-ove:" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="#F57F17" Margin="0,0,10,0"/>
                <Button Content="PROMENI..." DockPanel.Dock="Right"
                        Width="88" Height="26" Margin="8,0,0,0"
                        Background="#F9A825" Foreground="#212121" BorderThickness="0"
                        Cursor="Hand" Command="{Binding PromeniFolderCommand}"/>
                <TextBox Text="{Binding OutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         IsReadOnly="True" Background="#FFFDE7" BorderBrush="#FFE082"/>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9" Padding="12,8">
            <DockPanel>
                <Button Content="ZATVORI" DockPanel.Dock="Right"
                        Width="90" Height="30"
                        Background="#455A64" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Command="{Binding ZatvoriCommand}"/>
                <Button Content="F5 OSVEZI" DockPanel.Dock="Right"
                        Width="90" Height="30" Margin="0,0,8,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>

                <WrapPanel VerticalAlignment="Center">
                    <Button Content="IZABERI SVE" Width="100" Height="30" Margin="0,0,5,0"
                            Background="#546E7A" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Command="{Binding IzaberiSveCommand}"/>
                    <Button Content="PONIŠTI SVE" Width="100" Height="30" Margin="0,0,20,0"
                            Background="#546E7A" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Command="{Binding PonistiSveCommand}"/>

                    <Button Content="1. GENERIŠI PDF-OVE" Width="155" Height="30" Margin="0,0,5,0"
                            Background="#1565C0" Foreground="White" BorderThickness="0"
                            FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Generiše PDF listic za svakog izabranog radnika i otvara folder"
                            Command="{Binding GenerisiPdfoveCommand}"/>
                    <Button Content="2. POŠALJI SVIMA" Width="140" Height="30"
                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                            FontWeight="SemiBold" Cursor="Hand"
                            ToolTip="Otvara email klijent (mailto:) za svakog izabranog radnika"
                            Command="{Binding PostaljiSvimaCommand}"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Tabela radnika -->
        <DataGrid x:Name="RadniciGrid"
                  ItemsSource="{Binding Redovi}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  Background="White"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  AlternatingRowBackground="#F1F8E9"
                  FontFamily="Tahoma" FontSize="11"
                  RowHeight="28"
                  Margin="4,4,4,0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1B5E20"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush" Value="#2E7D32"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <!-- Checkbox kolona -->
                <DataGridTemplateColumn Header="" Width="36" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Izabran, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Br." Binding="{Binding Broj}" Width="55" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez}" Width="220" IsReadOnly="True"/>
                <DataGridTextColumn Header="Email adresa" Binding="{Binding Email}" Width="240" IsReadOnly="True"/>

                <!-- Za isplatu -->
                <DataGridTextColumn Header="Za isplatu" Width="110" IsReadOnly="True">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Stavka.Zaisplatu" StringFormat="N2"/>
                    </DataGridTextColumn.Binding>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Status -->
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#2E7D32"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Pošalji jednom -->
                <DataGridTemplateColumn Header="" Width="80" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="MEJL"
                                    Height="22" Margin="2"
                                    Background="#1565C0" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="10"
                                    Command="{Binding DataContext.PostaljiJednomCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
