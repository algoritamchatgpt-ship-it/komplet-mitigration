<Window x:Class="Algoritam.WPF.Views.Zarade.PppView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PARAMETRI ZARADE ZAPOSLENIH"
        Width="1260"
        Height="830"
        WindowStartupLocation="CenterScreen"
        Background="#D6D6D6"
        Closing="OnWindowClosing">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="LegacyInputStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="Background" Value="#EDEDED"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="3,0,3,0"/>
        </Style>
        <Style x:Key="LegacyDateStyle" TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="#EDEDED"/>
        </Style>
        <Style x:Key="RedLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#9B111E"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>
        <Style x:Key="BlueLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0039A6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#B7CCE2" BorderBrush="#8A8A8A" BorderThickness="1" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding FirmaNaziv}" FontFamily="Tahoma" FontSize="20" FontWeight="Bold" Foreground="#111111"/>
                    <TextBlock Text="{Binding FirmaMesto}" FontFamily="Tahoma" FontSize="14" Foreground="#2D2D2D" Margin="0,2,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Padding="12,6" BorderThickness="1" BorderBrush="#4A4A4A" Background="#E8EEF4">
                    <StackPanel>
                        <TextBlock Text="PORESKA PRIJAVA" FontFamily="Tahoma" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="OBRAZAC PPP-PD" FontFamily="Tahoma" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#F1C8B4" BorderBrush="#8A8A8A" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="560"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tip isplate" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Width="70" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.TipIsplate, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource HintStyle}" Text="1=Pravno lice nije iz budzeta 2=Pravno lice iz budzeta 3=Strano predstavnistvo"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Vrsta id isplatioca 0=pib 1=jmbg" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Width="70" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.VrstaIdIsplatioca, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource HintStyle}" Text="4=Preduzetnik 5=Fizicko lice, 6=Vojska RS 7=Poljoprivredno"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Propisana osnovica" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Width="130" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.PropisanaOsnovica, UpdateSourceTrigger=LostFocus}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Sifra opstine" Style="{StaticResource RedLabelStyle}"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="70" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.SifraOpstine, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Text="Pib ili JMBG" Style="{StaticResource RedLabelStyle}" Margin="10,0,8,0"/>
                            <TextBox Width="220" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.PibIliJmbg, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="JMBG podnosioca" Style="{StaticResource RedLabelStyle}"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="220" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.JmbgPodnosioca, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Text="Maticni broj firme" Style="{StaticResource RedLabelStyle}" Margin="10,0,8,0"/>
                            <TextBox Width="160" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.MaticniBrojFirme, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Naziv/Prezime i ime" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Width="520" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.NazivPrezimeIme, UpdateSourceTrigger=LostFocus}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Sediste" Style="{StaticResource RedLabelStyle}"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="330" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.Sediste, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Text="Telefon" Style="{StaticResource RedLabelStyle}" Margin="10,0,8,0"/>
                            <TextBox Width="170" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.Telefon, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Ulica i broj" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Width="520" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.UlicaIBroj, UpdateSourceTrigger=LostFocus}"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Email" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="8" Grid.Column="1" Width="520" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.Email, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>
                </Border>

                <Border Background="#F1C8B4" BorderBrush="#8A8A8A" BorderThickness="1" Padding="10" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Vrsta izmene" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Width="120" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.VrstaIzmene, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource HintStyle}" Text="1=izmena, 2=po nalogu kontrole, 3=po odluci suda"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Identifikacija izmene" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Width="230" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.IdentifikacijaIzmene, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource HintStyle}" Text="Broj prijave koja se ovom prijavom menja"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Broj resenja" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Width="230" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.BrojResenja, UpdateSourceTrigger=LostFocus}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Osnov podnosenja" Style="{StaticResource RedLabelStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Width="230" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.OsnovPodnosenja, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource HintStyle}" Text="1=Zalba prvi stepen, 2=Zalba drugi stepen 3=Po nalogu suda"/>
                    </Grid>
                </Border>

                <Border Background="#CFE4CF" BorderBrush="#8A8A8A" BorderThickness="1" Padding="10" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Deklaracija-Broj prijave" Style="{StaticResource BlueLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Width="110" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.Deklaracija, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="5" Style="{StaticResource HintStyle}" Text="Upisati jedinstvenu oznaku"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Vrsta prijave" Style="{StaticResource BlueLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Width="90" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.VrstaPrijave, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="5" Style="{StaticResource HintStyle}" Text="1=opsta, 2=po sluz.duz, 3=samoprijavljivanje 4=po nalazu kontrole, 5=po odluci suda"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Godina" Style="{StaticResource BlueLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Width="110" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.Godina, UpdateSourceTrigger=LostFocus}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Isplata za mesec" Style="{StaticResource BlueLabelStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Width="90" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.IsplataZaMesec, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Redni broj isplate" Style="{StaticResource BlueLabelStyle}" Margin="8,0,6,0"/>
                        <TextBox Grid.Row="3" Grid.Column="3" Width="70" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.RedniBrojIsplate, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="3" Grid.Column="4" Text="Konacna" Style="{StaticResource BlueLabelStyle}" Margin="8,0,6,0"/>
                        <TextBox Grid.Row="3" Grid.Column="5" Width="70" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.Konacna, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="3" Grid.Column="6" Style="{StaticResource HintStyle}" Text="K=konacna"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Datum obaveze" Style="{StaticResource BlueLabelStyle}"/>
                        <DatePicker Grid.Row="4" Grid.Column="1" Width="150" Style="{StaticResource LegacyDateStyle}" SelectedDate="{Binding Parametar.DatumObaveze, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="5" Style="{StaticResource HintStyle}" Text="Ne popunjava se kod opste prijave"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Datum placanja" Style="{StaticResource BlueLabelStyle}"/>
                        <DatePicker Grid.Row="5" Grid.Column="1" Width="150" Style="{StaticResource LegacyDateStyle}" SelectedDate="{Binding Parametar.DatumPlacanja, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="5" Style="{StaticResource HintStyle}" Text="Najkasniji datum kada se planira isplata - posle toga ide kamata"/>
                    </Grid>
                </Border>

                <Border Background="#E6E6B5" BorderBrush="#8A8A8A" BorderThickness="1" Padding="10" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Broj dana" Style="{StaticResource BlueLabelStyle}"/>
                        <TextBox Grid.Column="1" Width="80" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.BrojDana, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Column="2" Text="Fond sati" Style="{StaticResource BlueLabelStyle}" Margin="8,0,0,0"/>
                        <TextBox Grid.Column="3" Width="80" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.FondSati, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Column="4" Text="Broj zaposlenih" Style="{StaticResource BlueLabelStyle}" Margin="8,0,0,0"/>
                        <TextBox Grid.Column="5" Width="80" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.BrojZaposlenih, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>
                </Border>

                <Border Background="#E3E3E3" BorderBrush="#8A8A8A" BorderThickness="1" Padding="6,5" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Link" FontFamily="Tahoma" FontSize="13" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Style="{StaticResource LegacyInputStyle}" Text="{Binding Parametar.Link, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#C8C8C8" BorderBrush="#9A9A9A" BorderThickness="0,1,0,0" Padding="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="160"
                        Height="38"
                        FontFamily="Tahoma"
                        FontSize="13"
                        FontWeight="Bold"
                        Content="SAČUVAJ"
                        Command="{Binding SacuvajCommand}"
                        Margin="0,0,6,0"/>

                <Button Grid.Column="1"
                        Width="160"
                        Height="38"
                        FontFamily="Tahoma"
                        FontSize="13"
                        Content="OSVEZI  (F5)"
                        Command="{Binding OsveziCommand}"
                        Margin="0,0,6,0"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding Poruka}"
                           FontFamily="Tahoma"
                           FontSize="12"
                           Foreground="#1C1C1C"
                           VerticalAlignment="Center"
                           Margin="12,0"/>

                <Button Grid.Column="3"
                        Width="160"
                        Height="38"
                        FontFamily="Tahoma"
                        FontSize="13"
                        Content="IZLAZ"
                        Click="ZatvoriClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>
