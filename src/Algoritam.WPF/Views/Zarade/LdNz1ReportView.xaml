<Window x:Class="Algoritam.WPF.Views.Zarade.LdNz1ReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obrazac NZ1-1"
        Width="1280"
        Height="760"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Tahoma"
        FontSize="11">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#607D8B" Padding="12,8" CornerRadius="4">
            <DockPanel>
                <TextBlock Text="OBRAZAC NZ1-1"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="Bold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="96"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="StampajClick"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Content="STAMPAJ"/>
                    <Button Width="90"
                            Height="28"
                            Click="ZatvoriClick"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Content="ZATVORI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="PrintRoot"
                Grid.Row="1"
                Margin="0,10,0,10"
                Background="White"
                BorderBrush="#C8E6C9"
                BorderThickness="1"
                Padding="10">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#E8F0FE">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="br" Binding="{Binding Br}" Width="70"/>
                    <DataGridTextColumn Header="ime_prez" Binding="{Binding ImePrez}" Width="320"/>
                    <DataGridTextColumn Header="bruto" Binding="{Binding Bruto, StringFormat=N2}" Width="140"/>
                    <DataGridTextColumn Header="pdete" Binding="{Binding Pdete, StringFormat=N2}" Width="140"/>
                    <DataGridTextColumn Header="oposto" Binding="{Binding Oposto, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="tposto" Binding="{Binding Tposto, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="sposto" Binding="{Binding Sposto, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="osnovp" Binding="{Binding Osnovp, StringFormat=N2}" Width="140"/>
                    <DataGridTextColumn Header="porez" Binding="{Binding Porez, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="zaisplat" Binding="{Binding Zaisplat, StringFormat=N2}" Width="140"/>
                    <DataGridTextColumn Header="dop" Binding="{Binding Dop, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="obaveze" Binding="{Binding Obaveze, StringFormat=N2}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NZ1"
                           FontFamily="Tahoma" FontSize="9" Foreground="#C8E6C9"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" Text="{Binding InfoTekst}"
                           FontFamily="Tahoma" FontSize="11" Foreground="#37474F"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
