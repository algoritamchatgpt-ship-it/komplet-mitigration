<Window x:Class="Algoritam.WPF.Views.Zarade.LdNaknadeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="900" Height="580"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
        <KeyBinding Key="F2" Command="{Binding SacuvajCommand}"/>
        <KeyBinding Key="Insert" Command="{Binding DodajCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <TextBlock Text="OBRAČUN NAKNADA (ldgod0.dbf)"
                       FontFamily="Tahoma" FontSize="16" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center" Margin="16,0"/>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#E8F5E9" Padding="8,6"
                BorderThickness="0,0,0,1" BorderBrush="#C8E6C9">
            <WrapPanel>
                <Button Content="DODAJ  Ins" Width="100" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding DodajCommand}"/>
                <Button Content="F2 SAČUVAJ" Width="100" Height="28" Margin="0,0,12,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding SacuvajCommand}"/>
                <Button Content="◀◀ PRVI" Width="72" Height="28" Margin="0,0,3,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrviCommand}"/>
                <Button Content="◀ GORE" Width="68" Height="28" Margin="0,0,3,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding GoreCommand}"/>
                <Button Content="▶ DOLE" Width="68" Height="28" Margin="0,0,3,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding DoleCommand}"/>
                <Button Content="▶▶ ZADNJI" Width="80" Height="28" Margin="0,0,16,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding ZadnjiCommand}"/>
                <Button Content="PRENOS IZ ARHIVE" Width="140" Height="28" Margin="0,0,4,0"
                        Background="#E65100" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding PrenosIzArhiveCommand}"
                        ToolTip="Prenosi radnike iz ld00 (platnog spiska) i računa POSATU"/>
                <Button Content="OBRAČUN NAKNADA" Width="140" Height="28" Margin="0,0,12,0"
                        Background="#AD1457" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding ObracunNaknadaCommand}"
                        ToolTip="Računa DIN naknade u ld00 na osnovu POSATU iz ldgod0"/>
                <Button Content="ŠTAMPA" Width="80" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        ToolTip="Štampaj obračun naknada"
                        Click="StampaClick"/>
                <Button Content="F5 OSVEZI" Width="84" Height="28"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding OsveziCommand}"/>
            </WrapPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,6">
            <DockPanel>
                <Button Content="ZATVORI" DockPanel.Dock="Right" Width="100" Height="28"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1B5E20" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="StavkeGrid"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9FBF9"
                  RowBackground="White"
                  FontFamily="Tahoma" FontSize="11"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Br." Binding="{Binding Broj}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez}" Width="220"/>
                <DataGridTextColumn Header="Čas. ukupno" Binding="{Binding Casuk, StringFormat=N2}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Din. ukupno" Binding="{Binding Dinuk, StringFormat=N2}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Po satu" Binding="{Binding Posatu, StringFormat=N4}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="P" Binding="{Binding Preneto}" Width="35"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
