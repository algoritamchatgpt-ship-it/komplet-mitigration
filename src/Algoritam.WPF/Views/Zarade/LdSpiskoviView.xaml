<Window x:Class="Algoritam.WPF.Views.Zarade.LdSpiskoviView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1040"
        Height="760"
        MinWidth="980"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <StackPanel VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="{Binding Naslov, FallbackValue='SPISAK ZA ISPLATU'}"
                           FontSize="16" FontWeight="Bold" Foreground="White" FontFamily="Tahoma"/>
                <TextBlock Text="Spiskovi za isplatu zarada"
                           FontSize="10" Foreground="#A5D6A7" FontFamily="Tahoma"/>
            </StackPanel>
        </Border>

        <!-- Banka status bar -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="12,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Banka:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1B5E20" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusBanke}" FontFamily="Tahoma" FontSize="11"
                           VerticalAlignment="Center" Foreground="#2E7D32"/>
            </StackPanel>
        </Border>

        <!-- Footer: RED 2 — navigacija + polja + izlaz -->
        <Border DockPanel.Dock="Bottom" Background="#ECEFF1" BorderBrush="#CFD8DC"
                BorderThickness="0,1,0,0" Padding="12,7">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="IZLAZ" Width="100" Height="30"
                        Background="#455A64" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Click="ZatvoriClick"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Navigacija -->
                    <Button Content="◀◀ PRVI"   Width="76" Height="28" Margin="0,0,4,0"
                            Background="#546E7A" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                            Command="{Binding PrviCommand}"/>
                    <Button Content="◀ GORE"    Width="76" Height="28" Margin="0,0,4,0"
                            Background="#546E7A" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                            Command="{Binding GoreCommand}"/>
                    <Button Content="▶ DOLE"    Width="76" Height="28" Margin="0,0,4,0"
                            Background="#546E7A" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                            Command="{Binding DoleCommand}"/>
                    <Button Content="▶▶ ZADNJI" Width="84" Height="28" Margin="0,0,24,0"
                            Background="#546E7A" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                            Command="{Binding ZadnjiCommand}"/>

                    <!-- Mesec / Isplata -->
                    <TextBlock Text="Mesec:" VerticalAlignment="Center"
                               FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#455A64" Margin="0,0,6,0"/>
                    <TextBox Width="46" Height="26" Text="{Binding Mesec}"
                             VerticalContentAlignment="Center" Margin="0,0,14,0"
                             FontFamily="Tahoma" FontSize="11"/>
                    <TextBlock Text="Isplata:" VerticalAlignment="Center"
                               FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#455A64" Margin="0,0,6,0"/>
                    <TextBox Width="46" Height="26" Text="{Binding Isplata}"
                             VerticalContentAlignment="Center"
                             FontFamily="Tahoma" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Footer: RED 0 — TXT izvoz po bankama -->
        <Border DockPanel.Dock="Bottom" Background="#FFF8E1" BorderBrush="#FFE082"
                BorderThickness="0,1,0,0" Padding="12,7">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="TXT izvoz:" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                           Foreground="#F57F17" Margin="0,0,10,0"/>
                <Button Content="POSTANSKA" Width="98" Height="28" Margin="0,0,4,0"
                        Background="#5C6BC0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding IzvozTxtPostanskaCommand}"/>
                <Button Content="INTESA" Width="72" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding IzvozTxtIntesaCommand}"/>
                <Button Content="UNIKREDIT" Width="88" Height="28" Margin="0,0,4,0"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding IzvozTxtUnikreditCommand}"/>
                <Button Content="SOCIETE" Width="76" Height="28" Margin="0,0,4,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding IzvozTxtSocieteCommand}"/>
                <Button Content="VOJVODJANSKA" Width="108" Height="28" Margin="0,0,4,0"
                        Background="#6A1B9A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding IzvozTxtVojvodjanskaCommand}"/>
                <Button Content="KOMERCIJALNA" Width="108" Height="28" Margin="0,0,4,0"
                        Background="#BF360C" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding IzvozTxtKomercijalnaCommand}"/>
                <Button Content="FINDOMESTIC" Width="100" Height="28" Margin="0,0,0,0"
                        Background="#4E342E" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding IzvozTxtFindomesticCommand}"/>
            </WrapPanel>
        </Border>

        <!-- Footer: RED 1 — akcijska dugmad u grupama -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="12,9">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Grupa: Radnje na spisku -->
                <Button Content="DODAJ"   Width="88" Height="30" Margin="0,0,5,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding DodajCommand}"/>
                <Button Content="BRIŠI"   Width="88" Height="30" Margin="0,0,5,0"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding ObrisiCommand}"/>
                <Button Content="PRENOS"  Width="88" Height="30"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrenosCommand}"/>

                <!-- Separator -->
                <Rectangle Width="1" Fill="#A5D6A7" Margin="16,2"/>

                <!-- Grupa: Pregledi -->
                <Button Content="SPISAK"      Width="95"  Height="30" Margin="0,0,5,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding SpisakCommand}"/>
                <Button Content="SPISKOVI"    Width="105" Height="30" Margin="0,0,5,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding SpiskoviCommand}"/>
                <Button Content="SALDO FIRME" Width="118" Height="30"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding SaldoFirmeCommand}"/>

                <!-- Separator -->
                <Rectangle Width="1" Fill="#A5D6A7" Margin="16,2"/>

                <!-- Grupa: Prenosi -->
                <Button Content="PRENOS PREVOZA" Width="140" Height="30" Margin="0,0,5,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrenosPrevozCommand}"/>
                <Button Content="PRENOS IZ OPJ1" Width="130" Height="30" Margin="0,0,5,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrenosIzOpj1Command}"/>
                <Button Content="PRENOS IZ OPJ6" Width="130" Height="30"
                        Background="#F9A825" Foreground="#212121" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrenosIzOpj6Command}"/>

            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  RowHeaderWidth="0"
                  BorderThickness="0"
                  Background="White"
                  AlternatingRowBackground="#F9FBF9"
                  FontFamily="Tahoma" FontSize="11"
                  Margin="0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1B5E20"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="6,5"/>
                    <Setter Property="BorderBrush" Value="#0D3F12"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Broj"
                                    Binding="{Binding Broj, UpdateSourceTrigger=PropertyChanged}"
                                    Width="75"/>
                <DataGridTextColumn Header="Ime i prezime"
                                    Binding="{Binding ImePrez, UpdateSourceTrigger=PropertyChanged}"
                                    Width="300"/>
                <DataGridTextColumn Header="Partija"
                                    Binding="{Binding Partija, UpdateSourceTrigger=PropertyChanged}"
                                    Width="230"/>
                <DataGridTextColumn Header="Iznos"
                                    Binding="{Binding Iznos, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                    Width="180"/>
                <DataGridTextColumn Header="Šifra"
                                    Binding="{Binding Sifra, UpdateSourceTrigger=PropertyChanged}"
                                    Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
