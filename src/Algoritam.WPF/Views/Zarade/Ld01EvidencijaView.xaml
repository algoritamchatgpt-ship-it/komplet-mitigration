<Window x:Class="Algoritam.WPF.Views.Zarade.Ld01EvidencijaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1500" Height="760"
        MinWidth="1000" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#E0F2F1"
        FontFamily="Tahoma" FontSize="11">

    <Window.InputBindings>
        <KeyBinding Key="F8"  Command="{Binding PreuzmiCommand}"/>
        <KeyBinding Key="F10" Command="{Binding PregledObracunaCommand}"/>
    </Window.InputBindings>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <Border Grid.Row="0" Background="#00695C" Padding="10,7" CornerRadius="3" Margin="0,0,0,8">
            <TextBlock Text="{Binding Naslov, FallbackValue='EVIDENCIJA OBRAČUNA'}"
                       FontWeight="Bold" FontSize="13" Foreground="White"/>
        </Border>

        <!-- Info bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#4DB6AC" BorderThickness="1"
                CornerRadius="3" Padding="10,7" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Vrsta" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBox Width="40" Height="24" Margin="0,0,14,0" Padding="4,2"
                         Text="{Binding InfoVrsta}" IsReadOnly="True" BorderBrush="#4DB6AC"/>
                <TextBlock Text="Mesec" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBox Width="44" Height="24" Margin="0,0,6,0" Padding="4,2"
                         Text="{Binding InfoMesec}" IsReadOnly="True" BorderBrush="#4DB6AC"/>
                <TextBox Width="130" Height="24" Margin="0,0,14,0" Padding="4,2"
                         Text="{Binding InfoNazmes}" IsReadOnly="True" BorderBrush="#4DB6AC"/>
                <TextBlock Text="Godina" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBox Width="58" Height="24" Margin="0,0,14,0" Padding="4,2"
                         Text="{Binding InfoGodina}" IsReadOnly="True" BorderBrush="#4DB6AC"/>
                <TextBlock Text="Dat1" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                <TextBox Width="88" Height="24" Padding="4,2"
                         Text="{Binding InfoDat1}" IsReadOnly="True" BorderBrush="#4DB6AC"/>
            </StackPanel>
        </Border>

        <!-- DataGrid (43 kolone) -->
        <DataGrid Grid.Row="2" Margin="0,0,0,8"
                  ItemsSource="{Binding Stavke}" SelectedItem="{Binding SelektovanaStavka}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#B2DFDB" VerticalGridLinesBrush="#B2DFDB"
                  RowHeaderWidth="0" Background="White" AlternatingRowBackground="#E0F2F1"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  BorderBrush="#4DB6AC" BorderThickness="1">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#00695C"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="5,4"/>
                    <Setter Property="BorderBrush" Value="#004D40"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Resources>
                <Style x:Key="RightCell" TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment" Value="Right"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Brobrac"   Binding="{Binding Brobrac}"             Width="58"/>
                <DataGridTextColumn Header="Mesec"     Binding="{Binding Mesec}"               Width="48"/>
                <DataGridTextColumn Header="Nazmes"    Binding="{Binding Nazmes}"              Width="88"/>
                <DataGridTextColumn Header="Vrsta"     Binding="{Binding Vrsta}"               Width="42"/>
                <DataGridTextColumn Header="Casuk"     Binding="{Binding Casuk,    StringFormat=N2}" Width="72" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Casbol"    Binding="{Binding Casbol,   StringFormat=N2}" Width="72" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Bruto"     Binding="{Binding Bruto,    StringFormat=N2}" Width="82" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Porez"     Binding="{Binding Porez,    StringFormat=N2}" Width="82" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Dopsocr"   Binding="{Binding Dopsocr,  StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Doppr"     Binding="{Binding Doppr,    StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Dopzr"     Binding="{Binding Dopzr,    StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Dopnr"     Binding="{Binding Dopnr,    StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Dopsocf"   Binding="{Binding Dopsocf,  StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Doppf"     Binding="{Binding Doppf,    StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Dopzf"     Binding="{Binding Dopzf,    StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Dopnf"     Binding="{Binding Dopnf,    StringFormat=N2}" Width="80" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Neto"      Binding="{Binding Neto,     StringFormat=N2}" Width="82" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Ukobust"   Binding="{Binding Ukobust,  StringFormat=N2}" Width="82" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Zaisplatu" Binding="{Binding Zaisplatu,StringFormat=N2}" Width="86" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Cenarada"  Binding="{Binding Cenarada, StringFormat=N6}" Width="90" ElementStyle="{StaticResource RightCell}"/>
                <DataGridTextColumn Header="Dat1"      Binding="{Binding Dat1,     StringFormat=dd.MM.yyyy}" Width="82"/>
                <DataGridTextColumn Header="Dat2"      Binding="{Binding Dat2,     StringFormat=dd.MM.yyyy}" Width="82"/>
                <DataGridTextColumn Header="Dat3"      Binding="{Binding Dat3,     StringFormat=dd.MM.yyyy}" Width="82"/>
                <DataGridTextColumn Header="Dat4"      Binding="{Binding Dat4,     StringFormat=dd.MM.yyyy}" Width="82"/>
                <DataGridTextColumn Header="Godina"    Binding="{Binding Godina}"  Width="54"/>
                <DataGridTextColumn Header="Ppopj1"    Binding="{Binding Ppopj1}"  Width="80"/>
                <DataGridTextColumn Header="Ppopj2"    Binding="{Binding Ppopj2}"  Width="80"/>
                <DataGridTextColumn Header="Ppopj3"    Binding="{Binding Ppopj3}"  Width="80"/>
                <DataGridTextColumn Header="Ppopj4"    Binding="{Binding Ppopj4}"  Width="80"/>
                <DataGridTextColumn Header="Ppod01"    Binding="{Binding Ppod01}"  Width="80"/>
                <DataGridTextColumn Header="Ppod02"    Binding="{Binding Ppod02}"  Width="80"/>
                <DataGridTextColumn Header="Ppod03"    Binding="{Binding Ppod03}"  Width="80"/>
                <DataGridTextColumn Header="Ppod04"    Binding="{Binding Ppod04}"  Width="80"/>
                <DataGridTextColumn Header="Ppod01v"   Binding="{Binding Ppod01v}" Width="80"/>
                <DataGridTextColumn Header="Ppod02v"   Binding="{Binding Ppod02v}" Width="80"/>
                <DataGridTextColumn Header="Ppod03v"   Binding="{Binding Ppod03v}" Width="80"/>
                <DataGridTextColumn Header="Ppod04v"   Binding="{Binding Ppod04v}" Width="80"/>
                <DataGridTextColumn Header="Ppod11"    Binding="{Binding Ppod11}"  Width="80"/>
                <DataGridTextColumn Header="Ppod12"    Binding="{Binding Ppod12}"  Width="80"/>
                <DataGridTextColumn Header="Ppod13"    Binding="{Binding Ppod13}"  Width="80"/>
                <DataGridTextColumn Header="Ppod14"    Binding="{Binding Ppod14}"  Width="80"/>
                <DataGridTextColumn Header="Opis1"     Binding="{Binding Opis1}"   Width="180"/>
                <DataGridTextColumn Header="Opis2"     Binding="{Binding Opis2}"   Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dugmad -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="NAVIGACIJA" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="78" Height="28" Margin="0,0,4,0" Content="PRVI"   Command="{Binding PrviCommand}"   Style="{StaticResource NavBtnStyle}"/>
                        <Button Width="78" Height="28" Margin="0,0,4,0" Content="GORE"   Command="{Binding GoreCommand}"   Style="{StaticResource NavBtnStyle}"/>
                        <Button Width="78" Height="28" Margin="0,0,4,0" Content="DOLE"   Command="{Binding DoleCommand}"   Style="{StaticResource NavBtnStyle}"/>
                        <Button Width="78" Height="28"                  Content="ZADNJI"  Command="{Binding ZadnjiCommand}" Style="{StaticResource NavBtnStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="AKCIJE" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="96"  Height="28" Margin="0,0,4,0" Content="OSVEŽI"              Style="{StaticResource NavBtnStyle}"     Command="{Binding OsveziCommand}"/>
                        <Button Width="196" Height="28" Margin="0,0,4,0" Content="PREUZMI OBRAČUNE  F8" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding PreuzmiCommand}"/>
                        <Button Width="196" Height="28" Margin="0,0,4,0" Content="PREGLED OBRAČUNA  F10" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding PregledObracunaCommand}"/>
                        <Button Width="210" Height="28"                  Content="PREGLED PORESKIH PRIJAVA" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding PregledPoreskihPrijavaCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="BRISANJE" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="130" Height="28" Margin="0,0,4,0" Content="BRISANJE REDA"   Style="{StaticResource DangerButtonStyle}" Command="{Binding ObrisiRedCommand}"/>
                        <Button Width="148" Height="28"                  Content="BRISANJE TABELE" Style="{StaticResource DangerButtonStyle}" Command="{Binding BrisanjeTabeleCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Button Width="90" Height="28" VerticalAlignment="Bottom" Content="IZLAZ"
                    Click="ZatvoriClick" Style="{StaticResource NeutralButtonStyle}"/>
        </StackPanel>

        <!-- Status bar -->
        <DockPanel Grid.Row="4" Margin="0,2,0,0">
            <TextBlock DockPanel.Dock="Left" Text="EVIDENCIJA" FontSize="9" Foreground="#4DB6AC" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding Poruka}" Foreground="#004D40" VerticalAlignment="Center"/>
        </DockPanel>
    </Grid>
</Window>
