<Window x:Class="Algoritam.WPF.Views.Zarade.LdOz08View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1400"
        Height="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">
    <DockPanel>
        <DataGrid DockPanel.Dock="Top"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  RowHeight="20"
                  BorderThickness="0"
                  Background="#F5F5F5"
                  AlternatingRowBackground="#EDF1F9">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1B5E20"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="K1zarada" Binding="{Binding K1zarada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="K1sati" Binding="{Binding K1sati, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="K1posatu" Binding="{Binding K1posatu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="K1mogsati" Binding="{Binding K1mogsati, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="K1prosmes" Binding="{Binding K1prosmes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="K1pzarada" Binding="{Binding K1pzarada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="K2zarada" Binding="{Binding K2zarada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="K2sati" Binding="{Binding K2sati, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="K2posatu" Binding="{Binding K2posatu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="K2mogsati" Binding="{Binding K2mogsati, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="K2prosmes" Binding="{Binding K2prosmes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="K2pzarada" Binding="{Binding K2pzarada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Koef" Binding="{Binding Koef, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N4}" Width="90"/>
                <DataGridTextColumn Header="Mesec1" Binding="{Binding Mesec1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Mesec2" Binding="{Binding Mesec2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1,1,1,0" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="OBRAZAC NAKNADA" Width="150" Height="28" Margin="0,0,8,0" Command="{Binding ObrazacNaknadaCommand}"/>
                    <Button Content="PRERACUN" Width="110" Height="28" Margin="0,0,8,0" Command="{Binding PreracunCommand}"/>
                    <Button Content="DODAJ" Width="90" Height="28" Margin="0,0,8,0" Command="{Binding DodajCommand}"/>
                    <Button Content="KARTICA F7" Width="120" Height="28" Margin="0,0,8,0" Command="{Binding KarticaF7Command}"/>
                    <Button Content="SAČUVAJ" Width="100" Height="28" Margin="0,0,8,0" Command="{Binding SacuvajRucnoCommand}"/>
                    <Button Content="BRISANJE" Width="110" Height="28" Margin="0,0,8,0" Command="{Binding BrisanjeCommand}"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="_IZLAZ"
                        Width="120"
                        Height="28"
                        Background="#C62828"
                        Foreground="White"
                        BorderThickness="0"
                        Click="IzlazClick"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#D7DBFF" BorderBrush="#A1A9E8" BorderThickness="1" Padding="8,5">
            <TextBlock Text="{Binding Poruka}" />
        </Border>
    </DockPanel>
</Window>
