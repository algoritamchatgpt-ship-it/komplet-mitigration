<Window x:Class="Algoritam.WPF.Views.Zarade.ListicNetoBrutoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Listić neto-bruto"
        Width="760" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1B5E20" Padding="12,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="LISTIC NETO-BRUTO"
                               Foreground="White"
                               FontFamily="Tahoma"
                               FontSize="15"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding RadnikTekst}"
                               Foreground="#BBDEFB"
                               FontFamily="Tahoma"
                               FontSize="12"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="92"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="StampajClick"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma"
                            FontWeight="Bold"
                            Content="STAMPAJ"/>
                    <Button Width="90"
                            Height="28"
                            Click="ZatvoriClick"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma"
                            FontWeight="Bold"
                            Content="ZATVORI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="PrintRoot"
                Grid.Row="1"
                Margin="0,10,0,10"
                Background="White"
                BorderBrush="#C8E6C9"
                BorderThickness="1"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding FirmaTekst}" FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="#1565C0"/>
                        <TextBlock Text="{Binding PeriodTekst}" FontFamily="Tahoma" FontSize="11" Foreground="#455A64"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DatumIsplateTekst}"
                               FontFamily="Tahoma"
                               FontSize="11"
                               Foreground="#455A64"
                               VerticalAlignment="Top"/>
                </Grid>

                <Border Grid.Row="1" Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" Padding="10,6" Margin="0,0,0,10">
                    <TextBlock Text="{Binding Napomena}"
                               FontFamily="Tahoma"
                               FontSize="11"
                               Foreground="#1565C0"
                               TextWrapping="Wrap"/>
                </Border>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Stavke}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F8FBFF"
                          FontFamily="Tahoma"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Opis" Binding="{Binding Naziv}" Width="*"/>
                        <DataGridTextColumn Header="Vrednost" Binding="{Binding Vrednost, StringFormat=N2}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NB-LISTIĆ"
                           FontFamily="Tahoma" FontSize="9" Foreground="#C8E6C9"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" FontFamily="Tahoma" FontSize="11"
                           Foreground="#37474F" VerticalAlignment="Center"
                           Text="ESC: zatvori   |   ENTER: stampa"/>
            </Grid>
        </Border>
    </Grid>
</Window>
