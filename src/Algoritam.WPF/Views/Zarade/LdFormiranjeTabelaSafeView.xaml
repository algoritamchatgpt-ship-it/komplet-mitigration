<Window x:Class="Algoritam.WPF.Views.Zarade.LdFormiranjeTabelaSafeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="820"
        Height="500"
        MinWidth="820"
        MinHeight="500"
        MaxWidth="820"
        MaxHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10,8"
                Background="#D7DBFF"
                BorderBrush="#A1A9E8"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Pregled i priprema Fox LD* tabela zarada (safe rezim)."
                           FontWeight="Bold"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Postupak: procena postojećih DBF izvora i, po potrebi, kopiranje nedostajućih LD tabela iz template-a."
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,8"
                Padding="10"
                Background="#F5F5F5"
                BorderBrush="#C8E6C9"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Button Content="PROCENI"
                            Width="120"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding ProceniCommand}"/>
                    <Button Content="KREIRAJ LD TABELE"
                            Width="170"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding KreirajLdTabeleCommand}"/>
                    <Button Content="SKENIRAJ DBF"
                            Width="150"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding FormirajSafeCommand}"/>
                    <Button Content="IZVEZI U FOX"
                            Width="130"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding IzveziFoxCommand}"/>
                    <Button Content="_IZLAZ"
                            Width="110"
                            Height="28"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            Click="IzlazClick"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,12,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Broj izvora zapisa:" FontWeight="Bold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UkupnoIzvora}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Postojecih zapisa u DBF:" FontWeight="Bold"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PostojecihStavki}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ukupno uneto:" FontWeight="Bold"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UkupnoUneto}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Template / backup:" FontWeight="Bold"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BackupPutanja}" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Kopirano / fajlova:" FontWeight="Bold"/>
                    <TextBlock Grid.Row="4" Grid.Column="1">
                        <Run Text="{Binding UkupnoIzvezeno}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding BrojFajlovaIzvoza}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="U toku / progres:" FontWeight="Bold"/>
                    <TextBlock Grid.Row="5" Grid.Column="1">
                        <Run Text="{Binding Radi}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding Progres}"/>
                    </TextBlock>
                </Grid>

                <ProgressBar Grid.Row="2"
                             Height="18"
                             Minimum="0"
                             Maximum="{Binding MaksProgres}"
                             Value="{Binding Progres}"/>

                <Border Grid.Row="3"
                        Margin="0,10,0,0"
                        Padding="8,6"
                        Background="#F0F0F0"
                        BorderBrush="#C8E6C9"
                        BorderThickness="1">
                    <TextBlock Text="{Binding Poruka}" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="8,5"
                Background="#E8F5E9"
                BorderBrush="#C8E6C9"
                BorderThickness="1">
            <TextBlock Text="Napomena: aplikacija čita DBF direktno; kreiranje LD tabela kopira samo nedostajuće template fajlove."/>
        </Border>
    </Grid>
</Window>
