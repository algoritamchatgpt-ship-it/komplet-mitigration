<Window x:Class="Algoritam.WPF.Views.Zarade.PlatniSpisakPreglediView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Platni spisak — pregledi"
        Width="820" Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#00695C" Padding="12,10" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="PREGLEDI I SPISKOVI"
                           Foreground="White"
                           FontFamily="Tahoma"
                           FontSize="15"
                           FontWeight="Bold"/>
                <TextBlock Text="Izaberite opciju pregleda za aktivni platni spisak."
                           Foreground="#C8E6C9"
                           FontFamily="Tahoma"
                           FontSize="11"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="12" Margin="0,10,0,10" BorderBrush="#CFD8DC" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="OSNOVNI PREGLEDI"
                               FontFamily="Tahoma"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#0D47A1"
                               Margin="0,0,0,8"/>

                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <Button Command="{Binding PregledJedanListicCommand}" Height="34" Margin="0,0,8,8" Background="#0D47A1" Foreground="White" BorderThickness="0" FontFamily="Tahoma" FontWeight="Bold" Content="JEDAN LISTIC (S+F3)"/>
                        <Button Command="{Binding PregledSviListiciCommand}" Height="34" Margin="0,0,0,8" Background="#1565C0" Foreground="White" BorderThickness="0" FontFamily="Tahoma" FontWeight="Bold" Content="SVI LISTICI (S+F4)"/>
                        <Button Command="{Binding PregledNetoBrutoListicCommand}" Height="34" Margin="0,0,8,8" Background="#1976D2" Foreground="White" BorderThickness="0" FontFamily="Tahoma" FontWeight="Bold" Content="LISTIC NETO-BRUTO"/>
                        <Button Command="{Binding PregledKoloneCommand}" Height="34" Margin="0,0,0,8" Background="#1E88E5" Foreground="White" BorderThickness="0" FontFamily="Tahoma" FontWeight="Bold" Content="PREGLED KOLONE"/>
                    </UniformGrid>

                    <TextBlock Text="FOX PODMENI PREGLEDI (LDREK00)"
                               FontFamily="Tahoma"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#00695C"
                               Margin="0,4,0,8"/>

                    <UniformGrid Columns="2">
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_1" Height="32" Margin="0,0,8,6" Content="SPISAK 1"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_2" Height="32" Margin="0,0,0,6" Content="SPISAK 2"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_3" Height="32" Margin="0,0,8,6" Content="SPISAK 3"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_4" Height="32" Margin="0,0,0,6" Content="SPISAK 4"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_5" Height="32" Margin="0,0,8,6" Content="SPISAK 5"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_6" Height="32" Margin="0,0,0,6" Content="SPISAK 6"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_7" Height="32" Margin="0,0,8,6" Content="SPISAK 7"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_8" Height="32" Margin="0,0,0,6" Content="SPISAK 8"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SPISAK_9" Height="32" Margin="0,0,8,6" Content="SPISAK 9"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="ZBIRNA_REKAPITULACIJA" Height="32" Margin="0,0,0,6" Content="ZBIRNA REKAPITULACIJA"/>

                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="MINI_REKAPITULACIJA" Height="32" Margin="0,0,8,6" Content="MINI REKAPITULACIJA"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="ZBIRNA_REK_OD_NETA" Height="32" Margin="0,0,0,6" Content="ZBIRNA REK OD NETA"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SAMODOPRINOSI" Height="32" Margin="0,0,8,6" Content="SAMODOPRINOSI"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SOLIDARNI_POREZ" Height="32" Margin="0,0,0,6" Content="SOLIDARNI POREZ"/>

                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="PREGLED_MTR" Height="32" Margin="0,0,8,6" Content="PREGLED PO MESTIMA TROSKOVA"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="PREGLED_GRUPE" Height="32" Margin="0,0,0,6" Content="PREGLED PO GRUPAMA"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SALDO_MTR" Height="32" Margin="0,0,8,6" Content="SALDO PO MESTIMA TROSKOVA"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SALDO_GRUPE" Height="32" Margin="0,0,0,6" Content="SALDO PO GRUPAMA"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="SALDO_OBJEKTI" Height="32" Margin="0,0,8,6" Content="SALDO PO OBJEKTIMA"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="PREGLED_GRUPA_GRUPA1" Height="32" Margin="0,0,0,6" Content="PREGLED PO GRUPI I GRUPI 1"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="PREGLED_GRUPE_POTPIS" Height="32" Margin="0,0,8,6" Content="PREGLED PO GRUPAMA POTPIS"/>

                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="PREGLED_EVID_1" Height="32" Margin="0,0,0,6" Content="PREGLED PO EVID.BROJU"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="PREGLED_EVID_2" Height="32" Margin="0,0,8,6" Content="PREGLED PO EVID.BROJU 2"/>
                        <Button Command="{Binding OtvoriFoxPregledCommand}" CommandParameter="PREGLED_EVID_3" Height="32" Margin="0,0,0,6" Content="PREGLED PO EVID.BROJU 3"/>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="2">
            <TextBlock DockPanel.Dock="Left"
                       Text="PLATNI SPISAK"
                       FontFamily="Tahoma" FontSize="9"
                       Foreground="#78909C"
                       VerticalAlignment="Center"
                       Margin="0,0,14,0"/>
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontFamily="Tahoma"
                       FontSize="11"
                       Foreground="#546E7A"
                       Text="ESC ili dugme ZATVORI za izlaz"/>
            <Button DockPanel.Dock="Right"
                    Width="94"
                    Height="30"
                    Click="ZatvoriClick"
                    Background="#C62828"
                    Foreground="White"
                    BorderThickness="0"
                    FontFamily="Tahoma"
                    FontWeight="Bold"
                    Content="ZATVORI"/>
        </DockPanel>
    </Grid>
</Window>
