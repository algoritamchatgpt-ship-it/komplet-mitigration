<Window x:Class="Algoritam.WPF.Views.Zarade.LdIzjavaRadnoVremeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">
    <DockPanel>
        <DataGrid DockPanel.Dock="Top"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  RowHeight="20"
                  BorderThickness="0"
                  Background="#F5F5F5"
                  AlternatingRowBackground="#EDF1F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Broj" Binding="{Binding Broj, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Ime_prez" Binding="{Binding ImePrez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                <DataGridTextColumn Header="Firma1" Binding="{Binding Firma1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Proc1" Binding="{Binding Proc1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Firma2" Binding="{Binding Firma2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Proc2" Binding="{Binding Proc2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Firma3" Binding="{Binding Firma3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Proc3" Binding="{Binding Proc3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Firma4" Binding="{Binding Firma4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Proc4" Binding="{Binding Proc4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Firma5" Binding="{Binding Firma5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Proc5" Binding="{Binding Proc5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Maticnibr" Binding="{Binding Maticnibr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                <DataGridTextColumn Header="Posta" Binding="{Binding Posta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Mesto" Binding="{Binding Mesto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Datdok" Binding="{Binding Datdok, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1,1,1,0" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="DODAJ +" Width="90" Height="28" Margin="0,0,8,0" Command="{Binding DodajCommand}"/>
                    <Button Content="RADNICI F4" Width="120" Height="28" Margin="0,0,8,0" Command="{Binding RadniciF4Command}"/>
                    <Button Content="IZJAVA" Width="90" Height="28" Margin="0,0,8,0" Command="{Binding IzjavaCommand}"/>
                    <Button Content="PRVI" Width="80" Height="28" Margin="0,0,8,0" Command="{Binding PrviCommand}"/>
                    <Button Content="GORE" Width="80" Height="28" Margin="0,0,8,0" Command="{Binding GoreCommand}"/>
                    <Button Content="DOLE" Width="80" Height="28" Margin="0,0,8,0" Command="{Binding DoleCommand}"/>
                    <Button Content="ZADNJI" Width="90" Height="28" Margin="0,0,8,0" Command="{Binding ZadnjiCommand}"/>
                    <Button Content="SAČUVAJ" Width="100" Height="28" Margin="0,0,8,0" Command="{Binding SacuvajRucnoCommand}"/>
                    <Button Content="BRISANJE" Width="110" Height="28" Margin="0,0,8,0" Command="{Binding BrisanjeCommand}"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="_IZLAZ"
                        Width="120"
                        Height="28"
                        Background="#C62828"
                        Foreground="White"
                        BorderThickness="0"
                        Click="IzlazClick"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#D7DBFF" BorderBrush="#A1A9E8" BorderThickness="1" Padding="8,5">
            <TextBlock Text="{Binding Poruka}" />
        </Border>
    </DockPanel>
</Window>
