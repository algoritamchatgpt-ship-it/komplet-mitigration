<Window x:Class="Algoritam.WPF.Views.Zarade.RadnoVremeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TABELA EVIDENCIJE RADNOG VREMENA"
        Width="1100" Height="680"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <StackPanel VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="{Binding Naslov}" Foreground="White"
                           FontFamily="Tahoma" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Footer buttons -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9"
                BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="6,4">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="IZLAZ"
                        Width="90" Height="28" Margin="4,0,2,0"
                        Background="#455A64" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Click="ZatvoriClick"/>

                <Button DockPanel.Dock="Left" Content="OTVORI TABELU"
                        Width="120" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding OtvoriTabeluCommand}"
                        Visibility="{Binding TabelaReadOnly, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button DockPanel.Dock="Left" Content="SAČUVAJ TABELU"
                        Width="120" Height="28" Margin="0,0,4,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding SacuvajTabeluCommand}"
                        Visibility="{Binding SacuvajVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button DockPanel.Dock="Left" Content="BRISANJE DATUMA"
                        Width="130" Height="28" Margin="0,0,4,0"
                        Background="#E65100" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding BrisanjeDatumaCommand}"/>

                <Button DockPanel.Dock="Left" Content="BRISANJE RADNIKA"
                        Width="130" Height="28" Margin="0,0,4,0"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding BrisanjeRadnikaCommand}"/>

                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11" Margin="8,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid DockPanel.Dock="Bottom" Margin="6,6,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="158"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Data grid -->
            <DataGrid Grid.Row="0" Grid.Column="0"
                      x:Name="GrdRadnoVreme"
                      ItemsSource="{Binding Stavke}"
                      SelectedItem="{Binding TrenutnaStavka, Mode=TwoWay}"
                      IsReadOnly="{Binding TabelaReadOnly}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      Background="White" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0E0E0"
                      HeadersVisibility="Column"
                      RowHeight="20"
                      FontFamily="Tahoma" FontSize="11"
                      BorderBrush="#C8E6C9" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Broj"      Binding="{Binding Broj}"    Width="55"/>
                    <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez}" Width="*"/>
                    <DataGridTextColumn Header="Datum"     Binding="{Binding Datum, StringFormat=dd.MM.yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Poc.sat"   Binding="{Binding PocSat}"  Width="70"/>
                    <DataGridTextColumn Header="Zad.sat"   Binding="{Binding ZadSat}"  Width="70"/>
                    <DataGridTextColumn Header="Sati"      Binding="{Binding Sati}"    Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Status label -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1"
                    Padding="4,2" Margin="0,2,4,0">
                <TextBlock Text="{Binding LblRad}" FontFamily="Tahoma" FontSize="11"/>
            </Border>

            <!-- Navigation buttons -->
            <WrapPanel Grid.Row="2" Grid.Column="0" Margin="0,4,4,0">
                <Button Content="DOLE" Width="80" Height="28" Margin="0,0,4,4"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding DoleCommand}"/>
                <Button Content="GORE" Width="80" Height="28" Margin="0,0,4,4"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding GoreCommand}"/>
                <Button Content="ZADNJI" Width="80" Height="28" Margin="0,0,4,4"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding ZadnjiCommand}"/>
                <Button Content="PRVI" Width="80" Height="28" Margin="0,0,4,4"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrviCommand}"/>
                <Button Content="OSVEZI" Width="80" Height="28" Margin="0,0,4,4"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding OsveziCommand}"/>
                <Button Content="RADNICI" Width="100" Height="28" Margin="8,0,4,4"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Click="RadniciClick"/>
            </WrapPanel>

            <!-- Right side action buttons -->
            <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                        Margin="4,0,0,0" VerticalAlignment="Top">

                <Button Content="DODAJ SVE RADNIKE"
                        Width="150" Height="28" Margin="0,4,0,4"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Click="DodajSveRadnikeClick"/>

                <Button Content="PRERACUNAJ"
                        Width="150" Height="28" Margin="0,0,0,4"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PreracunajCommand}"/>

                <Button Content="PREGLED"
                        Width="150" Height="28" Margin="0,0,0,4"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Click="PregledClick"/>
            </StackPanel>
        </Grid>

    </DockPanel>
</Window>
