<Window x:Class="Algoritam.WPF.Views.Zarade.LdArhivaZaradaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1420" Height="940"
        MinWidth="1000" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#E0F2F1"
        FontFamily="Tahoma" FontSize="11">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <Border Grid.Row="0" Background="#00695C" Padding="10,7" CornerRadius="3" Margin="0,0,0,8">
            <TextBlock Text="{Binding Naslov, FallbackValue='ARHIVA ZARADA'}"
                       FontWeight="Bold" FontSize="13" Foreground="White"/>
        </Border>

        <!-- Filter panel -->
        <Border Grid.Row="1" Background="White" BorderBrush="#4DB6AC" BorderThickness="1"
                CornerRadius="3" Padding="10,8" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Mesec" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Width="50" Height="24" Margin="0,0,14,0" Padding="4,2" Text="{Binding Mesec}" BorderBrush="#4DB6AC"/>
                    <TextBlock Text="Isplata" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Width="50" Height="24" Margin="0,0,14,0" Padding="4,2" Text="{Binding Isplata}" BorderBrush="#4DB6AC"/>
                    <TextBlock Text="Godina" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Width="60" Height="24" Margin="0,0,14,0" Padding="4,2" Text="{Binding Godina}" BorderBrush="#4DB6AC"/>
                    <TextBlock Text="Vrsta" VerticalAlignment="Center" Foreground="#00695C" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Width="50" Height="24" Margin="0,0,14,0" Padding="4,2" Text="{Binding Vrsta}" BorderBrush="#4DB6AC"/>
                    <CheckBox VerticalAlignment="Center" Content="Samo arhiva" IsChecked="{Binding SamoArhivirane}" Margin="0,0,14,0"/>
                    <TextBox Width="200" Height="24" Margin="0,0,8,0" Padding="4,2"
                             Text="{Binding PutanjaArhive}" BorderBrush="#4DB6AC"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Width="110" Height="26" Margin="0,0,6,0" Content="UČITAJ"
                            Background="#00695C" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                            Command="{Binding UcitajCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                    <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#004D40"/></Trigger>
                                    <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#9E9E9E"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Width="90" Height="26" Margin="0,0,6,0" Content="OSVEŽI (F5)" Style="{StaticResource NavBtnStyle}" Command="{Binding OsveziCommand}"/>
                    <Button Width="90" Height="26" Margin="0,0,6,0" Content="OZNAČI"      Style="{StaticResource PrimaryButtonStyle}" Command="{Binding OznaciArhivuCommand}"/>
                    <Button Width="90" Height="26" Margin="0,0,6,0" Content="SKINI"       Style="{StaticResource WarnButtonStyle}"    Command="{Binding SkiniArhivuCommand}"/>
                    <Button Width="90" Height="26"                   Content="OČISTI"      Style="{StaticResource NeutralButtonStyle}" Command="{Binding OcistiFilterCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" Margin="0,0,0,8"
                  ItemsSource="{Binding Stavke}" SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#B2DFDB" RowHeaderWidth="0"
                  Background="White" AlternatingRowBackground="#E0F2F1"
                  BorderBrush="#4DB6AC" BorderThickness="1">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#00695C"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="5,4"/>
                    <Setter Property="BorderBrush" Value="#004D40"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Broj"        Binding="{Binding Broj}"           Width="64"/>
                <DataGridTextColumn Header="Sifra"       Binding="{Binding Sifraprih}"      Width="84"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez}"      Width="210"/>
                <DataGridTextColumn Header="Evid.broj"   Binding="{Binding Evidbroj}"       Width="88"/>
                <DataGridTextColumn Header="Matični br." Binding="{Binding Maticnibr}"      Width="118"/>
                <DataGridTextColumn Header="ID broj"     Binding="{Binding Idbroj}"         Width="104"/>
                <DataGridTextColumn Header="Mesec"       Binding="{Binding Mesec}"          Width="56"/>
                <DataGridTextColumn Header="Isplata"     Binding="{Binding Isplata}"        Width="58"/>
                <DataGridTextColumn Header="Godina"      Binding="{Binding Godina}"         Width="64"/>
                <DataGridTextColumn Header="Vrsta"       Binding="{Binding Vrsta}"          Width="52"/>
                <DataGridTextColumn Header="Datum"       Binding="{Binding Datum, StringFormat=dd.MM.yyyy}" Width="92"/>
                <DataGridTextColumn Header="Bruto"       Binding="{Binding Bruto,     StringFormat=N2}" Width="92"/>
                <DataGridTextColumn Header="Porez"       Binding="{Binding Porez,     StringFormat=N2}" Width="88"/>
                <DataGridTextColumn Header="Neto"        Binding="{Binding Neto,      StringFormat=N2}" Width="92"/>
                <DataGridTextColumn Header="Naknade"     Binding="{Binding Naknade,   StringFormat=N2}" Width="92"/>
                <DataGridTextColumn Header="Uk.obust"    Binding="{Binding Ukobust,   StringFormat=N2}" Width="95"/>
                <DataGridTextColumn Header="Za isplatu"  Binding="{Binding Zaisplatu, StringFormat=N2}" Width="96"/>
                <DataGridTextColumn Header="Mtr"         Binding="{Binding Mtr}"     Width="58"/>
                <DataGridTextColumn Header="Grupa"       Binding="{Binding Grupa}"   Width="58"/>
                <DataGridTextColumn Header="Grupa1"      Binding="{Binding Grupa1}"  Width="58"/>
                <DataGridTextColumn Header="Arhiva"      Binding="{Binding Arhiva}"  Width="62"/>
                <DataGridTextColumn Header="Arhiva2"     Binding="{Binding Arhiva2}" Width="64"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dugmad red 1: Navigacija + Arhiva operacije + IZLAZ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="NAVIGACIJA" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="78" Height="28" Margin="0,0,4,0" Content="PRVI"   Command="{Binding PrviCommand}"   Style="{StaticResource NavBtnStyle}"/>
                        <Button Width="78" Height="28" Margin="0,0,4,0" Content="GORE"   Command="{Binding GoreCommand}"   Style="{StaticResource NavBtnStyle}"/>
                        <Button Width="78" Height="28" Margin="0,0,4,0" Content="DOLE"   Command="{Binding DoleCommand}"   Style="{StaticResource NavBtnStyle}"/>
                        <Button Width="78" Height="28"                  Content="ZADNJI"  Command="{Binding ZadnjiCommand}" Style="{StaticResource NavBtnStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="ARHIVA OPERACIJE" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="148" Height="28" Margin="0,0,4,0" Content="DODAVANJE MESECA"    Command="{Binding DodavanjeMesecaCommand}"  Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Width="138" Height="28" Margin="0,0,4,0" Content="BRISANJE MESECA"     Command="{Binding BrisanjeMesecaCommand}"   Style="{StaticResource WarnButtonStyle}"/>
                        <Button Width="124" Height="28" Margin="0,0,4,0" Content="PRENESI PPODP"       Command="{Binding PrenesiPpodpCommand}"     Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Width="140" Height="28" Margin="0,0,4,0" Content="PREGLED PODATAKA"    Command="{Binding PregledPodatakaCommand}"/>
                        <Button Width="148" Height="28" Margin="0,0,4,0" Content="BRISANJE PRAZNINA"   Command="{Binding BrisanjePrazninaCommand}" Style="{StaticResource WarnButtonStyle}"/>
                        <Button Width="154" Height="28" Margin="0,0,4,0" Content="UNESI REG.BROJ.PIO"  Command="{Binding UnesiRegBrojPioCommand}"  Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Width="148" Height="28"                  Content="VRATI IZ ARHIVE"    Command="{Binding VratiIzArhiveCommand}"     Style="{StaticResource WarnButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Button Width="90" Height="28" VerticalAlignment="Bottom" Content="IZLAZ"
                    Click="ZatvoriClick" Style="{StaticResource NeutralButtonStyle}"/>
        </StackPanel>

        <!-- Dugmad red 2: Jedan radnik + Saldo -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,6">
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="JEDAN RADNIK" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="138" Height="28" Margin="0,0,4,0" Content="JEDAN RADNIK SVE"      Command="{Binding JedanRadnikSveCommand}"/>
                        <Button Width="168" Height="28"                  Content="JEDAN RADNIK SKRAĆENI" Command="{Binding JedanRadnikSkraceniCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="SALDO" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="120" Height="28" Margin="0,0,4,0" Content="SALDO RADNIKA"           Command="{Binding SaldoRadnikaCommand}"/>
                        <Button Width="120" Height="28" Margin="0,0,4,0" Content="SALDO SKRAĆENI"          Command="{Binding SaldoSkraceniCommand}"/>
                        <Button Width="180" Height="28" Margin="0,0,4,0" Content="SALDO SKRAĆENI ZA MESEC" Command="{Binding SaldoSkraceniZaMesecCommand}"/>
                        <Button Width="100" Height="28" Margin="0,0,4,0" Content="SALDO SVE"               Command="{Binding SaldoSveCommand}"/>
                        <Button Width="150" Height="28"                  Content="SALDO SVE ZA MESEC"       Command="{Binding SaldoSveZaMesecCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Dugmad red 3: Saldo zbirno + M-4 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,6">
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Margin="0,0,8,0" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="SALDO ZBIRNO" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="138" Height="28" Margin="0,0,4,0" Content="SALDO PO MESECIMA"  Command="{Binding SaldoPoMesecimaCommand}"/>
                        <Button Width="138" Height="28" Margin="0,0,4,0" Content="SALDO PO DATUMIMA"  Command="{Binding SaldoPoDatumimaCommand}"/>
                        <Button Width="90"  Height="28" Margin="0,0,4,0" Content="MESTO"              Command="{Binding MestoCommand}"/>
                        <Button Width="138" Height="28" Margin="0,0,4,0" Content="SALDO DOPRINOSA"    Command="{Binding SaldoDoprinosaCommand}"/>
                        <Button Width="138" Height="28"                  Content="SALDO ZA NAKNADE"   Command="{Binding SaldoZaNaknadeCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="#4DB6AC" BorderThickness="1" CornerRadius="3" Padding="6,4">
                <StackPanel>
                    <TextBlock Text="M-4 OBRASCI" FontSize="9" FontWeight="SemiBold" Foreground="#00695C" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="98"  Height="28" Margin="0,0,4,0" Content="M-4K STARI"          Command="{Binding M4kStariCommand}"/>
                        <Button Width="98"  Height="28" Margin="0,0,4,0" Content="M-4K NOVI"           Command="{Binding M4kNoviCommand}"/>
                        <Button Width="164" Height="28" Margin="0,0,4,0" Content="M-4 NOVI POJEDINAČNI" Command="{Binding M4NoviPojedinacniCommand}"/>
                        <Button Width="126" Height="28" Margin="0,0,4,0" Content="M-4 /SP VLASNIK"    Command="{Binding M4SpVlasnikCommand}"/>
                        <Button Width="126" Height="28"                  Content="M-4 /C3 VLASNIK"    Command="{Binding M4C3VlasnikCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Status bar -->
        <DockPanel Grid.Row="6" Margin="0,2,0,0">
            <TextBlock DockPanel.Dock="Left" Text="ARHIVA ZARADA" FontSize="9" Foreground="#4DB6AC" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding Poruka}" Foreground="#004D40" VerticalAlignment="Center"/>
        </DockPanel>
    </Grid>
</Window>
