<Window x:Class="Algoritam.WPF.Views.Zarade.KreditiDetaljView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jedan kredit"
        Width="760" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="48">
            <TextBlock Text="JEDAN KREDIT"
                       Margin="14,0"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontFamily="Tahoma"
                       FontSize="15"
                       FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="OTKAZI"
                            Width="96"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding OtkaziCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="POTVRDI"
                            Width="96"
                            Height="28"
                            Background="#1B5E20"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding PotvrdiCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{Binding RadnikTekst}" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding PartnerTekst}" FontFamily="Tahoma" FontSize="11" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Kredit" Margin="0,0,8,8"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Stavka.Kredit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Broj" Margin="0,0,8,8"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Stavka.Broj, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Sifra" Margin="0,0,8,8"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Stavka.Sifra, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Partija" Margin="0,0,8,8"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Stavka.Partija, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Iznos" Margin="0,0,8,8"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Stavka.Iznos, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Koliko rata" Margin="0,0,8,8"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Stavka.Koliko, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Prva rata" Margin="0,0,8,8"/>
                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Stavka.PrvaRata, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Ostale rate" Margin="0,0,8,8"/>
                <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding Stavka.OstaleRate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Za obaviti" Margin="0,0,8,8"/>
                <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding Stavka.ZaObaviti, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Aktivna rata" Margin="0,0,8,8"/>
                <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding Stavka.AktivnaRata, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="Akontaciona rata" Margin="0,0,8,8"/>
                <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding Stavka.AkontRata, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="13" Grid.Column="0" Text="Ostatak" Margin="0,0,8,8"/>
                <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding Stavka.Ostatak, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="14" Grid.Column="0" Text="Odbijeno" Margin="0,0,8,8"/>
                <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding Stavka.Odbijeno, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="15" Grid.Column="0" Text="Evidbroj" Margin="0,0,8,8"/>
                <TextBox Grid.Row="15" Grid.Column="1" Text="{Binding Stavka.EvidBroj, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="16" Grid.Column="0" Text="Modelo" Margin="0,0,8,8"/>
                <TextBox Grid.Row="16" Grid.Column="1" Text="{Binding Stavka.Modelo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="17" Grid.Column="0" Text="Datdok" Margin="0,0,8,8"/>
                <DatePicker Grid.Row="17" Grid.Column="1" SelectedDate="{Binding Stavka.DatDok, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
