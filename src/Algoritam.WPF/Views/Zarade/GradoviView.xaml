<Window x:Class="Algoritam.WPF.Views.Zarade.GradoviView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mesta" Width="1150" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
        <KeyBinding Key="F2" Command="{Binding SacuvajCommand}"/>
        <KeyBinding Key="Insert" Command="{Binding DodajCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1B5E20" Height="50">
            <TextBlock Text="{Binding Naslov}" Foreground="White" FontSize="16" FontWeight="Bold"
                       FontFamily="Tahoma" VerticalAlignment="Center" Margin="16,0"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#E3F2FD" Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="#BBDEFB">
            <WrapPanel>
                <Button Content="DODAJ  Ins" Width="96" Height="27" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding DodajCommand}"/>
                <Button Content="KARTICA" Width="80" Height="27" Margin="0,0,4,0"
                        Background="#37474F" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding KarticaCommand}"
                        ToolTip="Prikaz detalja izabranog mesta"/>
                <Button Content="OBRIŠI  Del" Width="92" Height="27" Margin="0,0,4,0"
                        Background="#B71C1C" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding ObrisiCommand}"
                        ToolTip="Obriši izabrano mesto iz šifarnika"/>
                <Button Content="F2 SAČUVAJ" Width="96" Height="27" Margin="0,0,12,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding SacuvajCommand}"/>
                <Button Content="◀◀ PRVI" Width="68" Height="27" Margin="0,0,3,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrviCommand}"/>
                <Button Content="◀ GORE" Width="64" Height="27" Margin="0,0,3,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding GoreCommand}"/>
                <Button Content="▶ DOLE" Width="64" Height="27" Margin="0,0,3,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding DoleCommand}"/>
                <Button Content="▶▶ ZADNJI" Width="76" Height="27" Margin="0,0,12,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding ZadnjiCommand}"/>
                <Button Content="SPECIFIKACIJA" Width="110" Height="27" Margin="0,0,4,0"
                        Background="#BF360C" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding SpecifikacijaCommand}"
                        ToolTip="Specifikacija zdravstvo vlasnik po opštini"/>
            </WrapPanel>
        </Border>

        <!-- Pretraga -->
        <Border Grid.Row="2" Background="White" Padding="10,7" BorderThickness="0,0,0,1" BorderBrush="#B0BEC5">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Pretraga mesta:" FontFamily="Tahoma" FontSize="12"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBox Width="280" Margin="10,0,8,0" Padding="6,3"
                         FontFamily="Tahoma" FontSize="12"
                         Text="{Binding PretragaMesta, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="OCISTI" Width="80" Height="28"
                        FontFamily="Tahoma" FontSize="11"
                        Background="#607D8B" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiPretraguCommand}"/>
            </DockPanel>
        </Border>

        <!-- Tabela -->
        <DataGrid Grid.Row="3" Margin="4"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  Background="White" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" IsReadOnly="False"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="MP"           Binding="{Binding Mp}"            Width="50"/>
                <DataGridTextColumn Header="Pošta"        Binding="{Binding Posta}"          Width="60"/>
                <DataGridTextColumn Header="Mesto"        Binding="{Binding Mesto}"          Width="200"/>
                <DataGridTextColumn Header="Žiro 1"       Binding="{Binding Ziro1}"          Width="70"/>
                <DataGridTextColumn Header="Žiro 2"       Binding="{Binding Ziro2}"          Width="60"/>
                <DataGridTextColumn Header="Poreski br."  Binding="{Binding PorBroj}"        Width="130"/>
                <DataGridTextColumn Header="Reg. soc."    Binding="{Binding RegSoc}"         Width="80"/>
                <DataGridTextColumn Header="Porez %"      Binding="{Binding Por, StringFormat=N2}" Width="75"/>
                <DataGridTextColumn Header="Zdrav. %"     Binding="{Binding Zdr, StringFormat=N2}" Width="75"/>
                <DataGridTextColumn Header="PIO %"        Binding="{Binding Pio, StringFormat=N2}" Width="75"/>
                <DataGridTextColumn Header="Nezap. %"     Binding="{Binding Nez, StringFormat=N2}" Width="75"/>
                <DataGridTextColumn Header="Vrsta"        Binding="{Binding Vrsta}"          Width="50"/>
                <DataGridTextColumn Header="Mesec"        Binding="{Binding Mesec}"          Width="55"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#E8F5E9" Padding="12,7" BorderThickness="0,1,0,0" BorderBrush="#C8E6C9">
            <DockPanel>
                <Button Content="POPUNI"   DockPanel.Dock="Right" Width="110" Height="28" Margin="4,0,0,0"
                        FontFamily="Tahoma" FontSize="11"
                        Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Command="{Binding PopuniCommand}"/>
                <Button Content="ISPRAZNI" DockPanel.Dock="Right" Width="100" Height="28" Margin="4,0,0,0"
                        FontFamily="Tahoma" FontSize="11"
                        Background="#E65100" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Command="{Binding IsprazniCommand}"/>
                <Button Content="F5 OSVEZI" DockPanel.Dock="Right" Width="90" Height="28" Margin="4,0,0,0"
                        FontFamily="Tahoma" FontSize="11"
                        Background="#607D8B" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OsveziCommand}"/>
                <Button Content="ZATVORI"  DockPanel.Dock="Right" Width="100" Height="28" Margin="4,0,0,0"
                        FontFamily="Tahoma" FontSize="11"
                        Background="#455A64" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
