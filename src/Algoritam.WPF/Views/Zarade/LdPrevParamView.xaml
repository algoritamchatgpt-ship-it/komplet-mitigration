<Window x:Class="Algoritam.WPF.Views.Zarade.LdPrevParamView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Popunjavanje kolone"
        Width="400" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#607D8B" Height="44">
            <TextBlock Text="POPUNJAVANJE PODATAKA"
                       Margin="14,0" VerticalAlignment="Center"
                       Foreground="White" FontFamily="Tahoma" FontSize="13" FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="UNOS" Width="90" Height="28" Margin="0,0,8,0"
                        Background="#1B5E20" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Command="{Binding UnosCommand}"/>
                <Button Content="IZLAZ" Width="90" Height="28"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Click="ZatvoriClick"/>
            </StackPanel>
        </Border>

        <Grid Margin="20,16,20,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="DANA U MESECU:"
                       VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="0" Grid.Column="1" Height="26" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Dana, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="DNEVNA KARTA:"
                       VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="1" Grid.Column="1" Height="26" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Karta, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="NEOPOREZIVO:"
                       VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="2" Grid.Column="1" Height="26" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Neoporez, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="DATUM:"
                       VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="3" Grid.Column="1" Height="26" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Datum, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="MESEC:"
                       VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="4" Grid.Column="1" Height="26" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Mesec, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="NAZIV MESECA:"
                       VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
            <TextBox Grid.Row="5" Grid.Column="1" Height="26" VerticalContentAlignment="Center"
                     FontFamily="Tahoma" FontSize="11"
                     Text="{Binding Nazmes, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
    </DockPanel>
</Window>
