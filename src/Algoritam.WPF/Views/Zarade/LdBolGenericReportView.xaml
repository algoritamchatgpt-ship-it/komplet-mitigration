<Window x:Class="Algoritam.WPF.Views.Zarade.LdBolGenericReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        Width="1180"
        Height="760"
        FontFamily="Tahoma"
        FontSize="11">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#607D8B" Padding="12,8" CornerRadius="4">
            <DockPanel>
                <TextBlock Text="{Binding Naslov}"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="96"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="StampajClick"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Content="STAMPAJ"/>
                    <Button Width="90"
                            Height="28"
                            Click="ZatvoriClick"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Content="ZATVORI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="PrintRoot"
                Grid.Row="1"
                Margin="0,10,0,10"
                Background="White"
                BorderBrush="#C8E6C9"
                BorderThickness="1"
                Padding="10">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="True"
                      AutoGeneratingColumn="DataGridAutoGeneratingColumn"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#E8F0FE"/>
        </Border>

        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="1" Padding="10,6">
            <TextBlock Text="{Binding BrojStavkiTekst}"
                       Foreground="#37474F"/>
        </Border>
    </Grid>
</Window>
