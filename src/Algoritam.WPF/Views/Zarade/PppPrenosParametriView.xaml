<Window x:Class="Algoritam.WPF.Views.Zarade.PppPrenosParametriView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PARAMETRI PRENOSA ZARADA ZA PPP-PD"
        Width="980"
        Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#D7D7D7">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#B6CBE1" BorderBrush="#8A8A8A" BorderThickness="1" Padding="10" Margin="0,0,0,8">
            <TextBlock Text="PARAMETRI PRENOSA ZARADA ZA PPP-PD"
                       FontFamily="Tahoma"
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding SelektovanaStavka}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  Background="White"
                  BorderBrush="#8A8A8A"
                  BorderThickness="1"
                  RowHeaderWidth="0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Background" Value="#DCE4F1"/>
                    <Setter Property="BorderBrush" Value="#AAB0B8"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Opis" Binding="{Binding Opis, UpdateSourceTrigger=LostFocus}" Width="*"/>
                <DataGridTextColumn Header="Isplata" Binding="{Binding Isplata, UpdateSourceTrigger=LostFocus}" Width="120"/>
                <DataGridTextColumn Header="Mesec" Binding="{Binding Mesec, UpdateSourceTrigger=LostFocus}" Width="120"/>
                <DataGridTextColumn Header="Tabela" Binding="{Binding Tabela, UpdateSourceTrigger=LostFocus}" Width="180"/>
                <DataGridTextColumn Header="Tabela2" Binding="{Binding Tabela2, UpdateSourceTrigger=LostFocus}" Width="180"/>
                <DataGridTextColumn Header="Preneto" Binding="{Binding Preneto, UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="Idbr" Binding="{Binding Idbr, UpdateSourceTrigger=LostFocus}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="2" Margin="0,8,0,0">
            <Button Width="70" Height="30" Margin="0,0,6,0" Content="|&lt;" Command="{Binding PrviCommand}"/>
            <Button Width="70" Height="30" Margin="0,0,6,0" Content="&lt;" Command="{Binding GoreCommand}"/>
            <Button Width="70" Height="30" Margin="0,0,6,0" Content="&gt;" Command="{Binding DoleCommand}"/>
            <Button Width="70" Height="30" Margin="0,0,14,0" Content="&gt;|" Command="{Binding ZadnjiCommand}"/>

            <Button Width="90" Height="30" Margin="0,0,6,0" Content="DODAJ" Command="{Binding DodajCommand}"/>
            <Button Width="90" Height="30" Margin="0,0,6,0" Content="BRISI" Command="{Binding ObrisiCommand}"/>
            <Button Width="110" Height="30" Margin="0,0,14,0" Content="BRIŠI SVE" Command="{Binding ObrisiSveCommand}"/>

            <Button Width="110" Height="30" Margin="0,0,6,0" Content="OSVEZI" Command="{Binding OsveziCommand}"/>
            <Button Width="110" Height="30" Margin="0,0,6,0" Content="SAČUVAJ" Command="{Binding SacuvajCommand}"/>
            <Button Width="110" Height="30" Content="IZLAZ" Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <TextBlock Grid.Row="3"
                   Margin="0,8,0,0"
                   Text="{Binding Poruka}"
                   FontFamily="Tahoma"
                   FontSize="12"
                   Foreground="#1E293B"/>
    </Grid>
</Window>
