<Window x:Class="Algoritam.WPF.Views.Zarade.LdOsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1100" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <DockPanel>

        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding Naslov}"
                           FontFamily="Tahoma" FontSize="16" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="10,6">
            <DockPanel>
                <Button Content="ZATVORI" DockPanel.Dock="Right" Width="100" Height="28"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11"
                           Foreground="#1B5E20" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="#E8F5E9" Padding="8,6"
                BorderThickness="0,0,0,1" BorderBrush="#C8E6C9">
            <WrapPanel>
                <Button Content="DODAJ  Ins" Width="100" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding DodajCommand}"/>
                <Button Content="PREUZIMANJE" Width="110" Height="28" Margin="0,0,4,0"
                        Background="#E65100" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding PreuzimanjeCommand}"
                        ToolTip="Preuzima podatke iz platnog spiska (ld00.dbf)"/>
                <Button Content="BRISANJE" Width="90" Height="28" Margin="0,0,12,0"
                        Background="#B71C1C" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding BrisanjeCommand}"/>
                <Button Content="F2 SAČUVAJ" Width="100" Height="28" Margin="0,0,12,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding SacuvajCommand}"/>
                <Button Content="ŠTAMPA" Width="84" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        ToolTip="Štampaj OS obrazac"
                        Click="StampaClick"/>
                <Button Content="OSVEZI" Width="80" Height="28"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding OsveziCommand}"/>
            </WrapPanel>
        </Border>

        <DataGrid x:Name="StavkeGrid"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9FBF9"
                  RowBackground="White"
                  FontFamily="Tahoma" FontSize="11"
                  Margin="4">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Br." Binding="{Binding Broj}" Width="45"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez}" Width="160"/>
                <DataGridTextColumn Header="Mat. br." Binding="{Binding MaticniBr}" Width="90"/>
                <DataGridTextColumn Header="MESEC" Binding="{Binding Nazmes}" Width="65"/>
                <DataGridTextColumn Header="ISP" Binding="{Binding Isplata}" Width="40"/>
                <DataGridTextColumn Header="Od" Binding="{Binding Datod, StringFormat=dd.MM.yy}" Width="70"/>
                <DataGridTextColumn Header="Do" Binding="{Binding Datdo, StringFormat=dd.MM.yy}" Width="70"/>
                <DataGridTextColumn Header="BRUTO" Binding="{Binding Bruto, StringFormat=N2}" Width="85">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="DOP PIO R." Binding="{Binding Doppr, StringFormat=N2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="DOP ZDR R." Binding="{Binding Dopzr, StringFormat=N2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="DOP NEZ R." Binding="{Binding Dopnr, StringFormat=N2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="DOP PIO F." Binding="{Binding Doppf, StringFormat=N2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="BENDIN" Binding="{Binding Bendin, StringFormat=N2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="DOP ZDR F." Binding="{Binding Dopzf, StringFormat=N2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="DOP NEZ F." Binding="{Binding Dopnf, StringFormat=N2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Opštna" Binding="{Binding Opstina}" Width="55"/>
                <DataGridTextColumn Header="MP" Binding="{Binding Mp}" Width="40"/>
                <DataGridTextColumn Header="P" Binding="{Binding Preneto}" Width="30"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
