<Window x:Class="Algoritam.WPF.Views.Zarade.LdPutnal1View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Putni nalog"
        Width="820" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="48">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <TextBlock Text="PUTNI NALOG  " Foreground="White" FontFamily="Tahoma"
                           FontSize="14" FontWeight="Bold"/>
                <TextBlock Text="{Binding Putnal, StringFormat='br. {0}'}" Foreground="#A5D6A7"
                           FontFamily="Tahoma" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="OBRAČUN" Width="100" Height="28" Margin="0,0,6,0"
                            Background="#607D8B" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand" Command="{Binding ObracunCommand}"/>
                    <Button Content="ŠTAMPA" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#1B5E20" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand" Command="{Binding StampaCommand}"/>
                    <Button Content="SAČUVAJ" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#1B5E20" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand" Command="{Binding SacuvajCommand}"/>
                    <Button Content="IZLAZ" Width="90" Height="28"
                            Background="#C62828" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand" Click="ZatvoriClick"/>
                </StackPanel>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- Employee name strip -->
        <Border DockPanel.Dock="Top" Background="#FFB74D" BorderBrush="#F57C00"
                BorderThickness="0,0,0,1" Padding="10,5">
            <TextBlock Text="{Binding ImeRadnika}" FontFamily="Tahoma"
                       FontSize="12" FontWeight="SemiBold"/>
        </Border>

        <!-- Form body -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,8,10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Putnal + Datdok -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="BR. NALOGA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="0" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Putnal, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="DATUM POLASKA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="0" Grid.Column="4" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Datdok, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>

                <!-- Row 1: Broj + Datvrac -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="BROJ RADNIKA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="1" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Broj, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="DATUM POVRATKA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="1" Grid.Column="4" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Datvrac, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}"/>

                <!-- Row 2: Cilj -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="CILJ PUTOVANJA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Cilj, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Row 3: Svrha1 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="SVRHA 1:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Svrha1, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Row 4: Svrha2 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="SVRHA 2:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Svrha2, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Row 5: Vozilo + Akontac -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="VOZILO:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="5" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Vozilo, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="5" Grid.Column="3" Text="AKONTACIJA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="5" Grid.Column="4" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Akontac, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>

                <!-- Separator row 6 -->
                <Separator Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5"
                           Background="#B0BEC5" Margin="0,4"/>

                <!-- Expense accounts header -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="RAČUNI TROŠKOVA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="7" Grid.Column="1" Text="IZNOS"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="10" Foreground="#546E7A"/>
                <TextBlock Grid.Row="7" Grid.Column="3" Text="BROJ RAČUNA"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="10" Foreground="#546E7A"/>

                <!-- Racun 1 -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="RAČUN 1:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="8" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Racun1, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>
                <TextBox Grid.Row="8" Grid.Column="3" Grid.ColumnSpan="2" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Brrac1, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Racun 2 -->
                <TextBlock Grid.Row="9" Grid.Column="0" Text="RAČUN 2:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="9" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Racun2, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>
                <TextBox Grid.Row="9" Grid.Column="3" Grid.ColumnSpan="2" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Brrac2, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Racun 3 -->
                <TextBlock Grid.Row="10" Grid.Column="0" Text="RAČUN 3:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="10" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Racun3, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>
                <TextBox Grid.Row="10" Grid.Column="3" Grid.ColumnSpan="2" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Brrac3, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Racun 4 -->
                <TextBlock Grid.Row="11" Grid.Column="0" Text="RAČUN 4:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="11" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Racun4, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>
                <TextBox Grid.Row="11" Grid.Column="3" Grid.ColumnSpan="2" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Brrac4, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Racun 5 -->
                <TextBlock Grid.Row="12" Grid.Column="0" Text="RAČUN 5:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="12" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Racun5, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>
                <TextBox Grid.Row="12" Grid.Column="3" Grid.ColumnSpan="2" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Brrac5, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Separator row 12 already used — using row 12 for sep -->

                <!-- Row 13: Dnevnica fields -->
                <TextBlock Grid.Row="13" Grid.Column="0" Text="ČASOVA POLASKA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="13" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Caspol, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="13" Grid.Column="3" Text="ČASOVA DOLASKA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="13" Grid.Column="4" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Casdol, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Row 14: Brdnev + Dnevnica -->
                <TextBlock Grid.Row="14" Grid.Column="0" Text="BROJ DNEVNICA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="14" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Brdnev, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>
                <TextBlock Grid.Row="14" Grid.Column="3" Text="DNEVNICA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="14" Grid.Column="4" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Dnevnica, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>

                <!-- Row 15: Iznosdn + Svega -->
                <TextBlock Grid.Row="15" Grid.Column="0" Text="IZNOS DNEVNICA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="15" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11" IsReadOnly="True" Background="#F5F5F5"
                         Text="{Binding Iznosdn, StringFormat=N2}"/>
                <TextBlock Grid.Row="15" Grid.Column="3" Text="SVEGA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
                <TextBox Grid.Row="15" Grid.Column="4" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="12" FontWeight="SemiBold" IsReadOnly="True"
                         Background="#E8F5E9"
                         Text="{Binding Svega, StringFormat=N2}"/>

                <!-- Row 16: Napomena + Zaisplat -->
                <TextBlock Grid.Row="16" Grid.Column="0" Text="NAPOMENA:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="16" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Napomena, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="16" Grid.Column="3" Text="ZA ISPLATU:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"/>
                <TextBox Grid.Row="16" Grid.Column="4" Height="24" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="12" FontWeight="SemiBold" IsReadOnly="True"
                         Background="#E8F5E9"
                         Text="{Binding Zaisplat, StringFormat=N2}"/>

                <!-- Row 17: Izvest -->
                <TextBlock Grid.Row="17" Grid.Column="0" Text="IZVEŠTAJ:"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"/>
                <TextBox Grid.Row="17" Grid.Column="1" Grid.ColumnSpan="4" Height="24"
                         VerticalContentAlignment="Center" FontFamily="Tahoma" FontSize="11"
                         Text="{Binding Izvest1, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
