<Window x:Class="Algoritam.WPF.Views.Zarade.LdOz10View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1400"
        Height="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">
    <DockPanel>
        <DataGrid DockPanel.Dock="Top"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  RowHeight="20"
                  BorderThickness="0"
                  Background="#F5F5F5"
                  AlternatingRowBackground="#EDF1F9">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1B5E20"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Br" Binding="{Binding Br, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Ime_prez" Binding="{Binding ImePrez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                <DataGridTextColumn Header="Pol" Binding="{Binding Pol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn Header="Prvaispl" Binding="{Binding Prvaispl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Dod" Binding="{Binding Dod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTextColumn Header="Ddo" Binding="{Binding Ddo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="110"/>
                <DataGridTextColumn Header="Bolest" Binding="{Binding Bolest, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="80"/>
                <DataGridTextColumn Header="Povrad" Binding="{Binding Povrad, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="80"/>
                <DataGridTextColumn Header="Profbol" Binding="{Binding Profbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="80"/>
                <DataGridTextColumn Header="Nega65" Binding="{Binding Nega65, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="80"/>
                <DataGridTextColumn Header="Nega100" Binding="{Binding Nega, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="90"/>
                <DataGridTextColumn Header="Izolac" Binding="{Binding Izolac, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="80"/>
                <DataGridTextColumn Header="Davalac" Binding="{Binding Davalac, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="80"/>
                <DataGridTextColumn Header="Trudnoca" Binding="{Binding Trudnoca, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" Width="90"/>
                <DataGridTextColumn Header="Bruto" Binding="{Binding Bruto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Dopr" Binding="{Binding Dopr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Dopf" Binding="{Binding Dopf, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Porez" Binding="{Binding Porez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Zaisplat" Binding="{Binding Zaisplat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Svega" Binding="{Binding Svega, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1,1,1,0" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="OBRAZAC NAKNADA" Width="150" Height="28" Margin="0,0,8,0" Command="{Binding ObrazacNaknadaCommand}"/>
                    <Button Content="PREUZIMANJE" Width="120" Height="28" Margin="0,0,8,0" Command="{Binding PreuzimanjeCommand}"/>
                    <Button Content="SPECIFIKACIJA" Width="130" Height="28" Margin="0,0,8,0" Command="{Binding SpecifikacijaCommand}"/>
                    <Button Content="DODAJ" Width="90" Height="28" Margin="0,0,8,0" Command="{Binding DodajCommand}"/>
                    <Button Content="BRISANJE REDA" Width="130" Height="28" Margin="0,0,8,0" Command="{Binding BrisanjeRedaCommand}"/>
                    <Button Content="SAČUVAJ" Width="100" Height="28" Margin="0,0,8,0" Command="{Binding SacuvajRucnoCommand}"/>
                    <Button Content="BRISANJE" Width="110" Height="28" Margin="0,0,8,0" Command="{Binding BrisanjeCommand}"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="_IZLAZ"
                        Width="120"
                        Height="28"
                        Background="#C62828"
                        Foreground="White"
                        BorderThickness="0"
                        Click="IzlazClick"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#D7DBFF" BorderBrush="#A1A9E8" BorderThickness="1" Padding="8,5">
            <TextBlock Text="{Binding Poruka}" />
        </Border>
    </DockPanel>
</Window>
