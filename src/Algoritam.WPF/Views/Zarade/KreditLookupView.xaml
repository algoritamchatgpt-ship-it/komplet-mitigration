<Window x:Class="Algoritam.WPF.Views.Zarade.KreditLookupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="760" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#37474F" Padding="12,8">
            <TextBlock Text="{Binding Naslov}"
                       Foreground="White"
                       FontFamily="Tahoma"
                       FontSize="14"
                       FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="DODAJ"
                        Width="96"
                        Height="28"
                        Margin="0,0,8,0"
                        Command="{Binding DodajCommand}"
                        Visibility="{Binding OmoguciDodavanje, Converter={StaticResource BoolToVisibility}}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="OTKAZI"
                            Width="96"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding OtkaziCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="POTVRDI"
                            Width="96"
                            Height="28"
                            Background="#37474F"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding PotvrdiCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Globalna pretraga:"
                               VerticalAlignment="Center"
                               FontFamily="Tahoma"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                    <TextBox Width="300"
                             Margin="8,0,8,0"
                             Height="28"
                             VerticalContentAlignment="Center"
                             FontFamily="Tahoma"
                             FontSize="11"
                             Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Ocisti filtere"
                            Width="110"
                            Height="28"
                            Command="{Binding OcistiFiltereCommand}"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#C8E6C9" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                <WrapPanel>
                    <TextBlock Text="Sifra:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Margin="0,0,6,0"/>
                    <TextBox Width="110"
                             Height="28"
                             Margin="0,0,6,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding FilterSifra, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Nadji sifru"
                            Width="90"
                            Height="28"
                            Margin="0,0,12,0"
                            Command="{Binding TraziSifruCommand}"/>

                    <TextBlock Text="Naziv:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Margin="0,0,6,0"/>
                    <TextBox Width="220"
                             Height="28"
                             Margin="0,0,6,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding FilterNaziv, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Nadji naziv"
                            Width="96"
                            Height="28"
                            Margin="0,0,12,0"
                            Command="{Binding TraziNazivCommand}"/>

                    <TextBlock Text="{Binding DodatnoLabel}" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Margin="0,0,6,0"/>
                    <TextBox Width="160"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Text="{Binding FilterDodatno, UpdateSourceTrigger=PropertyChanged}"/>
                </WrapPanel>
            </Border>

            <Border Grid.Row="2" BorderBrush="#C8E6C9" BorderThickness="1" Background="White">
                <DataGrid ItemsSource="{Binding Stavke}"
                          SelectedItem="{Binding Izabrana, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F0F0F0"
                          FontFamily="Tahoma"
                          FontSize="11"
                          MouseDoubleClick="DataGridMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Sifra" Binding="{Binding Sifra}" Width="120"/>
                        <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                        <DataGridTextColumn Header="Dodatno" Binding="{Binding Dodatno}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
