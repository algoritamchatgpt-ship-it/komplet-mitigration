<Window x:Class="Algoritam.WPF.Views.Zarade.NalogZaPlacanjeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nalozi za plaćanje"
        Width="1560" Height="760"
        MinWidth="1100" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NalBtn" TargetType="Button">
            <Setter Property="FontFamily"   Value="Tahoma"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"       Value="28"/>
            <Setter Property="MinWidth"     Value="90"/>
            <Setter Property="Margin"       Value="2,0"/>
            <Setter Property="Padding"      Value="8,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
        <Style x:Key="NalGroupBox" TargetType="GroupBox">
            <Setter Property="FontFamily"   Value="Tahoma"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="Foreground"   Value="#455A64"/>
            <Setter Property="BorderBrush"  Value="#B0BEC5"/>
            <Setter Property="Margin"       Value="0,0,6,0"/>
            <Setter Property="Padding"      Value="4,2"/>
        </Style>
        <Style x:Key="HdrLbl" TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#1B5E20"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Tahoma"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="6,4"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5"     Command="{Binding OsveziCommand}"/>
        <KeyBinding Key="S"      Modifiers="Ctrl" Command="{Binding SacuvajCommand}"/>
        <KeyBinding Key="Insert" Modifiers="Ctrl" Command="{Binding DodajStavkuCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Zaglavlje -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Tabela -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Zaglavlje ───────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#1B5E20" Height="50">
            <DockPanel Margin="16,0">
                <!-- Indikator neačuvanih izmena -->
                <Border DockPanel.Dock="Right"
                        Background="#E65100" CornerRadius="3" Padding="8,2" Margin="0,0,4,0"
                        Visibility="{Binding ImaNeacuvana, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="NEACUVANE IZMENE"
                               Foreground="White" FontFamily="Tahoma" FontSize="10" FontWeight="Bold"/>
                </Border>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding BrojZapisa, StringFormat='Stavki: {0}'}"
                           Foreground="#A5D6A7" FontFamily="Tahoma" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding Naslov}"
                           Foreground="White" FontSize="16" FontWeight="Bold" FontFamily="Tahoma"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,0,0,1" Padding="8,5">
            <WrapPanel Orientation="Horizontal">

                <!-- UNOS -->
                <GroupBox Header=" UNOS " Style="{StaticResource NalGroupBox}">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource NalBtn}"
                                Background="#2E7D32" MinWidth="100"
                                Command="{Binding DodajStavkuCommand}"
                                ToolTip="Dodaj novi red u tabelu  [Ctrl+Insert]">
                            <TextBlock Text="+ DODAJ"/>
                        </Button>
                        <Button Style="{StaticResource NalBtn}"
                                Background="#1565C0" MinWidth="110"
                                Command="{Binding SacuvajCommand}"
                                ToolTip="Sačuvaj izmene u nalpep.dbf  [Ctrl+S]">
                            <TextBlock Text="SAČUVAJ"/>
                        </Button>
                        <Button Style="{StaticResource NalBtn}"
                                Background="#607D8B"
                                Command="{Binding OsveziCommand}"
                                ToolTip="Ponovo učitaj podatke iz fajla  [F5]">
                            <TextBlock Text="F5 OSVEZI"/>
                        </Button>
                    </StackPanel>
                </GroupBox>

                <!-- BRISANJE -->
                <GroupBox Header=" BRISANJE " Style="{StaticResource NalGroupBox}">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource NalBtn}"
                                Background="#C62828" MinWidth="120"
                                Command="{Binding ObrisiPrazneCommand}"
                                ToolTip="Obriši sve redove gde je DUG=0 i POT=0  [Shift+F10]">
                            <TextBlock Text="OBRIŠI PRAZNE"/>
                        </Button>
                        <Button Style="{StaticResource NalBtn}"
                                Background="#E65100" MinWidth="150"
                                Command="{Binding ObrisiVrednostiNalogaCommand}"
                                ToolTip="Postavi DUG=0 i POT=0 za sve redove tekućeg naloga (BRNAL)">
                            <TextBlock Text="VREDNOSTI NALOGA"/>
                        </Button>
                        <Button Style="{StaticResource NalBtn}"
                                Background="#BF360C" MinWidth="130"
                                Command="{Binding ObrisiSveVrednostiCommand}"
                                ToolTip="Postavi DUG=0 i POT=0 za sve redove u tabeli">
                            <TextBlock Text="SVE VREDNOSTI"/>
                        </Button>
                    </StackPanel>
                </GroupBox>

                <!-- PREGLED -->
                <GroupBox Header=" PREGLED " Style="{StaticResource NalGroupBox}">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource NalBtn}"
                                Background="#455A64" MinWidth="110"
                                Command="{Binding SaldirajCommand}"
                                ToolTip="Saldiranje naloga — grupisanje i poravnanje stavki">
                            <TextBlock Text="SALDIRANJE"/>
                        </Button>
                        <Button Style="{StaticResource NalBtn}"
                                Background="#455A64" MinWidth="90"
                                Command="{Binding StampaCommand}"
                                ToolTip="Štampa naloga za plaćanje">
                            <TextBlock Text="ŠTAMPA"/>
                        </Button>
                    </StackPanel>
                </GroupBox>

                <!-- PREUZIMANJE IZVODA -->
                <GroupBox Header=" PREUZIMANJE IZVODA " Style="{StaticResource NalGroupBox}">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource NalBtn}"
                                Background="#00695C" MinWidth="70"
                                Command="{Binding PreuzmiSdfCommand}"
                                ToolTip="Preuzmi bankarski SDF izvod (nalpep02.dbf format)">
                            <TextBlock Text="SDF"/>
                        </Button>
                        <Button Style="{StaticResource NalBtn}"
                                Background="#00695C" MinWidth="60"
                                Command="{Binding PreuzmiRfCommand}"
                                ToolTip="Preuzmi RF izvod (nalpep03.dbf format)">
                            <TextBlock Text="RF"/>
                        </Button>
                        <Button Style="{StaticResource NalBtn}"
                                Background="#00695C" MinWidth="70"
                                Command="{Binding PreuzmiXmlCommand}"
                                ToolTip="Preuzmi XML izvod banke">
                            <TextBlock Text="XML"/>
                        </Button>
                    </StackPanel>
                </GroupBox>

            </WrapPanel>
        </Border>

        <!-- ── Editabilna tabela ────────────────────────────────────────── -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding SelectedStavka}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  Background="White"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F0F0F0"
                  RowBackground="White"
                  FontFamily="Tahoma" FontSize="11"
                  ColumnHeaderStyle="{StaticResource HdrLbl}"
                  Margin="0">

            <DataGrid.Columns>

                <!-- Br. naloga -->
                <DataGridTextColumn Header="Br. naloga"
                                    Binding="{Binding BrNal, UpdateSourceTrigger=LostFocus}"
                                    Width="85"/>

                <!-- Datum dok. -->
                <DataGridTemplateColumn Header="Datum dok." Width="105">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DatDok, StringFormat=dd.MM.yyyy}"
                                       Padding="4,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding DatDok, UpdateSourceTrigger=PropertyChanged}"
                                        FontFamily="Tahoma" FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Datum val. -->
                <DataGridTemplateColumn Header="Datum val." Width="105">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Valuta, StringFormat=dd.MM.yyyy}"
                                       Padding="4,2" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding Valuta, UpdateSourceTrigger=PropertyChanged}"
                                        FontFamily="Tahoma" FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Konto -->
                <DataGridTextColumn Header="Konto"
                                    Binding="{Binding Konto, UpdateSourceTrigger=LostFocus}"
                                    Width="90"/>

                <!-- Šifra -->
                <DataGridTextColumn Header="Šifra"
                                    Binding="{Binding Sifra, UpdateSourceTrigger=LostFocus}"
                                    Width="60"/>

                <!-- Naziv -->
                <DataGridTextColumn Header="Naziv"
                                    Binding="{Binding Naziv, UpdateSourceTrigger=LostFocus}"
                                    Width="180"/>

                <!-- Br. računa -->
                <DataGridTextColumn Header="Br. računa"
                                    Binding="{Binding BrRac, UpdateSourceTrigger=LostFocus}"
                                    Width="155"/>

                <!-- Poziv Z -->
                <DataGridTextColumn Header="Poziv Z"
                                    Binding="{Binding PozivZ, UpdateSourceTrigger=LostFocus}"
                                    Width="120"/>

                <!-- Poziv P -->
                <DataGridTextColumn Header="Poziv P"
                                    Binding="{Binding PozivP, UpdateSourceTrigger=LostFocus}"
                                    Width="120"/>

                <!-- Opis -->
                <DataGridTextColumn Header="Opis"
                                    Binding="{Binding Opis, UpdateSourceTrigger=LostFocus}"
                                    Width="160"/>

                <!-- Duguje -->
                <DataGridTextColumn Header="Duguje"
                                    Binding="{Binding Dug, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                                    Width="105">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="Foreground"    Value="#C62828"/>
                            <Setter Property="FontWeight"    Value="SemiBold"/>
                            <Setter Property="Padding"       Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- Potražuje -->
                <DataGridTextColumn Header="Potražuje"
                                    Binding="{Binding Pot, StringFormat=N2, UpdateSourceTrigger=LostFocus}"
                                    Width="105">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="Foreground"    Value="#1B5E20"/>
                            <Setter Property="FontWeight"    Value="SemiBold"/>
                            <Setter Property="Padding"       Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- MP -->
                <DataGridTextColumn Header="MP"
                                    Binding="{Binding Mp, UpdateSourceTrigger=LostFocus}"
                                    Width="45"/>

                <!-- Dok -->
                <DataGridTextColumn Header="Dok"
                                    Binding="{Binding Dok, UpdateSourceTrigger=LostFocus}"
                                    Width="45"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Status bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#2E7D32"
                BorderBrush="#C8E6C9" BorderThickness="0,1,0,0"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="NALPEP"
                           FontFamily="Tahoma" FontSize="9"
                           Foreground="#A5D6A7"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <!-- Lijevo: tekući nalog saldo -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TekuciNalog}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                               Foreground="#1565C0" MinWidth="110"/>
                    <TextBlock Text="   Dug: " FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                    <TextBlock Text="{Binding NalogDug}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#C62828" MinWidth="85" TextAlignment="Right"/>
                    <TextBlock Text="   Pot: " FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                    <TextBlock Text="{Binding NalogPot}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#1B5E20" MinWidth="85" TextAlignment="Right"/>
                    <TextBlock Text="   Saldo: " FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                    <TextBlock Text="{Binding NalogSaldo}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                               MinWidth="85" TextAlignment="Right">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1B5E20"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NalogBalansiran}" Value="False">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#C8E6C9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NalogBalansiran}" Value="False">
                                        <Setter Property="Background" Value="#FFCDD2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontFamily="Tahoma" FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="URAVNOTEŽEN"/>
                                    <Setter Property="Foreground" Value="#1B5E20"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NalogBalansiran}" Value="False">
                                            <Setter Property="Text"       Value="NIJE BALANSIRAN"/>
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Centar: poruka -->
                <TextBlock Grid.Column="2"
                           Text="{Binding Poruka}"
                           FontFamily="Tahoma" FontSize="11"
                           Foreground="#455A64"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Margin="16,0"/>

                <!-- Desno: globalni zbir -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Uk. duguje: "
                               FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                    <TextBlock Text="{Binding UkupnoDug}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                               Foreground="#C62828" MinWidth="100" TextAlignment="Right"/>
                    <TextBlock Text="   Uk. potražuje: "
                               FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                    <TextBlock Text="{Binding UkupnoPot}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                               Foreground="#1B5E20" MinWidth="100" TextAlignment="Right"/>
                    <TextBlock Text="   Uk. saldo: "
                               FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                    <TextBlock Text="{Binding GlobalniSaldo}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                               MinWidth="100" TextAlignment="Right">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1B5E20"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GlobalniBalansiran}" Value="False">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="ZATVORI"
                            FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                            Foreground="White" Background="#C62828" BorderThickness="0"
                            Height="30" MinWidth="90" Padding="12,0"
                            Margin="16,0,0,0" Cursor="Hand"
                            Click="ZatvoriClick"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Window>
