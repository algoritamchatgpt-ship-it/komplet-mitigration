<Window x:Class="Algoritam.WPF.Views.Zarade.PutarRelacijeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Šifarnik relacija"
        Width="680" Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="44">
            <TextBlock Text="ŠIFARNIK PUTARINA — RELACIJE"
                       Margin="14,0" VerticalAlignment="Center"
                       Foreground="White" FontFamily="Tahoma" FontSize="14" FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="IZABERI" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11"
                            Cursor="Hand" Command="{Binding PotvrdiCommand}"/>
                    <Button Content="SAČUVAJ" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11"
                            Cursor="Hand" Command="{Binding SacuvajCommand}"/>
                    <Button Content="IZLAZ" Width="90" Height="28"
                            Background="#455A64" Foreground="White" BorderThickness="0"
                            FontFamily="Tahoma" FontSize="11"
                            Cursor="Hand" Click="ZatvoriClick"/>
                </StackPanel>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           FontFamily="Tahoma" FontSize="11"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#B0BEC5"
                BorderThickness="0,0,0,1" Padding="10,8">
            <WrapPanel>
                <TextBox Width="240" Height="26" VerticalContentAlignment="Center"
                         FontFamily="Tahoma" FontSize="11" Margin="0,0,6,0"
                         Text="{Binding PretragaTekst, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="TRAZI" Width="80" Height="28" Margin="0,0,10,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Command="{Binding TraziCommand}"/>
                <Button Content="DODAJ NOVU" Width="100" Height="28"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11"
                        Cursor="Hand" Command="{Binding DodajNovuCommand}"/>
            </WrapPanel>
        </Border>

        <Border Margin="10,6,10,6" BorderBrush="#B0BEC5" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Relacije}"
                      SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#FAFAFA"
                      FontFamily="Tahoma" FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Šifra" Binding="{Binding Sifrel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridTextColumn Header="Relacija / Naziv" Binding="{Binding Relacija, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="Iznos" Binding="{Binding Iznos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
