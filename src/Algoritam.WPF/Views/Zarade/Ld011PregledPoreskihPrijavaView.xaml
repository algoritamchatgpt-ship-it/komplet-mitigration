<Window x:Class="Algoritam.WPF.Views.Zarade.Ld011PregledPoreskihPrijavaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PREGLED PORESKIH PRIJAVA — LD011"
        Width="1260" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Cell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>
        <Style x:Key="CellR" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>
        <Style x:Key="SumCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#C0C0C0"/>
            <Setter Property="BorderBrush" Value="#808080"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="4,4,4,6">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource Btn}" Click="Stampaj_Click" Content="ŠTAMPAJ  (F10)"/>
                <Button Style="{StaticResource Btn}" Click="Zatvori_Click" Content="ZATVORI"/>
            </StackPanel>
        </Border>

        <!-- Print content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Border x:Name="PrintRoot"
                    Background="White"
                    BorderBrush="#808080" BorderThickness="1"
                    Padding="16"
                    Width="1160">
                <StackPanel>

                    <!-- Zaglavlje -->
                    <StackPanel Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding FirmaNaziv}"
                                           FontFamily="Tahoma" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="{Binding FirmaMesto}"
                                           FontFamily="Tahoma" FontSize="12"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Padding="10,4"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="PORESKA PRIJAVA"
                                               FontFamily="Tahoma"
                                               FontSize="11"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="OBRAZAC PPP-PD"
                                               FontFamily="Tahoma"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="EVIDENCIJA SVIH PORESKIH PRIJAVA"
                                   FontFamily="Tahoma" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <Rectangle Height="1" Fill="Black" Margin="0,2,0,6"/>
                    </StackPanel>

                    <!-- Header tabele -->
                    <Grid Background="#C0C8E0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="78"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="BR"/></Border>
                        <Border Grid.Column="1"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="MS"/></Border>
                        <Border Grid.Column="2"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="NAZIV MES"/></Border>
                        <Border Grid.Column="3"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="VR"/></Border>
                        <Border Grid.Column="4"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="BRUTO"/></Border>
                        <Border Grid.Column="5"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="POREZ"/></Border>
                        <Border Grid.Column="6"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="DOP PIO"/></Border>
                        <Border Grid.Column="7"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="DOP ZDR"/></Border>
                        <Border Grid.Column="8"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="DOP NEZ"/></Border>
                        <Border Grid.Column="9"  BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="DATUM"/></Border>
                        <Border Grid.Column="10" BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="PP OPJ-1"/></Border>
                        <Border Grid.Column="11" BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="PP OD"/></Border>
                        <Border Grid.Column="12" BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="PP OD VL"/></Border>
                        <Border Grid.Column="13" BorderBrush="#9090A0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Hdr}" Text="PP OD-1"/></Border>
                        <Border Grid.Column="14" BorderBrush="#9090A0" BorderThickness="0,0,0,1"><TextBlock Style="{StaticResource Hdr}" Text="GODINA"/></Border>
                    </Grid>

                    <!-- Redovi -->
                    <ItemsControl ItemsSource="{Binding Redovi}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="78"/>
                                        <ColumnDefinition Width="74"/>
                                        <ColumnDefinition Width="74"/>
                                        <ColumnDefinition Width="74"/>
                                        <ColumnDefinition Width="76"/>
                                        <ColumnDefinition Width="76"/>
                                        <ColumnDefinition Width="76"/>
                                        <ColumnDefinition Width="76"/>
                                        <ColumnDefinition Width="76"/>
                                        <ColumnDefinition Width="54"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Brobrac}"/></Border>
                                    <Border Grid.Column="1"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Mesec}"/></Border>
                                    <Border Grid.Column="2"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Nazmes}"/></Border>
                                    <Border Grid.Column="3"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Vrsta}"/></Border>
                                    <Border Grid.Column="4"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource CellR}" Text="{Binding Bruto}"/></Border>
                                    <Border Grid.Column="5"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource CellR}" Text="{Binding Porez}"/></Border>
                                    <Border Grid.Column="6"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource CellR}" Text="{Binding Doppr}"/></Border>
                                    <Border Grid.Column="7"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource CellR}" Text="{Binding Dopzr}"/></Border>
                                    <Border Grid.Column="8"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource CellR}" Text="{Binding Dopnr}"/></Border>
                                    <Border Grid.Column="9"  BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Dat1}"/></Border>
                                    <Border Grid.Column="10" BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Ppopj1}"/></Border>
                                    <Border Grid.Column="11" BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Ppod01}"/></Border>
                                    <Border Grid.Column="12" BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Ppod01v}"/></Border>
                                    <Border Grid.Column="13" BorderBrush="#D0D0D0" BorderThickness="0,0,1,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Ppod11}"/></Border>
                                    <Border Grid.Column="14" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1"><TextBlock Style="{StaticResource Cell}"  Text="{Binding Godina}"/></Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Zbir -->
                    <Grid Background="#E0E8F0" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="78"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Grid.ColumnSpan="4" BorderBrush="#808080" BorderThickness="1,1,1,1">
                            <TextBlock Style="{StaticResource SumCell}" Text="UKUPNO:" HorizontalAlignment="Left"/>
                        </Border>
                        <Border Grid.Column="4"  BorderBrush="#808080" BorderThickness="0,1,1,1"><TextBlock Style="{StaticResource SumCell}" Text="{Binding SumBruto}"/></Border>
                        <Border Grid.Column="5"  BorderBrush="#808080" BorderThickness="0,1,1,1"><TextBlock Style="{StaticResource SumCell}" Text="{Binding SumPorez}"/></Border>
                        <Border Grid.Column="6"  BorderBrush="#808080" BorderThickness="0,1,1,1"><TextBlock Style="{StaticResource SumCell}" Text="{Binding SumDoppr}"/></Border>
                        <Border Grid.Column="7"  BorderBrush="#808080" BorderThickness="0,1,1,1"><TextBlock Style="{StaticResource SumCell}" Text="{Binding SumDopzr}"/></Border>
                        <Border Grid.Column="8"  BorderBrush="#808080" BorderThickness="0,1,1,1"><TextBlock Style="{StaticResource SumCell}" Text="{Binding SumDopnr}"/></Border>
                        <Border Grid.Column="9"  BorderBrush="#808080" BorderThickness="0,1,1,1"/>
                        <Border Grid.Column="10" BorderBrush="#808080" BorderThickness="0,1,1,1"/>
                        <Border Grid.Column="11" BorderBrush="#808080" BorderThickness="0,1,1,1"/>
                        <Border Grid.Column="12" BorderBrush="#808080" BorderThickness="0,1,1,1"/>
                        <Border Grid.Column="13" BorderBrush="#808080" BorderThickness="0,1,1,1"/>
                        <Border Grid.Column="14" BorderBrush="#808080" BorderThickness="0,1,0,1"/>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
