<Window x:Class="Algoritam.WPF.Views.Zarade.IzvozTabelaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Izvoz tabele"
        Width="900"
        Height="580"
        MinWidth="900"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <Border Grid.Row="0"
                Height="50"
                Background="#1B5E20">
            <TextBlock Text="IZVOZ TABELE — DBF fajlovi aktivne firme"
                       FontWeight="Bold" FontSize="16" FontFamily="Tahoma"
                       Foreground="White" VerticalAlignment="Center" Margin="16,0"/>
        </Border>

        <!-- Glavni sadržaj -->
        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Leva kolona: lista tabela -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#C8E6C9"
                    BorderThickness="1"
                    CornerRadius="3">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Tabele (DBF fajlovi):"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>

                    <!-- Search -->
                    <Border Grid.Row="1"
                            BorderBrush="#B0BEC5"
                            BorderThickness="1"
                            CornerRadius="2"
                            Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding Pretraga, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Padding="4,3"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="&#128269;"
                                       Padding="4,3"
                                       VerticalAlignment="Center"
                                       Foreground="#607D8B"/>
                        </Grid>
                    </Border>

                    <!-- Lista tabela -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding PrikazaneTabele}"
                             SelectedItem="{Binding IzabranaTabela}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Naziv}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding BrojZapisa, StringFormat='({0})'}"
                                               Foreground="#757575"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#C8E6C9"/>
                                        <Setter Property="Foreground" Value="#1B5E20"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Desna kolona: opcije i akcije -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#C8E6C9"
                    BorderThickness="1"
                    CornerRadius="3">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Izabrana tabela -->
                    <Border Grid.Row="0"
                            Background="#E8F5E9"
                            BorderBrush="#C8E6C9"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="10,8"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Izabrana tabela:" Foreground="#616161" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding IzabranaTabela.Naziv, FallbackValue='— nije izabrana —'}"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Foreground="#1B5E20"/>
                            <TextBlock Margin="0,2,0,0">
                                <Run Text="Zapisa: " Foreground="#616161"/>
                                <Run Text="{Binding IzabranaTabela.BrojZapisa, FallbackValue='—'}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Format -->
                    <GroupBox Grid.Row="1"
                              Header="Format izvoza"
                              Margin="0,0,0,12"
                              Padding="10,8">
                        <StackPanel>
                            <RadioButton GroupName="Format"
                                         Content="XML — čitljiv format, sve kolone i vrednosti"
                                         IsChecked="{Binding XmlFormat, Mode=TwoWay}"
                                         Margin="0,0,0,6"
                                         Cursor="Hand"/>
                            <RadioButton GroupName="Format"
                                         Content="CSV — za Excel, razdvajač tačka-zarez (UTF-8)"
                                         IsChecked="{Binding CsvFormat, Mode=TwoWay}"
                                         Margin="0,0,0,6"
                                         Cursor="Hand"/>
                            <RadioButton GroupName="Format"
                                         Content="PDF — tabela u PDF dokumentu (A4)"
                                         IsChecked="{Binding PdfFormat, Mode=TwoWay}"
                                         Margin="0,0,0,6"
                                         Cursor="Hand"/>
                            <RadioButton GroupName="Format"
                                         Content="DBF — kopira originalni fajl (+ CDX/FPT ako postoje)"
                                         IsChecked="{Binding DbfFormat, Mode=TwoWay}"
                                         Cursor="Hand"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Putanja za izvoz -->
                    <TextBlock Grid.Row="2"
                               Text="Putanja za izvoz:"
                               FontWeight="Bold"
                               Margin="0,0,0,4"/>
                    <Grid Grid.Row="3" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                BorderBrush="#B0BEC5"
                                BorderThickness="1"
                                CornerRadius="2,0,0,2">
                            <TextBox Text="{Binding IzvozPutanja, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Padding="6,4"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="1"
                                Content="Pretraži..."
                                Width="90"
                                Height="28"
                                Background="#607D8B"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding OdaberiPutanjuCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="0,2,2,0"
                                            Padding="8,0">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#455A64"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Status poruka -->
                    <Border Grid.Row="4"
                            Background="#F0F0F0"
                            BorderBrush="#B0BEC5"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="10,8">
                        <TextBlock Text="{Binding Poruka}"
                                   TextWrapping="Wrap"
                                   Foreground="#37474F"/>
                    </Border>

                    <!-- Dugmad -->
                    <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button Content="IZVEZI"
                                Width="130"
                                Height="28"
                                Margin="0,0,8,0"
                                Background="#1565C0"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Command="{Binding IzveziCommand}"/>
                        <Button Content="IZLAZ"
                                Width="90"
                                Height="28"
                                Background="#C62828"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="IzlazClick"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar na dnu -->
        <DockPanel Grid.Row="2" Margin="0,4,0,0">
            <TextBlock DockPanel.Dock="Left" Text="DBF IZVOZ"
                       FontFamily="Tahoma" FontSize="9" Foreground="#607D8B"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ProgressBar Height="6" VerticalAlignment="Center"
                         IsIndeterminate="{Binding Radi}"
                         Visibility="{Binding Radi, Converter={StaticResource BoolToVisibilityConverter}}"
                         Foreground="#43A047"
                         Background="#E8F5E9"/>
        </DockPanel>
    </Grid>
</Window>
