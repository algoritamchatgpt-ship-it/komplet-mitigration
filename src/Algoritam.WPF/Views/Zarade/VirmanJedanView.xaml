<Window x:Class="Algoritam.WPF.Views.Zarade.VirmanJedanView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jedan virman — popuni" Width="580" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="Txt" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel>

        <!-- Header -->
        <Border Background="#1565C0" Padding="12,10">
            <TextBlock Text="JEDAN VIRMAN — POPUNI" Foreground="White"
                       FontFamily="Tahoma" FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- PLATILAC -->
        <Border Background="#1565C0" Margin="0,8,0,0">
            <TextBlock Text="PLATILAC (zaduženje — firma)" Style="{StaticResource Sec}"/>
        </Border>
        <Grid Margin="12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Naziv firme:" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Row="0" Grid.Column="1" Style="{StaticResource Txt}" Margin="0,3"
                      IsReadOnly="True" Background="#FAFAFA"
                      Text="{Binding FirmaNaziv, Mode=OneWay}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Žiro račun (Z):" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Row="1" Grid.Column="1" Style="{StaticResource Txt}" Margin="0,3"
                      IsReadOnly="True" Background="#FAFAFA"
                      Text="{Binding FirmaZiro, Mode=OneWay}"/>
        </Grid>

        <!-- Model Z / Poziv Z -->
        <Grid Margin="12,0,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Model Z / Poziv Z:" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Column="1" Style="{StaticResource Txt}" Margin="0,3,4,3"
                      MaxLength="2" Text="{Binding ModelZ, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox  Grid.Column="2" Style="{StaticResource Txt}" Margin="0,3"
                      Text="{Binding PozivZ, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- PRIMALAC -->
        <Border Background="#2E7D32" Margin="0,6,0,0">
            <TextBlock Text="PRIMALAC (odobrenje)" Style="{StaticResource Sec}"/>
        </Border>
        <Grid Margin="12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Naziv primaoca:" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Row="0" Grid.Column="1" Style="{StaticResource Txt}" Margin="0,3"
                      MaxLength="50" Text="{Binding NazRac, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Žiro račun (O):" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Row="1" Grid.Column="1" Style="{StaticResource Txt}" Margin="0,3"
                      MaxLength="18" Text="{Binding ZiroRac, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Model O / Poziv O -->
        <Grid Margin="12,0,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Model O / Poziv O:" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Column="1" Style="{StaticResource Txt}" Margin="0,3,4,3"
                      MaxLength="2" Text="{Binding Modelo, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox  Grid.Column="2" Style="{StaticResource Txt}" Margin="0,3"
                      Text="{Binding PozivO, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- DETALJI -->
        <Border Background="#455A64" Margin="0,6,0,0">
            <TextBlock Text="DETALJI PLAĆANJA" Style="{StaticResource Sec}"/>
        </Border>
        <Grid Margin="12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Iznos (RSD):" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Row="0" Grid.Column="1"  Style="{StaticResource Txt}" Margin="0,3"
                      FontWeight="Bold" FontSize="13"
                      Text="{Binding Dug, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Šifra plaćanja:" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Row="1" Grid.Column="1" Style="{StaticResource Txt}" Margin="0,3"
                      MaxLength="3" Text="{Binding Sif1, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Svrha plaćanja:" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <TextBox  Grid.Row="2" Grid.Column="1"  Grid.ColumnSpan="3" Style="{StaticResource Txt}" Margin="0,3"
                      MaxLength="50" Text="{Binding Svrha, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Datum dok.:" Style="{StaticResource Lbl}" Margin="0,4,6,4"/>
            <DatePicker Grid.Row="3" Grid.Column="1" FontFamily="Tahoma" FontSize="11" Margin="0,3"
                        SelectedDate="{Binding DatDok, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="Val.:" Style="{StaticResource Lbl}" Margin="6,4,4,4"/>
            <TextBox  Grid.Row="3" Grid.Column="3" Style="{StaticResource Txt}" Margin="0,3"
                      MaxLength="3" Text="{Binding Valuta, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Dugmad -->
        <Separator Margin="0,6,0,0" Background="#BDBDBD"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,8">
            <Button Style="{StaticResource Btn}" Content="ŠTAMPAJ"
                    Background="#E65100" Margin="0,0,8,0"
                    Command="{Binding StampajCommand}"/>
            <Button Style="{StaticResource Btn}" Content="POTVRDI"
                    Background="#1565C0" Margin="0,0,8,0"
                    Command="{Binding PotvrdiCommand}"/>
            <Button Style="{StaticResource Btn}" Content="ODUSTANI"
                    Background="#455A64"
                    Command="{Binding OdustaniCommand}"/>
        </StackPanel>

    </StackPanel>
</Window>
