<Window x:Class="Algoritam.WPF.Views.Zarade.OdRadniciView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obrazac OD"
        Width="1000" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <StackPanel VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="OBRAZAC OD — RADNICI"
                           FontFamily="Tahoma" FontSize="16" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="ldodn.dbf"
                           FontFamily="Tahoma" FontSize="10"
                           Foreground="#A5D6A7"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#2E7D32" Height="30">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="OD_RADNICI"
                           FontFamily="Tahoma" FontSize="9"
                           Foreground="#A5D6A7"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Poruka}"
                           FontFamily="Tahoma" FontSize="11"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9" Height="44">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="12,0">
                <Button Content="⟳ OSVEZI"
                        Width="90" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <Button Content="  ZATVORI  "
                        Width="110" Height="30"
                        FontFamily="Tahoma" FontSize="12" FontWeight="SemiBold"
                        Background="#757575" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="Zatvori_Click"/>
            </StackPanel>
        </Border>

        <!-- Sadržaj -->
        <Grid Margin="12">

            <!-- Prikaz dok se učitava ili nema podataka -->
            <TextBlock Text="{Binding Poruka}"
                       FontFamily="Tahoma" FontSize="14"
                       Foreground="#C8E6C9"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Stavke.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- DataGrid -->
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0E0E0"
                      BorderThickness="1" BorderBrush="#C8E6C9"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F9FBF9"
                      FontFamily="Tahoma" FontSize="12">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E8F5E9"/>
                        <Setter Property="Foreground" Value="#2E7D32"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#C8E6C9"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C8E6C9"/>
                                <Setter Property="Foreground" Value="#1B5E20"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kod" Binding="{Binding Kod}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Opis" Binding="{Binding Opis}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="AOP" Binding="{Binding Aop}" Width="50">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SK1" Width="110"
                                        Binding="{Binding Sk1, StringFormat=N2}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SK2" Width="110"
                                        Binding="{Binding Sk2, StringFormat=N2}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SK3" Width="110"
                                        Binding="{Binding Sk3, StringFormat=N2}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="SK4" Width="110"
                                        Binding="{Binding Sk4, StringFormat=N2}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Žiro račun" Binding="{Binding ZiroRac}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>

            </DataGrid>
        </Grid>

    </DockPanel>
</Window>
