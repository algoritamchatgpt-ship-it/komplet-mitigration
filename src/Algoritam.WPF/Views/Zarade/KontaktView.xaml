<Window x:Class="Algoritam.WPF.Views.Zarade.KontaktView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kontakt / Tehnička podrška"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <DockPanel Background="#F5F5F5">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Padding="20,14">
            <StackPanel>
                <TextBlock Text="TEHNIČKA PODRŠKA"
                           FontFamily="Tahoma" FontSize="14" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="TxtNazivFirme"
                           FontFamily="Tahoma" FontSize="11"
                           Foreground="#A5D6A7" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#EEEEEE" Padding="20,10">
            <DockPanel>
                <TextBlock x:Name="TxtNapomena"
                           FontFamily="Tahoma" FontSize="10" Foreground="#757575"
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           DockPanel.Dock="Left" Margin="0,0,12,0"/>
                <Button Content="IZLAZ"
                        Width="104" Height="34"
                        HorizontalAlignment="Right"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#455A64"
                        BorderBrush="#263238" BorderThickness="1"
                        Cursor="Hand"
                        Click="ZatvoriClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>

        <!-- Sadržaj -->
        <StackPanel Margin="24,18,24,6">

            <!-- Adresa -->
            <StackPanel x:Name="PanelAdresa">
                <TextBlock Text="Adresa" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="TxtAdresa" Style="{StaticResource ValueStyle}"/>
            </StackPanel>

            <!-- Telefon -->
            <StackPanel x:Name="PanelTelefon">
                <TextBlock Text="Telefon" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="TxtTelefon" Style="{StaticResource ValueStyle}"/>
            </StackPanel>

            <!-- E-mail -->
            <StackPanel x:Name="PanelEmail">
                <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="TxtEmail" Style="{StaticResource ValueStyle}"/>
            </StackPanel>

            <!-- Radno vreme -->
            <StackPanel x:Name="PanelRadnoVreme">
                <TextBlock Text="Radno vreme" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="TxtRadnoVreme" Style="{StaticResource ValueStyle}"/>
            </StackPanel>

            <!-- Website -->
            <StackPanel x:Name="PanelWebsite">
                <TextBlock Text="Web" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="TxtWebsite" Style="{StaticResource ValueStyle}"/>
            </StackPanel>

            <!-- Poruka kada nisu uneseni podaci -->
            <TextBlock x:Name="TxtPrazno"
                       Text="Kontakt podaci nisu još uneti.&#10;Obratite se prodavcu programa."
                       FontFamily="Tahoma" FontSize="12" Foreground="#9E9E9E"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,16,0,12"
                       Visibility="Collapsed"/>

        </StackPanel>

    </DockPanel>
</Window>
