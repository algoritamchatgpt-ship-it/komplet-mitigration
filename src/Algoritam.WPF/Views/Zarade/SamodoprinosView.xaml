<Window x:Class="Algoritam.WPF.Views.Zarade.SamodoprinosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Samodoprinos" Width="1100" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
        <KeyBinding Key="F2" Command="{Binding SacuvajCommand}"/>
        <KeyBinding Key="Insert" Command="{Binding DodajCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zaglavlje -->
        <Border Grid.Row="0" Background="#1565C0" Padding="16,10">
            <TextBlock Text="{Binding Naslov}" Foreground="White" FontSize="16" FontWeight="Bold" FontFamily="Tahoma"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#E3F2FD" Padding="10,6" BorderThickness="0,0,0,1" BorderBrush="#BBDEFB">
            <WrapPanel>
                <Button Content="DODAJ  Ins" Width="100" Height="28" Margin="0,0,4,0"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding DodajCommand}"/>
                <Button Content="BRISANJE  Del" Width="120" Height="28" Margin="0,0,4,0"
                        Background="#B71C1C" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding ObrisiCommand}"
                        ToolTip="Obriši izabranu stavku samodoprinosa"/>
                <Button Content="F2 SAČUVAJ" Width="100" Height="28" Margin="0,0,16,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding SacuvajCommand}"/>
                <Button Content="◀◀ PRVI" Width="76" Height="28" Margin="0,0,4,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding PrviCommand}"/>
                <Button Content="◀ GORE" Width="72" Height="28" Margin="0,0,4,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding GoreCommand}"/>
                <Button Content="▶ DOLE" Width="72" Height="28" Margin="0,0,4,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding DoleCommand}"/>
                <Button Content="▶▶ ZADNJI" Width="84" Height="28" Margin="0,0,16,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding ZadnjiCommand}"/>
                <Button Content="F5 OSVEZI" Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" Cursor="Hand"
                        Command="{Binding OsveziCommand}"/>
            </WrapPanel>
        </Border>

        <!-- Grid sa podacima -->
        <DataGrid Grid.Row="2" Margin="10,8,10,0"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  Background="White" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" IsReadOnly="False"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Šifra"       Binding="{Binding SamSif}"               Width="60"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Naziv"       Binding="{Binding SamoNaz}"              Width="200"/>
                <DataGridTextColumn Header="Procenat"    Binding="{Binding SamoProc, StringFormat=N4}" Width="90"/>
                <DataGridTextColumn Header="Žiro račun"  Binding="{Binding ZiroRac}"              Width="160"/>
                <DataGridTextColumn Header="Samodoprinos" Binding="{Binding SamoDop, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Sam1"        Binding="{Binding Sam1, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Sam2"        Binding="{Binding Sam2, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Sam3"        Binding="{Binding Sam3, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Sam4"        Binding="{Binding Sam4, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Mesec"       Binding="{Binding Mesec}"                Width="60"/>
                <DataGridTextColumn Header="Isplata"     Binding="{Binding Isplata}"              Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#E8F5E9" Padding="12,6" BorderThickness="0,1,0,0" BorderBrush="#C8E6C9">
            <DockPanel>
                <Button Content="ZATVORI" DockPanel.Dock="Right" Width="100" Height="28"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11"
                           VerticalAlignment="Center" Foreground="#1B5E20"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
