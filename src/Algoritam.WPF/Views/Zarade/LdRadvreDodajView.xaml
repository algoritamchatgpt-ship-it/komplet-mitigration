<Window x:Class="Algoritam.WPF.Views.Zarade.LdRadvreDodajView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DODAVANJE RADNIKA"
        Width="380" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">
    <!-- BackColor = RGB(128,255,255) -->

    <StackPanel Margin="12,10">

        <!-- Label1: DODAVANJE SVIH AKTIVNIH RADNIKA -->
        <Border BorderBrush="#B0BEC5" BorderThickness="1" Padding="4,3" Margin="0,0,0,10">
            <TextBlock Text="DODAVANJE SVIH AKTIVNIH RADNIKA"
                       FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Label2 + Text1: UNESITE DATUM -->
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#E8F5E9" BorderBrush="#B0BEC5" BorderThickness="1"
                    Padding="4,3" Margin="0,0,4,0">
                <TextBlock Text="UNESITE DATUM" FontFamily="Tahoma" FontSize="11"/>
            </Border>
            <DatePicker x:Name="DatumPicker" Grid.Column="1"
                        FontFamily="Tahoma" FontSize="11"
                        SelectedDate="{x:Static system:DateTime.Today}"
                        xmlns:system="clr-namespace:System;assembly=mscorlib"/>
        </Grid>

        <!-- Label3 + Text2: UNESITE SAT POČETKA -->
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#E8F5E9" BorderBrush="#B0BEC5" BorderThickness="1"
                    Padding="4,3" Margin="0,0,4,0">
                <TextBlock Text="UNESITE SAT POČETKA" FontFamily="Tahoma" FontSize="11"/>
            </Border>
            <TextBox x:Name="TxtPocSat" Grid.Column="1"
                     Text="0" TextAlignment="Right"
                     FontFamily="Tahoma" FontSize="11"
                     BorderBrush="#B0BEC5" BorderThickness="1"
                     Padding="4,2"/>
        </Grid>

        <!-- Command1: DODAVANJE | Command2: IZLAZ -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button x:Name="BtnDodavanje" Content="DODAVANJE"
                    Width="130" Height="28"
                    FontFamily="Tahoma" FontSize="11"
                    Background="#1565C0" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Margin="0,0,16,0"
                    Click="DodavanjeClick"/>
            <Button Content="IZLAZ"
                    Width="120" Height="28"
                    FontFamily="Tahoma" FontSize="11"
                    Background="#C62828" Foreground="White" BorderThickness="0"
                    Cursor="Hand"
                    Click="IzlazClick"/>
        </StackPanel>

    </StackPanel>
</Window>
