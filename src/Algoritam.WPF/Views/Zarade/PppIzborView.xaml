<Window x:Class="Algoritam.WPF.Views.Zarade.PppIzborView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OBRAZAC PPP-PD"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#D0D0D0">

    <Window.Resources>
        <Style x:Key="IzborBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#8A8A8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0E4F4"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B8D0E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <StackPanel>
        <!-- Header -->
        <Border Background="#3A6EA5" Padding="0,14,0,14">
            <StackPanel>
                <TextBlock Text="OBRAZAC PPP-PD"
                           FontFamily="Tahoma"
                           FontSize="19"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Izaberite formu koju zelite da otvorite"
                           FontFamily="Tahoma"
                           FontSize="11"
                           Foreground="#D0E4FF"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Dugmad -->
        <StackPanel Margin="16,16,16,0">
            <Button Style="{StaticResource IzborBtn}"
                    Margin="0,0,0,8"
                    Command="{Binding OtvoriParametreACommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="14"
                            Background="#3A6EA5" Margin="0,0,12,0">
                        <TextBlock Text="1" Foreground="White" FontFamily="Tahoma"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PARAMETRI A" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource IzborBtn}"
                    Command="{Binding OtvoriPreuzimanjePppPdCommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="14"
                            Background="#3A6EA5" Margin="0,0,12,0">
                        <TextBlock Text="2" Foreground="White" FontFamily="Tahoma"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PREUZIMANJE ZARADA I PPP-PD" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Separator + IZLAZ -->
        <Separator Margin="0,14,0,0" Background="#ABABAB"/>
        <Grid Margin="16,10,16,14">
            <Button HorizontalAlignment="Right"
                    Width="100"
                    Height="32"
                    FontFamily="Tahoma"
                    FontSize="13"
                    Content="IZLAZ"
                    Command="{Binding ZatvoriCommand}"/>
        </Grid>
    </StackPanel>
</Window>
