<Window x:Class="Algoritam.WPF.Views.Zarade.LdPorp12View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <DataGrid DockPanel.Dock="Top"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  RowHeight="20"
                  BorderThickness="0"
                  Background="#F5F5F5"
                  AlternatingRowBackground="#EDF1F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Broj" Binding="{Binding Broj, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Ime_prez" Binding="{Binding ImePrez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="350"/>
                <DataGridTextColumn Header="Mes" Binding="{Binding Mes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Mesec" Binding="{Binding Mesec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="240"/>
                <DataGridTextColumn Header="Bruto" Binding="{Binding Bruto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="160"/>
                <DataGridTextColumn Header="Neto" Binding="{Binding Neto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1,1,1,0" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="POTVRDA"
                            Width="110"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding PotvrdaCommand}"/>
                    <Button Content="DODAVANJE"
                            Width="120"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding DodavanjeCommand}"/>
                    <Button Content="BRISANJE"
                            Width="110"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding BrisanjeCommand}"/>
                    <Button Content="BRISANJE REDA"
                            Width="140"
                            Height="28"
                            Margin="0,0,8,0"
                            Command="{Binding BrisanjeRedaCommand}"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="F5 OSVEZI"
                        Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <Button DockPanel.Dock="Right"
                        Content="_IZLAZ"
                        Width="120"
                        Height="28"
                        Background="#C62828"
                        Foreground="White"
                        BorderThickness="0"
                        Click="IzlazClick"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#D7DBFF" BorderBrush="#A1A9E8" BorderThickness="1" Padding="8,5">
            <TextBlock Text="{Binding Poruka}" />
        </Border>
    </DockPanel>
</Window>
