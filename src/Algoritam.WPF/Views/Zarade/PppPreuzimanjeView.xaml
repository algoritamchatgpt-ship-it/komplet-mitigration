<Window x:Class="Algoritam.WPF.Views.Zarade.PppPreuzimanjeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PREUZIMANJE ZARADA I PORESKA PRIJAVA PPP-PD"
        Width="1880"
        Height="980"
        WindowStartupLocation="CenterScreen"
        Background="#E8ECF2"
        Closing="OnWindowClosing">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="31"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#B0BAC8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DDE8F8"/>
                    <Setter Property="BorderBrush" Value="#4A78C0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#BDD0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#FFF2F2"/>
            <Setter Property="BorderBrush" Value="#D06060"/>
            <Setter Property="Foreground" Value="#B02020"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFDADA"/>
                    <Setter Property="BorderBrush" Value="#A03030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#EEF3FC"/>
            <Setter Property="BorderBrush" Value="#6888C0"/>
            <Setter Property="Foreground" Value="#1A3468"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D4E2F8"/>
                    <Setter Property="BorderBrush" Value="#2C5099"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#BBC8EE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GreenActionBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#EBF7EB"/>
            <Setter Property="BorderBrush" Value="#44A044"/>
            <Setter Property="Foreground" Value="#1A5A1A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CDEACD"/>
                    <Setter Property="BorderBrush" Value="#2A7A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5A7090"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8,8,8,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ ZAGLAVLJE ═══ -->
        <Border Grid.Row="0" Background="#1F3A68" Padding="14,10" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="PREUZIMANJE ZARADA  —  PORESKA PRIJAVA PPP-PD"
                           FontFamily="Tahoma" FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Background="#2C5090" BorderBrush="#5888CC" BorderThickness="1"
                        Height="36" Width="148" Margin="16,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Strana: " Foreground="#90B8E0" FontFamily="Tahoma" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StranaTekst}" Foreground="White"
                                   FontFamily="Tahoma" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FirmaNaziv}" FontFamily="Tahoma" FontSize="13"
                               FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding FirmaMesto}" FontFamily="Tahoma" FontSize="11"
                               Foreground="#90B8E0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TABELA ═══ -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding SelektovanaStavka}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#A8B4C8"
                  BorderThickness="1"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#F3F6FB"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeaderWidth="0"
                  Margin="0,0,0,6"
                  FontFamily="Tahoma"
                  FontSize="12"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Background" Value="#2C4A7C"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1A3260"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="6,5"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#C0D8F8"/>
                            <Setter Property="Foreground" Value="#0A1E40"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Deklarac"    Binding="{Binding Deklarac,          UpdateSourceTrigger=LostFocus}" Width="92"/>
                <DataGridTextColumn Header="Br."         Binding="{Binding RedniBroj,         UpdateSourceTrigger=LostFocus}" Width="44"/>
                <DataGridTextColumn Header="Prezime"     Binding="{Binding Prezime,           UpdateSourceTrigger=LostFocus}" Width="170"/>
                <DataGridTextColumn Header="Ime"         Binding="{Binding Ime,               UpdateSourceTrigger=LostFocus}" Width="158"/>
                <DataGridTextColumn Header="Vrsta"       Binding="{Binding VrstaId,           UpdateSourceTrigger=LostFocus}" Width="50"/>
                <DataGridTextColumn Header="Prebiv."     Binding="{Binding Prebival,          UpdateSourceTrigger=LostFocus}" Width="52"/>
                <DataGridTextColumn Header="Šifra prih." Binding="{Binding SifraPrih,         UpdateSourceTrigger=LostFocus}" Width="84"/>
                <DataGridTextColumn Header="Matični br." Binding="{Binding MaticniBr,         UpdateSourceTrigger=LostFocus}" Width="118"/>
                <DataGridTextColumn Header="Dana"        Binding="{Binding BrojDana,          UpdateSourceTrigger=LostFocus}" Width="52"/>
                <DataGridTextColumn Header="Sati"        Binding="{Binding BrojSati,          UpdateSourceTrigger=LostFocus}" Width="56"/>
                <DataGridTextColumn Header="Fond sati"   Binding="{Binding FondSati,          UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="Bruto"       Binding="{Binding Bruto,             UpdateSourceTrigger=LostFocus}" Width="118"/>
                <DataGridTextColumn Header="Osn. porez"  Binding="{Binding OsnovicaP,         UpdateSourceTrigger=LostFocus}" Width="100"/>
                <DataGridTextColumn Header="Porez"       Binding="{Binding Porez,             UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="Osn. dop."   Binding="{Binding OsnovicaDop,       UpdateSourceTrigger=LostFocus}" Width="100"/>
                <DataGridTextColumn Header="PIO"         Binding="{Binding Pio,               UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="ZDR"         Binding="{Binding Zdr,               UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="NEZ"         Binding="{Binding Nez,               UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="PIO ben."    Binding="{Binding PioBen,            UpdateSourceTrigger=LostFocus}" Width="88"/>
                <DataGridTextColumn Header="MFP1"        Binding="{Binding Mfp1,              UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="MFP2"        Binding="{Binding Mfp2,              UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="MFP3%"       Binding="{Binding Mfp3Proc,          UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="MFP4"        Binding="{Binding Mfp4,              UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="MFP5"        Binding="{Binding Mfp5,              UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="MFP6"        Binding="{Binding Mfp6,              UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="MFP7"        Binding="{Binding Mfp7,              UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="MFP8Nepun"   Binding="{Binding Mfp8Nepun,         UpdateSourceTrigger=LostFocus}" Width="78"/>
                <DataGridTextColumn Header="MFP9NajOsn"  Binding="{Binding Mfp9NajOsn,        UpdateSourceTrigger=LostFocus}" Width="88"/>
                <DataGridTextColumn Header="MFP10Dvez"   Binding="{Binding Mfp10Dvez,         UpdateSourceTrigger=LostFocus}" Width="84"/>
                <DataGridTextColumn Header="MFP11Neop"   Binding="{Binding Mfp11Neop,         UpdateSourceTrigger=LostFocus}" Width="84"/>
                <DataGridTextColumn Header="MFP12"       Binding="{Binding Mfp12,             UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="KamPor"      Binding="{Binding KamPor,            UpdateSourceTrigger=LostFocus}" Width="88"/>
                <DataGridTextColumn Header="KamPio"      Binding="{Binding KamPio,            UpdateSourceTrigger=LostFocus}" Width="88"/>
                <DataGridTextColumn Header="KamZdr"      Binding="{Binding KamZdr,            UpdateSourceTrigger=LostFocus}" Width="88"/>
                <DataGridTextColumn Header="KamNez"      Binding="{Binding KamNez,            UpdateSourceTrigger=LostFocus}" Width="88"/>
                <DataGridTextColumn Header="KamBen"      Binding="{Binding KamBen,            UpdateSourceTrigger=LostFocus}" Width="88"/>
                <DataGridTextColumn Header="VrstaPrij"   Binding="{Binding VrstaPrijave,      UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="Godina"      Binding="{Binding Godina,            UpdateSourceTrigger=LostFocus}" Width="60"/>
                <DataGridTextColumn Header="IspZaMes"    Binding="{Binding IsplataZaMesec,    UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="Konacna"     Binding="{Binding Konacna,           UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="DatumObav"   Binding="{Binding DatumObavezeC,     UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="DatumPlac"   Binding="{Binding DatumPlacanjaC,    UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="VrstaIzm"    Binding="{Binding VrstaIzmene,       UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="Identifik"   Binding="{Binding Identifikacija,    UpdateSourceTrigger=LostFocus}" Width="130"/>
                <DataGridTextColumn Header="BrojRes"     Binding="{Binding BrojResenja,       UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="Osnov"       Binding="{Binding Osnov,             UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="TipIsp"      Binding="{Binding TipIsplate,        UpdateSourceTrigger=LostFocus}" Width="60"/>
                <DataGridTextColumn Header="VrstaIdIsp"  Binding="{Binding VrstaIdIsplatioca, UpdateSourceTrigger=LostFocus}" Width="80"/>
                <DataGridTextColumn Header="Najniza"     Binding="{Binding Najniza,           UpdateSourceTrigger=LostFocus}" Width="80"/>
                <DataGridTextColumn Header="PIB"         Binding="{Binding Pib,               UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="Dana(par)"   Binding="{Binding Dana,              UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="BrZapos"     Binding="{Binding BrojZapos,         UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="JMBG Podn."  Binding="{Binding JmbgPodnosioca,    UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="Maticni"     Binding="{Binding Maticni,           UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="Naziv"       Binding="{Binding Naziv,             UpdateSourceTrigger=LostFocus}" Width="160"/>
                <DataGridTextColumn Header="Sediste"     Binding="{Binding Sediste,           UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="Telefon"     Binding="{Binding Telefon,           UpdateSourceTrigger=LostFocus}" Width="110"/>
                <DataGridTextColumn Header="Ulica i br." Binding="{Binding UlicaIBr,          UpdateSourceTrigger=LostFocus}" Width="160"/>
                <DataGridTextColumn Header="Email"       Binding="{Binding Email,             UpdateSourceTrigger=LostFocus}" Width="160"/>
                <DataGridTextColumn Header="Period"      Binding="{Binding Period,            UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="RedIspl"     Binding="{Binding RedniIsplate,      UpdateSourceTrigger=LostFocus}" Width="72"/>
                <DataGridTextColumn Header="N.Bruto"     Binding="{Binding NBruto,            UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="100"/>
                <DataGridTextColumn Header="N.OsnP"      Binding="{Binding NOsnovicaP,        UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="N.Porez"     Binding="{Binding NPorez,            UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="N.OsnDop"    Binding="{Binding NOsnovicaDop,      UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="N.PIO"       Binding="{Binding NPio,              UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="80"/>
                <DataGridTextColumn Header="N.ZDR"       Binding="{Binding NZdr,              UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="80"/>
                <DataGridTextColumn Header="N.NEZ"       Binding="{Binding NNez,              UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="80"/>
                <DataGridTextColumn Header="N.PIOben"    Binding="{Binding NPioben,           UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="80"/>
                <DataGridTextColumn Header="N.KamPor"    Binding="{Binding NKamPor,           UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="N.KamPio"    Binding="{Binding NKamPio,           UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="N.KamZdr"    Binding="{Binding NKamZdr,           UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="N.KamNez"    Binding="{Binding NKamNez,           UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="N.KamBen"    Binding="{Binding NKamBen,           UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="88"/>
                <DataGridTextColumn Header="PIO-R"       Binding="{Binding PioR,              UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="ZDR-R"       Binding="{Binding ZdrR,              UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="NEZ-R"       Binding="{Binding NezR,              UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="PIO-F"       Binding="{Binding PioF,              UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="ZDR-F"       Binding="{Binding ZdrF,              UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="NEZ-F"       Binding="{Binding NezF,              UpdateSourceTrigger=LostFocus}" Width="90"/>
                <DataGridTextColumn Header="Opstina"     Binding="{Binding Opstina,           UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="Radnik"      Binding="{Binding Radnik,            UpdateSourceTrigger=LostFocus}" Width="60"/>
                <DataGridTextColumn Header="Mesto"       Binding="{Binding Mesto,             UpdateSourceTrigger=LostFocus}" Width="130"/>
                <DataGridTextColumn Header="Adresa"      Binding="{Binding Adresa,            UpdateSourceTrigger=LostFocus}" Width="150"/>
                <DataGridTextColumn Header="Preneto"     Binding="{Binding Preneto,           UpdateSourceTrigger=LostFocus}" Width="68"/>
                <DataGridTextColumn Header="IdBr"        Binding="{Binding Idbr,              UpdateSourceTrigger=LostFocus, StringFormat={}{0:0.##}}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ KONTROLNI PANEL ═══ -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="268"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lijevo: Navigacija + Dodavanje + Brisanje -->
            <Border Grid.Column="0"
                    BorderBrush="#A8B4C8" BorderThickness="1"
                    Background="#F6F8FB" Padding="10,10,10,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionLabel}" Text="NAVIGACIJA"/>
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,8">
                        <Button Style="{StaticResource NavBtn}" Content="|◄" ToolTip="První zapis"   Command="{Binding PrviCommand}"/>
                        <Button Style="{StaticResource NavBtn}" Content="GORE" ToolTip="Prethodni red" Command="{Binding GoreCommand}"/>
                        <Button Style="{StaticResource NavBtn}" Content="DOLE" ToolTip="Sledeći red"   Command="{Binding DoleCommand}"/>
                        <Button Style="{StaticResource NavBtn}" Content="►|"  ToolTip="Zadnji zapis"  Command="{Binding ZadnjiCommand}" Margin="0,0,0,0"/>
                    </UniformGrid>

                    <Separator Background="#D0D8E4" Margin="0,0,0,8"/>

                    <TextBlock Style="{StaticResource SectionLabel}" Text="DODAVANJE REDA"/>
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,8">
                        <Button Style="{StaticResource BaseBtn}" Content="+ RADNIK"  ToolTip="Dodaj red — Radnik"  Command="{Binding DodajRCommand}"  FontSize="11" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource BaseBtn}" Content="+ FIRMA"   ToolTip="Dodaj red — Firma"   Command="{Binding DodajFCommand}"  FontSize="11" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource BaseBtn}" Content="+ VLASNIK" ToolTip="Dodaj red — Vlasnik" Command="{Binding DodajVCommand}"  FontSize="11" Margin="0,0,0,0"/>
                    </UniformGrid>
                    <Button Style="{StaticResource BaseBtn}" HorizontalAlignment="Stretch"
                            Content="DODAJ SVE (do 8 redova)" Command="{Binding DodajSveCommand}"
                            Margin="0,0,0,8"/>

                    <Separator Background="#D0D8E4" Margin="0,0,0,8"/>

                    <TextBlock Style="{StaticResource SectionLabel}" Text="BRISANJE"/>
                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,5">
                        <Button Style="{StaticResource DangerBtn}" Content="BRIŠI RED"  Command="{Binding ObrisiCommand}"    Margin="0,0,4,0"/>
                        <Button Style="{StaticResource DangerBtn}" Content="BRIŠI SVE"  Command="{Binding ObrisiSveCommand}" Margin="0,0,0,0"/>
                    </UniformGrid>
                    <Button Style="{StaticResource DangerBtn}" HorizontalAlignment="Stretch"
                            Content="BRISANJE MESECA" Command="{Binding BrisiMesecCommand}" Margin="0,0,0,5"/>

                    <Separator Background="#D0D8E4" Margin="0,0,0,8"/>

                    <Button Style="{StaticResource BaseBtn}" HorizontalAlignment="Stretch" FontSize="11"
                            Content="Uputstvo za PPP-PD" Command="{Binding UputstvoCommand}" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Desno: Akcijska dugmad -->
            <Border Grid.Column="2"
                    BorderBrush="#A8B4C8" BorderThickness="1"
                    Background="#F6F8FB" Padding="10,10,10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- POPUNI — full width, istaknuto zeleno -->
                    <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                            Style="{StaticResource GreenActionBtn}"
                            Height="46"
                            HorizontalContentAlignment="Center"
                            Content="▶   POPUNI LDPPP  —  čita iz arhive zarada ili aktivnog LD*.dbf"
                            Command="{Binding PopuniObrazacCommand}"/>

                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource ActionBtn}" Content="1.  PARAMETRI PRENOSA"  Command="{Binding ParametriPrenosaCommand}"/>
                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource ActionBtn}" Content="4.  PREGLED PRIJAVE"     Command="{Binding PregledPrijaveCommand}"/>

                    <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource ActionBtn}" Content="2.  PREUZMI ZARADE"      Command="{Binding PreuzmiZaradeCommand}"/>
                    <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource ActionBtn}" Content="5.  PORESKA UPRAVA"      Command="{Binding PoreskaUpravaCommand}"/>

                    <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource ActionBtn}" Content="3.  NAPRAVI XML"         Command="{Binding NapraviXmlCommand}"/>
                    <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource ActionBtn}" Content="6.  PRENOS U ARHIVU"     Command="{Binding PrenosUArhivuCommand}"/>

                    <Separator Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Background="#D0D8E4" Margin="0,4,0,6"/>

                    <Button Grid.Row="5" Grid.Column="0" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Korekcija doprinosa" Command="{Binding KorekcijaDoprinosaCommand}"/>
                    <Button Grid.Row="5" Grid.Column="2" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Popuni opšte podatke" Command="{Binding PopuniOpstePodatkeCommand}"/>

                    <Button Grid.Row="6" Grid.Column="0" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Preuzmi OPJ 1-8 i ODP" Command="{Binding PreuzmiOpjOdpCommand}"/>
                    <Button Grid.Row="6" Grid.Column="2" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Preračunaj od poreza" Command="{Binding PreracunajOdPorezaCommand}"/>

                    <Button Grid.Row="7" Grid.Column="0" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Jedan radnik skraćeni" Command="{Binding JedanRadnikSkraceniCommand}"/>
                    <Button Grid.Row="7" Grid.Column="2" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Saldo skraćeni" Command="{Binding SaldoSkraceniCommand}"/>

                    <Button Grid.Row="8" Grid.Column="0" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Saldo obrasci" Command="{Binding SaldoObrasciCommand}"/>
                    <Button Grid.Row="8" Grid.Column="2" Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                            Content="Obrazac po mesecima" Command="{Binding ObrazacPoMesecimaCommand}"/>

                    <UniformGrid Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3" Rows="1" Columns="3" Margin="0,4,0,0">
                        <Button Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                                Content="Izvoz deo 2 (PPP2)" Command="{Binding IzvozPpp2Command}"/>
                        <Button Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                                Content="Izvoz deo 3 (PPP3)" Command="{Binding IzvozPpp3Command}"/>
                        <Button Style="{StaticResource BaseBtn}" Height="32" FontSize="11"
                                Content="Izvoz deo 4 (PPP4)" Command="{Binding IzvozPpp4Command}"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUSNA TRAKA ═══ -->
        <Border Grid.Row="3"
                Background="#EEF2F8" BorderBrush="#A8B4C8" BorderThickness="1"
                Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource BaseBtn}" Width="165" FontSize="11" Content="Traži šifru prihoda"  Command="{Binding TraziSifruPrihodaCommand}"/>
                <Button Grid.Column="1" Style="{StaticResource BaseBtn}" Width="155" FontSize="11" Content="Traži matični broj"   Command="{Binding TraziMaticniBrojCommand}"/>
                <Button Grid.Column="2" Style="{StaticResource BaseBtn}" Width="128" FontSize="11" Content="Traži prezime"        Command="{Binding TraziPrezimeCommand}"/>
                <Button Grid.Column="3" Style="{StaticResource BaseBtn}" Width="120" FontSize="11" Content="Eksport XLS / CSV"    Command="{Binding EksportXlsCommand}"/>
                <Button Grid.Column="4" Style="{StaticResource BaseBtn}" Width="80"  FontSize="12" FontWeight="Bold"
                        Content="IZLAZ" Command="{Binding IzlazCommand}" Margin="0,0,14,0"/>

                <TextBlock Grid.Column="5"
                           Text="{Binding Poruka}"
                           FontFamily="Tahoma" FontSize="12"
                           Foreground="#284070"
                           FontStyle="Italic"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>
