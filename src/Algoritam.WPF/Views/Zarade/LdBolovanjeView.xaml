<Window x:Class="Algoritam.WPF.Views.Zarade.LdBolovanjeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="560"
        Height="360"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="50">
            <StackPanel VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="BOLOVANJE" FontFamily="Tahoma" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Obrasci bolovanja" FontFamily="Tahoma" FontSize="10" Foreground="#A5D6A7"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Height="50">
            <Button Content="IZLAZ"
                    Width="182" Height="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#455A64" Foreground="White"
                    BorderThickness="0" FontFamily="Tahoma" FontSize="11"
                    Cursor="Hand"
                    Click="IzlazClick"/>
        </Border>

        <!-- Content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <Button Content="BOLOVANJE OZ 7 NOVI"
                    ToolTip="izrada i stampanje obrasca NZ-1 za porodilje"
                    Width="494" Height="28" Margin="0,0,0,8"
                    Background="#1565C0" Foreground="White"
                    BorderThickness="0" FontFamily="Tahoma" FontSize="11"
                    Cursor="Hand" HorizontalAlignment="Center"
                    Command="{Binding BolovanjeOz7NoviCommand}"/>

            <Button Content="BOLOVANJE OZ 7"
                    ToolTip="izrada i stampanje obrasca NZ-1 za porodilje"
                    Width="494" Height="28" Margin="0,0,0,8"
                    Background="#1565C0" Foreground="White"
                    BorderThickness="0" FontFamily="Tahoma" FontSize="11"
                    Cursor="Hand" HorizontalAlignment="Center"
                    Command="{Binding BolovanjeOz7Command}"/>

            <Button Content="BOLOVANJE OZ 8"
                    ToolTip="izrada i stampanje obrasca NZ-1 za porodilje"
                    Width="494" Height="28" Margin="0,0,0,8"
                    Background="#1565C0" Foreground="White"
                    BorderThickness="0" FontFamily="Tahoma" FontSize="11"
                    Cursor="Hand" HorizontalAlignment="Center"
                    Command="{Binding BolovanjeOz8Command}"/>

            <Button Content="BOLOVANJE OZ 9"
                    ToolTip="izrada i stampanje obrasca NZ-1 za porodilje"
                    Width="494" Height="28" Margin="0,0,0,8"
                    Background="#1565C0" Foreground="White"
                    BorderThickness="0" FontFamily="Tahoma" FontSize="11"
                    Cursor="Hand" HorizontalAlignment="Center"
                    Command="{Binding BolovanjeOz9Command}"/>

            <Button Content="BOLOVANJE OZ 10"
                    ToolTip="izrada i stampanje obrasca NZ-1 za porodilje"
                    Width="494" Height="28"
                    Background="#1565C0" Foreground="White"
                    BorderThickness="0" FontFamily="Tahoma" FontSize="11"
                    Cursor="Hand" HorizontalAlignment="Center"
                    Command="{Binding BolovanjeOz10Command}"/>
        </StackPanel>

    </DockPanel>
</Window>
