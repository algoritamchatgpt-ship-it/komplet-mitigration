<Window x:Class="Algoritam.WPF.Views.Zarade.FoxPregledTabelaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1040" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#607D8B" Padding="12,8" CornerRadius="4">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}" Foreground="White" FontFamily="Tahoma" FontSize="15" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Podnaslov}" Foreground="#BBDEFB" FontFamily="Tahoma" FontSize="11"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="96"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="StampajClick"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma"
                            FontWeight="Bold"
                            Content="STAMPAJ"/>
                    <Button Width="90"
                            Height="28"
                            Click="ZatvoriClick"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma"
                            FontWeight="Bold"
                            Content="ZATVORI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="PrintRoot"
                Grid.Row="1"
                Margin="0,10,0,10"
                Background="White"
                BorderBrush="#C8E6C9"
                BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding BrojStavkiTekst}" FontFamily="Tahoma" FontSize="12" Foreground="#37474F"/>
                    <TextBlock Grid.Column="1" Text="{Binding Ukupno1Tekst}" FontFamily="Tahoma" FontSize="12" FontWeight="Bold" Foreground="#1565C0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Ukupno2Tekst}" FontFamily="Tahoma" FontSize="12" FontWeight="Bold" Foreground="#00695C"/>
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Stavke}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#E8F0FE"
                          FontFamily="Tahoma"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Sifra" Binding="{Binding Sifra}" Width="130"/>
                        <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                        <DataGridTextColumn x:Name="Iznos1Column" Header="Iznos 1" Binding="{Binding Iznos1, StringFormat=N2}" Width="150"/>
                        <DataGridTextColumn x:Name="Iznos2Column" Header="Iznos 2" Binding="{Binding Iznos2, StringFormat=N2}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="1" Padding="10,6">
            <TextBlock Text="ENTER: stampa   |   ESC: zatvori"
                       FontFamily="Tahoma"
                       FontSize="11"
                       Foreground="#37474F"/>
        </Border>
    </Grid>
</Window>
