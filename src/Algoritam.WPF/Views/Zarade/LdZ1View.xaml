<Window x:Class="Algoritam.WPF.Views.Zarade.LdZ1View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F0F0F0"
        FontFamily="Tahoma"
        FontSize="11">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="Z1Btn" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#607D8B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1B5E20" Padding="12,8">
            <TextBlock Text="{Binding Naslov}"
                       Foreground="White" FontFamily="Tahoma"
                       FontSize="13" FontWeight="Bold"/>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9"
                BorderThickness="1,1,1,0" Padding="8,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="PREUZIMANJE" Style="{StaticResource Z1Btn}"
                            Width="130" Command="{Binding PreuzimanjeCommand}"/>
                    <Button Content="DODAJ" Style="{StaticResource Z1Btn}"
                            Width="80" Command="{Binding DodajCommand}"/>
                    <Button Content="BRISANJE REDA" Style="{StaticResource Z1Btn}"
                            Width="130" Command="{Binding BrisanjeRedaCommand}"/>
                    <Button Content="BRIŠI SVE" Style="{StaticResource Z1Btn}"
                            Width="100" Command="{Binding BrisiCommand}"/>
                    <Button Content="SAČUVAJ" Style="{StaticResource Z1Btn}"
                            Width="90" Command="{Binding SacuvajCommand}"
                            Background="#2E7D32"/>
                    <Button Content="PREGLED" Style="{StaticResource Z1Btn}"
                            Width="90" Command="{Binding PregledCommand}"/>
                    <Button Content="F5 OSVEZI" Style="{StaticResource Z1Btn}"
                            Width="90" Background="#607D8B" Foreground="White"
                            BorderThickness="0" Command="{Binding OsveziCommand}"/>
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="IZLAZ" Width="80" Height="28"
                        FontFamily="Tahoma" FontSize="11"
                        Background="#455A64" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="IzlazClick"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#D7DBFF" BorderBrush="#A1A9E8"
                BorderThickness="1" Padding="8,4">
            <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11"/>
        </Border>

        <!-- Grid -->
        <DataGrid ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  RowHeight="22"
                  BorderThickness="0"
                  Background="#F5F5F5"
                  AlternatingRowBackground="#EDF1F9"
                  Margin="0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1B5E20"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#0D3F12"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="Padding" Value="4,4"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Br"
                                    Binding="{Binding Br, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="50"/>
                <DataGridTextColumn Header="Opis"
                                    Binding="{Binding Opis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
                <DataGridTextColumn Header="Iznos"
                                    Binding="{Binding Iznos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                    Width="160"/>
                <DataGridTextColumn Header="Podatak"
                                    Binding="{Binding Podatak, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="70"/>
                <DataGridTextColumn Header="Rlini"
                                    Binding="{Binding Rlini, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="60"/>
                <DataGridTextColumn Header="Preneto"
                                    Binding="{Binding Preneto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="70"/>
                <DataGridTextColumn Header="Idbr"
                                    Binding="{Binding Idbr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
