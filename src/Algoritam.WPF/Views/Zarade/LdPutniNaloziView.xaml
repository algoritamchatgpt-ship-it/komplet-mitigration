<Window x:Class="Algoritam.WPF.Views.Zarade.LdPutniNaloziView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Putni nalozi"
        Width="1500" Height="780"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1B5E20" Height="48">
            <TextBlock Text="{Binding Naslov}"
                       Margin="14,0"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontFamily="Tahoma"
                       FontSize="15"
                       FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="F5 OSVEZI"
                        Width="90" Height="28" Margin="0,0,4,0"
                        Background="#607D8B" Foreground="White" BorderThickness="0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Command="{Binding OsveziCommand}"/>
                <Button DockPanel.Dock="Right"
                        Content="IZLAZ"
                        Width="110"
                        Height="28"
                        Margin="8,0,0,0"
                        Background="#C62828"
                        Foreground="White"
                        BorderThickness="0"
                        FontFamily="Tahoma"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="ZatvoriClick"/>
                <TextBlock Text="{Binding Poruka}"
                           VerticalAlignment="Center"
                           FontFamily="Tahoma"
                           FontSize="11"/>
            </DockPanel>
        </Border>

        <StackPanel DockPanel.Dock="Top" Margin="10,8,10,0">
            <WrapPanel Margin="0,0,0,8">
                <Button Content="PRVI" Width="80" Height="28" Margin="0,0,4,0" Command="{Binding PrviCommand}"/>
                <Button Content="GORE" Width="80" Height="28" Margin="0,0,4,0" Command="{Binding PrethodniCommand}"/>
                <Button Content="DOLE" Width="80" Height="28" Margin="0,0,4,0" Command="{Binding SledeciCommand}"/>
                <Button Content="ZADNJI" Width="90" Height="28" Margin="0,0,10,0" Command="{Binding PoslednjiCommand}"/>
                <Button Content="DODAJ" Width="90" Height="28" Margin="0,0,4,0" Command="{Binding DodajCommand}"/>
                <Button Content="BRISANJE" Width="90" Height="28" Margin="0,0,4,0" Command="{Binding BrisanjeJednogCommand}"/>
                <Button Content="JEDAN NALOG" Width="110" Height="28" Margin="0,0,4,0" Command="{Binding JedanNalogCommand}"/>
                <Button Content="PREGLED ZA PERIOD" Width="140" Height="28" Margin="0,0,4,0" Command="{Binding PregledZaPeriodCommand}"/>
                <Button Content="SAČUVAJ" Width="90" Height="28" Command="{Binding SacuvajCommand}"/>
            </WrapPanel>
        </StackPanel>

        <StackPanel Margin="10,0,10,10">
            <Border Background="#FFB74D" BorderBrush="#F57C00" BorderThickness="1" Padding="8,4" Margin="0,0,0,6">
                <TextBlock Text="{Binding ImeRadnika}" FontFamily="Tahoma" FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <Border BorderBrush="#B0BEC5" BorderThickness="1" Background="White">
                <DataGrid ItemsSource="{Binding Stavke}"
                          SelectedItem="{Binding Selektovana, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          FontFamily="Tahoma"
                          FontSize="11">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Putnal" Binding="{Binding Putnal}" Width="70"/>
                        <DataGridTextColumn Header="Datdok" Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="95"/>
                        <DataGridTextColumn Header="Datvrac" Binding="{Binding Datvrac, StringFormat=dd.MM.yyyy}" Width="95"/>
                        <DataGridTextColumn Header="Cilj" Binding="{Binding Cilj}" Width="170"/>
                        <DataGridTextColumn Header="Svrha1" Binding="{Binding Svrha1}" Width="120"/>
                        <DataGridTextColumn Header="Svrha2" Binding="{Binding Svrha2}" Width="120"/>
                        <DataGridTextColumn Header="Izvest1" Binding="{Binding Izvest1}" Width="120"/>
                        <DataGridTextColumn Header="Izvest2" Binding="{Binding Izvest2}" Width="120"/>
                        <DataGridTextColumn Header="Izvest3" Binding="{Binding Izvest3}" Width="120"/>
                        <DataGridTextColumn Header="Akontac" Binding="{Binding Akontac, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Vozilo" Binding="{Binding Vozilo}" Width="120"/>
                        <DataGridTextColumn Header="Racun1" Binding="{Binding Racun1, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Brrac1" Binding="{Binding Brrac1}" Width="110"/>
                        <DataGridTextColumn Header="Racun2" Binding="{Binding Racun2, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Brrac2" Binding="{Binding Brrac2}" Width="110"/>
                        <DataGridTextColumn Header="Racun3" Binding="{Binding Racun3, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Brrac3" Binding="{Binding Brrac3}" Width="110"/>
                        <DataGridTextColumn Header="Racun4" Binding="{Binding Racun4, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Brrac4" Binding="{Binding Brrac4}" Width="110"/>
                        <DataGridTextColumn Header="Racun5" Binding="{Binding Racun5, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Brrac5" Binding="{Binding Brrac5}" Width="110"/>
                        <DataGridTextColumn Header="Svega" Binding="{Binding Svega, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Zaisplat" Binding="{Binding Zaisplat, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Napomena" Binding="{Binding Napomena}" Width="170"/>
                        <DataGridTextColumn Header="Broj" Binding="{Binding Broj}" Width="60"/>
                        <DataGridTextColumn Header="Caspol" Binding="{Binding Caspol}" Width="70"/>
                        <DataGridTextColumn Header="Casdol" Binding="{Binding Casdol}" Width="70"/>
                        <DataGridTextColumn Header="Brdnev" Binding="{Binding Brdnev, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Dnevnica" Binding="{Binding Dnevnica, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Iznosdn" Binding="{Binding Iznosdn, StringFormat=N2}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
