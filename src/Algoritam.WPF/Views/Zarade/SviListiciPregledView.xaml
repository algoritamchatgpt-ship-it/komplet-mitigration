<Window x:Class="Algoritam.WPF.Views.Zarade.SviListiciPregledView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Svi listići"
        Width="1120" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#607D8B" Padding="12,8" CornerRadius="4">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="SVI LISTICI (S+F4)"
                               Foreground="White"
                               FontFamily="Tahoma"
                               FontSize="15"
                               FontWeight="Bold"/>
                    <TextBlock Text="Dvaput kliknite radnika ili kliknite OTVORI LISTIC."
                               Foreground="#BBDEFB"
                               FontFamily="Tahoma"
                               FontSize="11"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Width="120"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="StampajListuClick"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma"
                            FontWeight="Bold"
                            Content="STAMPAJ LISTU"/>
                    <Button Width="120"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="OtvoriListicClick"
                            Background="#607D8B"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma"
                            FontWeight="Bold"
                            Content="OTVORI LISTIC"/>
                    <Button Width="90"
                            Height="28"
                            Click="ZatvoriClick"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Tahoma"
                            FontWeight="Bold"
                            Content="ZATVORI"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <DataGrid x:Name="GridStavke"
                  Grid.Row="1"
                  Margin="0,10,0,10"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovana}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#E8F0FE"
                  FontFamily="Tahoma"
                  FontSize="12"
                  MouseDoubleClick="GridStavkeMouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Br." Binding="{Binding Broj}" Width="70"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrez}" Width="220"/>
                <DataGridTextColumn Header="BRUTO" Binding="{Binding Bruto, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="NETO" Binding="{Binding Neto, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="ZA ISPLATU" Binding="{Binding Zaisplatu, StringFormat=N2}" Width="130"/>
                <DataGridTextColumn Header="Porez" Binding="{Binding Porez, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Dop. radnik" Binding="{Binding Dopsocr, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Dop. firma" Binding="{Binding Dopsocf, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Isplata" Binding="{Binding Isplata}" Width="80"/>
                <DataGridTextColumn Header="Mesec" Binding="{Binding Mesec}" Width="80"/>
                <DataGridTextColumn Header="Godina" Binding="{Binding Godina}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#C8E6C9" BorderThickness="1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SVI LISTIĆI"
                           FontFamily="Tahoma" FontSize="9" Foreground="#C8E6C9"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" FontFamily="Tahoma" FontSize="11"
                           Foreground="#37474F" VerticalAlignment="Center"
                           Text="ENTER: otvori listic  |  F9: stampaj listu  |  ESC: zatvori  |  Dvoklik na red: otvori listic"/>
            </Grid>
        </Border>
    </Grid>
</Window>
