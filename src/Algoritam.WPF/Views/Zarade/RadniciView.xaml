                            <!-- ── Tab 5: Oznake/Datumi ────────────────────── -->
                            <TabItem Header="Oznake/Datumi">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                                    <StackPanel Margin="14,12">

                                        <Border BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Margin="0,0,0,8" Padding="0,0,0,3">
                                            <TextBlock Text="OZNAKE" Style="{StaticResource SectionLabelStyle}"/>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Prevoz (*):" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Selektovani.Prevoz, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="1" ToolTip="* = plaća se prevoz"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Neaktivan (*):" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding Selektovani.Neaktivan, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="1" ToolTip="* = neaktivan (ne prikazuje se u listi zeleno)"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Nepuno r.v. (1):" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Selektovani.NepunoRadno, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="1" ToolTip="1 = nepuno radno vreme kod jednog poslodavca"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Por. olakšice:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding Selektovani.Porolaks, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="% Umanjenja:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Selektovani.ProcUmanjenja, StringFormat=N4, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" ToolTip="% umanjenja poreske osnovice — poreska olakšica"/>
                                            <TextBlock Grid.Row="4" Grid.Column="2" Text="Porez fond zarada:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="3" Text="{Binding Selektovani.PorezFondZar, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" ToolTip="Iznos poreza koji se usmerava u fond zarada"/>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource FieldHintStyle}"
                                                       Text="Prevoz: * = plaća se prevoz radniku  |  Neaktivan: * = radnik ne ulazi u platni spisak (prestao radni odnos)  |  Nepuno r.v.: 1 = nepuno radno vreme kod jednog poslodavca  |  Por. olakšice = šifra poreske olakšice (katalog PU)  |  % Umanjenja = % olakšice na poresku osnovicu"/>
                                        </Grid>

                                        <Border BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Margin="0,14,0,8" Padding="0,0,0,3">
                                            <TextBlock Text="DATUMI I RADNI STAZ" Style="{StaticResource SectionLabelStyle}"/>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Poc.dat. minulog rada:" Style="{StaticResource FormLabelStyle}"/>
                                            <DatePicker Grid.Row="0" Grid.Column="1"
                                                        SelectedDate="{Binding Selektovani.DatMinulogRada, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectedDateFormat="Short" FontFamily="Tahoma" FontSize="11" Height="26"
                                                        IsEnabled="{Binding JeURezimuIzmene}" BorderBrush="#C8E6C9"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Dat. nezaposlenosti:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding Selektovani.DatNezap, StringFormat=dd.MM.yyyy, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Preth. staz — dana:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Selektovani.BrojDana, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Meseci:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding Selektovani.BrojMeseci, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Godina:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Selektovani.BrojGodina, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Roditelj:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding Selektovani.Roditelj, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" ToolTip="Ime i prezime roditelja / staratelja"/>
                                            <TextBlock Grid.Row="6" Grid.Column="2" Text="Email adresa:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="6" Grid.Column="3" Text="{Binding Selektovani.Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" ToolTip="Email za slanje OZ-7 listića elektronski"/>
                                            <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource FieldHintStyle}"
                                                       Text="Poc.dat. minulog rada = datum od kog se računa staz kod ovog poslodavca  |  Dat. nezaposlenosti = datum prijave Zavodu za zapošljavanje  |  Preth. staz = radni staž pre dolaska (dana / meseci / godina odvojeno)  |  Email = za elektronsko slanje listića (OZ-7)"/>
                                        </Grid>
                                        <Rectangle Height="14"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ── Tab 6: Osiguranje ───────────────────────── -->
                            <TabItem Header="Osiguranje">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                                    <StackPanel Margin="14,12">

                                        <Border BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Margin="0,0,0,8" Padding="0,0,0,3">
                                            <TextBlock Text="ZDRAVSTVENO OSIGURANJE" Style="{StaticResource SectionLabelStyle}"/>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="LBO broj:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Selektovani.LboBroj, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="11" ToolTip="LBO broj osiguranika (C11)"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="ZK broj:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding Selektovani.ZkBroj, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="11" ToolTip="Broj zdravstvene knjizice (C11)"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Osig. od:" Style="{StaticResource FormLabelStyle}"/>
                                            <DatePicker Grid.Row="2" Grid.Column="1"
                                                        SelectedDate="{Binding Selektovani.DatumOsigOd, UpdateSourceTrigger=PropertyChanged}"
                                                        FontFamily="Tahoma" FontSize="11" Height="26"
                                                        IsEnabled="{Binding JeURezimuIzmene}" ToolTip="Datum osiguranja od"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Osig. do:" Style="{StaticResource FormLabelStyle}"/>
                                            <DatePicker Grid.Row="2" Grid.Column="3"
                                                        SelectedDate="{Binding Selektovani.DatumOsigDo, UpdateSourceTrigger=PropertyChanged}"
                                                        FontFamily="Tahoma" FontSize="11" Height="26"
                                                        IsEnabled="{Binding JeURezimuIzmene}" ToolTip="Datum osiguranja do"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Osnov osiguranja:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Selektovani.OsnovOsiguranja, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="10" ToolTip="Osnov zdravstvenog osiguranja (npr. 01=zaposleni)"/>
                                            <TextBlock Grid.Row="4" Grid.Column="2" Text="Reg. br. social.:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="3" Text="{Binding Selektovani.RegBrojSocijalno, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="10" ToolTip="Registracioni broj socijalnog osiguranja"/>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource FieldHintStyle}"
                                                       Text="LBO = lični broj osiguranika (max 11 znakova)  |  ZK = broj zdravstvene knjižice  |  Osig. od/do = period važenja zdravstvenog osiguranja  |  Osnov osiguranja = šifra osnova (npr. 01=zaposleni, za M-A obrazac)  |  Reg.br.soc. = registracioni broj socijalnog osiguranja"/>
                                        </Grid>
                                        <Rectangle Height="14"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ── Tab 7: Napomene ─────────────────────────── -->
                            <TabItem Header="Napomene">
                                <Grid Margin="14,12" Background="White">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Margin="0,0,0,8" Padding="0,0,0,3">
                                        <TextBlock Text="NAPOMENA 2" Style="{StaticResource SectionLabelStyle}"/>
                                    </Border>
                                    <TextBox Grid.Row="1"
                                             Text="{Binding Selektovani.Napomena2, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormInputStyle}"
                                             IsReadOnly="{Binding NijeURezimuIzmene}"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             VerticalContentAlignment="Top"
                                             Padding="8"/>
                                </Grid>
                            </TabItem>

                        </TabControl>
                    </Grid>
                </Grid>
            </Grid>

        </Grid>

    </DockPanel>
</Window>
