<Window x:Class="Algoritam.WPF.Views.Zarade.RadniciView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding NaslovProzora}"
        Width="1280" Height="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}">

    <Window.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style x:Key="ToolbarSepStyle" TargetType="Rectangle">
            <Setter Property="Width"  Value="1"/>
            <Setter Property="Fill"   Value="#B0BEC5"/>
            <Setter Property="Margin" Value="8,3,8,3"/>
        </Style>
        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F7" Command="{Binding TraziImeCommand}"/>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#1B5E20">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="RADNICI — Šifarnik zaposlenih"
                               FontFamily="Tahoma" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ldrad.dbf" FontFamily="Tahoma" FontSize="10" Foreground="#A5D6A7"/>
                </StackPanel>

                <!-- Selected worker info badge -->
                <Border Grid.Column="2" Background="#2E7D32" CornerRadius="4"
                        Padding="14,7" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Selektovani}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock FontFamily="Tahoma" FontSize="13" FontWeight="SemiBold" Foreground="White">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="Selektovani.Prezime" FallbackValue=""/>
                                    <Binding Path="Selektovani.Ime"     FallbackValue=""/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontFamily="Tahoma" FontSize="10" Foreground="#A5D6A7">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}Evid.br. {0}   |   {1}">
                                    <Binding Path="Selektovani.EvidBroj"    FallbackValue=""/>
                                    <Binding Path="Selektovani.RadnoMesto"  FallbackValue=""/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Status bar ──────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Background="#2E7D32" Height="28">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Edit mode pill -->
                <Border Grid.Column="0" Background="#E65100" CornerRadius="2"
                        Padding="6,2" Margin="0,5,10,5" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding JeURezimuIzmene}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="IZMENA" FontFamily="Tahoma" FontSize="10" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="RADNICI" FontFamily="Tahoma" FontSize="9"
                           Foreground="#A5D6A7" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusInfo}"
                           FontFamily="Tahoma" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" FontFamily="Tahoma" FontSize="11"
                           Foreground="White" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} / {1}">
                            <Binding Path="TrenutnaIndeks"/>
                            <Binding Path="UkupnoRadnika"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Background="#E8F5E9"
                BorderThickness="0,1,0,0" BorderBrush="#C8E6C9"
                Padding="10,8">
            <Border.Resources>
                <Style x:Key="GbStyle" TargetType="GroupBox">
                    <Setter Property="BorderBrush" Value="#B0BEC5"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="Margin" Value="0,0,8,0"/>
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="Foreground" Value="#37474F"/>
                </Style>
                <Style x:Key="TbBtn" TargetType="Button">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Height" Value="28"/>
                    <Setter Property="Padding" Value="8,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Margin" Value="0,0,4,0"/>
                    <Setter Property="Background" Value="#1565C0"/>
                </Style>
            </Border.Resources>
            <WrapPanel>

                <!-- NAVIGACIJA -->
                <GroupBox Header=" NAVIGACIJA " Style="{StaticResource GbStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="|◀ PRVI"    Command="{Binding PrviCommand}"      Style="{StaticResource TbBtn}" MinWidth="70"/>
                        <Button Content="◀ PRETH."   Command="{Binding PrethodniCommand}" Style="{StaticResource TbBtn}" MinWidth="75"/>
                        <Button Content="SLED. ▶"    Command="{Binding SledeciCommand}"   Style="{StaticResource TbBtn}" MinWidth="70"/>
                        <Button Content="ZADNJI ▶|"  Command="{Binding PoslednjiCommand}" Style="{StaticResource TbBtn}" MinWidth="80" Margin="0"/>
                    </StackPanel>
                </GroupBox>

                <!-- IZMENE -->
                <GroupBox Header=" IZMENE " Style="{StaticResource GbStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="DODAJ +"  Command="{Binding DodajCommand}"        Style="{StaticResource TbBtn}" MinWidth="74" Background="#1565C0"/>
                        <Button Content="IZMENI"   Command="{Binding IzmeniCommand}"       Style="{StaticResource TbBtn}" MinWidth="70" Background="#1565C0"/>
                        <Button Content="KOPIRAJ"  Command="{Binding KopirajRedCommand}"   Style="{StaticResource TbBtn}" MinWidth="74" Background="#1565C0"
                                ToolTip="Kopiraj izabranog radnika kao polaznu tačku za novog"/>
                        <Button Content="SAČUVAJ"  Command="{Binding SacuvajCommand}"      Style="{StaticResource TbBtn}" MinWidth="76" Background="#2E7D32"/>
                        <Button Content="OTKAZI"   Command="{Binding OtkaziIzmenuCommand}" Style="{StaticResource TbBtn}" MinWidth="70" Background="#546E7A"/>
                        <Button Content="BRIŠI"    Command="{Binding BrisiCommand}"        Style="{StaticResource TbBtn}" MinWidth="66" Background="#C62828" Margin="0"/>
                    </StackPanel>
                </GroupBox>

                <!-- PRETRAGA -->
                <GroupBox Header=" PRETRAGA " Style="{StaticResource GbStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding TekstIme, UpdateSourceTrigger=PropertyChanged}"
                                 Width="130" Height="26" Margin="0,0,4,0"
                                 VerticalContentAlignment="Center" Padding="4,0"
                                 FontFamily="Tahoma" FontSize="11"
                                 ToolTip="Pretraga po prezimenu ili imenu (F7)"/>
                        <Button Content="F7 TRAŽI IME"   Command="{Binding TraziImeCommand}"      Style="{StaticResource TbBtn}" MinWidth="110"/>
                        <TextBox Text="{Binding TekstEvidbroj, UpdateSourceTrigger=PropertyChanged}"
                                 Width="90" Height="26" Margin="0,0,4,0"
                                 VerticalContentAlignment="Center" Padding="4,0"
                                 FontFamily="Tahoma" FontSize="11"
                                 ToolTip="Pretraga po evidencionom broju"/>
                        <Button Content="TRAŽI EVID.BR." Command="{Binding TraziEvidbrojCommand}" Style="{StaticResource TbBtn}" MinWidth="120"/>
                        <Button Content="OČISTI"         Command="{Binding OcistiPretraguCommand}" Style="{StaticResource TbBtn}" MinWidth="66" Background="#546E7A"/>
                        <Button Content="OSVEZI F5"      Command="{Binding OsveziCommand}"         Style="{StaticResource TbBtn}" MinWidth="82" Background="#607D8B" Margin="0"/>
                    </StackPanel>
                </GroupBox>

                <!-- AKCIJE -->
                <GroupBox Header=" AKCIJE " Style="{StaticResource GbStyle}" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="RADNI STAŽ"    Command="{Binding SrediRadniStazCommand}" Style="{StaticResource TbBtn}" MinWidth="106" Background="#E65100"
                                ToolTip="Automatski izračunaj i snimi broj godina staža"/>
                        <Button Content="EXPORT U EXCEL" Command="{Binding ExportUExcelCommand}"  Style="{StaticResource TbBtn}" MinWidth="126" Background="#00695C" Margin="0"
                                ToolTip="Exportuj listu radnika u CSV"/>
                    </StackPanel>
                </GroupBox>

            </WrapPanel>
        </Border>

        <!-- ── Main content ────────────────────────────────────────────── -->
        <Grid>

            <!-- Loading overlay -->
            <Grid Panel.ZIndex="10" Background="#80000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="White" CornerRadius="6" Padding="32,24"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                                     Foreground="#43A047" Background="#E8F5E9" BorderThickness="0"/>
                        <TextBlock Text="Učitavanje podataka..."
                                   FontFamily="Tahoma" FontSize="12" Foreground="#37474F"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: DataGrid -->
                <Border Grid.Column="0" BorderThickness="1" BorderBrush="#C8E6C9" Margin="0,0,6,0">
                    <Grid>
                    <DataGrid ItemsSource="{Binding FiltovaniRadnici}"
                              SelectedItem="{Binding Selektovani}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEEEEE"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FBF9"
                              FontFamily="Tahoma" FontSize="11"
                              ColumnHeaderStyle="{StaticResource AppDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource AppDataGridRowStyle}">

                        <DataGrid.Columns>
                            <!-- Status indicator -->
                            <DataGridTemplateColumn Header="" Width="18" CanUserResize="False" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#43A047"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Neaktivan}" Value="*">
                                                            <Setter Property="Fill" Value="#B0BEC5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Br." Binding="{Binding Broj}" Width="38">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Evid." Binding="{Binding EvidBroj}" Width="46">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding"     Value="4,4"/>
                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Background="White"
                            Visibility="{Binding IsListaPrazan, Converter={StaticResource BoolToVisibilityConverter}}"
                            Panel.ZIndex="1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="Nema radnika koji odgovaraju kriterijumu pretrage"
                                       FontFamily="Tahoma" FontSize="12" Foreground="#9E9E9E"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"
                                       MaxWidth="200" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    </Grid>
                </Border>

                <!-- RIGHT: Detail panel -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Edit mode banner -->
                    <Border Grid.Row="0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EditModeBannerStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding JeURezimuIzmene}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="  REZIM IZMENE — izmenite podatke, zatim kliknite Sačuvaj ili Otkazi"
                                   FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold" Foreground="#E65100"/>
                    </Border>

                    <Grid Grid.Row="1">

                        <!-- No-selection placeholder -->
                        <Border Background="White" BorderThickness="1" BorderBrush="#E8F5E9">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Selektovani}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Izaberite radnika iz liste levo"
                                       FontFamily="Tahoma" FontSize="14" Foreground="#C8E6C9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- TabControl -->
                        <TabControl FontFamily="Tahoma" FontSize="11" BorderBrush="#C8E6C9">
                            <TabControl.Style>
                                <Style TargetType="TabControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Selektovani}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TabControl.Style>

                            <!-- ── Tab 1: Lični podaci ─────────────────────── -->
                            <TabItem Header="Lični podaci">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                                    <StackPanel Margin="14,12">

                                        <!-- IDENTIFIKACIJA -->
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Margin="0,0,0,8" Padding="0,0,0,3">
                                            <TextBlock Text="IDENTIFIKACIJA" Style="{StaticResource SectionLabelStyle}"/>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Evid. broj:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Selektovani.EvidBroj, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="True"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Broj:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding Selektovani.Broj, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="True"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Prezime:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Selektovani.Prezime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Ime:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding Selektovani.Ime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Matični br.:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Selektovani.MaticniBr, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>
                                            <TextBlock Grid.Row="4" Grid.Column="2" Text="ID broj:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="3" Text="{Binding Selektovani.IdBroj, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Pol:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding Selektovani.Pol, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" MaxLength="1" ToolTip="M = Muški   Ž = Ženski"/>
                                            <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource FieldHintStyle}"
                                                       Text="Pol: M = Muški   Ž = Ženski  |  Evid. broj: interni evidencioni broj radnika (jedinstveni, unosi se ručno)  |  Matični br. = JMBG (13 cifara)  |  ID broj = broj lične karte"/>
                                        </Grid>

                                        <!-- ADRESA I KONTAKT -->
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Margin="0,14,0,8" Padding="0,0,0,3">
                                            <TextBlock Text="ADRESA I KONTAKT" Style="{StaticResource SectionLabelStyle}"/>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Adresa:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Selektovani.Adresa, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Poštanski br.:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Selektovani.Posta, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Mesto:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding Selektovani.Mesto, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Telefon:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Selektovani.Telefon, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Roditelj:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Selektovani.Roditelj, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>
                                        </Grid>

                                        <!-- OSTALO -->
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#C8E6C9" Margin="0,14,0,8" Padding="0,0,0,3">
                                            <TextBlock Text="OSTALO" Style="{StaticResource SectionLabelStyle}"/>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Napomena:" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Top" Margin="0,4,6,0"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Selektovani.Napomena, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Mesto poreza:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Selektovani.MestoPoreza, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Posl. jed.:" Style="{StaticResource FormLabelStyle}"/>
                                            <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding Selektovani.PoslJedinica, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Vrsta primanja:" Style="{StaticResource FormLabelStyle}"/>
                                            <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal">
                                                <TextBox Text="{Binding Selektovani.VrstaPrimanja, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormInputStyle}" IsReadOnly="{Binding NijeURezimuIzmene}" Width="50" MaxLength="2"/>
