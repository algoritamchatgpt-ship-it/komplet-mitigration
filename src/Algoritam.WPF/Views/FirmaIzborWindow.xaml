<Window x:Class="Algoritam.WPF.Views.FirmaIzborWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IZBOR FIRME"
        Width="820" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F0">

    <Window.Resources>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="DetailValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1B5E20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Sadrzaj -->
            <RowDefinition Height="56"/>   <!-- Footer dugmad -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#2E7D32">
            <Grid Margin="16,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="IZBOR FIRME"
                               FontFamily="Tahoma" FontSize="16" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding KorisnikInfo}"
                               FontFamily="Tahoma" FontSize="11"
                               Foreground="#A5D6A7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SADRZAJ: levo grid, desno detalji ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>   <!-- Grid firmi -->
                <ColumnDefinition Width="1"/>     <!-- Separator -->
                <ColumnDefinition Width="*"/>     <!-- Detalji -->
            </Grid.ColumnDefinitions>

            <!-- ── LEVO: Grid sa firmama ── -->
            <Border Grid.Column="0" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Zaglavlje grida -->
                    <Border Grid.Row="0" Background="#388E3C">
                        <Grid Margin="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Firme"
                                       FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="+ Dodaj"
                                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                                        Padding="10,3"
                                        Margin="0,4,4,4"
                                        Background="#66BB6A"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding DodajFirmuCommand}"/>
                                <Button Content="⬡ Arhiviraj"
                                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                                        Padding="10,3"
                                        Margin="0,4,4,4"
                                        Background="#1565C0"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding ArhivirajFirmuCommand}"/>
                                <Button Content="✕ Briši"
                                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                                        Padding="10,3"
                                        Margin="0,4,0,4"
                                        Background="#E53935"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding ObrisiFirmuCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              x:Name="GridFirmi"
                              ItemsSource="{Binding Firme}"
                              SelectedItem="{Binding SelektovanaFirma}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E0E0E0"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FBF9"
                              FontFamily="Tahoma" FontSize="12">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Setter Property="Foreground" Value="#2E7D32"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#C8E6C9"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#C8E6C9"/>
                                        <Setter Property="Foreground" Value="#1B5E20"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Aktivna}" Value="False">
                                        <Setter Property="Foreground" Value="#9E9E9E"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Naziv firme"
                                               Binding="{Binding Naziv}"
                                               Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Grad"
                                               Binding="{Binding Mesto}"
                                               Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,6"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>

                        <!-- Dvostruki klik = potvrdi -->
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding PotvrdiCommand}"/>
                        </DataGrid.InputBindings>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Separator -->
            <Rectangle Grid.Column="1" Fill="#BDBDBD"/>

            <!-- ── DESNO: Detalji selektovane firme ── -->
            <Border Grid.Column="2" Background="#FAFAFA" Padding="24,20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Podaci o firmi"
                                   FontFamily="Tahoma"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   Margin="0,0,0,10"/>

                        <!-- Placeholder kad nema selekcije -->
                        <TextBlock Text="Izaberite firmu iz liste"
                                   FontFamily="Tahoma" FontSize="14"
                                   Foreground="#BDBDBD" FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   Margin="0,60,0,0"
                                   Visibility="{Binding SelektovanaFirma,
                                       Converter={StaticResource NullToVisibilityConverter}}"/>

                        <!-- Detalji firme -->
                        <StackPanel Visibility="{Binding SelektovanaFirma,
                                        Converter={StaticResource NotNullToVisibilityConverter}}">

                            <!-- Naziv -->
                            <TextBlock Style="{StaticResource DetailLabelStyle}" Text="Naziv firme"/>
                            <TextBlock Style="{StaticResource DetailValueStyle}"
                                       FontSize="15"
                                       Text="{Binding SelektovanaFirma.Naziv}"/>

                            <TextBlock Style="{StaticResource DetailLabelStyle}" Text="Puni naziv"/>
                            <TextBlock Style="{StaticResource DetailValueStyle}"
                                       Text="{Binding SelektovanaFirma.Naziv2}"/>

                            <TextBlock Style="{StaticResource DetailLabelStyle}" Text="FOX folder (izvor podataka)"/>
                            <TextBlock Style="{StaticResource DetailValueStyle}"
                                       FontSize="11"
                                       Foreground="#37474F"
                                       Text="{Binding SelektovanaFirma.FolderPath}"/>

                            <!-- Adresa -->
                            <Separator Margin="0,4,0,12" Background="#E0E0E0"/>
                            <TextBlock Style="{StaticResource DetailLabelStyle}" Text="Adresa"/>
                            <TextBlock Style="{StaticResource DetailValueStyle}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1}, {2} {3}">
                                        <Binding Path="SelektovanaFirma.Ulica"/>
                                        <Binding Path="SelektovanaFirma.BrojUlice"/>
                                        <Binding Path="SelektovanaFirma.PostanskiBroj"/>
                                        <Binding Path="SelektovanaFirma.Mesto"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- PIB / Matični -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="PIB"/>
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               Text="{Binding SelektovanaFirma.Pib}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource DetailLabelStyle}" Text="Matični broj"/>
                                    <TextBlock Style="{StaticResource DetailValueStyle}"
                                               Text="{Binding SelektovanaFirma.Maticni}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Žiro račun -->
                            <TextBlock Style="{StaticResource DetailLabelStyle}" Text="Žiro račun"/>
                            <TextBlock Style="{StaticResource DetailValueStyle}"
                                       Text="{Binding SelektovanaFirma.ZiroRacun}"/>

                            <!-- Status -->
                            <Separator Margin="0,4,0,12" Background="#E0E0E0"/>
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="10" Padding="10,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelektovanaFirma.Aktivna}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelektovanaFirma.Aktivna}" Value="False">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontFamily="Tahoma" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelektovanaFirma.Aktivna}" Value="True">
                                                        <Setter Property="Text" Value="✓ Aktivna firma"/>
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelektovanaFirma.Aktivna}" Value="False">
                                                        <Setter Property="Text" Value="✗ Neaktivna firma"/>
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ LOADING OVERLAY ═══ -->
        <Grid Grid.RowSpan="3"
              Panel.ZIndex="10"
              Background="#CC1A1A1A"
              Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#1E2A1E"
                    CornerRadius="8"
                    Padding="40,30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="340">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="280" Height="5"
                                 Foreground="#66BB6A"
                                 Background="#37474F"
                                 BorderThickness="0"
                                 Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding MigrationStatus}"
                               FontFamily="Tahoma" FontSize="13"
                               Foreground="#A5D6A7"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="280"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ FOOTER: Dugmad ═══ -->
        <Border Grid.Row="2" Background="#E8F5E9" BorderThickness="0,1,0,0" BorderBrush="#C8E6C9">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Dvaput kliknite na firmu ili izaberite i pritisnite ULAZ"
                               FontFamily="Tahoma" FontSize="11" Foreground="#757575"/>
                    <TextBlock Text="{Binding MigrationStatus}"
                               FontFamily="Tahoma" FontSize="11" Foreground="#1565C0"
                               Visibility="{Binding MigrationStatus, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="  ULAZ  "
                        Width="120"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#43A047" Foreground="White"
                        Command="{Binding PotvrdiCommand}"
                        IsDefault="True"/>

                <Button Grid.Column="3"
                        Content="  IZLAZ  "
                        Width="100"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#757575" Foreground="White"
                        Command="{Binding OtkaciCommand}"
                        IsCancel="True"/>
            </Grid>
        </Border>

    </Grid>
</Window>
