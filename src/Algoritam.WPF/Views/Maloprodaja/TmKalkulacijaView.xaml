<Window x:Class="Algoritam.WPF.Views.Maloprodaja.TmKalkulacijaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1250" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#E65100" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#FFCCBC" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#FFF3E0" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#FFE0B2">
            <WrapPanel>
                <TextBlock Text="Pretraga:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                         Width="300" Height="26" Padding="6,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#E65100" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#FFE0B2" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Stavke}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#FFF3E0"
                      RowBackground="White"
                      BorderThickness="0"
                      FontFamily="Tahoma" FontSize="12"
                      SelectionMode="Single"
                      EnableRowVirtualization="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FFF3E0"/>
                        <Setter Property="Foreground" Value="#E65100"/>
                        <Setter Property="FontFamily" Value="Tahoma"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#FFE0B2"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Šifra"  Binding="{Binding [SIFRA]}"  Width="90"/>
                    <DataGridTextColumn Header="Naziv"  Binding="{Binding [NAZIV]}"  Width="*"/>
                    <DataGridTextColumn Header="JM"     Binding="{Binding [JM]}"     Width="45"/>
                    <DataGridTextColumn Header="Nab. cena" Binding="{Binding [CENAV], StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Prod. cena" Binding="{Binding [CENAP], StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Razlika u ceni" Binding="{Binding [RAZLIKA], StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#E65100"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kalo" Binding="{Binding [KALO], StringFormat=N2}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PDV%" Binding="{Binding [PDV_S], StringFormat=N0}" Width="55">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Konto"  Binding="{Binding [KONTO]}"  Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#FFF3E0" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#FFE0B2" Margin="0,4,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Artika:" FontFamily="Tahoma" FontSize="11"
                               Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Stavke.Count}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="Uk. razlika u ceni:" FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding UkupnoRazlika, StringFormat=N2}"
                               FontFamily="Tahoma" FontSize="12" FontWeight="Bold"
                               Foreground="#E65100" VerticalAlignment="Center" MinWidth="130" TextAlignment="Right"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Osveži" Width="80" Height="28" Margin="0,0,6,0"
                            Command="{Binding OsveziCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Zatvori" Width="80" Height="28"
                            Command="{Binding ZatvoriCommand}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
