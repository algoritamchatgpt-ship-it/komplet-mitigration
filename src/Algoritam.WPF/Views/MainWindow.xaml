<Window x:Class="Algoritam.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Algoritam.WPF.ViewModels"
        xmlns:zarade="clr-namespace:Algoritam.WPF.Views.Zarade"
        xmlns:gk="clr-namespace:Algoritam.WPF.Views.GlavnaKnjiga"
        xmlns:an="clr-namespace:Algoritam.WPF.Views.Analitika"
        xmlns:bl="clr-namespace:Algoritam.WPF.Views.Blagajna"
        xmlns:tv="clr-namespace:Algoritam.WPF.Views.Veleprodaja"
        xmlns:tm="clr-namespace:Algoritam.WPF.Views.Maloprodaja"
        xmlns:os="clr-namespace:Algoritam.WPF.Views.OsnovnaSredstva"
        xmlns:us="clr-namespace:Algoritam.WPF.Views.Komunal"
        xmlns:si="clr-namespace:Algoritam.WPF.Views.Sifarnici"
        xmlns:del="clr-namespace:Algoritam.WPF.Views.Delovodnik"
        xmlns:teh="clr-namespace:Algoritam.WPF.Views.Teh"
        xmlns:pro="clr-namespace:Algoritam.WPF.Views.Proizvodnja"
        xmlns:trn="clr-namespace:Algoritam.WPF.Views.Transport"
        xmlns:mlk="clr-namespace:Algoritam.WPF.Views.Mlekara"
        Title="ALGORITAM FIN — Finansijski informacioni sistem"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F5">

    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding OtvoriPodatkeOFirmiCommand}"/>
        <KeyBinding Key="G" Modifiers="Control" Command="{Binding OtvoriGradoveCommand}"/>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding OtvoriPartnereCommand}"/>
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding OtvoriFormiranjeLozinkiCommand}"/>
        <KeyBinding Key="Q" Modifiers="Control" Command="{Binding OdjaviCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ZatvoriModulCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- ── Stil za dugmice modula u izborniku ── -->
        <Style x:Key="ModulButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="5">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontFamily="Tahoma"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.35"/>
                                <Setter TargetName="Border" Property="Background" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
        </Style>

        <Style x:Key="StatusSeparatorStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#A5D6A7"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Text" Value="|"/>
        </Style>

        <!-- ── DataTemplates za module ── -->
        <DataTemplate DataType="{x:Type vm:ZaradeMenuViewModel}">
            <zarade:ZaradeMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:GlavnaKnjigaMenuViewModel}">
            <gk:GlavnaKnjigaMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AnalitikaMenuViewModel}">
            <an:AnalitikaMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:BlagajnaMenuViewModel}">
            <bl:BlagajnaMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:VeleprodajaMenuViewModel}">
            <tv:VeleprodajaMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MaloprodajaMenuViewModel}">
            <tm:MaloprodajaMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:OsnovnaSredstvaMenuViewModel}">
            <os:OsnovnaSredstvaMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:KomunalMenuViewModel}">
            <us:KomunalMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SifarniciMenuViewModel}">
            <si:SifarniciMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DelMenuViewModel}">
            <del:DelMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TehMenuViewModel}">
            <teh:TehMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProMenuViewModel}">
            <pro:ProMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TransportMenuViewModel}">
            <trn:TransportMenuView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MlekaraMenuViewModel}">
            <mlk:MlekaraMenuView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>

        <!-- ── GORNJI HEADER ── -->
        <Border DockPanel.Dock="Top" Background="#0D2137" Padding="16,10,16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                    <TextBlock Text="ALGORITAM FIN"
                               FontFamily="Tahoma" FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Finansijski informacioni sistem"
                               FontFamily="Tahoma" FontSize="11"
                               Foreground="#7FAACC" Margin="0,1,0,0"/>
                    <TextBlock Text="{Binding PozdravnaPortuka}"
                               FontFamily="Tahoma" FontSize="10"
                               Foreground="#90CAF9" Margin="0,4,0,0"/>
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16,0,0,0">
                    <Button Content="Podaci o firmi"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Background="#1565C0"
                            ToolTip="Ctrl+F — Podaci o firmi"
                            Command="{Binding OtvoriPodatkeOFirmiCommand}"/>
                    <Button Content="Mesta"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Background="#1976D2"
                            ToolTip="Ctrl+G — Mesta i gradovi"
                            Command="{Binding OtvoriGradoveCommand}"/>
                    <Button Content="Partneri"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Background="#1E88E5"
                            ToolTip="Ctrl+P — Partneri"
                            Command="{Binding OtvoriPartnereCommand}"/>
                    <Button Content="Formiranje lozinki"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Background="#00897B"
                            ToolTip="Ctrl+L — Formiranje lozinki"
                            Command="{Binding OtvoriFormiranjeLozinkiCommand}"/>
                    <Button Content="Promeni firmu"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Background="#F57F17"
                            ToolTip="Povratak na izbor firme"
                            Command="{Binding PromeniFirmuCommand}"/>
                    <Button Content="Odjava"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Background="#C62828"
                            ToolTip="Ctrl+Q — Odjava"
                            Margin="0,0,0,6"
                            Command="{Binding OdjaviCommand}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ── STATUSNA TRAKA ── -->
        <Border DockPanel.Dock="Bottom" Background="#0D2137" Height="30">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource StatusLabelStyle}" Text="{Binding KorisnikInfo}"/>
                    <TextBlock Style="{StaticResource StatusSeparatorStyle}"/>
                    <TextBlock Style="{StaticResource StatusLabelStyle}" Text="{Binding FirmaInfo}"/>
                    <TextBlock Style="{StaticResource StatusSeparatorStyle}"/>
                    <TextBlock Style="{StaticResource StatusLabelStyle}" Text="{Binding GodinaInfo}"/>
                    <TextBlock Style="{StaticResource StatusSeparatorStyle}"/>
                    <TextBlock Style="{StaticResource StatusLabelStyle}" Text="{Binding DatumInfo}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AktivniModulNaziv}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                               Foreground="#90CAF9" VerticalAlignment="Center"
                               Visibility="{Binding ImaOtvorenogModula,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="Izaberite modul"
                               FontFamily="Tahoma" FontSize="11"
                               Foreground="#4A7FA8" VerticalAlignment="Center"
                               Visibility="{Binding NemaOtvorenogModula,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── GLAVNI SADRŽAJ ── -->
        <Border Background="#ECEFF1" Padding="12">
            <Border Background="White" BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="5">

                <!-- Prikaz izbornika modula kada nema otvorenog modula -->
                <Grid>
                    <!-- Izbornik modula -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding NemaOtvorenogModula,
                                      Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,30">

                            <TextBlock Text="{Binding FirmaInfo}"
                                       FontFamily="Tahoma" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#1B3A5C" HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Izaberite modul za rad"
                                       FontFamily="Tahoma" FontSize="12"
                                       Foreground="#90A4AE" HorizontalAlignment="Center"
                                       Margin="0,0,0,24"/>

                            <WrapPanel HorizontalAlignment="Center" MaxWidth="920">

                                <!-- GK — Glavna knjiga -->
                                <Button Content="GLAVNA&#10;KNJIGA"
                                        Tag="📒"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#1A237E"
                                        ToolTip="Finansijsko knjigovodstvo — nalozi, kontni plan, zaključci, PDV"
                                        IsEnabled="{Binding MozeGlavnaKnjiga}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="GK"/>

                                <!-- AN — Analitika -->
                                <Button Content="ANALITIKA"
                                        Tag="📊"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#006064"
                                        ToolTip="Analitičke kartice kupaca i dobavljača"
                                        IsEnabled="{Binding MozeAnalitika}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="AN"/>

                                <!-- BL — Blagajna -->
                                <Button Content="BLAGAJNA"
                                        Tag="💰"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#1B5E20"
                                        ToolTip="Blagajničke uplate i isplate"
                                        IsEnabled="{Binding MozeBlagajna}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="BL"/>

                                <!-- TV — Veleprodaja -->
                                <Button Content="VELEPRODAJA"
                                        Tag="🏭"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#BF360C"
                                        ToolTip="Fakturisanje, roba, kalkulacije — veleprodaja"
                                        IsEnabled="{Binding MozeVeleprodaja}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="TV"/>

                                <!-- TM — Maloprodaja -->
                                <Button Content="MALOPRODAJA"
                                        Tag="🛒"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#E65100"
                                        ToolTip="Kasa, maloprodajna roba, pregledi"
                                        IsEnabled="{Binding MozeMaloprodaja}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="TM"/>

                                <!-- LD — Zarade -->
                                <Button Content="ZARADE"
                                        Tag="👤"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#1B5E20"
                                        ToolTip="Obračun zarada i drugih ličnih primanja"
                                        IsEnabled="{Binding MozeLdo}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="LD"/>

                                <!-- OS — Osnovna sredstva -->
                                <Button Content="OSNOVNA&#10;SREDSTVA"
                                        Tag="🏗"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#4527A0"
                                        ToolTip="Evidencija i amortizacija osnovnih sredstava"
                                        IsEnabled="{Binding MozeOS}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="OS"/>

                                <!-- US — Komunal -->
                                <Button Content="KOMUNALNE&#10;USLUGE"
                                        Tag="🏘"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#37474F"
                                        ToolTip="Komunalne usluge — obračun i naplate"
                                        IsEnabled="{Binding MozeKomunal}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="US"/>

                                <!-- SI — Šifarnici -->
                                <Button Content="ŠIFARNICI"
                                        Tag="📋"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#1565C0"
                                        ToolTip="Centralni šifarnici — partneri, roba, kontni plan, mesta"
                                        IsEnabled="{Binding MozeOstalo}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="SI"/>

                                <!-- DEL — Delovodnik -->
                                <Button Content="DELOVODNIK"
                                        Tag="🗂"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#5D4037"
                                        ToolTip="Evidencija prijema i otpreme pošte i dokumenata"
                                        IsEnabled="{Binding MozeOstalo}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="DEL"/>

                                <!-- TEH — Registar vozila -->
                                <Button Content="REGISTAR&#10;VOZILA"
                                        Tag="🚗"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#00695C"
                                        ToolTip="Registracija vozila, tehnički pregledi i virman nalozi"
                                        IsEnabled="{Binding MozeOstalo}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="TEH"/>

                                <!-- PRO — Proizvodnja -->
                                <Button Content="PROIZVODNJA"
                                        Tag="🏭"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#33691E"
                                        ToolTip="Proizvodni nalozi, norme/recepture, kalkulacije troškova"
                                        IsEnabled="{Binding MozeOstalo}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="PRO"/>

                                <!-- TRANSPORT — AAT/PCE -->
                                <Button Content="TRANSPORT /&#10;ŠPEDICIJA"
                                        Tag="🚚"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#01579B"
                                        ToolTip="Međunarodni transport, profitni centri, promet vozila"
                                        IsEnabled="{Binding MozeOstalo}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="TRANSPORT"/>

                                <!-- MLEKARA — HC0/MLE -->
                                <Button Content="MLEKARA"
                                        Tag="🥛"
                                        Style="{StaticResource ModulButtonStyle}"
                                        Background="#F57F17"
                                        ToolTip="Otkup mleka i HACCP sistem kvaliteta proizvodnje"
                                        IsEnabled="{Binding MozeOstalo}"
                                        Command="{Binding OtvoriModulCommand}"
                                        CommandParameter="MLEKARA"/>

                            </WrapPanel>

                            <!-- Poruka o nedostupnim modulima -->
                            <TextBlock Text="Moduli su dostupni prema vašim korisničkim pravima"
                                       FontFamily="Tahoma" FontSize="10"
                                       Foreground="#B0BEC5" HorizontalAlignment="Center"
                                       Margin="0,20,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Aktivan modul -->
                    <ContentPresenter Content="{Binding AktivniModulPogled}"
                                      Margin="4"
                                      Visibility="{Binding ImaOtvorenogModula,
                                          Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

            </Border>
        </Border>
    </DockPanel>
</Window>
