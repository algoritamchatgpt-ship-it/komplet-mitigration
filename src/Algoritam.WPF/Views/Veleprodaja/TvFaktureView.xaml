<Window x:Class="Algoritam.WPF.Views.Veleprodaja.TvFaktureView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1400" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#BF360C" Padding="16,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}"
                               FontFamily="Tahoma" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusPoruka}"
                               FontFamily="Tahoma" FontSize="10" Foreground="#FFAB91" Margin="0,2,0,0"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="White" Background="Transparent" BorderThickness="0"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="#FBE9E7" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#FFCCBC">
            <WrapPanel>
                <TextBlock Text="Od:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#BF360C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumOd}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="Do:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#BF360C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker SelectedDate="{Binding DatumDo}"
                            Width="120" Height="26" FontFamily="Tahoma" FontSize="11" Margin="0,0,16,0"/>
                <TextBlock Text="Šifra:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#BF360C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterSifra, UpdateSourceTrigger=PropertyChanged}"
                         Width="90" Height="26" Padding="4,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,12,0"/>
                <TextBlock Text="Pretraga:" FontFamily="Tahoma" FontSize="11"
                           Foreground="#BF360C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding FilterTekst, UpdateSourceTrigger=PropertyChanged}"
                         Width="200" Height="26" Padding="4,0"
                         FontFamily="Tahoma" FontSize="12" VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Očisti" Height="26" Padding="10,0"
                        FontFamily="Tahoma" FontSize="11" FontWeight="SemiBold"
                        Foreground="White" Background="#BF360C" BorderThickness="0" Cursor="Hand"
                        Command="{Binding OcistiFilterCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Zaglavlja (master) -->
        <Border Grid.Row="2" Margin="8,8,8,0" BorderBrush="#FFCCBC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#FBE9E7" Padding="8,4">
                    <TextBlock Text="{Binding NaslovZaglavlja}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold" Foreground="#BF360C"/>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Zaglavlja}"
                          SelectedItem="{Binding IzabranoZaglavlje}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#FFF3EE"
                          RowBackground="White"
                          BorderThickness="0"
                          FontFamily="Tahoma" FontSize="12"
                          SelectionMode="Single"
                          EnableRowVirtualization="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FBE9E7"/>
                            <Setter Property="Foreground" Value="#BF360C"/>
                            <Setter Property="FontFamily" Value="Tahoma"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#FFCCBC"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- fak.dbf -->
                        <DataGridTextColumn Header="Br.fak"   Binding="{Binding [BRFAK]}"  Width="90"/>
                        <!-- kal.dbf / kal+fak shared -->
                        <DataGridTextColumn Header="Br.kal"   Binding="{Binding [BRKAL]}"  Width="90"/>
                        <DataGridTextColumn Header="Dat.dok"  Binding="{Binding [DATDOK], StringFormat='dd.MM.yyyy'}" Width="90"/>
                        <DataGridTextColumn Header="Šifra"    Binding="{Binding [SIFRA]}"  Width="70"/>
                        <DataGridTextColumn Header="Br.računa" Binding="{Binding [BRRAC]}" Width="110"/>
                        <DataGridTextColumn Header="Vr.dok"   Binding="{Binding [FVRSTA]}" Width="60"/>
                        <DataGridTextColumn Header="Br.nal"   Binding="{Binding [BRNAL]}"  Width="80"/>
                        <DataGridTextColumn Header="Valuta"   Binding="{Binding [VALUTA]}" Width="55"/>
                        <!-- kal specific -->
                        <DataGridTextColumn Header="Dat.isp"  Binding="{Binding [DATISP], StringFormat='dd.MM.yyyy'}" Width="90"/>
                        <DataGridTextColumn Header="Dokum"    Binding="{Binding [DOKUM]}"  Width="70"/>
                        <!-- fak specific -->
                        <DataGridTextColumn Header="Napomena" Binding="{Binding [NAPOMENAG]}" Width="*"/>
                        <DataGridTextColumn Header="CMR"      Binding="{Binding [CMR]}"    Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                      Background="#FFCCBC" ResizeDirection="Rows"/>

        <!-- Stavke (detail) -->
        <Border Grid.Row="4" Margin="8,0,8,0" BorderBrush="#FFCCBC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#FFF3E0" Padding="8,4">
                    <TextBlock Text="{Binding NaslovStavki}"
                               FontFamily="Tahoma" FontSize="11" FontWeight="Bold" Foreground="#E65100"/>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Stavke}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#FFF8E1"
                          RowBackground="White"
                          BorderThickness="0"
                          FontFamily="Tahoma" FontSize="12"
                          SelectionMode="Single"
                          EnableRowVirtualization="True">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFF3E0"/>
                            <Setter Property="Foreground" Value="#E65100"/>
                            <Setter Property="FontFamily" Value="Tahoma"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="#FFCC80"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Rsif"      Binding="{Binding [RSIF]}"    Width="70"/>
                        <DataGridTextColumn Header="Naziv"     Binding="{Binding [NAZ]}"     Width="200"/>
                        <DataGridTextColumn Header="Podnaziv"  Binding="{Binding [PODNAZIV]}" Width="120"/>
                        <DataGridTextColumn Header="Jed."      Binding="{Binding [JED]}"     Width="50"/>
                        <DataGridTextColumn Header="Kol."      Binding="{Binding [KOL], StringFormat=N3}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Vel.cena"  Binding="{Binding [VELCENA], StringFormat=N2}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Vel.vred." Binding="{Binding [VELVRED], StringFormat=N2}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Mal.cena"  Binding="{Binding [MALCENA], StringFormat=N2}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Mal.vred." Binding="{Binding [MALVRED], StringFormat=N2}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="PDV%"      Binding="{Binding [PROCPOR]}" Width="55"/>
                        <DataGridTextColumn Header="Tarifa"    Binding="{Binding [TARIFA]}"  Width="60"/>
                        <!-- kal specific -->
                        <DataGridTextColumn Header="Prodaja"   Binding="{Binding [PRODAJA], StringFormat=N2}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Kvalitet"  Binding="{Binding [KVALITET]}" Width="70"/>
                        <DataGridTextColumn Header="Magacin"   Binding="{Binding [MAGACIN]}"  Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="5" Background="#FBE9E7" Padding="12,8"
                BorderThickness="0,1,0,0" BorderBrush="#FFCCBC" Margin="0,4,0,0">
            <DockPanel>
                <TextBlock Text="{Binding Zaglavlja.Count, StringFormat='Dokumenata: {0}'}"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"
                           Foreground="#BF360C" Margin="0,0,20,0"/>
                <TextBlock Text="{Binding Stavke.Count, StringFormat='Stavki: {0}'}"
                           VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11"
                           Foreground="#E65100" Margin="0,0,20,0"/>
                <Button Content="Osveži" DockPanel.Dock="Left" Width="80" Height="28" Margin="0,0,6,0"
                        Command="{Binding OsveziCommand}"
                        Style="{StaticResource NavButtonStyle}"/>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="80" Height="28"
                        Command="{Binding ZatvoriCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
