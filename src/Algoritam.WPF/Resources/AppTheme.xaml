<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════
         BOJE
    ═══════════════════════════════════ -->

    <!-- Zelene (header, navigacija, čuvanje) -->
    <SolidColorBrush x:Key="HeaderBrush"           Color="#1B5E20"/>
    <SolidColorBrush x:Key="HeaderAccentBrush"     Color="#2E7D32"/>
    <SolidColorBrush x:Key="NavButtonBrush"        Color="#43A047"/>
    <SolidColorBrush x:Key="GridBorderBrush"       Color="#C8E6C9"/>
    <SolidColorBrush x:Key="GridHeaderBgBrush"     Color="#E8F5E9"/>
    <SolidColorBrush x:Key="GridHeaderFgBrush"     Color="#2E7D32"/>
    <SolidColorBrush x:Key="GridSelectionBgBrush"  Color="#C8E6C9"/>
    <SolidColorBrush x:Key="GridSelectionFgBrush"  Color="#1B5E20"/>

    <!-- Plave (primarne akcije) -->
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#1565C0"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush"      Color="#0D47A1"/>

    <!-- Crvene (opasne akcije, greške) -->
    <SolidColorBrush x:Key="DangerBrush"           Color="#C62828"/>
    <SolidColorBrush x:Key="DangerLightBrush"      Color="#B71C1C"/>
    <SolidColorBrush x:Key="ValidationErrorBrush"  Color="#C62828"/>

    <!-- Neutralne -->
    <SolidColorBrush x:Key="NeutralBrush"          Color="#757575"/>
    <SolidColorBrush x:Key="NeutralDarkBrush"      Color="#546E7A"/>

    <!-- Pozadine forme -->
    <SolidColorBrush x:Key="WindowBgBrush"         Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ReadOnlyBgBrush"       Color="#ECEFF1"/>
    <SolidColorBrush x:Key="EditBannerBgBrush"     Color="#FFF9C4"/>
    <SolidColorBrush x:Key="EditBannerBorderBrush" Color="#F9A825"/>

    <!-- Tekst -->
    <SolidColorBrush x:Key="LabelFgBrush"          Color="#555555"/>
    <SolidColorBrush x:Key="TextFgBrush"           Color="#37474F"/>
    <SolidColorBrush x:Key="ReadOnlyFgBrush"       Color="#546E7A"/>
    <SolidColorBrush x:Key="HintFgBrush"           Color="#999999"/>

    <!-- ═══════════════════════════════════
         IMPLICITNI STILOVI (primjenjuju se
         automatski bez x:Key)
    ═══════════════════════════════════ -->

    <!-- TextBox: siva pozadina kad je ReadOnly, crveni border na grešci -->
    <Style TargetType="TextBox">
        <Style.Triggers>
            <Trigger Property="IsReadOnly" Value="True">
                <Setter Property="Background"  Value="#ECEFF1"/>
                <Setter Property="Foreground"  Value="#546E7A"/>
            </Trigger>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush"     Value="#C62828"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="ToolTip"
                        Value="{Binding (Validation.Errors)/ErrorContent,
                                RelativeSource={RelativeSource Self}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Button: hover/pressed/disabled efekti na svim dugmadima -->
    <Style TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <Border x:Name="HoverLayer" Background="Transparent" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverLayer" Property="Background" Value="#28FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HoverLayer" Property="Background" Value="#35000000"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabItem: aktivan tab — zelen i bold; neaktivan — siv -->
    <Style TargetType="TabItem">
        <Setter Property="FontFamily"  Value="Tahoma"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="Padding"     Value="14,6"/>
        <Setter Property="Foreground"  Value="#607D8B"/>
        <Setter Property="FontWeight"  Value="Normal"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground"  Value="#1B5E20"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#2E7D32"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════
         LABELE
    ═══════════════════════════════════ -->

    <!-- Labela pored polja (desno poravnanje, siva) -->
    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"           Value="Tahoma"/>
        <Setter Property="FontSize"             Value="11"/>
        <Setter Property="Foreground"           Value="#555555"/>
        <Setter Property="HorizontalAlignment"  Value="Right"/>
        <Setter Property="VerticalAlignment"    Value="Center"/>
        <Setter Property="Margin"               Value="0,0,6,0"/>
    </Style>

    <!-- Labela iznad polja (bold, tamna — za Parametri stil) -->
    <Style x:Key="StackedLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Tahoma"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="#37474F"/>
        <Setter Property="Margin"      Value="0,0,0,4"/>
    </Style>

    <!-- ═══════════════════════════════════
         POLJA FORME (keyed — eksplicitna
         primjena sa Style="{StaticResource}")
    ═══════════════════════════════════ -->

    <!-- Standardni TextBox sa svim svojstvima -->
    <Style x:Key="FormInputStyle" TargetType="TextBox">
        <Setter Property="FontFamily"              Value="Tahoma"/>
        <Setter Property="FontSize"                Value="12"/>
        <Setter Property="Padding"                 Value="4,2"/>
        <Setter Property="BorderBrush"             Value="#C8E6C9"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsReadOnly" Value="True">
                <Setter Property="Background" Value="#ECEFF1"/>
                <Setter Property="Foreground" Value="#546E7A"/>
            </Trigger>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush"     Value="#C62828"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="ToolTip"
                        Value="{Binding (Validation.Errors)/ErrorContent,
                                RelativeSource={RelativeSource Self}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Uvijek ReadOnly prikaz (siv) -->
    <Style x:Key="FormDisplayStyle" TargetType="TextBox" BasedOn="{StaticResource FormInputStyle}">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Background" Value="#ECEFF1"/>
        <Setter Property="Foreground" Value="#546E7A"/>
    </Style>

    <!-- DatePicker baza -->
    <Style x:Key="FormDateStyle" TargetType="DatePicker">
        <Setter Property="FontFamily" Value="Tahoma"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Height"     Value="26"/>
    </Style>

    <!-- ComboBox baza -->
    <Style x:Key="FormComboStyle" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Tahoma"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Padding"    Value="4,2"/>
    </Style>

    <!-- ═══════════════════════════════════
         DUGMAD
    ═══════════════════════════════════ -->

    <!-- Osnovna baza (borderless, hand cursor) -->
    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"       Value="Tahoma"/>
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="Foreground"       Value="White"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Height"           Value="26"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <Border x:Name="HoverLayer" Background="Transparent" IsHitTestVisible="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverLayer" Property="Background" Value="#28FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HoverLayer" Property="Background" Value="#35000000"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor"  Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Navigaciono dugme (zeleno, 26px) -->
    <Style x:Key="NavButtonStyle"     TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#43A047"/>
    </Style>

    <!-- Primarno dugme (plavo) -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#1565C0"/>
    </Style>

    <!-- Dugme čuvanja (tamno zeleno) -->
    <Style x:Key="SaveButtonStyle"    TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#2E7D32"/>
    </Style>

    <!-- Opasno/brisanje dugme (crveno) -->
    <Style x:Key="DangerButtonStyle"  TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#C62828"/>
    </Style>

    <!-- Header dugme (veće, bold — za window header trake) -->
    <Style x:Key="HeaderButtonStyle"  TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Padding"     Value="14,8"/>
        <Setter Property="Height"      Value="Auto"/>
    </Style>

    <!-- Navigaciono dugme: PRVI / GORE / DOLE / ZADNJI (plavo-sivo) -->
    <Style x:Key="NavBtnStyle"        TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#607D8B"/>
    </Style>

    <!-- Neutralno/Izlaz dugme (tamno sivo) -->
    <Style x:Key="NeutralButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#455A64"/>
    </Style>

    <!-- Upozorenje — OCISTI FILTER, BRISANJE MESECA i sl. (narandžasto) -->
    <Style x:Key="WarnButtonStyle"    TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#E65100"/>
    </Style>

    <!-- ═══════════════════════════════════
         DATAGRID
    ═══════════════════════════════════ -->

    <Style x:Key="AppDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background"       Value="#E8F5E9"/>
        <Setter Property="Foreground"       Value="#2E7D32"/>
        <Setter Property="FontWeight"       Value="Bold"/>
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="Padding"          Value="6,5"/>
        <Setter Property="BorderThickness"  Value="0,0,1,1"/>
        <Setter Property="BorderBrush"      Value="#C8E6C9"/>
    </Style>

    <Style x:Key="AppDataGridRowStyle" TargetType="DataGridRow">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#C8E6C9"/>
                <Setter Property="Foreground" Value="#1B5E20"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E8F5E9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════
         WINDOW KOMPONENTE
    ═══════════════════════════════════ -->

    <!-- Header traka prozora -->
    <Style x:Key="WindowHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="#1B5E20"/>
        <Setter Property="Height"     Value="50"/>
    </Style>

    <Style x:Key="WindowHeaderTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Tahoma"/>
        <Setter Property="FontSize"    Value="16"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="White"/>
    </Style>

    <Style x:Key="WindowHeaderSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Tahoma"/>
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="Foreground" Value="#A5D6A7"/>
    </Style>

    <!-- Status bar -->
    <Style x:Key="StatusBarBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#2E7D32"/>
        <Setter Property="Height"     Value="30"/>
    </Style>

    <Style x:Key="StatusBarTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"        Value="Tahoma"/>
        <Setter Property="FontSize"          Value="11"/>
        <Setter Property="Foreground"        Value="White"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusBarLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusBarTextStyle}">
        <Setter Property="FontSize"   Value="9"/>
        <Setter Property="Foreground" Value="#A5D6A7"/>
        <Setter Property="Margin"     Value="0,0,14,0"/>
    </Style>

    <!-- Edit mode banner (žuta traka) -->
    <Style x:Key="EditModeBannerStyle" TargetType="Border">
        <Setter Property="Background"       Value="#FFF9C4"/>
        <Setter Property="BorderBrush"      Value="#F9A825"/>
        <Setter Property="BorderThickness"  Value="0,0,0,2"/>
        <Setter Property="Padding"          Value="10,4"/>
    </Style>

    <!-- GroupBox -->
    <Style x:Key="AppGroupBoxStyle" TargetType="GroupBox">
        <Setter Property="FontFamily"  Value="Tahoma"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="#37474F"/>
        <Setter Property="BorderBrush" Value="#B0BEC5"/>
        <Setter Property="Margin"      Value="0,0,0,10"/>
    </Style>

</ResourceDictionary>
