<Window x:Class="OsnovnaSredstva.Views.OsKarticaLookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="820" Height="560"
        MinWidth="700" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F1F4F8">

    <Window.Resources>
        <Style x:Key="AkcijaDugme" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#2F4F6D"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="EditorField" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#9CC0E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="OptionalEditorLabel" TargetType="TextBlock" BasedOn="{StaticResource EditorLabel}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding PrikaziDodatno}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OptionalEditorField" TargetType="TextBox" BasedOn="{StaticResource EditorField}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding PrikaziDodatno}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F5F9D" Padding="14,10">
            <TextBlock Text="{Binding Naslov}"
                       FontFamily="Tahoma"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <Grid Grid.Row="1" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Pretraga:"
                       VerticalAlignment="Center"
                       FontFamily="Tahoma"
                       FontSize="11"
                       Foreground="#355070"
                       Margin="0,0,8,0"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Pretraga, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding HintPretraga}"
                     FontFamily="Tahoma"
                     FontSize="12"
                     Padding="6,4"
                     BorderBrush="#9CC0E7"
                     BorderThickness="1"/>
        </Grid>

        <Border Grid.Row="2" Margin="12,0,12,8" BorderBrush="#CED9E4" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Stavke}"
                      SelectedItem="{Binding IzabranaStavka}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      FontFamily="Tahoma"
                      FontSize="11"
                      RowHeight="24"
                      Background="White"
                      AlternatingRowBackground="#F7FAFF"
                      SelectionUnit="FullRow"
                      BorderThickness="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      MouseDoubleClick="OnGridMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding SifraNaslov}" Binding="{Binding Sifra, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                    <DataGridTextColumn Header="{Binding NazivNaslov}" Binding="{Binding Naziv, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="{Binding DodatnoNaslov}" Binding="{Binding Dodatno, UpdateSourceTrigger=PropertyChanged}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.PrikaziDodatno, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.PrikaziDodatno, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Margin="12,0,12,8" Background="#F3F7FD" BorderBrush="#CFDBE9" BorderThickness="1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Style="{StaticResource EditorLabel}" Text="{Binding SifraNaslov}"/>
                <TextBox Grid.Column="1"
                         Style="{StaticResource EditorField}"
                         Text="{Binding IzabranaStavka.Sifra, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="2"
                           Style="{StaticResource EditorLabel}"
                           Text="{Binding NazivNaslov}"/>
                <TextBox Grid.Column="3"
                         Style="{StaticResource EditorField}"
                         Text="{Binding IzabranaStavka.Naziv, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="4"
                           Style="{StaticResource OptionalEditorLabel}"
                           Text="{Binding DodatnoNaslov}"
                           HorizontalAlignment="Right"/>
                <TextBox Grid.Column="5"
                         Style="{StaticResource OptionalEditorField}"
                         Text="{Binding IzabranaStavka.Dodatno, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Margin="12,0,12,0" Background="#ECF2F8" BorderBrush="#D0DBE7" BorderThickness="1" Padding="10,6">
            <TextBlock Text="{Binding Poruka}"
                       FontFamily="Tahoma"
                       FontSize="11"
                       Foreground="#355070"/>
        </Border>

        <Border Grid.Row="5" Background="#E5EDF6" BorderBrush="#C4D4E5" BorderThickness="0,1,0,0" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="DODAJ"
                        Style="{StaticResource AkcijaDugme}"
                        Background="#2C7BE5"
                        Command="{Binding DodajCommand}"/>
                <Button Content="SACUVAJ"
                        Style="{StaticResource AkcijaDugme}"
                        Background="#2F9E44"
                        Command="{Binding SacuvajCommand}"/>
                <Button Content="IZABERI"
                        Style="{StaticResource AkcijaDugme}"
                        Background="#0D47A1"
                        IsDefault="True"
                        Command="{Binding IzaberiCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Button Content="IZLAZ"
                        Style="{StaticResource AkcijaDugme}"
                        Background="#546E7A"
                        Margin="0"
                        IsCancel="True"
                        Command="{Binding OtkaziCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
