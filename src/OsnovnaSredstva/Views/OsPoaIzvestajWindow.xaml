<Window x:Class="OsnovnaSredstva.Views.OsPoaIzvestajWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1180" Height="620"
        MinWidth="980" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F8" FontFamily="Tahoma">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1F5F9D" Padding="12,8">
            <TextBlock Text="{Binding Naslov}" FontSize="14" FontWeight="Bold" Foreground="White"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#D8E4F0" Padding="8,6"
                BorderBrush="#B8CCE4" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="84" Height="28"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="OnZatvoriClick"/>
                <Button Content="CSV" DockPanel.Dock="Right" Width="60" Height="28"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,4,0"
                        Command="{Binding IzveziCsvCommand}"/>
                <Button Content="Štampaj" DockPanel.Dock="Right" Width="74" Height="28"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,4,0"
                        Command="{Binding StampajCommand}"/>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           Foreground="#333" FontSize="12"/>
            </DockPanel>
        </Border>

        <DataGrid ItemsSource="{Binding Stavke}" AutoGenerateColumns="False"
                  IsReadOnly="True" AlternatingRowBackground="#F0F4FA"
                  HorizontalGridLinesBrush="#DDD" VerticalGridLinesBrush="#DDD"
                  FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Osifra" Binding="{Binding Osifra}" Width="80"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="220"/>
                <DataGridTextColumn Header="InvBroj" Binding="{Binding InvBroj}" Width="110"/>
                <DataGridTextColumn Header="Datprod" Binding="{Binding DatProd, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Nacinob" Binding="{Binding NacinOb}" Width="90"/>
                <DataGridTextColumn Header="Sad" Binding="{Binding Sad, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Sad2" Binding="{Binding Sad2, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="PAM" Binding="{Binding Pam, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="RAM" Binding="{Binding Ram, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Obezvredj" Binding="{Binding Obezvredj, StringFormat=N2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
