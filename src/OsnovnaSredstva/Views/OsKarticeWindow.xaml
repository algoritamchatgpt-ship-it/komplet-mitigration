<Window x:Class="OsnovnaSredstva.Views.OsKarticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Osnovna sredstva - Sifarnik 1"
        Width="1520" Height="820"
        MinWidth="1100" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#B9B6F1">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SacuvajCommand}"/>
        <KeyBinding Key="F5" Command="{Binding OsveziCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Stil isti kao FoxPro: siva dugmad, crni tekst -->
        <Style x:Key="FoxDugme" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#C0C0C0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D8D8D8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- LBLNAZIV — cyan label, kao u Foxu -->
            <RowDefinition Height="*"/>     <!-- Grid -->
            <RowDefinition Height="Auto"/>  <!-- Dugmad — 4 reda kao u Foxu -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- LBLNAZIV: cyan label iznad grida, kao u FoxPro -->
        <Border Grid.Row="0" Background="#80FFFF" BorderBrush="#40C0C0" BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding NazivIzabrane}"
                       FontFamily="Tahoma" FontSize="11" FontWeight="Bold"
                       Foreground="#CC0000"
                       Padding="8,4"
                       MinHeight="22"/>
        </Border>

        <!-- DataGrid — identican FoxPro gridu -->
        <DataGrid Grid.Row="1"
                  x:Name="GridKartice"
                  ItemsSource="{Binding Kartice}"
                  SelectedItem="{Binding IzabranaKartica}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma"
                  FontSize="11"
                  RowHeight="20"
                  Background="#F2F2F2"
                  AlternatingRowBackground="#F2F2F2"
                  SelectionUnit="FullRow"
                  BorderThickness="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  SelectionMode="Single"
                  MouseDoubleClick="OnGridDvoklik">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F8FAB8"/>
                            <Setter Property="Foreground" Value="#C60000"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <!-- Redosljed kolona iz FoxPro SCX: Osifra, Naz, Godpro, Konto, Vrsta, Mtr, Invbroj, Stopaot, Datnab, Nab0, Isp0, Sad0... pa ostale -->
                <DataGridTextColumn Header="Osifra"    Binding="{Binding Osifra,   UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                <DataGridTextColumn Header="Naz"       Binding="{Binding Naz,      UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                <DataGridTextColumn Header="Godpro"    Binding="{Binding ExtraPolja[GODPRO],   UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                <DataGridTextColumn Header="Konto"     Binding="{Binding Konto,    UpdateSourceTrigger=PropertyChanged}" Width="88"/>
                <DataGridTextColumn Header="Vrsta"     Binding="{Binding Vrsta,    UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                <DataGridTextColumn Header="Mtr"       Binding="{Binding ExtraPolja[MTR],      UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Invbroj"   Binding="{Binding InvBroj,  UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Stopaot"   Binding="{Binding StopaOt,  UpdateSourceTrigger=PropertyChanged, StringFormat=N3}" Width="90"/>
                <DataGridTextColumn Header="Datnab"    Binding="{Binding DatNab,   UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="90"/>
                <DataGridTextColumn Header="Nab0"      Binding="{Binding Nab0,     UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Isp0"      Binding="{Binding Isp0,     UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Sad0"      Binding="{Binding Sad0,     UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Procena"   Binding="{Binding ExtraPolja[PROCENA],  UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Razlproc"  Binding="{Binding ExtraPolja[RAZLPROC], UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Brnal"     Binding="{Binding BrNal,    UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                <DataGridTextColumn Header="Datprod"   Binding="{Binding ExtraPolja[DATPROD],  UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="90"/>
                <DataGridTextColumn Header="Brnalp"    Binding="{Binding ExtraPolja[BRNALP],   UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                <DataGridTextColumn Header="Sifra"     Binding="{Binding ExtraPolja[SIFRA],    UpdateSourceTrigger=PropertyChanged}" Width="75"/>
                <DataGridTextColumn Header="Naziv"     Binding="{Binding ExtraPolja[NAZIV],    UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                <DataGridTextColumn Header="Brrac"     Binding="{Binding ExtraPolja[BRRAC],    UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                <DataGridTextColumn Header="Valuta"    Binding="{Binding ExtraPolja[VALUTA],   UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Devkurs"   Binding="{Binding ExtraPolja[DEVKURS],  UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" Width="100"/>
                <DataGridTextColumn Header="Devdin"    Binding="{Binding ExtraPolja[DEVDIN],   UpdateSourceTrigger=PropertyChanged, StringFormat=N4}" Width="100"/>
                <DataGridTextColumn Header="Osdane"    Binding="{Binding ExtraPolja[OSDANE],   UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                <DataGridTextColumn Header="Adresa"    Binding="{Binding ExtraPolja[ADRESA],   UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                <DataGridTextColumn Header="Mestol"    Binding="{Binding ExtraPolja[MESTOL],   UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                <DataGridTextColumn Header="Listnepo"  Binding="{Binding ExtraPolja[LISTNEPO], UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Katasto"   Binding="{Binding ExtraPolja[KATASTO],  UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Knjigov"   Binding="{Binding ExtraPolja[KNJIGOV],  UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Datproc"   Binding="{Binding ExtraPolja[DATPROC],  UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="92"/>
                <DataGridTextColumn Header="Dathip"    Binding="{Binding ExtraPolja[DATHIP],   UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="92"/>
                <DataGridTextColumn Header="Hippover"  Binding="{Binding ExtraPolja[HIPPOVER], UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Osnovhip"  Binding="{Binding ExtraPolja[OSNOVHIP], UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Obezbdug"  Binding="{Binding ExtraPolja[OBEZBDUG], UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Redhip"    Binding="{Binding ExtraPolja[REDHIP],   UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Povrsina"  Binding="{Binding ExtraPolja[POVRSINA], UpdateSourceTrigger=PropertyChanged, StringFormat=N3}" Width="90"/>
                <DataGridTextColumn Header="Povobj"    Binding="{Binding ExtraPolja[POVOBJ],   UpdateSourceTrigger=PropertyChanged, StringFormat=N3}" Width="90"/>
                <DataGridTextColumn Header="Proizv"    Binding="{Binding ExtraPolja[PROIZV],   UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Lokacija"  Binding="{Binding ExtraPolja[LOKACIJA], UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Strukt1"   Binding="{Binding ExtraPolja[STRUKT1],  UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Strukt2"   Binding="{Binding ExtraPolja[STRUKT2],  UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Parcela"   Binding="{Binding ExtraPolja[PARCELA],  UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Isprave1"  Binding="{Binding ExtraPolja[ISPRAVE1], UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Isprave2"  Binding="{Binding ExtraPolja[ISPRAVE2], UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Isprave3"  Binding="{Binding ExtraPolja[ISPRAVE3], UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Osnovkor"  Binding="{Binding OsnovKor, UpdateSourceTrigger=PropertyChanged}" Width="86"/>
                <DataGridTextColumn Header="Izvor"     Binding="{Binding Izvor,    UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Nacinstic" Binding="{Binding ExtraPolja[NACINSTIC],UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Rashod"    Binding="{Binding ExtraPolja[RASHOD],   UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Kom"       Binding="{Binding Kom,      UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"/>
                <DataGridTextColumn Header="Cena"      Binding="{Binding Cena,     UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="95"/>
                <DataGridTextColumn Header="Stopaot2"  Binding="{Binding ExtraPolja[STOPAOT2], UpdateSourceTrigger=PropertyChanged, StringFormat=N3}" Width="90"/>
                <DataGridTextColumn Header="Mp"        Binding="{Binding ExtraPolja[MP],       UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn Header="Mesto"     Binding="{Binding Mesto,    UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                <DataGridTextColumn Header="Nomenkl"   Binding="{Binding ExtraPolja[NOMENKL],  UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Nab02"     Binding="{Binding ExtraPolja[NAB02],    UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Isp02"     Binding="{Binding ExtraPolja[ISP02],    UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Sad02"     Binding="{Binding ExtraPolja[SAD02],    UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Ag"        Binding="{Binding Ag,       UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                <DataGridTextColumn Header="Agpod"     Binding="{Binding AgPod,    UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Procgod"   Binding="{Binding ExtraPolja[PROCGOD],  UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Grupa"     Binding="{Binding ExtraPolja[GRUPA],    UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Oper"      Binding="{Binding ExtraPolja[OPER],     UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Preneto"   Binding="{Binding Preneto,  UpdateSourceTrigger=PropertyChanged}" Width="74"/>
                <DataGridTextColumn Header="Datstartam" Binding="{Binding ExtraPolja[DATSTARTAM],UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="96"/>
                <DataGridTextColumn Header="Iznosulag"  Binding="{Binding ExtraPolja[IZNOSULAG], UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Datulag"    Binding="{Binding ExtraPolja[DATULAG],   UpdateSourceTrigger=PropertyChanged, StringFormat=dd.MM.yyyy}" Width="92"/>
                <DataGridTextColumn Header="Nacinob"    Binding="{Binding ExtraPolja[NACINOB],   UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Polje1"     Binding="{Binding ExtraPolja[POLJE1],    UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="Polje2"     Binding="{Binding ExtraPolja[POLJE2],    UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ DUGMAD — tačan raspored iz FoxPro SCX ═══ -->
        <Border Grid.Row="2" Background="#B9B6F1" Padding="7,5,7,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Lijeva strana: 4 reda dugmadi kao u FoxPro -->
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">

                    <!-- Red 1: DOLE GORE ZADNJI PRVI DODAJ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="DOLE"    Style="{StaticResource FoxDugme}" Width="60"  Command="{Binding DoleCommand}"/>
                        <Button Content="GORE"    Style="{StaticResource FoxDugme}" Width="60"  Command="{Binding GoreCommand}"/>
                        <Button Content="ZADNJI"  Style="{StaticResource FoxDugme}" Width="70"  Command="{Binding ZadnjiCommand}"/>
                        <Button Content="PRVI"    Style="{StaticResource FoxDugme}" Width="60"  Command="{Binding PrviCommand}"/>
                        <Button Content="DODAJ"   Style="{StaticResource FoxDugme}" Width="70"  Click="OnDodajClick"/>
                        <Button Content="OBRISI"  Style="{StaticResource FoxDugme}" Width="70"  Command="{Binding ObrisiCommand}" Margin="0"/>
                    </StackPanel>

                    <!-- Red 2: BRISANJE PRAZNINA + TXTTRAZI -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="BRISANJE PRAZNINA" Style="{StaticResource FoxDugme}" Width="148" Command="{Binding BrisanjePrazninaCommand}"/>
                        <TextBox x:Name="TxtTrazi"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Tahoma" FontSize="11"
                                 Width="240" Height="24"
                                 VerticalContentAlignment="Center" Padding="4,0"
                                 BorderBrush="#707070" Background="White" Margin="0"/>
                    </StackPanel>

                    <!-- Red 3: GRUPE ZA AMORTIZACIJU | NEPOKRETNOSTI | KARTICA -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="GRUPE ZA AMORTIZACIJU"    Style="{StaticResource FoxDugme}" Width="168" Command="{Binding GrupeZaAmortizacijuCommand}"/>
                        <Button Content="NEPOKRETNOSTI"            Style="{StaticResource FoxDugme}" Width="118" Command="{Binding NepokretnostiCommand}"/>
                        <Button Content="KARTICA"                  Style="{StaticResource FoxDugme}" Width="80"  Command="{Binding KarticaCommand}" Margin="0"/>
                    </StackPanel>

                    <!-- Red 4: PODGRUPE ZA AMORTIZACIJU | POPISNA LISTA -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="PODGRUPE ZA AMORTIZACIJU" Style="{StaticResource FoxDugme}" Width="198" Command="{Binding PodgrupeZaAmortizacijuCommand}"/>
                        <Button Content="POPISNA LISTA"            Style="{StaticResource FoxDugme}" Width="118" Command="{Binding PopisnaListaCommand}" Margin="0"/>
                    </StackPanel>

                </StackPanel>

                <!-- Desna strana: SORT/IZVOZI/SACUVAJ/IZLAZ — svaki u svom redu -->
                <Grid Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Red 1 desno: SORT -->
                    <Button Grid.Row="0" Content="SORT"
                            Style="{StaticResource FoxDugme}" Width="120"
                            HorizontalAlignment="Right" Margin="0"
                            Command="{Binding SortCommand}"/>

                    <!-- Red 2 desno: IZVOZ TXT-1 -->
                    <Button Grid.Row="2" Content="IZVOZ TXT-1"
                            Style="{StaticResource FoxDugme}" Width="120"
                            HorizontalAlignment="Right" Margin="0"
                            Command="{Binding IzvozTxt1Command}"/>

                    <!-- Red 3 desno: IZVOZ EXCEL -->
                    <Button Grid.Row="4" Content="IZVOZ EXCEL"
                            Style="{StaticResource FoxDugme}" Width="120"
                            HorizontalAlignment="Right" Margin="0"
                            Command="{Binding IzvozExcelCommand}"/>

                    <!-- Red 4 desno: SACUVAJ + IZVOZ EXCEL 2 + IZLAZ -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="SACUVAJ"      Style="{StaticResource FoxDugme}" Width="90" Command="{Binding SacuvajCommand}"/>
                        <Button Content="IZVOZ EXCEL 2" Style="{StaticResource FoxDugme}" Width="120" Command="{Binding IzvozExcel2Command}"/>
                        <Button Content="IZLAZ"        Style="{StaticResource FoxDugme}" Width="80" Margin="0" Click="OnZatvoriClick"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#A0A0C0" BorderBrush="#8080A0" BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock Text="{Binding Poruka}"
                       FontFamily="Tahoma" FontSize="11"
                       Foreground="Black" VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
