<Window x:Class="OsnovnaSredstva.Views.OsSaldoPoMestuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SALDO PO MESTIMA"
        Width="570" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#E9ECD8"
        FontFamily="Tahoma"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="FoxDugme" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#C0C0C0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#FFB0D5" Padding="10" Margin="0,0,0,18">
            <TextBlock Text="SALDO PO MESTIMA"
                       FontSize="15" FontWeight="Bold"
                       Foreground="#8B1A2B" TextAlignment="Center"/>
        </Border>

        <Label Grid.Row="1" Grid.Column="0"
               Content="KONTO"
               FontSize="12" FontWeight="Bold"
               Foreground="#AB212C"
               VerticalContentAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Width="210" Height="30" MaxLength="10"
                 HorizontalAlignment="Left"
                 VerticalContentAlignment="Center"
                 Text="{Binding Konto, UpdateSourceTrigger=PropertyChanged}"/>

        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Margin="0,18,0,10" Padding="10"
                Background="#F5F7EA"
                BorderBrush="#C8CCB8" BorderThickness="1">
            <TextBlock Text="{Binding Poruka}" TextWrapping="Wrap"
                       Foreground="#555" VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="SALDO" Width="145"
                    Style="{StaticResource FoxDugme}"
                    IsDefault="True"
                    Command="{Binding SaldoCommand}"/>
            <Button Content="IZLAZ" Width="120"
                    Style="{StaticResource FoxDugme}"
                    Foreground="#B00000"
                    IsCancel="True"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
