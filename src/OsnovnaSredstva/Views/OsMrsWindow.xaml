<Window x:Class="OsnovnaSredstva.Views.OsMrsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OsnovnaSredstva.Converters"
        Title="{Binding Naslov}" Width="1100" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F8" FontFamily="Segoe UI">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="12,8">
            <TextBlock Text="{Binding Naslov}" FontSize="14" FontWeight="Bold" Foreground="White"/>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="#D8E4F0" Padding="8,6"
                BorderBrush="#B8CCE4" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button Content="Zatvori" DockPanel.Dock="Right" Width="84" Height="28"
                        Background="#C62828" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="OnZatvoriClick"/>
                <Button Content="CSV" DockPanel.Dock="Right" Width="60" Height="28"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,4,0"
                        Command="{Binding IzveziCsvCommand}"/>
                <Button Content="Štampaj" DockPanel.Dock="Right" Width="74" Height="28"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,4,0"
                        Command="{Binding StampajCommand}"/>
                <TextBlock Text="{Binding Poruka}" VerticalAlignment="Center"
                           Foreground="#333" FontSize="12"/>
            </DockPanel>
        </Border>
        <DataGrid x:Name="GridStavke"
                  ItemsSource="{Binding Stavke}" AutoGenerateColumns="False"
                  IsReadOnly="True" AlternatingRowBackground="#F0F4FA"
                  HorizontalGridLinesBrush="#DDD" VerticalGridLinesBrush="#DDD"
                  FontSize="12">
            <DataGrid.Columns>
                <!-- Zajedničke kolone — uvijek vidljive -->
                <DataGridTextColumn Header="Šifra"  Binding="{Binding Sifra}"  Width="70"/>
                <DataGridTextColumn Header="Naziv"  Binding="{Binding Naziv}"  Width="190"/>
                <DataGridTextColumn Header="Konto"  Binding="{Binding Konto}"  Width="90"
                    Visibility="{Binding DataContext.JeMrs,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Mesto"  Binding="{Binding Mesto}"  Width="70"
                    Visibility="{Binding DataContext.JeMrs,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="AG"     Binding="{Binding Ag}"     Width="55"
                    Visibility="{Binding DataContext.JeMrs,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={StaticResource BoolToVis}}"/>

                <!-- MRS kolone -->
                <DataGridTextColumn Header="Nab0"   Binding="{Binding Nab0,   StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JeMrs,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Isp0"   Binding="{Binding Isp0,   StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JeMrs,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Sad0"   Binding="{Binding Sad0,   StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JeMrs,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Stopa%" Binding="{Binding StopaOt,StringFormat=N3}" Width="72"
                    Visibility="{Binding DataContext.JeMrs,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Amort"  Binding="{Binding Amort,  StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JeMrs,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Isp."   Binding="{Binding Isp,    StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JeMrs,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Sad."   Binding="{Binding Sad,    StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JeMrs,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>

                <!-- PP Stara kolone -->
                <DataGridTextColumn Header="Nab02"  Binding="{Binding Nab02,  StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JePoreskaStara,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Isp02"  Binding="{Binding Isp02,  StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JePoreskaStara,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Sad02"  Binding="{Binding Sad02,  StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JePoreskaStara,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="St.PP%" Binding="{Binding StopaOt2,StringFormat=N3}" Width="72"
                    Visibility="{Binding DataContext.JePoreskaStara,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>

                <!-- PP Nova kolone -->
                <DataGridTextColumn Header="Amort2" Binding="{Binding Amort2, StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JePoreskaNova,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Isp2"   Binding="{Binding Isp2,   StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JePoreskaNova,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Sad2"   Binding="{Binding Sad2,   StringFormat=N2}" Width="110"
                    Visibility="{Binding DataContext.JePoreskaNova,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="St.PP%" Binding="{Binding StopaOt2,StringFormat=N3}" Width="72"
                    Visibility="{Binding DataContext.JePoreskaNova,RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
