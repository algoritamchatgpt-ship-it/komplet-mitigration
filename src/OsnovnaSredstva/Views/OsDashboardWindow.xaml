<Window x:Class="OsnovnaSredstva.Views.OsDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pregled firme"
        Width="740" Height="620"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F8" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1565C0" Padding="16,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding DatumOsvezavanja}"
                           FontSize="11" Foreground="#BBDEFB"
                           VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="PREGLED FIRME" FontSize="15" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding NazivFirme}" FontSize="11" Foreground="#BBDEFB" Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 4 kartice -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="10,10,10,4">

            <Border Margin="4" Background="#1565C0" CornerRadius="8" Padding="14,12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UkupnoKartica, StringFormat={}{0:N0}}"
                               FontSize="28" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Broj OS" FontSize="11" Foreground="#BBDEFB"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="4" Background="#00695C" CornerRadius="8" Padding="14,12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UkupnaNabavna, StringFormat={}{0:N2}}"
                               FontSize="18" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Nabavna vr." FontSize="11" Foreground="#80CBC4"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="4" Background="#E65100" CornerRadius="8" Padding="14,12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UkupnaAmortizacija, StringFormat={}{0:N2}}"
                               FontSize="18" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Amortizacija" FontSize="11" Foreground="#FFCCBC"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="4" Background="#2E7D32" CornerRadius="8" Padding="14,12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UkupnoNeotpisano, StringFormat={}{0:N2}}"
                               FontSize="18" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Neotpisano" FontSize="11" Foreground="#A5D6A7"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- Tabela po vrsti -->
        <Border Grid.Row="2" Margin="14,4,14,4" Background="White"
                BorderBrush="#C5D5E8" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Pregled po vrsti OS"
                           FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"
                           Margin="12,8,0,4"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding StavkePoVrsti}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowBackground="White"
                          AlternatingRowBackground="#F4F7FC"
                          BorderThickness="0"
                          FontSize="12"
                          ColumnHeaderHeight="30"
                          RowHeight="26"
                          Margin="0,0,0,4">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1565C0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vrsta" Binding="{Binding Vrsta}" Width="*"/>
                        <DataGridTextColumn Header="Broj" Binding="{Binding Broj, StringFormat={}{0:N0}}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Nabavna vr." Binding="{Binding NabavnaVr, StringFormat={}{0:N2}}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Amortizacija" Binding="{Binding Amortizacija, StringFormat={}{0:N2}}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Neotpisano" Binding="{Binding Neotpisano, StringFormat={}{0:N2}}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#D8E4F0" Padding="10,7"
                BorderBrush="#B8CCE4" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button Content="Zatvori" DockPanel.Dock="Right"
                        Width="84" Height="28"
                        Background="#C62828" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        IsCancel="True" Click="OnZatvoriClick"/>
                <Button Content="Osveži" DockPanel.Dock="Left"
                        Height="28" Padding="16,0"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding OsveziCommand}"/>
                <TextBlock Text="{Binding Poruka}"
                           VerticalAlignment="Center" Foreground="#C62828"
                           FontSize="11" Margin="10,0"
                           Visibility="{Binding Poruka, Converter={StaticResource StringToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="4" Background="#88FFFFFF" Panel.ZIndex="10"
                Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Učitavam podatke..."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#1565C0" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
