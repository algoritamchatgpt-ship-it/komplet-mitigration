<Window x:Class="OsnovnaSredstva.Views.OsPrenosaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prenos podataka u novu godinu"
        Width="480" Height="450"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="AkcijaDugme" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#E65100">
            <StackPanel VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="Prenos podataka u novu godinu"
                           FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Ažuriranje perioda i prenošenje SAD2 → SAD02 u os.dbf"
                           FontSize="10" Foreground="#FFCCBC"/>
            </StackPanel>
        </Border>

        <!-- Trenutni period -->
        <Border Grid.Row="1" Background="#FFF3E0" BorderBrush="#FFB74D" BorderThickness="0,0,0,1" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Trenutni period: "
                           FontSize="12" Foreground="#5D4037" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TrenutniPeriod}"
                           FontSize="12" FontWeight="SemiBold" Foreground="#BF360C" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Izbor nove godine -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Ciljna godina prenosa:"
                           FontSize="12" Foreground="#555555" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="◀" Width="30" Height="32"
                            Style="{StaticResource AkcijaDugme}"
                            Background="#BDBDBD" Foreground="#333333"
                            Command="{Binding SmanjuGodinuCommand}"/>
                    <TextBox Text="{Binding NovaGodina, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" Height="32"
                             FontSize="16" FontWeight="SemiBold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CCCCCC" BorderThickness="1"
                             Margin="4,0"/>
                    <Button Content="▶" Width="30" Height="32"
                            Style="{StaticResource AkcijaDugme}"
                            Background="#BDBDBD" Foreground="#333333"
                            Command="{Binding PovecajGodinuCommand}"/>
                    <TextBlock Text=". godina"
                               FontSize="13" Foreground="#666666"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Upozorenje statično (kad je godina OK) -->
        <Border Grid.Row="3" Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="0,0,0,1" Padding="14,8"
                Visibility="{Binding ImaUpozorenje, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#5D4037"
                       Text="⚠  Operacija mijenja ospodaci.dbf (datumi perioda) i os.dbf (DATUM0, SAD02, AMORT2). Preporučuje se arhiviranje firme prije prenosa."/>
        </Border>

        <!-- Greška o godini (kad je ista ili manja) -->
        <Border Grid.Row="3" Background="#FFEBEE" BorderBrush="#EF9A9A" BorderThickness="0,0,0,1" Padding="14,8"
                Visibility="{Binding ImaUpozorenje, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock TextWrapping="Wrap" FontSize="11" FontWeight="SemiBold" Foreground="#B71C1C"
                       Text="{Binding Upozorenje}"/>
        </Border>

        <!-- Log -->
        <Border Grid.Row="4" Margin="8,6" BorderBrush="#E0E0E0" BorderThickness="1" Background="White">
            <ListBox x:Name="LogBox"
                     ItemsSource="{Binding Log}"
                     BorderThickness="0"
                     FontFamily="Consolas" FontSize="11"
                     Background="White"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Border>

        <!-- Status -->
        <Border Grid.Row="5" Background="#EEEEEE" BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0" Padding="10,5">
            <Grid>
                <TextBlock Text="{Binding StatusPoruka}"
                           FontSize="11" Foreground="#444444"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <ProgressBar HorizontalAlignment="Right"
                             Width="100" Height="5"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Foreground="#E65100"
                             Visibility="{Binding UToku, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- Dugmad -->
        <Border Grid.Row="6" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Button HorizontalAlignment="Left"
                        Content="Pokreni prenos" Width="150"
                        Padding="14,0"
                        Background="#E65100"
                        FontWeight="SemiBold"
                        Style="{StaticResource AkcijaDugme}"
                        Command="{Binding PokrenuiPrenosuCommand}"/>

                <Button HorizontalAlignment="Right"
                        Content="Zatvori" Width="90"
                        Padding="14,0"
                        Background="#757575"
                        Style="{StaticResource AkcijaDugme}"
                        Click="OnZatvoriClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>
