<Window x:Class="OsnovnaSredstva.Views.OsKarticaKarticaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1220" Height="800"
        MinWidth="1020" MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F1F4F8"
        PreviewKeyDown="OnPreviewKeyDown">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#B71C1C"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="FieldStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>

        <Style x:Key="LookupButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F5F9D"/>
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="..."/>
        </Style>

        <Style x:Key="LookupNazivFieldStyle" TargetType="TextBox" BasedOn="{StaticResource FieldStyle}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#EEF3FA"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="Foreground" Value="#2E3D49"/>
        </Style>

        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="SelectedDateFormat" Value="Short"/>
            <Setter Property="IsTodayHighlighted" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F5F9D" Padding="16,12">
            <StackPanel>
                <TextBlock Text="{Binding Naslov}"
                           FontFamily="Tahoma"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="{Binding Podnaslov}"
                           FontFamily="Tahoma"
                           FontSize="11"
                           Foreground="#CFE6FF"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="10" Background="#F6F6EC" BorderBrush="#CFD8DC" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14">
                <StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="SIFRA" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding SifraOs, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="2" Text="Naz" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="14,0,8,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FieldStyle}" Text="{Binding NazivOs, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">

                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="DATUM NABAVKE"/><DatePicker Grid.Column="1" Style="{StaticResource DatePickerStyle}" SelectedDate="{Binding DatumNabavke, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="DATUM POCETKA AMORTIZACIJE"/><DatePicker Grid.Column="1" Style="{StaticResource DatePickerStyle}" SelectedDate="{Binding DatumPocetkaAmortizacije, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="DATUM PRODAJE"/><DatePicker Grid.Column="1" Style="{StaticResource DatePickerStyle}" SelectedDate="{Binding DatumProdaje, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="GODINA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding GodinaProizvodnje, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="VRSTA"/>
                                <TextBox x:Name="VrstaBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding Vrsta, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding VrstaNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupVrstaCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="POVRSINA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding Povrsina, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="STRUKTURA OBJEKTA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding StrukturaObjekta, UpdateSourceTrigger=PropertyChanged}"/></Grid>

                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="BROJ PARCELE"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding BrojParcele, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="KATASTARSKA OPSTINA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding KatastarskaOpstina, UpdateSourceTrigger=PropertyChanged}"/></Grid>

                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="ISPRAVE O SVOJINI 1"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding IspravaSvojine1, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="ISPRAVE O SVOJINI 2"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding IspravaSvojine2, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="ISPRAVE O SVOJINI 3"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding IspravaSvojine3, UpdateSourceTrigger=PropertyChanged}"/></Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="OSNOV KORISCENJA"/>
                                <TextBox x:Name="OsnovKorBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding OsnovKoriscenja, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding OsnovKoriscenjaNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupOsnovKoriscenjaCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="IZVOR FINANSIRANJA NABAVKE"/>
                                <TextBox x:Name="IzvorBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding IzvorFinansiranjaNabavke, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding IzvorFinansiranjaNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupIzvorFinansiranjaCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="NACIN STICANJA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding NacinSticanja, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="BROJ I DATUM ODLUKE O RASHOD."/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding BrojDatumOdlukeRashod, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="MESTO"/>
                                <TextBox x:Name="MestoLokacijeBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding MestoLokacije, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding MestoLokacijeNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupMestoLokacijeCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="MESTO TROSKOVA"/>
                                <TextBox x:Name="MestoTroskovaBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding MestoTroskova, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding MestoTroskovaNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupMestoCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="KONTO"/>
                                <TextBox x:Name="KontoBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding Konto, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding KontoNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupKontoCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="NOMENKLATURNI BROJ"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding NomenklaturniBroj, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="INVENTARSKI BROJ"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding InventarskiBroj, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="GRUPA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding Grupa, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="AMORTIZACIONA GRUPA"/>
                                <TextBox x:Name="AgBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding AmortizacionaGrupa, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding AmortizacionaGrupaNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupAmortizacionaGrupaCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="AMORTIZACIONA PODGRUPA"/>
                                <TextBox x:Name="AgPodBox" Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding AmortizacionaPodgrupa, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource LookupNazivFieldStyle}" Text="{Binding AmortizacionaPodgrupaNaziv}"/>
                                <Button Grid.Column="3"
                                        Style="{StaticResource LookupButton}"
                                        Command="{Binding LookupAmortizacionaPodgrupaCommand}"
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="FIRMA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding Firma, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="NACIN OBRACUNA (POA/014)"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding NacinObracuna, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="KOLICINA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding Kolicina, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="STOPA OTPISA MRS"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding StopaOtpisaMrs, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="STOPA OTPISA POR.PROP."/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding StopaOtpisaPorProp, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="POCETNA NABAVNA MRS"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding PocetnaNabavnaMrs, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="POCETNA ISPRAVKA MRS"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding PocetnaIspravkaMrs, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="POCETNA SADASNJA MRS"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding PocetnaSadasnjaMrs, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="POCETNA NABAVNA PP"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding PocetnaNabavnaPp, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="POCETNA ISPRAVKA PP"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding PocetnaIspravkaPp, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="POCETNA SADASNJA PP"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding PocetnaSadasnjaPp, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="PROCENA KORISCENJA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding ProcenaKoriscenja, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="IZNOS NAKNADNOG ULAGANJA"/><TextBox Grid.Column="1" Style="{StaticResource FieldStyle}" Text="{Binding IznosNaknadnogUlaganja, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="DATUM NAKNADNOG ULAGANJA"/><DatePicker Grid.Column="1" Style="{StaticResource DatePickerStyle}" SelectedDate="{Binding DatumNaknadnogUlaganja, UpdateSourceTrigger=PropertyChanged}"/></Grid>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="#E5EDF6" BorderBrush="#C4D4E5" BorderThickness="0,1,0,0" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="POTVRDI"
                        Style="{StaticResource ActionButton}"
                        Background="#2F9E44"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Command="{Binding PotvrdiCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Button Content="OTKAZI"
                        Style="{StaticResource ActionButton}"
                        Background="#546E7A"
                        IsCancel="True"
                        Command="{Binding OtkaziCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
