<Window x:Class="OsnovnaSredstva.Views.UpozorenjaAmortizacijeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upozorenja — prekomjerna amortizacija"
        Width="820" Height="460"
        MinWidth="600" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F8" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#E65100" Padding="14,10">
            <StackPanel>
                <TextBlock Text="PREKOMJERNA AMORTIZACIJA"
                           FontSize="14" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Kartice kod kojih ISP0 (amortizacija) premašuje NAB0 (nabavnu vrijednost)"
                           FontSize="11" Foreground="#FFCCBC" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tabela -->
        <DataGrid Grid.Row="1"
                  x:Name="DgUpozorenja"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowBackground="White"
                  AlternatingRowBackground="#FFF3E0"
                  BorderThickness="0"
                  FontSize="12"
                  ColumnHeaderHeight="30"
                  RowHeight="26"
                  Margin="8,6,8,0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"   Value="#E65100"/>
                    <Setter Property="Foreground"   Value="White"/>
                    <Setter Property="FontWeight"   Value="SemiBold"/>
                    <Setter Property="Padding"      Value="8,4"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Šifra"  Binding="{Binding Osifra}"  Width="90"/>
                <DataGridTextColumn Header="Naziv"  Binding="{Binding Naziv}"   Width="*"/>
                <DataGridTextColumn Header="Nab.vr." Binding="{Binding Nab0, StringFormat={}{0:N2}}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Amortizacija" Binding="{Binding Isp0, StringFormat={}{0:N2}}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Sad.vr." Binding="{Binding Sad0, StringFormat={}{0:N2}}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="% Amort." Binding="{Binding PostoAmortizacije, StringFormat={}{0:N1} %}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#D8E4F0" Padding="10,7"
                BorderBrush="#B8CCE4" BorderThickness="0,1,0,0" Margin="0,6,0,0">
            <DockPanel>
                <Button Content="Zatvori" DockPanel.Dock="Right"
                        Width="84" Height="28"
                        Background="#C62828" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        IsCancel="True" Click="OnZatvoriClick"/>
                <TextBlock x:Name="TxtBrojac"
                           VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
