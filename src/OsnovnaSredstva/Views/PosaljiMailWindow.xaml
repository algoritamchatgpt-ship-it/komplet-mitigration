<Window x:Class="OsnovnaSredstva.Views.PosaljiMailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Posalji putem e-maila"
        Width="520" Height="440"
        MinWidth="420" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F8" FontFamily="Segoe UI">
    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Slanje putem e-maila"
                   FontSize="15" FontWeight="SemiBold" Foreground="#1A237E"
                   Margin="0,0,0,14"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Za:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding Primaoci, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5" Padding="4,3"
                     ToolTip="Vise adresa odvojite zarezom ili tacka-zarezom"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Predmet:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding Predmet, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5" Padding="4,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Poruka:" VerticalAlignment="Top" Margin="0,10,0,0"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding Tekst, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5" Padding="4,3"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Prilog:" VerticalAlignment="Center" Margin="0,8"/>
            <Border Grid.Row="3" Grid.Column="1" Background="#E3F2FD" CornerRadius="3"
                    BorderBrush="#90CAF9" BorderThickness="1" Padding="8,4" Margin="0,8">
                <TextBlock Text="{Binding PdfNazivPrikaz}"
                           Foreground="#1565C0" FontSize="11" FontFamily="Consolas"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFF8E1" CornerRadius="4"
                BorderBrush="#FFE082" BorderThickness="1" Padding="8,6" Margin="0,8,0,4">
            <TextBlock Text="{Binding Poruka}" Foreground="#5D4037" FontSize="11"
                       TextWrapping="Wrap" MinHeight="16"/>
        </Border>

        <Border Grid.Row="3" Background="#D8E4F0" Padding="10,7"
                BorderBrush="#B8CCE4" BorderThickness="0,1,0,0" Margin="-20,4,-20,-16">
            <DockPanel>
                <Button Content="Zatvori" DockPanel.Dock="Right"
                        Width="84" Height="28"
                        Background="#607D8B" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        IsCancel="True" Click="OnZatvoriClick"/>
                <Button Content="Posalji" DockPanel.Dock="Right" Margin="0,0,6,0"
                        Width="84" Height="28"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding PosaljiCommand}"/>
                <Button Content="Podesavanja SMTP..." Height="28" HorizontalAlignment="Left"
                        Padding="14,0"
                        Background="#455A64" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding OtvoriPodesavanjaCommand}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
