<Window x:Class="OsnovnaSredstva.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pregled pre štampe"
        Width="980" Height="720"
        MinWidth="600" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F8" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DocumentViewer x:Name="Viewer" Grid.Row="0"/>

        <Border Grid.Row="1" Background="#D8E4F0" Padding="10,7"
                BorderBrush="#B8CCE4" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button Content="Zatvori" DockPanel.Dock="Right"
                        Width="84" Height="28"
                        Background="#C62828" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        IsCancel="True" Click="OnZatvoriClick"/>
                <Button x:Name="BtnPosaljiMail" Content="Posalji mailom" DockPanel.Dock="Right"
                        Height="28" Padding="12,0" Margin="0,0,6,0"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="Collapsed"
                        Click="OnPosaljiMailClick"/>
                <Button x:Name="BtnSacuvajPdf" Content="Sacuvaj PDF" DockPanel.Dock="Right"
                        Height="28" Padding="12,0" Margin="0,0,6,0"
                        Background="#2E7D32" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Visibility="Collapsed"
                        Click="OnSacuvajPdfClick"/>
                <TextBlock Text="Za stampanje koristite dugme  u toolbar-u iznad (ili Ctrl+P)."
                           VerticalAlignment="Center" Foreground="#444" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
