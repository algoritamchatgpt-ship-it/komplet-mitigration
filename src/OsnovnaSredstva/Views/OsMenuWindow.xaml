<Window x:Class="OsnovnaSredstva.Views.OsMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FIN Osnovna sredstva"
        Width="500" Height="850"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Converter za prikaz emoji ikonice -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Stil za main menu dugmad -->
        <Style x:Key="MenuDugme" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="4,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.18" Color="#000000"/>
                            </Border.Effect>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4">
                                <TextBlock Text="{TemplateBinding Tag}"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,3"
                                           Visibility="{Binding Tag, RelativeSource={RelativeSource TemplatedParent},
                                                        Converter={StaticResource StringToVisibilityConverter}}"/>
                                <TextBlock Text="{TemplateBinding Content}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Padding="8,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.68"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stil za footer utility dugmad -->
        <Style x:Key="UtilDugme" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Background="#F0F4FA">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="16,12">
            <StackPanel>
                <TextBlock Text="OSNOVNA SREDSTVA"
                           FontSize="17" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding NaslovHeader}"
                           FontSize="11" Foreground="#BBDEFB" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="#D8E4F0"
                BorderBrush="#B0C4DE" BorderThickness="0,1,0,0" Padding="10,8">
            <DockPanel>
                <Button Content="Izlaz"
                        DockPanel.Dock="Right"
                        Style="{StaticResource UtilDugme}"
                        Background="#B71C1C" Width="88"
                        Command="{Binding OdjavaCommand}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Promena firme"
                            Style="{StaticResource UtilDugme}"
                            Background="#37474F"
                            Command="{Binding PromenaFirmeCommand}"/>
                    <Button Content="Promena godine"
                            Style="{StaticResource UtilDugme}"
                            Background="#37474F"
                            Command="{Binding PromenaGodineCommand}"/>
                    <Button Content="Korisnici"
                            Style="{StaticResource UtilDugme}"
                            Background="#37474F"
                            Command="{Binding OtvoriLozinkeCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separator između menija i footera -->
        <Border DockPanel.Dock="Bottom" Height="1" Background="#C5D5E8"/>

        <!-- Upozorenje amortizacije (žuti banner, vidljiv samo ako ima problema) -->
        <Border DockPanel.Dock="Bottom"
                Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="0,1,0,0"
                Padding="12,7"
                Visibility="{Binding UpozerenjePoruka,
                    Converter={StaticResource StringToVisibilityConverter}}">
            <DockPanel>
                <Button Content="Prikaži"
                        DockPanel.Dock="Right"
                        Height="26" Padding="14,0"
                        Background="#E65100" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding PrikaziUpozorenjaCommand}"/>
                <TextBlock Text="{Binding UpozerenjePoruka}"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="#E65100" FontWeight="SemiBold"
                           TextWrapping="Wrap" Margin="0,0,10,0"/>
            </DockPanel>
        </Border>

        <!-- Meni dugmad — 2 kolone, 6 redova, isti red = ista boja -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8,8,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Red 0: Dashboard -->
                <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        Content="Pregled firme (Dashboard)"
                        Style="{StaticResource MenuDugme}"
                        Height="48"
                        Background="#1A237E"
                        Command="{Binding OtvoriDashboardCommand}"/>

                <!-- Red 1: Plava (#1565C0) — Osnovne OS funkcije -->
                <Button Grid.Row="1" Grid.Column="0"
                        Content="Kartice OS"
                        Style="{StaticResource MenuDugme}"
                        Background="#1565C0"
                        Command="{Binding OtvoriKarticeCommand}"/>
                <Button Grid.Row="1" Grid.Column="1"
                        Content="Evidencija OS"
                        Style="{StaticResource MenuDugme}"
                        Background="#1565C0"
                        Command="{Binding OtvoriEvidencijuCommand}"/>

                <!-- Red 2: Tirkiz (#00695C) — Amortizacija i šifarnici -->
                <Button Grid.Row="2" Grid.Column="0"
                        Content="Amortizacija OA"
                        Style="{StaticResource MenuDugme}"
                        Background="#00695C"
                        Command="{Binding OtvoriStampaCommand}"/>
                <Button Grid.Row="2" Grid.Column="1"
                        Content="Šifarnici OS"
                        Style="{StaticResource MenuDugme}"
                        Background="#00695C"
                        Command="{Binding OtvoriSifarNiciCommand}"/>

                <!-- Red 3: Narandžasta (#E65100) — Arhiva i prenos -->
                <Button Grid.Row="3" Grid.Column="0"
                        Content="Arhiva"
                        Style="{StaticResource MenuDugme}"
                        Background="#E65100"
                        Command="{Binding OtvoriArhivuCommand}"/>
                <Button Grid.Row="3" Grid.Column="1"
                        Content="Prenos u novu godinu"
                        Style="{StaticResource MenuDugme}"
                        Background="#E65100"
                        Command="{Binding OtvoriPrenosuCommand}"/>

                <!-- Red 4: Zelena (#2E7D32) — Šifarnici partnera i mesta -->
                <Button Grid.Row="4" Grid.Column="0"
                        Content="Partneri"
                        Style="{StaticResource MenuDugme}"
                        Background="#2E7D32"
                        Command="{Binding OtvoriPartnereCommand}"/>
                <Button Grid.Row="4" Grid.Column="1"
                        Content="Mesta"
                        Style="{StaticResource MenuDugme}"
                        Background="#2E7D32"
                        Command="{Binding OtvoriMestaCommand}"/>

                <!-- Red 5: Ljubičasta (#512DA8) — Alati i podešavanja -->
                <Button Grid.Row="5" Grid.Column="0"
                        Content="Izvoz tabele"
                        Style="{StaticResource MenuDugme}"
                        Background="#512DA8"
                        Command="{Binding OtvoriIzvozCommand}"/>
                <Button Grid.Row="5" Grid.Column="1"
                        Content="Podaci o firmi"
                        Style="{StaticResource MenuDugme}"
                        Background="#512DA8"
                        Command="{Binding OtvoriPodatkeOFirmiCommand}"/>

                <!-- Red 6: Sivo-smeđa (#5D4037) — Amortizacione grupe i OS podaci -->
                <Button Grid.Row="6" Grid.Column="0"
                        Content="Grupe amortizacije"
                        Style="{StaticResource MenuDugme}"
                        Background="#5D4037"
                        Command="{Binding OtvoriGrupeAmortizacijeCommand}"/>
                <Button Grid.Row="6" Grid.Column="1"
                        Content="Podaci OS (period)"
                        Style="{StaticResource MenuDugme}"
                        Background="#5D4037"
                        Command="{Binding OtvoriPodatkeOsCommand}"/>

                <!-- Red 7: Tamnoplava (#006064) — Pregledi i izveštaji -->
                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                        Content="Pregledi / Izveštaji OS"
                        Style="{StaticResource MenuDugme}"
                        Background="#006064"
                        Command="{Binding OtvoriPregledeCommand}"/>

                <!-- Red 8: Teget (#00838F) — XML obrazac OST -->
                <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                        Content="XML obrazac — Ostali rezultat"
                        Style="{StaticResource MenuDugme}"
                        Background="#00838F"
                        Command="{Binding OtvoriXmlOstCommand}"/>

                <!-- Red 9: Tamno siva (#263238) — Backup -->
                <Button Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                        Content="Backup firme"
                        Style="{StaticResource MenuDugme}"
                        Background="#263238"
                        Command="{Binding NapraviBackupCommand}"/>

                <!-- Status backup poruke -->
                <Border Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                        Background="#E8F5E9" CornerRadius="5"
                        BorderBrush="#A5D6A7" BorderThickness="1"
                        Padding="10,6" Margin="4,2"
                        Visibility="{Binding BackupPoruka,
                            Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding BackupPoruka}"
                               FontSize="11" Foreground="#1B5E20"
                               TextWrapping="Wrap"/>
                </Border>

            </Grid>
        </ScrollViewer>

    </DockPanel>
</Window>
