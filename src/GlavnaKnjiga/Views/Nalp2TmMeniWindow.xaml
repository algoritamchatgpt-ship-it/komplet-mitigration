<Window x:Class="GlavnaKnjiga.Views.Nalp2TmMeniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KEPU KNJIGA — OPIS"
        Width="460" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        ResizeMode="NoResize">

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Izaberi" Width="110" Height="38" IsDefault="True"
                    Command="{Binding IzaberiCommand}"/>
            <Button Content="Izlaz" Width="90" Height="38" Margin="10,0,0,0"
                    Foreground="#B00000" Command="{Binding IzlazCommand}"/>
        </StackPanel>

        <ListBox ItemsSource="{Binding Opcije}"
                 SelectedItem="{Binding SelectedOption}"
                 FontFamily="Tahoma" FontSize="14"
                 Background="#F5F5F5" Padding="6"/>
    </DockPanel>
</Window>
