<Window x:Class="GlavnaKnjiga.Views.NalvrstaPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IZBOR VRSTE NALOGA"
        Width="680" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Izaberi" Width="110" Height="36" IsDefault="True"
                    Command="{Binding IzaberiCommand}"/>
            <Button Content="Izlaz" Width="90" Height="36" Margin="10,0,0,0"
                    Foreground="#B00000" Command="{Binding IzlazCommand}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Redovi}" SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  FontFamily="Tahoma" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vrsta" Binding="{Binding Vrnal}" Width="90"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                <DataGridTextColumn Header="Dok." Binding="{Binding Dok}" Width="80"/>
                <DataGridTextColumn Header="MP" Binding="{Binding Mp}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
