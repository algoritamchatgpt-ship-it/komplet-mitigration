<Window x:Class="GlavnaKnjiga.Views.NalbrojWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EVIDENCIJA NALOGA"
        Height="560" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Info label (Label1 — tekući nalog) -->
        <Border DockPanel.Dock="Top" Background="#FEF2E9" BorderBrush="#B7BCF9" BorderThickness="0,0,0,1" Height="28">
            <TextBlock Text="{Binding LabelInfo}" FontFamily="Tahoma" FontSize="11"
                       VerticalAlignment="Center" Margin="4,0"/>
        </Border>

        <!-- Dugmad dno -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4,4,4">
            <Button Content="PRVI"        Width="70" Margin="2" Command="{Binding IdiNaVrhCommand}" Background="#C0C0C0" FontFamily="Tahoma" FontSize="11" Foreground="Blue"/>
            <Button Content="GORE"        Width="70" Margin="2" Command="{Binding IdiGoreCommand}"   Background="#C0C0C0" FontFamily="Tahoma" FontSize="11" Foreground="Blue"/>
            <Button Content="DOLE"        Width="70" Margin="2" Command="{Binding IdiDoleCommand}"   Background="#C0C0C0" FontFamily="Tahoma" FontSize="11" Foreground="Blue"/>
            <Button Content="ZADNJI"      Width="70" Margin="2" Command="{Binding IdiNaDnoCommand}"  Background="#C0C0C0" FontFamily="Tahoma" FontSize="11" Foreground="Blue"/>
            <Separator Width="10"/>
            <Button Content="DODAJ +"     Width="80"  Margin="2" Command="{Binding DodajCommand}"     Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="TRAŽENJE F6" Width="100" Margin="2" Command="{Binding TraziF6Command}"   Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="KARTICA F7"  Width="100" Margin="2" Command="{Binding KarticaF7Command}" Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="BRISANJE"    Width="80"  Margin="2" Command="{Binding BrisanjeCommand}"  Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Separator Width="10"/>
            <Button Content="Izlaz"       Width="80"  Margin="2" Command="{Binding IzlazCommand}"     Background="#C0C0C0" FontFamily="Tahoma" FontSize="11" Foreground="Red"/>
        </StackPanel>

        <!-- Główna tabela -->
        <DataGrid ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="11"
                  Background="#F5F5F5"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#B7BCF9"
                  VerticalGridLinesBrush="#B7BCF9"
                  RowBackground="#F5F5F5"
                  SelectionMode="Single"
                  Margin="2"
                  MouseDoubleClick="Grid_DoubleClick">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Background" Value="#B7BCF9"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Brnal"   Binding="{Binding Brnal}"                      Width="70"/>
                <DataGridTextColumn Header="Datum"   Binding="{Binding Datum, StringFormat=dd.MM.yyyy}" Width="85"/>
                <DataGridTextColumn Header="Vrnal"   Binding="{Binding Vrnal}"                      Width="50"/>
                <DataGridTextColumn Header="Opis"    Binding="{Binding Opis}"                       Width="200"/>
                <DataGridTextColumn Header="Datod"   Binding="{Binding Datod, StringFormat=dd.MM.yyyy}" Width="85"/>
                <DataGridTextColumn Header="Datdo"   Binding="{Binding Datdo, StringFormat=dd.MM.yyyy}" Width="85"/>
                <DataGridTextColumn Header="Dug"     Binding="{Binding Dug,   StringFormat=N2}"     Width="80"/>
                <DataGridTextColumn Header="Pot"     Binding="{Binding Pot,   StringFormat=N2}"     Width="80"/>
                <DataGridTextColumn Header="Datknji" Binding="{Binding Datknji, StringFormat=dd.MM.yyyy}" Width="85"/>
                <DataGridTextColumn Header="Oper"    Binding="{Binding Oper}"                       Width="40"/>
                <DataGridTextColumn Header="Preneto" Binding="{Binding Preneto}"                    Width="50"/>
                <DataGridTextColumn Header="Idbr"    Binding="{Binding Idbr}"                       Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
