<Window x:Class="GlavnaKnjiga.Views.NalplobrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ANALIZA OBRTNIH SREDSTAVA POTRAŽIVANJA I OBAVEZA"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Toolbar -->
        <WrapPanel DockPanel.Dock="Bottom" Margin="4,4,4,4">
            <Button Content="DOLE"   Width="70"  Margin="2" Command="{Binding DoleCommand}"/>
            <Button Content="GORE"   Width="70"  Margin="2" Command="{Binding GoreCommand}"/>
            <Button Content="ZADNJI" Width="70"  Margin="2" Command="{Binding ZadnjiCommand}"/>
            <Button Content="PRVI"   Width="70"  Margin="2" Command="{Binding PrviCommand}"/>
            <Separator Width="8"/>
            <Button Content="&lt;DODAJ"            Width="100" Margin="2" Background="#80FFFF"  Command="{Binding DodajCommand}"/>
            <Button Content="&lt;BRISANJE REDA"    Width="120" Margin="2" Background="#80FF80"  Command="{Binding BrisanjeRedaCommand}"/>
            <Button Content="&lt;BRISANJE TABELE"  Width="120" Margin="2" Background="#80FF80"  Command="{Binding BrisanjeTabeleCommand}"/>
            <Separator Width="8"/>
            <Button Content="&lt;DATUMI I PUTANJE"            Width="150" Margin="2" Background="#B9FFB9"  Command="{Binding DatumiIPutanjeCommand}"/>
            <Button Content="PREGLED ANALIZE"                Width="140" Margin="2" Background="#F3FAA3"  Command="{Binding PregledAnalizeCommand}"/>
            <Button Content="&lt;UČITAJ KONTA IZ GL.KNJIGE"  Width="200" Margin="2" Background="#80FFFF"  Command="{Binding UcitajKontaIzGlavneKnjigeCommand}"/>
            <Button Content="&lt;PRENOS IZ GLAVNE KNJIGE"    Width="180" Margin="2" Background="#80FFFF"  Command="{Binding PrenosIzGlavneKnjigeCommand}"/>
            <Separator Width="8"/>
            <Button Content="&lt;IZLAZ" Width="80" Margin="2" Foreground="Red" Background="#FF8080"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  FontSize="11"
                  RowHeight="20"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="K2"     Binding="{Binding K2}"     Width="50"/>
                <DataGridTextColumn Header="DugPot" Binding="{Binding Dugpot}" Width="55"/>
                <DataGridTextColumn Header="Gnaz"   Binding="{Binding Gnaz}"   Width="*"/>
                <DataGridTextColumn Header="Dug"    Binding="{Binding Dug,    StringFormat=N0}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Pot"    Binding="{Binding Pot,    StringFormat=N0}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Saldo"  Binding="{Binding Saldo,  StringFormat=N0}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Dat0"   Binding="{Binding Dat0,   StringFormat=dd.MM.yyyy}" Width="90"/>
                <DataGridTextColumn Header="Dat1"   Binding="{Binding Dat1,   StringFormat=dd.MM.yyyy}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
