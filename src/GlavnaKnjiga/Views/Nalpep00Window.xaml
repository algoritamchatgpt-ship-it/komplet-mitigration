<Window x:Class="GlavnaKnjiga.Views.Nalpep00Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Height="200" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#ECE9D8"
        KeyDown="Window_KeyDown">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PUTANJA ZA PREUZIMANJE IZVODA"
                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"
                   Foreground="#BE0000" TextDecorations="Underline"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Unesite putanju i ime datoteke"
                       Foreground="#BE0000" TextDecorations="Underline"
                       FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding Putanja, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11" MaxLength="70"/>
            <Button Grid.Column="2" Content="..." Width="30" Margin="4,0,0,0"
                    Command="{Binding PutanjaBrowseCommand}"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="PREUZMI"  Width="100" Margin="8,0" Background="#C0C0C0"
                    Command="{Binding PreuzmiCommand}"/>
            <Button Content="IZLAZ"   Width="80"  Margin="8,0" Background="#C0C0C0" Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
