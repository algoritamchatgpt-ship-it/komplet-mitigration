<Window x:Class="GlavnaKnjiga.Views.NaluniorKursWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UNOS KURSA U DEVIZNIM RAČUNIMA"
        Width="590" Height="300"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#F1D1AD"
                Padding="10" Margin="0,0,0,18">
            <TextBlock Text="Unos kursa" TextAlignment="Center"
                       FontFamily="Tahoma" FontSize="15" FontWeight="Bold"/>
        </Border>

        <Label Grid.Row="1" Grid.Column="0" Content="Oznaka devize"
               FontFamily="Tahoma" FontSize="12"
               Foreground="#8B0000" VerticalContentAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Width="90" Height="32"
                 HorizontalAlignment="Left" MaxLength="3"
                 CharacterCasing="Upper"
                 FontFamily="Tahoma" FontSize="13"
                 VerticalContentAlignment="Center"
                 Text="{Binding Deviza, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,18,0,0"
                   TextWrapping="Wrap" Foreground="#444"
                   Text="Kurs se traži u dev.dbf prema izabranoj devizi i datumu PDV-a svakog računa. Devizna osnovica i ukupan iznos biće automatski preračunati."/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="UNESI KURS" Width="150" Height="42" Margin="4"
                    FontWeight="Bold" IsDefault="True"
                    Command="{Binding UnesiKursCommand}"/>
            <Button Content="IZLAZ" Width="100" Height="42" Margin="4"
                    Foreground="#B00000" IsCancel="True"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
