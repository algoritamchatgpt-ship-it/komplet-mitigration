<Window x:Class="GlavnaKnjiga.Views.NalbrojBrisiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BRISANJE EVIDENCIJE NALOGA"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#95BC94">

    <StackPanel Margin="16">
        <Border Background="#F3FAA3" BorderBrush="Gray" BorderThickness="1" Padding="8,4">
            <TextBlock Text="BRISANJE SVIH NALOGA KOJIH NEMA U GLAVNOJ KNJIZI"
                       FontFamily="Tahoma" FontSize="11" FontWeight="Bold"/>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <TextBlock Text="Potvrda D/N:" FontFamily="Tahoma" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtDane" Width="40" MaxLength="1"
                     FontFamily="Tahoma" FontSize="11"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
            <Button Content="POTVRDA" Width="100" Margin="8,0"
                    Click="BtnPotvrda_Click"
                    FontFamily="Tahoma" FontSize="11" Background="#C0C0C0"/>
            <Button Content="IZLAZ" Width="100" Margin="8,0"
                    Click="BtnIzlaz_Click"
                    FontFamily="Tahoma" FontSize="11" Background="#FF8080"/>
        </StackPanel>
    </StackPanel>
</Window>
