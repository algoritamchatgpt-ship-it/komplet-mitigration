<Window x:Class="GlavnaKnjiga.Views.NalzatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Height="430" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="KONTO PRIHODA"
               Visibility="{Binding PrikaziKonta, Converter={StaticResource BoolToVisibilityConverter}}"
               FontFamily="Tahoma" FontSize="12" Foreground="#BE0000" Background="#80FF80"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding KontoPrihoda, UpdateSourceTrigger=PropertyChanged}"
                 Visibility="{Binding PrikaziKonta, Converter={StaticResource BoolToVisibilityConverter}}"
                 MaxLength="1" Width="70" HorizontalAlignment="Left" Style="{StaticResource InputStyle}"/>

        <Label Grid.Row="1" Grid.Column="0" Content="KONTO RASHODA"
               Visibility="{Binding PrikaziKonta, Converter={StaticResource BoolToVisibilityConverter}}"
               FontFamily="Tahoma" FontSize="12" Foreground="#BE0000" Background="#80FF80"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding KontoRashoda, UpdateSourceTrigger=PropertyChanged}"
                 Visibility="{Binding PrikaziKonta, Converter={StaticResource BoolToVisibilityConverter}}"
                 MaxLength="1" Width="70" HorizontalAlignment="Left" Style="{StaticResource InputStyle}"/>

        <Label Grid.Row="2" Grid.Column="0" Content="POČETNI DATUM"
               FontFamily="Tahoma" FontSize="12" Foreground="#BE0000" Background="#80FFFF"/>
        <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding PocetniDatum}"
                    FontFamily="Tahoma" FontSize="12" Height="30" Margin="0,3"/>

        <Label Grid.Row="3" Grid.Column="0" Content="ZADNJI DATUM"
               FontFamily="Tahoma" FontSize="12" Foreground="#BE0000" Background="#80FFFF"/>
        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding ZadnjiDatum}"
                    FontFamily="Tahoma" FontSize="12" Height="30" Margin="0,3"/>

        <Label Grid.Row="4" Grid.Column="0" Content="BROJ NALOGA"
               FontFamily="Tahoma" FontSize="12" Foreground="#BE0000" Background="#80FFFF"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BrojNaloga, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="6" Width="130" HorizontalAlignment="Left" Style="{StaticResource InputStyle}"/>

        <Label Grid.Row="5" Grid.Column="0" Content="OPIS"
               FontFamily="Tahoma" FontSize="12" Foreground="#BE0000" Background="#80FFFF"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Opis, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="30" Style="{StaticResource InputStyle}"/>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Zatvaranje" Width="150" Height="44" IsDefault="True"
                    FontFamily="Tahoma" FontSize="12" Command="{Binding ZatvaranjeCommand}"/>
            <Button Content="Izlaz" Width="100" Height="44" Margin="12,0,0,0"
                    FontFamily="Tahoma" FontSize="12" Foreground="#B00000"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
