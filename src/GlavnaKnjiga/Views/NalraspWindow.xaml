<Window x:Class="GlavnaKnjiga.Views.NalraspWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RASPODELA KLASE 9"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Header: LBLNALOG + LBLREC -->
        <Border DockPanel.Dock="Top" Background="#E2FEE2" BorderBrush="#8080A0" BorderThickness="0,0,0,1" Padding="4,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="{Binding LblNalog}" FontFamily="Tahoma" FontSize="10" FontWeight="Bold"
                       Background="#E2FEE2" Padding="2,0"/>
                <Label Grid.Column="1" Content="{Binding LblRec}"
                       FontFamily="Tahoma" FontSize="10" FontWeight="Bold" FontStyle="Italic"
                       Background="#C0C0C0" Foreground="Red" Padding="4,0" MinWidth="120"
                       BorderThickness="1" BorderBrush="Gray"/>
            </Grid>
        </Border>

        <!-- LBLAN0 info (yellow) -->
        <Border DockPanel.Dock="Top" Background="#FEFFC6" BorderBrush="#8080A0" BorderThickness="0,0,0,1" Padding="4,2">
            <Label Content="{Binding LblKonto}" FontFamily="Tahoma" FontSize="10" FontWeight="Bold" Padding="0"/>
        </Border>

        <!-- Bottom: konto + mtr info -->
        <Border DockPanel.Dock="Bottom" Background="#FDECCC" BorderBrush="#8080A0" BorderThickness="0,1,0,0" Padding="4,2">
            <StackPanel>
                <TextBlock Text="{Binding LblKonto}" FontFamily="Tahoma" FontSize="10" FontWeight="Bold"/>
                <TextBlock Text="{Binding LblMtr}"   FontFamily="Tahoma" FontSize="10"/>
            </StackPanel>
        </Border>

        <!-- Main body: Grid + Right buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <!-- Nav buttons below grid -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4">
                    <Button Content="◄◄" Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiNaVrhCommand}" ToolTip="PRVI"/>
                    <Button Content="◄"  Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiGoreCommand}" ToolTip="GORE"/>
                    <Button Content="►"  Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiDoleCommand}" ToolTip="DOLE"/>
                    <Button Content="►►" Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiNaDnoCommand}" ToolTip="ZADNJI"/>
                    <Button Content="+" Width="46" Height="28" Margin="8,0,2,0"
                            FontFamily="Tahoma" FontSize="10" Background="#80FFFF"
                            Command="{Binding DodajCommand}" ToolTip="DODAVANJE NOVOG REDA"/>
                </StackPanel>

                <!-- Action buttons row -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4">
                    <Button Content="BRISANJE REDA" Width="120" Height="28" Margin="2,0"
                            FontFamily="Tahoma" FontSize="10" Background="#80FF80"
                            Command="{Binding BrisanjeRedaCommand}"/>
                    <Button Content="BRISANJE TABELE" Width="130" Height="28" Margin="4,0"
                            FontFamily="Tahoma" FontSize="10" Background="#80FF80"
                            Command="{Binding BrisanjeTabeleCommand}"/>
                    <Button Content="NAPUNI SVA KONTA IZ GLAVNE KNJIGE" Width="230" Height="28" Margin="4,0"
                            FontFamily="Tahoma" FontSize="10" Background="#80FFFF"
                            Command="{Binding NapuniSvaKontaCommand}"/>
                    <Button Content="NAPUNI KONTA 52-55 I 60-62" Width="180" Height="28" Margin="4,0"
                            FontFamily="Tahoma" FontSize="10" Background="#80FFFF"
                            Command="{Binding NapuniKonta5255Command}"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="GrdMain"
                          ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          FontFamily="Tahoma" FontSize="11"
                          Background="#F5F5F5"
                          SelectionMode="Single"
                          HorizontalGridLinesBrush="#B7BCF9"
                          VerticalGridLinesBrush="#B7BCF9"
                          SelectionChanged="GrdMain_SelectionChanged"
                          CellEditEnding="GrdMain_CellEditEnding">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Konto"   Binding="{Binding Konto}"                       Width="110"/>
                        <DataGridTextColumn Header="K9"      Binding="{Binding K9}"                          Width="110"/>
                        <DataGridTextColumn Header="Učešće"  Binding="{Binding Ucesce, StringFormat=N3}"     Width="80"/>
                        <DataGridTextColumn Header="Dp"      Binding="{Binding Dp}"                          Width="45"/>
                        <DataGridTextColumn Header="Dug"     Binding="{Binding Dug, StringFormat=N2}"        Width="130"/>
                        <DataGridTextColumn Header="Pot"     Binding="{Binding Pot, StringFormat=N2}"        Width="130"/>
                        <DataGridTextColumn Header="Opis"    Binding="{Binding Opis}"                        Width="150"/>
                        <DataGridTextColumn Header="Mtr"     Binding="{Binding Mtr}"                         Width="55"/>
                        <DataGridTextColumn Header="Datdok"  Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Brnal"   Binding="{Binding Brnal}"                       Width="70"/>
                        <DataGridTextColumn Header="Dok"     Binding="{Binding Dok}"                         Width="45"/>
                        <DataGridTextColumn Header="K1"      Binding="{Binding K1}"                          Width="35"/>
                        <DataGridTextColumn Header="K2"      Binding="{Binding K2}"                          Width="40"/>
                        <DataGridTextColumn Header="K3"      Binding="{Binding K3}"                          Width="45"/>
                        <DataGridTextColumn Header="K4"      Binding="{Binding K4}"                          Width="50"/>
                        <DataGridTextColumn Header="K5"      Binding="{Binding K5}"                          Width="55"/>
                        <DataGridTextColumn Header="K6"      Binding="{Binding K6}"                          Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Right panel: action buttons -->
            <DockPanel Grid.Column="1" Margin="4,0,4,0">
                <Button DockPanel.Dock="Bottom" Content="Izlaz" Height="36" Margin="4,4"
                        FontFamily="Tahoma" FontSize="11" Background="#C0C0C0" Foreground="Red"
                        Command="{Binding IzlazCommand}"/>

                <StackPanel Margin="0,8,0,0">
                    <Button Content="PREUZIMANJE F6"  Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#80FFFF" Command="{Binding PreuzimanjeCommand}"/>
                    <Button Content="KNJIŽENJE F5"    Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#80FFFF" Command="{Binding KnjizenjeCommand}"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
