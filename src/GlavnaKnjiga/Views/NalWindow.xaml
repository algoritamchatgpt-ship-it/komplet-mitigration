<Window x:Class="GlavnaKnjiga.Views.NalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DNEVNIK GLAVNE KNJIGE"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A237E" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="105"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="NALOG:" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding IzabraniNalog}" Foreground="#FFF59D"
                           FontWeight="Bold" Margin="7,0,18,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="DATUM:" Foreground="White" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding IzabraniDatum}" Foreground="#FFF59D"
                           FontWeight="Bold" Margin="7,0,18,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="{Binding Brojac}" Foreground="White"
                           FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8EAF6" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Konto: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding IzabraniKonto}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding KontoNaziv}" FontWeight="Bold"/>
                </StackPanel>
                <Button Grid.Column="1" Content="IZLAZ" Width="100" Height="32"
                        Foreground="#B00000" Command="{Binding IzlazCommand}"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="285"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="5">
                    <Button Content="|◄" Width="38" Height="30" Margin="2" Command="{Binding IdiNaVrhCommand}"/>
                    <Button Content="◄" Width="38" Height="30" Margin="2" Command="{Binding IdiGoreCommand}"/>
                    <Button Content="►" Width="38" Height="30" Margin="2" Command="{Binding IdiDoleCommand}"/>
                    <Button Content="►|" Width="38" Height="30" Margin="2" Command="{Binding IdiNaDnoCommand}"/>
                    <Button Content="{Binding SortOpis}" MinWidth="220" Height="30"
                            Margin="12,2,2,2" Command="{Binding PromeniSortiranjeCommand}"/>
                </StackPanel>

                <DataGrid x:Name="GrdNal"
                          ItemsSource="{Binding Redovi}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          FontFamily="Tahoma"
                          FontSize="11"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Konto" Binding="{Binding Konto}" Width="100"/>
                        <DataGridTextColumn Header="Duguje" Binding="{Binding Dug, StringFormat=N2}" Width="115"/>
                        <DataGridTextColumn Header="Potražuje" Binding="{Binding Pot, StringFormat=N2}" Width="115"/>
                        <DataGridTextColumn Header="Opis" Binding="{Binding Opis}" Width="220"/>
                        <DataGridTextColumn Header="Datum" Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Nalog" Binding="{Binding Brnal}" Width="75"/>
                        <DataGridTextColumn Header="Dok." Binding="{Binding Dok}" Width="60"/>
                        <DataGridTextColumn Header="MP" Binding="{Binding Mp, StringFormat=N0}" Width="55"/>
                        <DataGridTextColumn Header="MTR" Binding="{Binding Mtr, StringFormat=N0}" Width="60"/>
                        <DataGridTextColumn Header="Dev." Binding="{Binding Dev}" Width="55"/>
                        <DataGridTextColumn Header="Dev. kurs" Binding="{Binding Devkurs, StringFormat=N4}" Width="85"/>
                        <DataGridTextColumn Header="Dev. duguje" Binding="{Binding Devdug, StringFormat=N2}" Width="110"/>
                        <DataGridTextColumn Header="Dev. potražuje" Binding="{Binding Devpot, StringFormat=N2}" Width="120"/>
                        <DataGridTextColumn Header="Šifra" Binding="{Binding Sifra}" Width="95"/>
                        <DataGridTextColumn Header="Broj računa" Binding="{Binding Brrac}" Width="120"/>
                        <DataGridTextColumn Header="Ulaz" Binding="{Binding Ulaz, StringFormat=N3}" Width="90"/>
                        <DataGridTextColumn Header="Izlaz" Binding="{Binding Izlaz, StringFormat=N3}" Width="90"/>
                        <DataGridTextColumn Header="Operater" Binding="{Binding Oper}" Width="85"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <GroupBox Header="Traženje" Margin="0,0,0,8">
                        <StackPanel Margin="6">
                            <TextBlock Text="Konto (početak)"/>
                            <DockPanel Margin="0,2,0,7">
                                <Button DockPanel.Dock="Right" Content="F5" Width="42"
                                        Command="{Binding NadjiKontoCommand}"/>
                                <TextBox Text="{Binding TraziKonto, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>
                            <TextBlock Text="Broj naloga"/>
                            <DockPanel Margin="0,2,0,7">
                                <Button DockPanel.Dock="Right" Content="F9" Width="42"
                                        Command="{Binding NadjiNalogCommand}"/>
                                <TextBox Text="{Binding TraziNalog, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>
                            <TextBlock Text="Datum dokumenta"/>
                            <DockPanel Margin="0,2,0,0">
                                <Button DockPanel.Dock="Right" Content="F8" Width="42"
                                        Command="{Binding NadjiDatumCommand}"/>
                                <DatePicker SelectedDate="{Binding TraziDatum}"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Zbir izabranog naloga" Margin="0,0,0,8">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Duguje:" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="{Binding NalogDuguje, StringFormat=N2}"
                                       TextAlignment="Right"/>
                            <TextBlock Grid.Row="1" Text="Potražuje:" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding NalogPotrazuje, StringFormat=N2}" TextAlignment="Right"/>
                            <TextBlock Grid.Row="2" Text="Saldo:" FontWeight="Bold"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding NalogSaldo, StringFormat=N2}" TextAlignment="Right"/>
                        </Grid>
                    </GroupBox>

                    <Button Content="PREGLED NALOGA F10" Height="32" Margin="0,2"
                            Command="{Binding PregledNalogaCommand}"/>
                    <Button Content="PREGLED KONTA F6" Height="32" Margin="0,2"
                            Command="{Binding PregledKontaCommand}"/>
                    <Button Content="NALOG SINTETIKA" Height="32" Margin="0,2"
                            Command="{Binding NalogSintetikaCommand}"/>
                    <Button Content="DEVIZNI NALOG" Height="32" Margin="0,8,0,2"
                            Command="{Binding DevizniNalogCommand}"/>
                    <Button Content="DEVIZNI KONTO" Height="32" Margin="0,2"
                            Command="{Binding DevizniKontoCommand}"/>
                    <Button Content="KONTNI PLAN F4" Height="32" Margin="0,8,0,2"
                            Background="#C5E1A5" Command="{Binding KontniPlanCommand}"/>
                    <Button Content="IZVEŠTAJ DNEVNIKA" Height="32" Margin="0,2"
                            Background="#BBDEFB" Command="{Binding DnevnikIzvestajCommand}"/>
                    <Button Content="RAZNO" Height="32" Margin="0,2"
                            Background="#FFE0B2" Command="{Binding RaznoCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
