<Window x:Class="GlavnaKnjiga.Views.NalprkonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Height="520" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#D0DFD0"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Buttons -->
        <WrapPanel DockPanel.Dock="Bottom" Margin="6,4" HorizontalAlignment="Center">
            <Button Content="PREUZIMANJE"  Width="110" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding PreuzimanjeCommand}"/>
            <Button Content="KARTICA F10"  Width="100" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding KarticaF10Command}"/>
            <Button Content="SORT"         Width="70"  Margin="4,2" Background="#C0C0C0"
                    Command="{Binding SortCommand}"/>
            <Button Content="TRAŽENJE F6"  Width="100" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding TraziF6Command}"/>
            <Button Content="PRVI"         Width="55"  Margin="4,2"
                    Command="{Binding IdiNaVrhCommand}"/>
            <Button Content="GORE"         Width="55"  Margin="4,2"
                    Command="{Binding IdiGoreCommand}"/>
            <Button Content="DOLE"         Width="55"  Margin="4,2"
                    Command="{Binding IdiDoleCommand}"/>
            <Button Content="ZADNJI"       Width="60"  Margin="4,2"
                    Command="{Binding IdiNaDnoCommand}"/>
            <Button Content="Izlaz"        Width="80"  Margin="4,2" Background="#C0C0C0"
                    Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid x:Name="Grd0"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelektovaniRed}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="10"
                  SelectionMode="Single"
                  LoadingRow="Grd0_LoadingRow"
                  Margin="4,4,4,4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Konto"  Binding="{Binding Konto}"         Width="90"/>
                <DataGridTextColumn Header="Dug"    Binding="{Binding Dug,    StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Pot"    Binding="{Binding Pot,    StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Saldo"  Binding="{Binding Saldo,  StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Naziv"  Binding="{Binding Naziv}"                   Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
