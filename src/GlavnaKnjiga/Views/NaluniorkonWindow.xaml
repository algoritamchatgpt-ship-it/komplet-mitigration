<Window x:Class="GlavnaKnjiga.Views.NaluniorkonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tabela kontiranja Unior"
        Height="460" Width="760"
        WindowStartupLocation="CenterScreen"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <WrapPanel DockPanel.Dock="Bottom" Margin="6,4" HorizontalAlignment="Center">
            <Button Content="+"                  Width="40"  Margin="4,2" Background="#B7BCF9"
                    Command="{Binding DodajCommand}"/>
            <Button Content="BRISANJE ZADNJE"    Width="140" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding BrisanjeZadnjeCommand}"/>
            <Button Content="PRVI"               Width="50"  Margin="4,2"
                    Command="{Binding IdiNaVrhCommand}"/>
            <Button Content="GORE"               Width="50"  Margin="4,2"
                    Command="{Binding IdiGoreCommand}"/>
            <Button Content="DOLE"               Width="50"  Margin="4,2"
                    Command="{Binding IdiDoleCommand}"/>
            <Button Content="ZADNJI"             Width="55"  Margin="4,2"
                    Command="{Binding IdiNaDnoCommand}"/>
            <Button Content="Izlaz"              Width="75"  Margin="4,2" Background="#C0C0C0"
                    Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <DataGrid x:Name="Grd0"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelektovaniRed}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="10"
                  SelectionMode="Single"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vpdv"      Binding="{Binding Vpdv,      UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                <DataGridTextColumn Header="Kontoa"    Binding="{Binding Kontoa,    UpdateSourceTrigger=PropertyChanged}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="Blue"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Konto"     Binding="{Binding Konto,     UpdateSourceTrigger=PropertyChanged}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="Red"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Pogon"     Binding="{Binding Pogon,     UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Povezanol" Binding="{Binding Povezanol, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridTextColumn Header="Vrstaf"    Binding="{Binding Vrstaf,    UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Preneto"   Binding="{Binding Preneto,   UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn Header="Numred"    Binding="{Binding Numred}"                                          Width="70"/>
                <DataGridTextColumn Header="Idbr"      Binding="{Binding Idbr}"                                            Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
