<Window x:Class="GlavnaKnjiga.Views.NalzamenakontaKontaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Height="480" Width="760"
        WindowStartupLocation="CenterScreen"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Buttons -->
        <WrapPanel DockPanel.Dock="Bottom" Margin="6,4" HorizontalAlignment="Center">
            <Button Content="DODAJ"           Width="90"  Margin="4,2" Background="#B7BCF9"
                    Command="{Binding DodajCommand}"/>
            <Button Content="BRISANJE REDA"   Width="110" Margin="4,2" Background="#B7BCF9"
                    Command="{Binding BrisanjeCommand}"/>
            <Button Content="BRISANJE TABELE" Width="120" Margin="4,2" Background="#E09090"
                    Command="{Binding BrisanjeTabeleCommand}"/>
            <Button Content="ZAMENA"          Width="80"  Margin="4,2" Background="#90E090"
                    Command="{Binding ZamenaCommand}"/>
            <Button Content="PRVI"            Width="50"  Margin="4,2"
                    Command="{Binding IdiNaVrhCommand}"/>
            <Button Content="GORE"            Width="50"  Margin="4,2"
                    Command="{Binding IdiGoreCommand}"/>
            <Button Content="DOLE"            Width="50"  Margin="4,2"
                    Command="{Binding IdiDoleCommand}"/>
            <Button Content="ZADNJI"          Width="55"  Margin="4,2"
                    Command="{Binding IdiNaDnoCommand}"/>
            <Button Content="Izlaz"           Width="75"  Margin="4,2" Background="#B7BCF9"
                    Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid x:Name="Grd0"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelektovaniRed}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="10"
                  SelectionMode="Single"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kod"     Binding="{Binding Kod,     UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Naziv"   Binding="{Binding Naziv,   UpdateSourceTrigger=PropertyChanged}" Width="280"/>
                <DataGridTextColumn Header="Nazkto1" Binding="{Binding Nazkto1, UpdateSourceTrigger=PropertyChanged}" Width="280"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
