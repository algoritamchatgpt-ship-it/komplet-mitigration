<Window x:Class="GlavnaKnjiga.Views.NalzamenakontaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZAMENA KONTA"
        Height="320" Width="340"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAB8"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="OsMeniDugme" TargetType="Button">
            <Setter Property="Width"       Value="280"/>
            <Setter Property="Height"      Value="32"/>
            <Setter Property="Margin"      Value="0,3"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Background"  Value="#C0C0C0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"     Value="8,0"/>
        </Style>
    </Window.Resources>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <Button Style="{StaticResource OsMeniDugme}"
                Content="KLASE"
                Command="{Binding OtvoriKlaseCommand}"/>
        <Button Style="{StaticResource OsMeniDugme}"
                Content="GRUPE"
                Command="{Binding OtvoriGrupeCommand}"/>
        <Button Style="{StaticResource OsMeniDugme}"
                Content="SINTETIKA"
                Command="{Binding OtvoriSintetikaCommand}"/>
        <Button Style="{StaticResource OsMeniDugme}"
                Content="ANALITIKA 10"
                Command="{Binding OtvoriAnalitika10Command}"/>
        <Button Style="{StaticResource OsMeniDugme}"
                Content="PREKNJIŽAVANJE KONTA"
                Command="{Binding OtvoriPreknjizbKontaCommand}"/>
        <Button Style="{StaticResource OsMeniDugme}"
                Content="UPOREDNI PREGLED"
                Command="{Binding OtvoriUporedniPregledCommand}"/>
        <Button Style="{StaticResource OsMeniDugme}"
                Content="IZLAZ"
                Foreground="Red"
                Command="{Binding IzlazCommand}"/>
    </StackPanel>
</Window>
