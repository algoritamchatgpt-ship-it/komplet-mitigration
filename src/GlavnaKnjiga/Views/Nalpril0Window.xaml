<Window x:Class="GlavnaKnjiga.Views.Nalpril0Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DODAVANJE KONTA ANALITIKE"
        Height="500" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2B2B8C" Padding="8,4">
            <TextBlock Text="DODAVANJE KONTA ANALITIKE"
                       Foreground="White" FontSize="11" FontWeight="Bold"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="8,4">
            <Button Content="DODAVANJE"    Width="110" Margin="2" Background="#C0C0C0"
                    Command="{Binding DodavanjeCommand}"/>
            <Button Content="BRISANJE REDA" Width="120" Margin="2" Background="#C0C0C0"
                    Command="{Binding BrisanjeRedaCommand}"/>
            <Button Content="|&lt;" Width="36" Margin="2" Background="#C0C0C0" Command="{Binding PrviCommand}"/>
            <Button Content="&lt;"  Width="36" Margin="2" Background="#C0C0C0" Command="{Binding GoreCommand}"/>
            <Button Content="&gt;"  Width="36" Margin="2" Background="#C0C0C0" Command="{Binding DoleCommand}"/>
            <Button Content="&gt;|" Width="36" Margin="2" Background="#C0C0C0" Command="{Binding ZadnjiCommand}"/>
            <Button Content="Izlaz" Width="80" Margin="2" Background="#C0C0C0" Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  FontSize="11"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Konto"   Binding="{Binding Konto}"   Width="120"/>
                <DataGridTextColumn Header="Dp"      Binding="{Binding Dp}"      Width="50"/>
                <DataGridTextColumn Header="Preneto" Binding="{Binding Preneto}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
