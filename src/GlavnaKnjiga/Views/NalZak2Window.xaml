<Window x:Class="GlavnaKnjiga.Views.NalZak2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZAKLJUČNI LIST — REZULTATI"
        Height="300" Width="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Blue group: štampa -->
        <WrapPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="KLASE 1"        Width="130" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding Klase1Command}"/>
            <Button Content="GRUPE 2"        Width="130" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding Grupe2Command}"/>
            <Button Content="SINTETIKA 3"    Width="130" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding Sintetika3Command}"/>
            <Button Content="SINTETIKA 4"    Width="130" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding Sintetika4Command}"/>
        </WrapPanel>

        <!-- Blue Excel group -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="EXCEL KLASE 1"       Width="148" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding ExcelKlase1Command}"/>
            <Button Content="EXCEL GRUPE 2"       Width="148" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding ExcelGrupe2Command}"/>
            <Button Content="EXCEL SINTETIKA 3"   Width="148" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding ExcelSintetika3Command}"/>
            <Button Content="EXCEL SINTETIKA 4"   Width="148" Margin="4,2" Background="#C0C0C0" Foreground="Blue"
                    Command="{Binding ExcelSintetika4Command}"/>
        </WrapPanel>

        <!-- Red group: analitika -->
        <WrapPanel Grid.Row="4" Orientation="Horizontal">
            <Button Content="ANALITIKA 6"          Width="130" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding Analitika6Command}"/>
            <Button Content="ANALITIKA 10"         Width="130" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding Analitika10Command}"/>
            <Button Content="EXCEL ANALITIKA 2"    Width="148" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding ExcelAnalitika2Command}"/>
            <Button Content="TXT ANALITIKA 2"      Width="148" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding TxtAnalitika2Command}"/>
            <Button Content="EXCEL ANALITIKA 6"    Width="148" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding ExcelAnalitika6Command}"/>
        </WrapPanel>

        <!-- Other -->
        <WrapPanel Grid.Row="6" Orientation="Horizontal">
            <Button Content="SVE SA NAZIVIMA KONTA"  Width="200" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding SveSaNazivimaKontaCommand}"/>
            <Button Content="SVE BEZ NAZIVA KONTA"   Width="200" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding SveBezNazivaKontaCommand}"/>
            <Button Content="AKTIVNI KONTNI PLAN"    Width="200" Margin="4,2" Background="#C0C0C0" Foreground="DarkRed"
                    Command="{Binding AktivniKontniPlanCommand}"/>
        </WrapPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="IZLAZ" Width="80" Background="#FF8080" Foreground="DarkRed"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
