<Window x:Class="GlavnaKnjiga.Views.NalzamkonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZAMENA KONTA U GLAVNOJ KNJIZI"
        Height="330" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#95BC94"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="STARI KONTO"
               FontFamily="Tahoma" FontSize="12" Background="#80FF80"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 Text="{Binding StariKonto, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="10" Style="{StaticResource InputStyle}"/>

        <Label Grid.Row="1" Grid.Column="0" Content="NOVI KONTO"
               FontFamily="Tahoma" FontSize="12" Background="#80FF80"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding NoviKonto, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="10" Style="{StaticResource InputStyle}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   Margin="0,18,0,0" TextWrapping="Wrap"
                   Text="Menjaju se samo redovi čiji je konto potpuno jednak starom kontu."
                   FontFamily="Tahoma" FontSize="11" Foreground="#303030"/>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Zamena" Width="140" Height="46" IsDefault="True"
                    FontFamily="Tahoma" FontSize="12" Command="{Binding ZamenaCommand}"/>
            <Button Content="Izlaz" Width="100" Height="46" Margin="12,0,0,0"
                    FontFamily="Tahoma" FontSize="12" Foreground="#B00000"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
