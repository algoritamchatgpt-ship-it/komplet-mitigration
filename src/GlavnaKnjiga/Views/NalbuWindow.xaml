<Window x:Class="GlavnaKnjiga.Views.NalbuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BILANS USPEHA" Height="540" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#ECE9D8"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Tahoma"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="Foreground"    Value="#C40000"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"        Value="4,2"/>
        </Style>
        <Style x:Key="Txt" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="2,2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <WrapPanel DockPanel.Dock="Bottom" Margin="8,6" HorizontalAlignment="Center">
            <Button Content="PREGLED" Width="120" Margin="4,2"
                    Command="{Binding PregledCommand}" Background="#C8F0FF"/>
            <Button Content="IZLAZ"   Width="80"  Margin="4,2" Background="#C0C0C0"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"  Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO PRIHODA"/>
            <TextBox   Grid.Row="0"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoP1, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="1"  Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO PRIHODA"/>
            <TextBox   Grid.Row="1"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoP2, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="2"  Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO PRIHODA"/>
            <TextBox   Grid.Row="2"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoP3, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="3"  Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO RASHODA"/>
            <TextBox   Grid.Row="3"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoR1, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="4"  Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO RASHODA"/>
            <TextBox   Grid.Row="4"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoR2, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="5"  Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO RASHODA"/>
            <TextBox   Grid.Row="5"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoR3, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="6"  Grid.Column="0" Style="{StaticResource Lbl}" Text="POČETNI DATUM"/>
            <DatePicker Grid.Row="6" Grid.Column="1" Margin="2" SelectedDate="{Binding Dat0}"/>

            <TextBlock Grid.Row="7"  Grid.Column="0" Style="{StaticResource Lbl}" Text="ZADNJI DATUM"/>
            <DatePicker Grid.Row="7" Grid.Column="1" Margin="2" SelectedDate="{Binding Dat1}"/>

            <TextBlock Grid.Row="8"  Grid.Column="0" Style="{StaticResource Lbl}" Text="OBJEKAT (DOK)"/>
            <TextBox   Grid.Row="8"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding Dok, UpdateSourceTrigger=PropertyChanged}" MaxLength="4"/>

            <TextBlock Grid.Row="9"  Grid.Column="0" Style="{StaticResource Lbl}" Text="MESTO-GRAD (MP)"/>
            <TextBox   Grid.Row="9"  Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding Mp, UpdateSourceTrigger=PropertyChanged}" MaxLength="2"/>

            <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource Lbl}" Text="MESTO TROŠKOVA"/>
            <TextBox   Grid.Row="10" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding Mtr, UpdateSourceTrigger=PropertyChanged}" MaxLength="3"/>

            <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource Lbl}" Text="SVODJENJE NA KURS D/N"/>
            <TextBox   Grid.Row="11" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding Kurs, UpdateSourceTrigger=PropertyChanged}" MaxLength="1"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource Lbl}" Text="NALOG KOJI SE IZUZIMA 1"/>
            <TextBox   Grid.Row="12" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding Brnal1, UpdateSourceTrigger=PropertyChanged}" MaxLength="6"/>

            <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource Lbl}" Text="NALOG KOJI SE IZUZIMA 2"/>
            <TextBox   Grid.Row="13" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding Brnal2, UpdateSourceTrigger=PropertyChanged}" MaxLength="6"/>

            <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource Lbl}" Text="SALDO PO OBJEKTIMA D/N"/>
            <TextBox   Grid.Row="14" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding SaldoObj, UpdateSourceTrigger=PropertyChanged}" MaxLength="1"/>

            <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource Lbl}" Text="UKLJUČI DODA. PRIH/RASH D/N"/>
            <TextBox   Grid.Row="15" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding DodPrih, UpdateSourceTrigger=PropertyChanged}" MaxLength="1"/>

            <TextBlock Grid.Row="16" Grid.Column="0" Style="{StaticResource Lbl}" Text="SALDO PO MESTIMA TROŠKOVA D/N"/>
            <TextBox   Grid.Row="16" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding SaldoMtr, UpdateSourceTrigger=PropertyChanged}" MaxLength="1"/>
        </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
