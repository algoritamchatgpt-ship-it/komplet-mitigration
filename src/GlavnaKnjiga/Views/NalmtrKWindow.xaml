<Window x:Class="GlavnaKnjiga.Views.NalmtrKWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KONTA MESTA TROŠKOVA"
        Height="700" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        WindowState="Maximized">

    <DockPanel>
        <!-- Button row -->
        <WrapPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4">
            <Button Content="PRVI"            Width="55"  Margin="2" Command="{Binding IdiNaVrhCommand}" Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Button Content="GORE"            Width="55"  Margin="2" Command="{Binding IdiGoreCommand}"  Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Button Content="DOLE"            Width="55"  Margin="2" Command="{Binding IdiDoleCommand}"  Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Button Content="ZADNJI"          Width="55"  Margin="2" Command="{Binding IdiNaDnoCommand}" Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Separator Width="8"/>
            <Button Content="DODAJ"           Width="70"  Margin="2" Command="{Binding DodajCommand}"          Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="BRISANJE"        Width="80"  Margin="2" Command="{Binding BrisanjeCommand}"       Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="BRISANJE TABELE" Width="120" Margin="2" Command="{Binding BrisanjeTabeleCommand}" Background="#F3FAA3" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="SNIMI"           Width="70"  Margin="2" Command="{Binding SnimiCommand}"          Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Separator Width="8"/>
            <Button Content="Izlaz"           Width="70"  Margin="2" Command="{Binding IzlazCommand}"          Background="#C0C0C0" FontFamily="Tahoma" FontSize="11" Foreground="Red"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="11"
                  Background="#F5F5F5"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#B7BCF9"
                  VerticalGridLinesBrush="#B7BCF9"
                  SelectionMode="Single"
                  Margin="2">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Background" Value="#B7BCF9"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kontotr" Binding="{Binding Kontotr}" Width="120"/>
                <DataGridTextColumn Header="Naziv"   Binding="{Binding Naziv}"   Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
