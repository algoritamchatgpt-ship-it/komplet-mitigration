<Window x:Class="GlavnaKnjiga.Views.NalpMatizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="380" Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#95BC94"
        KeyDown="Window_KeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row: NALOG + DATUM -->
        <Grid Grid.Row="0" Background="#FFFFB7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="NALOG" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="1" FontSize="11" Text="{Binding Row.Brnal, Mode=OneWay}" IsReadOnly="True" Margin="0,1"/>
            <TextBlock Grid.Column="2" Text="DATUM" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="3" FontSize="11" Text="{Binding Row.Datdok, StringFormat=dd.MM.yyyy, Mode=OneWay}" IsReadOnly="True" Margin="0,1"/>
        </Grid>

        <!-- Konto + Naziv -->
        <Grid Grid.Row="2" Background="#FFFFB7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Konto" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="1" FontSize="11" Text="{Binding Row.Konto, Mode=OneWay}" IsReadOnly="True" Margin="0,1"/>
            <TextBox Grid.Column="2" FontSize="11" Text="{Binding Naziv, Mode=OneWay}" IsReadOnly="True" Margin="4,1,0,1"/>
        </Grid>

        <!-- Dug + Pot + Opis -->
        <Grid Grid.Row="4" Background="#FFFFB7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="DUGUJE"    FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="1"   FontSize="11" Text="{Binding Row.Dug, Mode=OneWay}" IsReadOnly="True" Margin="0,1"/>
            <TextBlock Grid.Column="2" Text="POTRAŽUJE" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="3"   FontSize="11" Text="{Binding Row.Pot, Mode=OneWay}" IsReadOnly="True" Margin="0,1"/>
            <TextBlock Grid.Column="4" Text="OPIS" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Grid.Column="5"   FontSize="11" Text="{Binding Row.Opis, Mode=OneWay}" IsReadOnly="True" Margin="0,1"/>
        </Grid>

        <!-- Stanje + Saldo (computed) -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="KOLIČINA NA STANJU" FontSize="11" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" FontSize="11" Text="{Binding MStanje, Mode=OneWay}" IsReadOnly="True"/>
            <TextBlock Grid.Column="2" Text="VREDNOST NA STANJU" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <TextBox Grid.Column="3" FontSize="11" Text="{Binding MSaldo, Mode=OneWay}" IsReadOnly="True"/>
        </Grid>

        <!-- Separator label -->
        <Border Grid.Row="8" Background="#D3EBF1" Padding="4,2">
            <TextBlock Text="EVIDENCIJA IZLAZA MATERIJALA" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- IZLAZNA KOLIČINA -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="IZLAZNA KOLIČINA" FontSize="11" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" FontSize="11"
                     Text="{Binding Row.Izlaz, UpdateSourceTrigger=LostFocus}"/>
        </Grid>

        <!-- IZLAZNA CENA (readonly) -->
        <Grid Grid.Row="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="IZLAZNA CENA" FontSize="11" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" FontSize="11" Text="{Binding Row.Cena, Mode=OneWay}" IsReadOnly="True"/>
        </Grid>

        <!-- IZLAZNA VREDNOST (readonly) -->
        <Grid Grid.Row="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="IZLAZNA VREDNOST" FontSize="11" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" FontSize="11" Text="{Binding Row.UkupnoP, Mode=OneWay}" IsReadOnly="True"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="18" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="&lt;Obračun" Width="120" Margin="8,0"
                    Background="#C0C0C0"
                    Command="{Binding ObracunCommand}"/>
            <Button Content="&lt;Izlaz" Width="100" Margin="8,0"
                    Background="#C0C0C0" Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
