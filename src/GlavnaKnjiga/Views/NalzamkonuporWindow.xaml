<Window x:Class="GlavnaKnjiga.Views.NalzamkonuporWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UPOREDNI PREGLED KONTA"
        Height="500" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <WrapPanel DockPanel.Dock="Bottom" Margin="6,4" HorizontalAlignment="Center">
            <Button Content="DODAJ"              Width="90"  Margin="4,2" Background="#B7BCF9"
                    Command="{Binding DodajCommand}"/>
            <Button Content="BRISANJE REDA"      Width="110" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding BrisanjeRedaCommand}"/>
            <Button Content="BRISANJE TABELE"    Width="120" Margin="4,2" Background="#FFD7D7"
                    Command="{Binding BrisanjeTabeleCommand}"/>
            <Button Content="PREUZMI IZ TXT"     Width="110" Margin="4,2" Background="#B7BCF9"
                    Command="{Binding PreuzmiUporedanuCommand}"/>
            <Button Content="KOPIRAJ U TXT"      Width="110" Margin="4,2" Background="#B7BCF9"
                    Command="{Binding KopirajUTekstCommand}"/>
            <Button Content="PRVI"               Width="50"  Margin="4,2"
                    Command="{Binding IdiNaVrhCommand}"/>
            <Button Content="GORE"               Width="50"  Margin="4,2"
                    Command="{Binding IdiGoreCommand}"/>
            <Button Content="DOLE"               Width="50"  Margin="4,2"
                    Command="{Binding IdiDoleCommand}"/>
            <Button Content="ZADNJI"             Width="55"  Margin="4,2"
                    Command="{Binding IdiNaDnoCommand}"/>
            <Button Content="Izlaz"              Width="75"  Margin="4,2" Background="#B7BCF9"
                    Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <DataGrid x:Name="Grd0"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelektovaniRed}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="9"
                  SelectionMode="Single"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Skonto"  Binding="{Binding Skonto,  UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Deo"     Binding="{Binding Deo,     UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                <DataGridTextColumn Header="Sopis"   Binding="{Binding Sopis,   UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                <DataGridTextColumn Header="Konto"   Binding="{Binding Konto,   UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Opis"    Binding="{Binding Opis,    UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                <DataGridTextColumn Header="Preneto" Binding="{Binding Preneto, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn Header="Numred"  Binding="{Binding Numred}"                                       Width="70"/>
                <DataGridTextColumn Header="Idbr"    Binding="{Binding Idbr}"                                         Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
