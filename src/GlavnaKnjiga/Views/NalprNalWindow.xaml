<Window x:Class="GlavnaKnjiga.Views.NalprNalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Height="520" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#D8D0E8"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Buttons -->
        <WrapPanel DockPanel.Dock="Bottom" Margin="6,4" HorizontalAlignment="Center">
            <Button Content="PREUZIMANJE"       Width="110" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding PreuzimanjeCommand}"/>
            <Button Content="NALOG SINTETIKA F10" Width="140" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding NalogSintetikaF10Command}"/>
            <Button Content="SORT"              Width="70"  Margin="4,2" Background="#C0C0C0"
                    Command="{Binding SortCommand}"/>
            <Button Content="TRAŽENJE F6"       Width="100" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding TraziF6Command}"/>
            <Button Content="PRVI"              Width="55"  Margin="4,2"
                    Command="{Binding IdiNaVrhCommand}"/>
            <Button Content="GORE"              Width="55"  Margin="4,2"
                    Command="{Binding IdiGoreCommand}"/>
            <Button Content="DOLE"              Width="55"  Margin="4,2"
                    Command="{Binding IdiDoleCommand}"/>
            <Button Content="ZADNJI"            Width="60"  Margin="4,2"
                    Command="{Binding IdiNaDnoCommand}"/>
            <Button Content="Izlaz"             Width="80"  Margin="4,2" Background="#C0C0C0"
                    Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid x:Name="Grd0"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelektovaniRed}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="10"
                  SelectionMode="Single"
                  Margin="4,4,4,4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Brnal"   Binding="{Binding Brnal}"                      Width="60"/>
                <DataGridTextColumn Header="Datdok"  Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="80"/>
                <DataGridTextColumn Header="Dug"     Binding="{Binding Dug,    StringFormat=N2}"    Width="100"/>
                <DataGridTextColumn Header="Pot"     Binding="{Binding Pot,    StringFormat=N2}"    Width="100"/>
                <DataGridTextColumn Header="Opis"    Binding="{Binding Opis}"                       Width="150"/>
                <DataGridTextColumn Header="Dok"     Binding="{Binding Dok}"                        Width="40"/>
                <DataGridTextColumn Header="Mp"      Binding="{Binding Mp}"                         Width="36"/>
                <DataGridTextColumn Header="Mtr"     Binding="{Binding Mtr}"                        Width="40"/>
                <DataGridTextColumn Header="Automnal" Binding="{Binding Automnal}"                  Width="50"/>
                <DataGridTextColumn Header="Vrnal"   Binding="{Binding Vrnal}"                      Width="44"/>
                <DataGridTextColumn Header="Naziv"   Binding="{Binding Naziv}"                      Width="120"/>
                <DataGridTextColumn Header="Obl"     Binding="{Binding Obl}"                        Width="32"/>
                <DataGridTextColumn Header="Period"  Binding="{Binding Period}"                     Width="50"/>
                <DataGridTextColumn Header="Naldok"  Binding="{Binding Naldok}"                     Width="48"/>
                <DataGridTextColumn Header="Znakovi" Binding="{Binding Znakovi}"                    Width="55"/>
                <DataGridTextColumn Header="Pocsif"  Binding="{Binding Pocsif}"                     Width="50"/>
                <DataGridTextColumn Header="Nauto"   Binding="{Binding Nauto}"                      Width="44"/>
                <DataGridTextColumn Header="Konto"   Binding="{Binding Konto}"                      Width="80"/>
                <DataGridTextColumn Header="Saldo"   Binding="{Binding Saldo,  StringFormat=N2}"    Width="100"/>
                <DataGridTextColumn Header="Datknji" Binding="{Binding Datknji, StringFormat=dd.MM.yyyy}" Width="80"/>
                <DataGridTextColumn Header="Oper"    Binding="{Binding Oper}"                       Width="40"/>
                <DataGridTextColumn Header="Preneto" Binding="{Binding Preneto}"                    Width="55"/>
                <DataGridTextColumn Header="Idbr"    Binding="{Binding Idbr}"                       Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
