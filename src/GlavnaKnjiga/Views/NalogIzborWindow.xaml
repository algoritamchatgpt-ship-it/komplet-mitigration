<Window x:Class="GlavnaKnjiga.Views.NalogIzborWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Izbor naloga"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="CanResize"
        MaxHeight="600"
        KeyDown="Window_KeyDown">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="80" MaxHeight="350"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Broj naloga:" FontSize="11" Margin="0,0,0,2"/>
        <TextBox Grid.Row="1" x:Name="TxtBrnal" FontSize="12" Padding="4,2"
                 MaxLength="6" Margin="0,0,0,6"
                 KeyDown="TxtBrnal_KeyDown"/>

        <ListBox Grid.Row="2" x:Name="LstNalozi" FontFamily="Consolas" FontSize="11"
                 Margin="0,0,0,6"
                 MouseDoubleClick="LstNalozi_DoubleClick"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,6,0"
                    IsDefault="True" Click="BtnOk_Click" Background="#C0C0C0"/>
            <Button Content="Odustani" Width="80" Height="28"
                    IsCancel="True" Background="#C0C0C0"/>
        </StackPanel>
    </Grid>
</Window>
