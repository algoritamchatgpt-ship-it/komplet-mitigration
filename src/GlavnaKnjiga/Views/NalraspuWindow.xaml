<Window x:Class="GlavnaKnjiga.Views.NalraspuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PREUZIMANJE PODATAKA ZA RASPODELU KLASE 9"
        Height="280" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Početni datum -->
        <Label Grid.Row="0" Grid.Column="0" Content="POČETNI DATUM"
               FontFamily="Tahoma" FontSize="11" Foreground="#BE0000" Background="#80FFFF" Padding="2"/>
        <DatePicker x:Name="TxtDat0" Grid.Row="0" Grid.Column="1"
                    FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Zadnji datum -->
        <Label Grid.Row="1" Grid.Column="0" Content="ZADNJI DATUM"
               FontFamily="Tahoma" FontSize="11" Foreground="#BE0000" Background="#80FFFF" Padding="2"/>
        <DatePicker x:Name="TxtDat1" Grid.Row="1" Grid.Column="1"
                    FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Mesto troškova -->
        <Label Grid.Row="2" Grid.Column="0" Content="MESTO TROŠKOVA"
               FontFamily="Tahoma" FontSize="11" Foreground="#BE0000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtMtr" Grid.Row="2" Grid.Column="1" MaxLength="5"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="70" HorizontalAlignment="Left"/>

        <!-- Broj naloga -->
        <Label Grid.Row="3" Grid.Column="0" Content="BROJ NALOGA"
               FontFamily="Tahoma" FontSize="11" Foreground="#BE0000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtBrnal" Grid.Row="3" Grid.Column="1" MaxLength="6" Text="900001"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="80" HorizontalAlignment="Left"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button x:Name="BtnPreuzmi" Content="PREUZMI" Width="120" Height="36"
                    FontFamily="Tahoma" FontSize="11" Background="#C0C0C0"
                    Click="BtnPreuzmi_Click"/>
            <Button Content="IZLAZ" Width="80" Height="36" Margin="12,0,0,0"
                    FontFamily="Tahoma" FontSize="11" Background="#C0C0C0" Foreground="Red"
                    Click="BtnIzlaz_Click"/>
        </StackPanel>
    </Grid>
</Window>
