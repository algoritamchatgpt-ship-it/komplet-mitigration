<Window x:Class="GlavnaKnjiga.Views.GkMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Glavna knjiga" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FB">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A237E" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding NaslovHeader}" Foreground="White" FontFamily="Tahoma" FontSize="13" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Firma" Width="90" Margin="0,0,8,0" Command="{Binding OtvoriPodatkeOFirmiCommand}"/>
                    <Button Content="Promena firme" Width="120" Margin="0,0,8,0" Command="{Binding PromenaFirmeCommand}"/>
                    <Button Content="Odjava" Width="90" Command="{Binding OdjavaCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24" Width="420" HorizontalAlignment="Left">
            <Button Content="IZRADA NALOGA ZA KNJIŽENJE (NALP2)"    Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalp2Command}"/>
            <Button Content="NEDOVRŠENI NALOZI (NALPN)"             Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalpNCommand}"/>
            <Button Content="DEFINICIJA KONTA ANALITIKE (NALPDEFK)" Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalpDefkCommand}"/>
            <Button Content="EVIDENCIJA NALOGA (NALBROJ)"           Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalbrojCommand}"/>
            <Button Content="VRSTE NALOGA (NALVRSTA)"               Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalvrstaCommand}"/>
            <Button Content="PARAMETRI ANALITIKE (NALANPAR)"        Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalanparCommand}"/>
            <Button Content="DNEVNIK GLAVNE KNJIGE (NAL)"          Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalCommand}"/>
            <Button Content="IZVEŠTAJ DNEVNIKA GK (NALDNEV)"       Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNaldnevCommand}"/>
            <Button Content="KARTICE GK (NALKARTICE)"              Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalkarticeCommand}"/>
            <Button Content="MESTA TROŠKOVA (NALMTR)"              Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalmtrCommand}"/>
            <Button Content="EVIDENCIJA KLASE 9 — 10 CIFARA (NALGK10)" Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalgk10Command}"/>
            <Button Content="RASPODELA KLASE 9 (NALRASP)"             Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalraspCommand}"/>
            <Button Content="RAZNO — SERVISNE OPERACIJE (NALRAZNO)"  Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalraznoCommand}"/>
            <Button Content="KOPIRANJE NALOGA (NALKOPI)"           Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalkopCommand}"/>
            <Button Content="IZVEŠTAJI GK (NALIZV)"               Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalizivCommand}"/>
            <Button Content="PREGLED PO KONTIMA (NALPRKON)"        Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalprkonCommand}"/>
            <Button Content="PREGLED PO NALOZIMA (NALPRNAL)"       Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalprNalCommand}"/>
            <Button Content="ZAMENA KONTA (NALZAMENAKONTA)"        Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalzamenakontaCommand}"/>
            <Button Content="UNIOR — PRIJEM RAČUNA IZ STRIP-A"    Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNaluniorPrijemCommand}"/>
            <Button Content="ZAKLJUČNI LIST (NALZAKLJ)"            Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalzakljCommand}"/>
            <Button Content="ZAKLJUČNI LIST — NALP (NALZAKLJ10)"   Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalzaklj10Command}"/>
            <Button Content="BRZI ZAKLJUČNI LIST (NALZAKLJB)"      Style="{StaticResource OsMeniDugme}" Command="{Binding OtvoriNalzakljbCommand}"/>
        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
