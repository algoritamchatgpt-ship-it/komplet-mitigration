<Window x:Class="GlavnaKnjiga.Views.Nalp2KartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GlavnaKnjiga.ViewModels"
        Title="Knjiženje analitike"
        SizeToContent="Height"
        Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Label" x:Key="FieldLabel">
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#BE0000"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"         Value="2,0"/>
        </Style>
        <Style TargetType="TextBox" x:Key="EntryBox">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="2,1"/>
            <Setter Property="Background" Value="#BDE5C5"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ReadBox">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#F5F9B0"/>
            <Setter Property="Padding"    Value="2,1"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Konto + BrNal header -->
            <RowDefinition Height="Auto"/>  <!-- 1: Naziv konta -->
            <RowDefinition Height="Auto"/>  <!-- 2: Opis -->
            <RowDefinition Height="Auto"/>  <!-- 3: Sifra partnera -->
            <RowDefinition Height="Auto"/>  <!-- 4: Separator -->
            <RowDefinition Height="Auto"/>  <!-- 5: Dug / Pot -->
            <RowDefinition Height="Auto"/>  <!-- 6: Separator -->
            <RowDefinition Height="Auto"/>  <!-- 7: Mtr -->
            <RowDefinition Height="Auto"/>  <!-- 8: Mp -->
            <RowDefinition Height="Auto"/>  <!-- 9: Dev panel (conditional) -->
            <RowDefinition Height="Auto"/>  <!-- 10: Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Konto + BrNal ── -->
        <Border Grid.Row="0" Background="#B8FEF7" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Konto" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Text="{Binding KontoKod}" IsReadOnly="True"
                         Background="Transparent" BorderThickness="0"
                         FontSize="12" FontWeight="Bold" Foreground="Green"/>
                <Label Grid.Column="3" Content="Broj naloga" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="4" Text="{Binding BrNal}" Style="{StaticResource ReadBox}"
                         FontSize="12"/>
            </Grid>
        </Border>

        <!-- ── Row 1: Naziv konta ── -->
        <Border Grid.Row="1" Background="#B8FEF7" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Naziv konta" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Text="{Binding KontoNaziv}" IsReadOnly="True"
                         Background="#E9ECE8" FontSize="11" Padding="2,1"/>
            </Grid>
        </Border>

        <!-- ── Row 2: Opis knjiženja ── -->
        <Border Grid.Row="2" Background="#B8FEF7" Padding="4,2" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Opis knjiženja" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Text="{Binding Opis}" IsReadOnly="True"
                         Background="#E9ECE8" FontSize="11" Padding="2,1"/>
            </Grid>
        </Border>

        <!-- ── Row 3: Šifra partnera ── -->
        <Border Grid.Row="3" Background="#B8FEF7" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Šifra partnera" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding Sifra, UpdateSourceTrigger=LostFocus}"
                         x:Name="TxtSifra"
                         ToolTip="UNOS ŠIFRE PARTNERA, AKO JE PRAZNA SA ENTER SE PRELAZI U ŠIFARNIK PARTNERA"/>
                <TextBox Grid.Column="2" Text="{Binding An0Naziv}" Style="{StaticResource ReadBox}"
                         Margin="4,0,0,0" Background="#F5F9B0"/>
            </Grid>
        </Border>

        <!-- ── Row 4: Separator ── -->
        <Border Grid.Row="4" Background="#B9B6F1" Height="6" Margin="0,2"/>

        <!-- ── Row 5: Dug + Pot ── -->
        <Border Grid.Row="5" Background="#B9B6F1" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Duguje" FontSize="11"
                       VerticalContentAlignment="Center" Padding="2,0"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}" Background="White"
                         Text="{Binding Dug, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                         x:Name="TxtDug"/>
                <Label Grid.Column="3" Content="Potražuje" FontSize="11"
                       VerticalContentAlignment="Center" Padding="2,0"/>
                <TextBox Grid.Column="4" Style="{StaticResource EntryBox}" Background="White"
                         Text="{Binding Pot, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                         x:Name="TxtPot"/>
            </Grid>
        </Border>

        <!-- ── Row 6: Separator ── -->
        <Border Grid.Row="6" Background="#B9B6F1" Height="4" Margin="0,2"/>

        <!-- ── Row 7: Mtr ── -->
        <Border Grid.Row="7" Background="#80FFFF" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Mesto troškova" Style="{StaticResource FieldLabel}"
                       Foreground="#AB212C"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding MtrKod, UpdateSourceTrigger=LostFocus}"
                         x:Name="TxtMtr"/>
                <TextBox Grid.Column="2" Text="{Binding MtrNaziv}" Style="{StaticResource ReadBox}"
                         Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Row 8: Mp ── -->
        <Border Grid.Row="8" Background="#80FFFF" Padding="4,2" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Mesto-grad" Style="{StaticResource FieldLabel}"
                       Foreground="#AB212C"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding MpKod, UpdateSourceTrigger=LostFocus}"
                         x:Name="TxtMp"/>
                <TextBox Grid.Column="2" Text="{Binding MpNaziv}" Style="{StaticResource ReadBox}"
                         Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Row 9: Devizno (conditional) ── -->
        <Border Grid.Row="9" Background="#B9B6D1" Padding="4,2" Margin="0,0,0,4"
                Visibility="{Binding DeviznoVidlj, Converter={StaticResource BoolVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Dev + Devkurs -->
                <Grid Grid.Row="0" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Šifra devize" Style="{StaticResource FieldLabel}"
                           Foreground="#AB212C"/>
                    <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                             Text="{Binding Dev, UpdateSourceTrigger=LostFocus}"
                             x:Name="TxtDev" ToolTip="UNOS OZNAKE DEVIZA"/>
                    <Label Grid.Column="2" Content="devizni kurs" FontSize="11"
                           Foreground="#AB212C" Padding="6,0,2,0"
                           VerticalContentAlignment="Center"/>
                    <TextBox Grid.Column="3" Text="{Binding Devkurs}" IsReadOnly="True"
                             Background="#CFCDf5" FontSize="11" FontWeight="Bold" Padding="2,1"/>
                </Grid>
                <!-- Devdug + Devpot -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="devizno duguje" Style="{StaticResource FieldLabel}"
                           Foreground="#AB212C"/>
                    <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                             Text="{Binding Devdug, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                             Foreground="Red" FontWeight="Bold" Background="White"/>
                    <Label Grid.Column="3" Content="devizno potražuje" Style="{StaticResource FieldLabel}"
                           Foreground="#AB212C"/>
                    <TextBox Grid.Column="4" Style="{StaticResource EntryBox}"
                             Text="{Binding Devpot, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                             Foreground="Red" FontWeight="Bold" Background="White"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Row 10: Buttons ── -->
        <StackPanel Grid.Row="10" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,4">
            <Button Content="&lt;Izlaz" Width="100" Height="38"
                    Command="{Binding IzlazCommand}"
                    FontSize="11" Background="#C0C0C0" Cursor="Hand"
                    ToolTip="IZLAZ IZ TABELE"/>
        </StackPanel>
    </Grid>
</Window>
