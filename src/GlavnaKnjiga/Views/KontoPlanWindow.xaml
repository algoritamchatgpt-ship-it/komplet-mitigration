<Window x:Class="GlavnaKnjiga.Views.KontoPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1200" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#004D40" Padding="14,9">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{Binding Naslov}" FontFamily="Tahoma"
                               FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding Status}" FontFamily="Tahoma"
                               FontSize="10" Foreground="#80CBC4"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Background="#E0F2F1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Konto:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding FilterKonto, UpdateSourceTrigger=PropertyChanged}"
                         Width="140" Height="28"/>
                <TextBlock Text="Naziv:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <TextBox Text="{Binding FilterNaziv, UpdateSourceTrigger=PropertyChanged}"
                         Width="320" Height="28"/>
                <Button Content="Osveži" Width="90" Height="28" Margin="16,0,0,0"
                        Command="{Binding OsveziCommand}"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E0F2F1" Padding="8">
            <Button Content="Izlaz" Width="90" Height="32" HorizontalAlignment="Right"
                    Foreground="#B00000" Command="{Binding IzlazCommand}"/>
        </Border>

        <DataGrid ItemsSource="{Binding Konta}"
                  SelectedItem="{Binding IzabranoKonto}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  FontFamily="Tahoma" FontSize="12"
                  AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Konto" Binding="{Binding Konto}" Width="110"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="*"/>
                <DataGridTextColumn Header="K1" Binding="{Binding K1}" Width="55"/>
                <DataGridTextColumn Header="K2" Binding="{Binding K2}" Width="65"/>
                <DataGridTextColumn Header="K3" Binding="{Binding K3}" Width="75"/>
                <DataGridTextColumn Header="K4" Binding="{Binding K4}" Width="85"/>
                <DataGridTextColumn Header="K5" Binding="{Binding K5}" Width="95"/>
                <DataGridTextColumn Header="K6" Binding="{Binding K6}" Width="105"/>
                <DataGridTextColumn Header="Kod" Binding="{Binding Kod}" Width="130"/>
                <DataGridTextColumn Header="S-konto" Binding="{Binding Skonto}" Width="100"/>
                <DataGridTextColumn Header="Jed." Binding="{Binding Jed}" Width="80"/>
                <DataGridTextColumn Header="Konto N" Binding="{Binding Konton}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
