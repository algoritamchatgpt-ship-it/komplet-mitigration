<Window x:Class="GlavnaKnjiga.Views.NalzakljWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OSNOVNI ZAKLJUČNI LIST"
        Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Konto -->
        <Label Grid.Row="0" Grid.Column="0" Content="Konto"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#80FF80" Padding="2"/>
        <TextBox x:Name="TxtKonp" Grid.Row="0" Grid.Column="1" MaxLength="8"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Početni datum -->
        <Label Grid.Row="1" Grid.Column="0" Content="Početni datum"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#80FFFF" Padding="2"/>
        <DatePicker x:Name="TxtDat0" Grid.Row="1" Grid.Column="1"
                    FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Zadnji datum -->
        <Label Grid.Row="2" Grid.Column="0" Content="Zadnji datum"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#80FFFF" Padding="2"/>
        <DatePicker x:Name="TxtDat1" Grid.Row="2" Grid.Column="1"
                    FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Objekat -->
        <Label Grid.Row="3" Grid.Column="0" Content="Objekat"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtDok" Grid.Row="3" Grid.Column="1" MaxLength="3"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="60" HorizontalAlignment="Left"/>

        <!-- Saldo po objektima D/N -->
        <Label Grid.Row="4" Grid.Column="0" Content="Saldo po objektima D/N"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtSaldoObj" Grid.Row="4" Grid.Column="1" MaxLength="1" Text="N"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="40" HorizontalAlignment="Left"/>

        <!-- Mesto-grad -->
        <Label Grid.Row="5" Grid.Column="0" Content="Mesto-grad"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtMp" Grid.Row="5" Grid.Column="1" MaxLength="2"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="50" HorizontalAlignment="Left"/>

        <!-- Mesto troškova -->
        <Label Grid.Row="6" Grid.Column="0" Content="Mesto troškova"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtMtr" Grid.Row="6" Grid.Column="1" MaxLength="3" Text="0"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="60" HorizontalAlignment="Left"/>

        <!-- Svedeno na kurs D/N -->
        <Label Grid.Row="7" Grid.Column="0" Content="Svedeno na kurs D/N"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtKurs" Grid.Row="7" Grid.Column="1" MaxLength="1"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="40" HorizontalAlignment="Left"/>

        <!-- Nalog koji se izuzima 1 -->
        <Label Grid.Row="8" Grid.Column="0" Content="Nalog koji se izuzima 1"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtBrnal1" Grid.Row="8" Grid.Column="1" MaxLength="6" Text="999991"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="80" HorizontalAlignment="Left"/>

        <!-- Nalog koji se izuzima 2 -->
        <Label Grid.Row="9" Grid.Column="0" Content="Nalog koji se izuzima 2"
               FontFamily="Tahoma" FontSize="11" Foreground="#C40000" Background="#FFFF80" Padding="2"/>
        <TextBox x:Name="TxtBrnal2" Grid.Row="9" Grid.Column="1" MaxLength="6" Text="999992"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2" Width="80" HorizontalAlignment="Left"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button x:Name="BtnPregled" Content="Pregled" Width="120" Height="36"
                    FontFamily="Tahoma" FontSize="11" Background="#C0C0C0"
                    Click="BtnPregled_Click"/>
            <Button Content="Izlaz" Width="80" Height="36" Margin="12,0,0,0"
                    FontFamily="Tahoma" FontSize="11" Background="#C0C0C0" Foreground="Red"
                    Click="BtnIzlaz_Click"/>
        </StackPanel>
    </Grid>
</Window>
