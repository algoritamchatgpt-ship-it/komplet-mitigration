<Window x:Class="GlavnaKnjiga.Views.NalprilWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PRILOG UZ NALOG"
        Height="600" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#E9ECD8"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2B2B8C" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRILOG UZ NALOG"
                           Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LblKonto}" Foreground="Yellow" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4">
            <Button Content="+" Width="36" Margin="2" Background="#C0C0C0" Command="{Binding DodajCommand}"/>
            <Button Content="OBRISI AUTOMATSKE" Width="160" Margin="2" Background="#C0C0C0"
                    Command="{Binding BrisiPautoRedoveCommand}"/>
            <Button Content="KONTA ANALITIKE"   Width="130" Margin="2" Background="#C0C0C0"
                    Command="{Binding OtvoriKontaAnalitikeCommand}"/>
            <Button Content="PREUZMI IZ ANALITIKE" Width="170" Margin="2" Background="#C0C0C0"
                    Command="{Binding PreuzmiIzAnalitikeCommand}"/>
            <Button Content="TEKUĆA LIKVIDNOST" Width="145" Margin="2" Background="#C0C0C0"
                    Command="{Binding TekucaLikvidnostCommand}"/>
            <Button Content="UKUPNA LIKVIDNOST" Width="145" Margin="2" Background="#C0C0C0"
                    Command="{Binding UkupnaLikvidnostCommand}"/>
            <Button Content="|&lt;" Width="36" Margin="2" Background="#C0C0C0" Command="{Binding PrviCommand}"/>
            <Button Content="&lt;"  Width="36" Margin="2" Background="#C0C0C0" Command="{Binding GoreCommand}"/>
            <Button Content="&gt;"  Width="36" Margin="2" Background="#C0C0C0" Command="{Binding DoleCommand}"/>
            <Button Content="&gt;|" Width="36" Margin="2" Background="#C0C0C0" Command="{Binding ZadnjiCommand}"/>
            <Button Content="Izlaz" Width="80"  Margin="2" Background="#C0C0C0" Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  FontSize="11"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Konto"   Binding="{Binding Konto}"   Width="100"/>
                <DataGridTextColumn Header="Sifra"   Binding="{Binding Sifra}"   Width="55"/>
                <DataGridTextColumn Header="Dug"     Binding="{Binding Dug,   StringFormat={}{0:F2}}" Width="90"/>
                <DataGridTextColumn Header="Pot"     Binding="{Binding Pot,   StringFormat={}{0:F2}}" Width="90"/>
                <DataGridTextColumn Header="Dugpre"  Binding="{Binding Dugpre,StringFormat={}{0:F2}}" Width="90"/>
                <DataGridTextColumn Header="Potpre"  Binding="{Binding Potpre,StringFormat={}{0:F2}}" Width="90"/>
                <DataGridTextColumn Header="Naziv"   Binding="{Binding Naziv}"   Width="130"/>
                <DataGridTextColumn Header="Brrac"   Binding="{Binding Brrac}"   Width="100"/>
                <DataGridTextColumn Header="Pauto"   Binding="{Binding Pauto}"   Width="50"/>
                <DataGridTextColumn Header="Opis"    Binding="{Binding Opis}"    Width="130"/>
                <DataGridTextColumn Header="Dat0"    Binding="{Binding Dat0, StringFormat={}{0:dd.MM.yyyy}}" Width="90"/>
                <DataGridTextColumn Header="Dat1"    Binding="{Binding Dat1, StringFormat={}{0:dd.MM.yyyy}}" Width="90"/>
                <DataGridTextColumn Header="K1"      Binding="{Binding K1}"      Width="35"/>
                <DataGridTextColumn Header="K2"      Binding="{Binding K2}"      Width="40"/>
                <DataGridTextColumn Header="K3"      Binding="{Binding K3}"      Width="45"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
