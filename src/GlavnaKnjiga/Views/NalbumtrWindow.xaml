<Window x:Class="GlavnaKnjiga.Views.NalbumtrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}" Height="380" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#ECE9D8"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Tahoma"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="Foreground"    Value="#C40000"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"        Value="4,2"/>
        </Style>
        <Style x:Key="Txt" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="2,2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <WrapPanel DockPanel.Dock="Bottom" Margin="8,6" HorizontalAlignment="Center">
            <Button Content="PREGLED" Width="120" Margin="4,2" Background="#E3BE95"
                    Command="{Binding PregledCommand}"/>
            <Button Content="IZLAZ"   Width="80"  Margin="4,2" Background="#C0C0C0"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO PRIHODA"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoP1, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO PRIHODA"/>
            <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoP2, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO PRIHODA"/>
            <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoP3, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO RASHODA"/>
            <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoR1, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO RASHODA"/>
            <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoR2, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource Lbl}" Text="KONTO RASHODA"/>
            <TextBox   Grid.Row="5" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding KontoR3, UpdateSourceTrigger=PropertyChanged}" MaxLength="10"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource Lbl}" Text="POČETNI DATUM"/>
            <DatePicker Grid.Row="6" Grid.Column="1" Margin="2" SelectedDate="{Binding Dat0}"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource Lbl}" Text="ZADNJI DATUM"/>
            <DatePicker Grid.Row="7" Grid.Column="1" Margin="2" SelectedDate="{Binding Dat1}"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource Lbl}" Text="UKLJUČI DOD. PRIH/RASH D/N"/>
            <TextBox   Grid.Row="8" Grid.Column="1" Style="{StaticResource Txt}" Text="{Binding DodPrih, UpdateSourceTrigger=PropertyChanged}" MaxLength="1"/>
        </Grid>
    </DockPanel>
</Window>
