<Window x:Class="GlavnaKnjiga.Views.NalogPregledWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="1400" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A237E" Padding="14,9">
            <StackPanel>
                <TextBlock Text="{Binding Naslov}" FontFamily="Tahoma"
                           FontSize="14" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding Status}" FontFamily="Tahoma"
                           FontSize="11" Foreground="#C5CAE9"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8EAF6" Padding="8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Devizno duguje: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding UkupnoDevDug, StringFormat=N2}" Margin="0,0,18,0"/>
                    <TextBlock Text="Devizno potražuje: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding UkupnoDevPot, StringFormat=N2}"/>
                </StackPanel>
                <Button Content="Izlaz" Width="90" Height="32" HorizontalAlignment="Right"
                        Foreground="#B00000" Command="{Binding IzlazCommand}"/>
            </Grid>
        </Border>

        <DataGrid ItemsSource="{Binding Redovi}" SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  FontFamily="Tahoma" FontSize="11"
                  AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Konto" Binding="{Binding Konto}" Width="105"/>
                <DataGridTextColumn Header="Duguje" Binding="{Binding Dug, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Potražuje" Binding="{Binding Pot, StringFormat=N2}" Width="120"/>
                <DataGridTextColumn Header="Opis" Binding="{Binding Opis}" Width="230"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="105"/>
                <DataGridTextColumn Header="Nalog" Binding="{Binding Brnal}" Width="80"/>
                <DataGridTextColumn Header="Dok." Binding="{Binding Dok}" Width="65"/>
                <DataGridTextColumn Header="MP" Binding="{Binding Mp, StringFormat=N0}" Width="60"/>
                <DataGridTextColumn Header="MTR" Binding="{Binding Mtr, StringFormat=N0}" Width="70"/>
                <DataGridTextColumn Header="Dev." Binding="{Binding Dev}" Width="60"/>
                <DataGridTextColumn Header="Kurs" Binding="{Binding Devkurs, StringFormat=N4}" Width="90"/>
                <DataGridTextColumn Header="Dev. duguje" Binding="{Binding Devdug, StringFormat=N2}" Width="115"/>
                <DataGridTextColumn Header="Dev. potražuje" Binding="{Binding Devpot, StringFormat=N2}" Width="125"/>
                <DataGridTextColumn Header="Šifra" Binding="{Binding Sifra}" Width="100"/>
                <DataGridTextColumn Header="Broj računa" Binding="{Binding Brrac}" Width="120"/>
                <DataGridTextColumn Header="Ulaz" Binding="{Binding Ulaz, StringFormat=N3}" Width="95"/>
                <DataGridTextColumn Header="Izlaz" Binding="{Binding Izlaz, StringFormat=N3}" Width="95"/>
                <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, StringFormat=N2}" Width="115"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
