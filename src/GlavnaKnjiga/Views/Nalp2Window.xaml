<Window x:Class="GlavnaKnjiga.Views.Nalp2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GlavnaKnjiga.ViewModels"
        Title="{Binding Caption}"
        WindowState="Maximized"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="GkBtn">
            <Setter Property="Background"   Value="#C0C0C0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="Padding"      Value="2,1"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ReadOnly">
            <Setter Property="IsReadOnly"   Value="True"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Padding"      Value="1,0"/>
        </Style>
        <Style TargetType="Label" x:Key="InfoLbl">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Header -->
            <RowDefinition Height="*"/>      <!-- 1: Grid -->
            <RowDefinition Height="Auto"/>   <!-- 2: Info panel -->
            <RowDefinition Height="Auto"/>   <!-- 3: Button panel -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Row 0 — Header (NALOG / DATUM / Sifra / Naziv) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#B7BCF9" Margin="2,2,2,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="2,1">
                    <Label Style="{StaticResource InfoLbl}" Content="NALOG" FontWeight="Bold"/>
                </Border>
                <TextBox Grid.Column="1" Style="{StaticResource ReadOnly}"
                         Text="{Binding Brnal}" Background="#F3FAA3"
                         FontSize="11" Margin="2,1"/>

                <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="2,1">
                    <Label Style="{StaticResource InfoLbl}" Content="DATUM" FontWeight="Bold"/>
                </Border>
                <TextBox Grid.Column="3" Style="{StaticResource ReadOnly}"
                         Text="{Binding Datdok, StringFormat=dd.MM.yyyy}"
                         Background="#F3FAA3" FontSize="11" Margin="2,1"/>

                <Label Grid.Column="4" Content="Sifra"
                       Style="{StaticResource InfoLbl}" Margin="8,1,2,1"/>
                <TextBox Grid.Column="5" Style="{StaticResource ReadOnly}"
                         Text="{Binding TxtSifra}" Background="#E2FEDA"
                         FontSize="11" Margin="0,1"/>

                <Label Grid.Column="6" Content="Naziv"
                       Style="{StaticResource InfoLbl}" Margin="8,1,2,1"/>
                <TextBox Grid.Column="7" Style="{StaticResource ReadOnly}"
                         Text="{Binding TxtNaziv3}" Background="#E2FEDA"
                         FontSize="11" Margin="0,1"/>

                <!-- LBLREC top right -->
                <TextBlock Grid.Column="8"
                           Text="{Binding LblRec}"
                           Foreground="Red" FontWeight="Bold" FontStyle="Italic"
                           FontSize="10" Background="#C0C0C0"
                           Padding="4,2" Margin="4,1,2,1"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Row 1 — Main DataGrid (55 kolona) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="1"
                  x:Name="Grd0"
                  ItemsSource="{Binding NalpRows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="All"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  RowHeight="19"
                  FontFamily="Tahoma" FontSize="10"
                  Background="#F5F5F5"
                  HorizontalGridLinesBrush="#B7BCF9"
                  VerticalGridLinesBrush="#B7BCF9"
                  RowBackground="#F5F5F5"
                  AlternatingRowBackground="#F0F0F0"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  Margin="2,2,2,0"
                  CellEditEnding="Grd0_CellEditEnding"
                  SelectionChanged="Grd0_SelectionChanged">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#B1E47E"/>
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Col1: Konto -->
                <DataGridTextColumn Header="Konto"     Binding="{Binding Konto, UpdateSourceTrigger=LostFocus}"     Width="90"/>
                <!-- Col2: Dug -->
                <DataGridTextColumn Header="Dug"       Binding="{Binding Dug,   UpdateSourceTrigger=LostFocus, StringFormat=N2}" Width="110">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="Blue"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <!-- Col3: Pot -->
                <DataGridTextColumn Header="Pot"       Binding="{Binding Pot,   UpdateSourceTrigger=LostFocus, StringFormat=N2}" Width="95">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="Red"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <!-- Col4: Opis -->
                <DataGridTextColumn Header="Opis"      Binding="{Binding Opis,  UpdateSourceTrigger=LostFocus}"     Width="200"/>
                <!-- Col5: Datdok -->
                <DataGridTextColumn Header="Datdok"    Binding="{Binding Datdok, UpdateSourceTrigger=LostFocus, StringFormat=dd.MM.yy}" Width="65"/>
                <!-- Col6: Brnal (readonly) -->
                <DataGridTextColumn Header="Brnal"     Binding="{Binding Brnal}"  Width="45" IsReadOnly="True"/>
                <!-- Col7: Dok -->
                <DataGridTextColumn Header="Dok"       Binding="{Binding Dok,   UpdateSourceTrigger=LostFocus}"     Width="70"/>
                <!-- Col8: Mp -->
                <DataGridTextColumn Header="Mp"        Binding="{Binding Mp,    UpdateSourceTrigger=LostFocus}"     Width="35"/>
                <!-- Col9: Mtr -->
                <DataGridTextColumn Header="Mtr"       Binding="{Binding Mtr,   UpdateSourceTrigger=LostFocus}"     Width="38"/>
                <!-- Col10: Dev -->
                <DataGridTextColumn Header="Dev"       Binding="{Binding Dev,   UpdateSourceTrigger=LostFocus}"     Width="32"/>
                <!-- Col11: Devkurs -->
                <DataGridTextColumn Header="Devkurs"   Binding="{Binding Devkurs, UpdateSourceTrigger=LostFocus}"   Width="50"/>
                <!-- Col12: Devdug -->
                <DataGridTextColumn Header="Devdug"    Binding="{Binding Devdug, UpdateSourceTrigger=LostFocus}"    Width="80"/>
                <!-- Col13: Devpot -->
                <DataGridTextColumn Header="Devpot"    Binding="{Binding Devpot, UpdateSourceTrigger=LostFocus}"    Width="80"/>
                <!-- Col14: Brdok -->
                <DataGridTextColumn Header="Brdok"     Binding="{Binding Brdok, UpdateSourceTrigger=LostFocus}"     Width="80"/>
                <!-- Col15: Napomena1 -->
                <DataGridTextColumn Header="Napomena1" Binding="{Binding Napomena1, UpdateSourceTrigger=LostFocus}" Width="250"/>
                <!-- Col16: Napomena2 -->
                <DataGridTextColumn Header="Napomena2" Binding="{Binding Napomena2, UpdateSourceTrigger=LostFocus}" Width="185"/>
                <!-- Col17: Kurs -->
                <DataGridTextColumn Header="Kurs"      Binding="{Binding Kurs}"     Width="82"/>
                <!-- Col18: Kursdug -->
                <DataGridTextColumn Header="Kursdug"   Binding="{Binding Kursdug}"  Width="78"/>
                <!-- Col19: Kurspot -->
                <DataGridTextColumn Header="Kurspot"   Binding="{Binding Kurspot}"  Width="80"/>
                <!-- Col20: Dpsaldo -->
                <DataGridTextColumn Header="Dpsaldo"   Binding="{Binding Dpsaldo}"  Width="62"/>
                <!-- Col21: Cena -->
                <DataGridTextColumn Header="Cena"      Binding="{Binding Cena}"     Width="68"/>
                <!-- Col22: Ulaz -->
                <DataGridTextColumn Header="Ulaz"      Binding="{Binding Ulaz}"     Width="70"/>
                <!-- Col23: Izlaz -->
                <DataGridTextColumn Header="Izlaz"     Binding="{Binding Izlaz}"    Width="67"/>
                <!-- Col24: Ukupno_d -->
                <DataGridTextColumn Header="Ukupno_d"  Binding="{Binding UkupnoD}"  Width="90"/>
                <!-- Col25: Ukupno_p -->
                <DataGridTextColumn Header="Ukupno_p"  Binding="{Binding UkupnoP}"  Width="92"/>
                <!-- Col26: Sifra -->
                <DataGridTextColumn Header="Sifra"     Binding="{Binding Sifra, UpdateSourceTrigger=LostFocus}"     Width="40"/>
                <!-- Col27: Brrac -->
                <DataGridTextColumn Header="Brrac"     Binding="{Binding Brrac}"    Width="104"/>
                <!-- Col28: Valuta -->
                <DataGridTextColumn Header="Valuta"    Binding="{Binding Valuta}"   Width="65"/>
                <!-- Col29: Datpri -->
                <DataGridTextColumn Header="Datpri"    Binding="{Binding Datpri, StringFormat=dd.MM.yy}" Width="79"/>
                <!-- Col30: Datpdv -->
                <DataGridTextColumn Header="Datpdv"    Binding="{Binding Datpdv, StringFormat=dd.MM.yy}" Width="64"/>
                <!-- Col31: Stanje -->
                <DataGridTextColumn Header="Stanje"    Binding="{Binding Stanje}"   Width="68"/>
                <!-- Col32: Saldo -->
                <DataGridTextColumn Header="Saldo"     Binding="{Binding Saldo}"    Width="66"/>
                <!-- Col33: Oznaka -->
                <DataGridTextColumn Header="Oznaka"    Binding="{Binding Oznaka}"   Width="42"/>
                <!-- Col34: Datum -->
                <DataGridTextColumn Header="Datum"     Binding="{Binding Datum, StringFormat=dd.MM.yy}"  Width="88"/>
                <!-- Col35: Vreme -->
                <DataGridTextColumn Header="Vreme"     Binding="{Binding Vreme}"    Width="85"/>
                <!-- Col36: Skonto -->
                <DataGridTextColumn Header="Skonto"    Binding="{Binding Skonto}"   Width="68"/>
                <!-- Col37: Automnal -->
                <DataGridTextColumn Header="Automnal"  Binding="{Binding Automnal}" Width="50"/>
                <!-- Col38: Oper -->
                <DataGridTextColumn Header="Oper"      Binding="{Binding Oper}"     Width="29"/>
                <!-- Col39: Probni -->
                <DataGridTextColumn Header="Probni"    Binding="{Binding Probni}"   Width="35"/>
                <!-- Col40: Gkonto -->
                <DataGridTextColumn Header="Gkonto"    Binding="{Binding Gkonto}"   Width="38"/>
                <!-- Col41: Arhiva -->
                <DataGridTextColumn Header="Arhiva"    Binding="{Binding Arhiva}"   Width="34"/>
                <!-- Col42: Arhiva2 -->
                <DataGridTextColumn Header="Arhiva2"   Binding="{Binding Arhiva2}"  Width="40"/>
                <!-- Col43: Devizno -->
                <DataGridTextColumn Header="Devizno"   Binding="{Binding Devizno}"  Width="42"/>
                <!-- Col44: Vrsta -->
                <DataGridTextColumn Header="Vrsta"     Binding="{Binding Vrsta}"    Width="29"/>
                <!-- Col45: Imetabele -->
                <DataGridTextColumn Header="Imetabele" Binding="{Binding Imetabele}" Width="65"/>
                <!-- Col46: Datrazduz -->
                <DataGridTextColumn Header="Datrazduz" Binding="{Binding Datrazduz, StringFormat=dd.MM.yy}" Width="60"/>
                <!-- Col47: Opisu -->
                <DataGridTextColumn Header="Opisu"     Binding="{Binding Opisu}"    Width="126"/>
                <!-- Col48: Dinrazduz -->
                <DataGridTextColumn Header="Dinrazduz" Binding="{Binding Dinrazduz}" Width="79"/>
                <!-- Col49: Sifprod -->
                <DataGridTextColumn Header="Sifprod"   Binding="{Binding Sifprod}"  Width="38"/>
                <!-- Col50: Dp -->
                <DataGridTextColumn Header="Dp"        Binding="{Binding Dp}"       Width="18"/>
                <!-- Col51: Doddug -->
                <DataGridTextColumn Header="Doddug"    Binding="{Binding Doddug}"   Width="95"/>
                <!-- Col52: Dodpot -->
                <DataGridTextColumn Header="Dodpot"    Binding="{Binding Dodpot}"   Width="94"/>
                <!-- Col53: Preneto -->
                <DataGridTextColumn Header="Preneto"   Binding="{Binding Preneto}"  Width="37"/>
                <!-- Col54: Numred -->
                <DataGridTextColumn Header="Numred"    Binding="{Binding Numred}"   Width="90"/>
                <!-- Col55: Idbr -->
                <DataGridTextColumn Header="Idbr"      Binding="{Binding Idbr}"     Width="78"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Row 2 — Info panel (konto/mesta/mtr + totali) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#B7BCF9" Margin="2,2,2,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- konto kod -->
                    <ColumnDefinition Width="*"/>      <!-- konto naziv / mesto / mtr -->
                    <ColumnDefinition Width="Auto"/>   <!-- dug/pot/saldo labels -->
                    <ColumnDefinition Width="120"/>    <!-- dug/pot/saldo values -->
                    <ColumnDefinition Width="Auto"/>   <!-- txt dug/pot/saldo -->
                    <ColumnDefinition Width="120"/>    <!-- txt values -->
                </Grid.ColumnDefinitions>

                <!-- Konto info -->
                <StackPanel Grid.Column="0" Margin="2,0">
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtKonto2}"
                             Background="#FDBCB9" Width="100" Margin="0,1"/>
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtMp}"
                             Background="#BFFEB8" Width="100" Margin="0,1"/>
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtMtr}"
                             Background="#E3BE95" Width="100" Margin="0,1"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="2,0">
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtNaziv}"
                             Background="#FDBCB9" Margin="0,1"/>
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtMesto}"
                             Background="#BFFEB8" Margin="0,1"/>
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtNaziv2}"
                             Background="#E3BE95" Margin="0,1"/>
                </StackPanel>

                <!-- DUG/POT/SALDO labels -->
                <StackPanel Grid.Column="2" Margin="6,0,2,0">
                    <Label Content=" DUGUJE    " Style="{StaticResource InfoLbl}"
                           Foreground="#000080" Background="#80FFFF"
                           FontWeight="Bold" FontFamily="Arial" FontSize="12"
                           BorderBrush="Gray" BorderThickness="1" Margin="0,1"/>
                    <Label Content=" POTRAŽUJE " Style="{StaticResource InfoLbl}"
                           Foreground="#008000"
                           FontWeight="Bold" FontFamily="Arial" FontSize="12"
                           BorderBrush="Gray" BorderThickness="1" Margin="0,1"/>
                    <Label Content=" SALDO     " Style="{StaticResource InfoLbl}"
                           Foreground="#800000" Background="#A8FFA8"
                           FontWeight="Bold" FontFamily="Arial" FontSize="12"
                           BorderBrush="Gray" BorderThickness="1" Margin="0,1"/>
                </StackPanel>
                <!-- DUG/POT/SALDO values (readonly textboxes) -->
                <StackPanel Grid.Column="3" Margin="0,0,2,0">
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtDug}"
                             Background="#80FFFF" FontSize="11" TextAlignment="Right"
                             Margin="0,1"/>
                    <TextBox Style="{StaticResource ReadOnly}" Text="{Binding TxtPot}"
                             FontSize="11" TextAlignment="Right" Margin="0,1"/>
                    <TextBox x:Name="TxtSaldoBox"
                             Text="{Binding TxtSaldo}"
                             IsReadOnly="True" BorderThickness="1"
                             Padding="1,0"
                             FontSize="11" TextAlignment="Right" Margin="0,1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="IsReadOnly"      Value="True"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaldoJeNula}" Value="True">
                                        <Setter Property="Background" Value="#A8FFA8"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SaldoJeNula}" Value="False">
                                        <Setter Property="Background" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Row 3 — Button panel -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#B7BCF9" Margin="2,2,2,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Left nav + ops -->
                    <ColumnDefinition Width="*"/>      <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>   <!-- Center ops -->
                    <ColumnDefinition Width="*"/>      <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>   <!-- Right ops -->
                </Grid.ColumnDefinitions>

                <!-- LEFT: navigation + ops -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="2">
                    <!-- Navigation row -->
                    <StackPanel Orientation="Horizontal" Margin="0,1">
                        <Button Style="{StaticResource GkBtn}" Content="↓"
                                Width="30" Command="{Binding IdiDoleCommand}"
                                ToolTip="Dole"/>
                        <Button Style="{StaticResource GkBtn}" Content="↑"
                                Width="30" Command="{Binding IdiGoreCommand}"
                                ToolTip="Gore"/>
                        <Button Style="{StaticResource GkBtn}" Content="⊥"
                                Width="38" Command="{Binding IdiNaDnoCommand}"
                                ToolTip="Poslednji"/>
                        <Button Style="{StaticResource GkBtn}" Content="⊤"
                                Width="30" Command="{Binding IdiNaVrhCommand}"
                                ToolTip="Prvi"/>
                        <Button Style="{StaticResource GkBtn}" Content="LOK"
                                Width="30" Margin="4,0,0,0"/>
                    </StackPanel>
                    <!-- Op buttons -->
                    <Button Style="{StaticResource GkBtn}" Content="PARAMETRI A+F9"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding ParametriCommand}"
                            ToolTip="PODEŠAVANJE NAČINA KNJIŽENJA ANALITIKA"/>
                    <Button Style="{StaticResource GkBtn}" Content="BRISANJE NALOGA"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding BrisiNalogCommand}"
                            ToolTip="BRISANJE CELOG NALOGA"/>
                    <Button Style="{StaticResource GkBtn}" Content="PRAZNI NALOG S+F7"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding PrazniNalogCommand}"
                            ToolTip="BRISANJE STAVKI IZ NALOGA"/>
                    <Button Style="{StaticResource GkBtn}" Content="KOPIRAJ RED S+F5"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding KopirajRedCommand}"
                            ToolTip="KOPIRANJE ZADNJEG REDA U NOVI"/>
                </StackPanel>

                <!-- CENTER: KONTNI PLAN + KNJIŽI + DODAJ ZBIR + previews -->
                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="6,2">
                    <Button Style="{StaticResource GkBtn}" Content="&lt;KONTNI PLAN F4"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding KontniPlanCommand}"
                            ToolTip="KONTNI PLAN" Background="#C5FEB4"/>
                    <Button Style="{StaticResource GkBtn}" Content="K&lt;NJIŽI F5"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding KnjiziCommand}"
                            ToolTip="KNJIŽENJE NALOGA U DNEVNIK"/>
                    <Button Style="{StaticResource GkBtn}" Content="DODAJ ZBIR F6"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding DodajZbirCommand}"
                            ToolTip="DODAVANJE UKRŠTENOG ZBIRA NALOGU"/>
                    <Button Style="{StaticResource GkBtn}" Content="NALOG F10"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding NalogF10Command}"
                            ToolTip="PREGLED NALOGA"/>
                    <Button Style="{StaticResource GkBtn}" Content="DEVIZNI NALOG A+F10"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding DevizniNalogCommand}"
                            ToolTip="PREGLED NALOGA DEVIZNO"/>
                    <Button Style="{StaticResource GkBtn}" Content="NALOG EKO"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding NalogEkoCommand}"
                            ToolTip="PREGLED NALOGA EKO"/>
                    <Button Style="{StaticResource GkBtn}" Content="KEPU KNJIGE"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,5,0,1"
                            Command="{Binding KepuKnjigeCommand}"
                            ToolTip="PRENOS PAZARA I USLUGA IZ KEPU KNJIGA"
                            Background="#B9FFB9"/>
                </StackPanel>

                <!-- RIGHT: DODAJ + BRISI PRAZNINE + IZLAZ -->
                <StackPanel Grid.Column="4" Orientation="Vertical" Margin="6,2">
                    <Button Style="{StaticResource GkBtn}" Content="DODAJ RED"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding DodajRedCommand}"
                            ToolTip="DODAVANJE NOVOG REDA" Background="#C0C0C0"/>
                    <Button Style="{StaticResource GkBtn}" Content="BRIŠI PRAZNINE"
                            Width="135" HorizontalContentAlignment="Left" Margin="0,1"
                            Command="{Binding BrisiPraznineCommand}"
                            ToolTip="BRISANJE PRAZNINA"/>
                    <Button Style="{StaticResource GkBtn}" Content="Izlaz"
                            Width="135" Height="38" Margin="0,4"
                            Command="{Binding IzlazCommand}"
                            ToolTip="POVRATAK U PRETHODNI PROZOR"
                            Background="#C0C0C0" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
