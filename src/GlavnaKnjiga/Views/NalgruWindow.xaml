<Window x:Class="GlavnaKnjiga.Views.NalgruWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Height="460" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#D5E8D4"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Toolbar buttons -->
        <WrapPanel DockPanel.Dock="Bottom" Margin="6,4" HorizontalAlignment="Center">
            <Button Content="PREGLED"  Width="100" Margin="4,2" Background="#80FFFF"
                    Command="{Binding PregledCommand}"/>
            <Button Content="DODAJ"    Width="80"  Margin="4,2" Background="#C8FFC8"
                    Command="{Binding DodajCommand}"/>
            <Button Content="BRISANJE" Width="90"  Margin="4,2" Background="#C8FFC8"
                    Command="{Binding BrisanjeCommand}"/>
            <Button Content="PRVI"     Width="60"  Margin="4,2"
                    Command="{Binding IdiNaVrhCommand}"/>
            <Button Content="GORE"     Width="60"  Margin="4,2"
                    Command="{Binding IdiGoreCommand}"/>
            <Button Content="DOLE"     Width="60"  Margin="4,2"
                    Command="{Binding IdiDoleCommand}"/>
            <Button Content="ZADNJI"   Width="70"  Margin="4,2"
                    Command="{Binding IdiNaDnoCommand}"/>
            <Button Content="IZLAZ"    Width="80"  Margin="4,2" Background="#C0C0C0"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid x:Name="Grd0"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelektovaniRed}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="11"
                  RowBackground="White"
                  AlternatingRowBackground="#F0F8F0"
                  SelectionMode="Single"
                  Margin="6,6,6,4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="KONTO"   Binding="{Binding Konto,   UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="PRENETO" Binding="{Binding Preneto, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="IDBR"    Binding="{Binding Idbr,    UpdateSourceTrigger=PropertyChanged}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
