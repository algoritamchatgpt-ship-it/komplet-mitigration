<Window x:Class="GlavnaKnjiga.Views.NalptkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="820" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel Margin="10">
        <Border DockPanel.Dock="Top" Background="#1A237E" Padding="12,8">
            <StackPanel>
                <TextBlock Text="{Binding Naslov}" Foreground="White"
                           FontWeight="Bold" FontSize="14"/>
                <TextBlock Text="{Binding Status}" Foreground="#DDE2FF" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="IZABERI SVE" Width="110" Height="36" Margin="3"
                    Command="{Binding IzaberiSveCommand}"/>
            <Button Content="PONIŠTI SVE" Width="110" Height="36" Margin="3"
                    Command="{Binding PonistiSveCommand}"/>
            <Button Content="DODAJ U NALOG" Width="150" Height="36" Margin="12,3,3,3"
                    FontWeight="Bold" Background="#B9FFB9"
                    Command="{Binding DodajUNalogCommand}"/>
            <Button Content="IZLAZ" Width="90" Height="36" Margin="3"
                    Foreground="#B00000" Command="{Binding IzlazCommand}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Knjige}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  FontFamily="Tahoma"
                  FontSize="11"
                  AlternatingRowBackground="#F5F5F5"
                  Margin="0,8,0,0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Prenesi" Binding="{Binding Izabrana}" Width="70"/>
                <DataGridTextColumn Header="RBR" Binding="{Binding Sifprod}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="Maloprodaja" Binding="{Binding Naziv}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Mesto" Binding="{Binding Mesto}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Konto pazara" Binding="{Binding KontoPazara}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Konto usluga" Binding="{Binding KontoUsluga}" Width="110" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
