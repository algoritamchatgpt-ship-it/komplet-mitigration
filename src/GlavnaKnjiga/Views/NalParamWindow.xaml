<Window x:Class="GlavnaKnjiga.Views.NalParamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PARAMETRI KNJIŽENJA"
        Height="150" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#95BC94"
        KeyDown="Window_KeyDown">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PARAMETRI KNJIŽENJA"
                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"
                   Background="#FFFF80" Padding="8,4"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="PRIKAZ NALOGA SA ANALITIKOM 1=DA"
                       Background="#FFFF80" Foreground="#BE0000" TextDecorations="Underline"
                       FontSize="11" VerticalAlignment="Center" Padding="4,2"/>
            <TextBox Grid.Column="1" FontSize="11" MaxLength="1"
                     Text="{Binding Par2, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="\&lt;IZLAZ" Width="100" Margin="8,0" Background="#ECE9D8"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
