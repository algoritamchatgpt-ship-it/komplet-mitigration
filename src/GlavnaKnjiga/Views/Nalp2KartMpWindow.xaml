<Window x:Class="GlavnaKnjiga.Views.Nalp2KartMpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Knjiženje pazara"
        SizeToContent="Height"
        Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Label" x:Key="FieldLabel">
            <Setter Property="FontSize"                  Value="12"/>
            <Setter Property="FontStyle"                 Value="Normal"/>
            <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
            <Setter Property="Foreground"                Value="#BE0000"/>
            <Setter Property="VerticalContentAlignment"  Value="Center"/>
            <Setter Property="Padding"                   Value="2,0"/>
            <Setter Property="MinWidth"                  Value="130"/>
        </Style>
        <Style TargetType="TextBox" x:Key="EntryBox">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="2,1"/>
            <Setter Property="Background" Value="#BDDDC5"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ReadBox">
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="IsReadOnly"      Value="True"/>
            <Setter Property="Background"      Value="#E9ECD8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="2,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Konto + BrNal header -->
            <RowDefinition Height="Auto"/>  <!-- 1: Naziv konta -->
            <RowDefinition Height="Auto"/>  <!-- 2: Opis knjiženja -->
            <RowDefinition Height="Auto"/>  <!-- 3: Datum (DATDOK) -->
            <RowDefinition Height="Auto"/>  <!-- 4: Broj objekta (REDDOK + DOK + PNAZIV) -->
            <RowDefinition Height="Auto"/>  <!-- 5: Uplaćeno (POT) -->
            <RowDefinition Height="Auto"/>  <!-- 6: Datum razduženja -->
            <RowDefinition Height="Auto"/>  <!-- 7: Opis uplate (OPISU) -->
            <RowDefinition Height="Auto"/>  <!-- 8: Iznos razduženja (DINRAZDUZ) -->
            <RowDefinition Height="Auto"/>  <!-- 9: Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Konto + BrNal ── (Shape8 = #B8FEF7) -->
        <Border Grid.Row="0" Background="#B8FEF7" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Konto" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Text="{Binding KontoKod}" IsReadOnly="True"
                         Background="#00FF00" FontSize="12" FontWeight="Bold"
                         BorderThickness="0" Padding="2,1"/>
                <Label Grid.Column="3" Content="Broj naloga" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="4" Text="{Binding BrNal}" Style="{StaticResource ReadBox}"
                         Background="#80FF80" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ── Row 1: Naziv konta ── -->
        <Border Grid.Row="1" Background="#B8FEF7" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Naziv konta" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Text="{Binding KontoNaziv}" Style="{StaticResource ReadBox}"
                         Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Row 2: Opis knjiženja ── -->
        <Border Grid.Row="2" Background="#B8FEF7" Padding="4,2" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Opis knjiženja" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Text="{Binding Opis}" Style="{StaticResource ReadBox}"
                         Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Row 3: Datum (DATDOK) ── -->
        <Border Grid.Row="3" Background="#ECE9D8" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Datum" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding Datdok, UpdateSourceTrigger=LostFocus, StringFormat=d}"
                         x:Name="TxtDatdok"
                         ToolTip="UNOS DATUMA RAČUNA"/>
            </Grid>
        </Border>

        <!-- ── Row 4: Broj objekta (REDDOK + DOK + PNAZIV) ── -->
        <Border Grid.Row="4" Background="#ECE9D8" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Broj objekta" Style="{StaticResource FieldLabel}"
                       Foreground="#AB212C"/>
                <!-- TXTREDDOK: user enters numeric red (2 digits max) -->
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding RedDok, UpdateSourceTrigger=LostFocus}"
                         x:Name="TxtRedDok" MaxLength="2"/>
                <!-- txtdok: auto-filled DOK='M'+redDok, readonly -->
                <TextBox Grid.Column="2" Text="{Binding Dok}" Style="{StaticResource ReadBox}"
                         Margin="4,0,0,0" Background="#BDDDC5"/>
                <!-- LBLPNAZIV: naziv iz nalpdefk -->
                <TextBox Grid.Column="3" Text="{Binding PNaziv}" Style="{StaticResource ReadBox}"
                         Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Row 5: Uplaćeno (POT) ── -->
        <Border Grid.Row="5" Background="#ECE9D8" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Uplaćeno" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding Pot, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                         x:Name="TxtPot"/>
            </Grid>
        </Border>

        <!-- ── Row 6: Datum razduženja (DATRAZDUZ) ── -->
        <Border Grid.Row="6" Background="#ECE9D8" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Datum razduženja" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding Datrazduz, UpdateSourceTrigger=LostFocus, StringFormat=d}"
                         x:Name="TxtDatrazduz"
                         ToolTip="UNOS DATUMA RAČUNA"/>
            </Grid>
        </Border>

        <!-- ── Row 7: Opis uplate (OPISU) ── -->
        <Border Grid.Row="7" Background="#ECE9D8" Padding="4,2" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Opis uplate" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding Opisu, UpdateSourceTrigger=LostFocus}"
                         MaxLength="60" Margin="4,0,0,0"
                         ToolTip="UNOS BROJA RAČUNA IZ FAKTURE DOBAVLJAČA"/>
                <Button Grid.Column="2" Content="..." Width="38" Height="26" Margin="4,0,0,0"
                        Command="{Binding IzaberiOpisCommand}"
                        ToolTip="Izbor standardnog opisa uplate"/>
            </Grid>
        </Border>

        <!-- ── Row 8: Iznos razduženja (DINRAZDUZ) ── -->
        <Border Grid.Row="8" Background="#ECE9D8" Padding="4,2" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Iznos razduženja" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" Style="{StaticResource EntryBox}"
                         Text="{Binding Dinrazduz, UpdateSourceTrigger=LostFocus, StringFormat=N2}"
                         x:Name="TxtDinrazduz"/>
            </Grid>
        </Border>

        <!-- ── Row 9: Buttons ── -->
        <StackPanel Grid.Row="9" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,4">
            <Button Content="&lt;Izlaz" Width="100" Height="38"
                    Command="{Binding IzlazCommand}"
                    FontSize="11" Background="#C0C0C0" Cursor="Hand"
                    ToolTip="IZLAZ IZ TABELE"/>
        </StackPanel>
    </Grid>
</Window>
