<Window x:Class="GlavnaKnjiga.Views.NalmtrPregledWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PREGLED MESTA TROŠKOVA"
        Width="1350" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#E0F2F1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Početni datum:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker SelectedDate="{Binding Dat0}" Width="140" Height="28"/>
                <TextBlock Text="Zadnji datum:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <DatePicker SelectedDate="{Binding Dat1}" Width="140" Height="28"/>
                <TextBlock Text="Kurs:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <TextBox Text="{Binding Kurs}" Width="100" Height="28"/>
                <Button Content="Klasa 5" Width="100" Height="30" Margin="18,0,0,0"
                        Command="{Binding PregledKlasa5Command}"/>
                <Button Content="Klasa 6" Width="100" Height="30" Margin="6,0,0,0"
                        Command="{Binding PregledKlasa6Command}"/>
                <Button Content="Sve" Width="90" Height="30" Margin="6,0,0,0"
                        Command="{Binding PregledSveCommand}"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E0F2F1" Padding="8">
            <Grid>
                <TextBlock Text="{Binding Status}" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Izlaz" Width="90" Height="32" HorizontalAlignment="Right"
                        Foreground="#B00000" Command="{Binding IzlazCommand}"/>
            </Grid>
        </Border>

        <DataGrid x:Name="GrdMain"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  FontFamily="Tahoma" FontSize="10"
                  AlternatingRowBackground="#F5F5F5"/>
    </DockPanel>
</Window>
