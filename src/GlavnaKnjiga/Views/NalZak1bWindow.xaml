<Window x:Class="GlavnaKnjiga.Views.NalZak1bWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZAKLJUČNI LIST"
        Height="440" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#E9ECD8"
        KeyDown="Window_KeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ZAKLJUČNI LIST"
                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"
                   Background="#F1D1AD" Padding="8,4"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"  Grid.Column="0" Text="Prefiks konta"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0"  Grid.Column="1" FontSize="11"
                       Text="{Binding Konp, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="2"  Grid.Column="0" Text="Datum od"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="2" Grid.Column="1" FontSize="11"
                        SelectedDate="{Binding Dat0}"/>

            <TextBlock Grid.Row="4"  Grid.Column="0" Text="Datum do"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="4" Grid.Column="1" FontSize="11"
                        SelectedDate="{Binding Dat1}"/>

            <TextBlock Grid.Row="6"  Grid.Column="0" Text="Nalog koji se izuzima 1"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="6"  Grid.Column="1" FontSize="11"
                       Text="{Binding Brnal1, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="8"  Grid.Column="0" Text="Nalog koji se izuzima 2"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="8"  Grid.Column="1" FontSize="11"
                       Text="{Binding Brnal2, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Nalog koji se izuzima 3"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="10" Grid.Column="1" FontSize="11"
                       Text="{Binding Brnal3, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Text="Nalog koji se izuzima 4"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="12" Grid.Column="1" FontSize="11"
                       Text="{Binding Brnal4, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="14" Grid.Column="0" Text="Dokument"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="14" Grid.Column="1" FontSize="11"
                       Text="{Binding Dok, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="16" Grid.Column="0" Text="Mesto plaćanja"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="16" Grid.Column="1" FontSize="11"
                       Text="{Binding Mp, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="18" Grid.Column="0" Text="Mesto troška"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="18" Grid.Column="1" FontSize="11"
                       Text="{Binding Mtr, StringFormat={}{0:F0}, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="20" Grid.Column="0" Text="Cifre (D/N)"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="20" Grid.Column="1" FontSize="11" MaxLength="1"
                       Text="{Binding Cifre, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="22" Grid.Column="0" Text="Nedovršeni (D/N)"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="22" Grid.Column="1" FontSize="11" MaxLength="1"
                       Text="{Binding Nedovrseni, UpdateSourceTrigger=LostFocus}"/>

            <TextBlock Grid.Row="24" Grid.Column="0" Text="Automatski (D/N)"
                       Foreground="#950000" TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="24" Grid.Column="1" FontSize="11" MaxLength="1"
                       Text="{Binding Automatski, UpdateSourceTrigger=LostFocus}"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="\&lt;Pregled" Width="120" Margin="8,0" Background="#C0C0C0"
                    Command="{Binding PregledCommand}"/>
            <Button Content="\&lt;Izlaz"   Width="80"  Margin="8,0" Background="#C0C0C0" Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
