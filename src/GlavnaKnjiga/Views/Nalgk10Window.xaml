<Window x:Class="GlavnaKnjiga.Views.Nalgk10Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IZRADA NALOGA ZA KNJIŽENJE"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Header strip: NALOG + DATUM + LBLREC -->
        <Border DockPanel.Dock="Top" Background="#B7BCF9" BorderBrush="#8080A0" BorderThickness="0,0,0,1" Padding="4,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="NALOG" FontFamily="Tahoma" FontSize="11" FontWeight="Bold" Padding="2,0"/>
                <Label x:Name="LblBrnal" Grid.Column="1" Content="{Binding LblBrnal}"
                       FontFamily="Tahoma" FontSize="11" Background="#F3FA63" Padding="4,0" MinWidth="80"
                       BorderThickness="1" BorderBrush="Gray"/>
                <Label Grid.Column="2" Content="  DATUM " FontFamily="Tahoma" FontSize="11" FontWeight="Bold" Padding="2,0"/>
                <Label x:Name="LblDatdok" Grid.Column="3" Content="{Binding LblDatdok}"
                       FontFamily="Tahoma" FontSize="11" Background="#F3FA63" Padding="4,0" MinWidth="90"
                       BorderThickness="1" BorderBrush="Gray"/>
                <Label x:Name="LblRec" Grid.Column="5" Content="{Binding LblRec}"
                       FontFamily="Tahoma" FontSize="10" FontWeight="Bold" FontStyle="Italic"
                       Background="#C0C0C0" Foreground="Red" Padding="4,0" MinWidth="120"
                       BorderThickness="1" BorderBrush="Gray"/>
            </Grid>
        </Border>

        <!-- Bottom strip: Konto + Naziv -->
        <Border DockPanel.Dock="Bottom" Background="#FDE0B9" BorderBrush="#8080A0" BorderThickness="0,1,0,0" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <Label Content="KONTO:" FontFamily="Tahoma" FontSize="10" FontWeight="Bold" Padding="2,0"/>
                <TextBox x:Name="TxtKonto2" Text="{Binding KontoInfo}" IsReadOnly="True"
                         FontFamily="Tahoma" FontSize="10" Background="#FDB9B5"
                         BorderThickness="0" Padding="2,0" MinWidth="100"/>
                <TextBox x:Name="TxtNaziv" Text="{Binding NazIvInfo}" IsReadOnly="True"
                         FontFamily="Tahoma" FontSize="10" Background="#FDB9B5"
                         BorderThickness="0" Padding="4,0" MinWidth="400"/>
            </StackPanel>
        </Border>

        <!-- Main body: Grid + Right panel -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation + Action buttons below grid -->
            <DockPanel Grid.Column="0">
                <!-- Nav + command buttons at bottom of grid area -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4,4,4">
                    <Button Content="◄◄" Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiNaVrhCommand}" ToolTip="PRVI"/>
                    <Button Content="◄"  Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiGoreCommand}" ToolTip="GORE"/>
                    <Button Content="►"  Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiDoleCommand}" ToolTip="DOLE"/>
                    <Button Content="►►" Width="32" Height="28" Margin="2,0" FontFamily="Tahoma" FontSize="10"
                            Command="{Binding IdiNaDnoCommand}" ToolTip="ZADNJI"/>
                    <Button Content="+" Width="46" Height="28" Margin="8,0,2,0"
                            FontFamily="Tahoma" FontSize="10" Background="#80FFFF"
                            Command="{Binding DodajCommand}" ToolTip="DODAVANJE NOVOG REDA"/>
                    <Button Content="PRAZNI NALOG S+F7" Width="140" Height="28" Margin="8,0,2,0"
                            FontFamily="Tahoma" FontSize="10" Background="#FFAAD5"
                            Command="{Binding PrazniNalogCommand}"/>
                    <Button Content="BRISANJE NALOGA" Width="130" Height="28" Margin="4,0,2,0"
                            FontFamily="Tahoma" FontSize="10" Background="#408080" Foreground="White"
                            Command="{Binding BrisanjeNalogaCommand}"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="GrdMain"
                          ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          FontFamily="Tahoma" FontSize="11"
                          Background="#F5F5F5"
                          RowBackground="#F5F5F5"
                          AlternatingRowBackground="#EEEEF8"
                          SelectionMode="Single"
                          HorizontalGridLinesBrush="#B7BCF9"
                          VerticalGridLinesBrush="#B7BCF9"
                          SelectionChanged="GrdMain_SelectionChanged"
                          CellEditEnding="GrdMain_CellEditEnding">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Arhiva}" Value=" ">
                                    <Setter Property="Background" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                            <Setter Property="Background" Value="#B8F8E3"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Konto"  Binding="{Binding Konto}"  Width="110"/>
                        <DataGridTextColumn Header="Dug"    Binding="{Binding Dug, StringFormat=N2}"   Width="130"/>
                        <DataGridTextColumn Header="Pot"    Binding="{Binding Pot, StringFormat=N2}"   Width="130"/>
                        <DataGridTextColumn Header="Opis"   Binding="{Binding Opis}"   Width="220"/>
                        <DataGridTextColumn Header="Datdok" Binding="{Binding Datdok, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Brnal"  Binding="{Binding Brnal}"  Width="70"/>
                        <DataGridTextColumn Header="Arhiva" Binding="{Binding Arhiva}" Width="55" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Right panel: Totals + Buttons -->
            <DockPanel Grid.Column="1" Margin="4,0,4,0">
                <!-- IZLAZ at bottom right -->
                <Button DockPanel.Dock="Bottom" Content="IZLAZ" Height="36" Margin="4,4"
                        FontFamily="Tahoma" FontSize="11" Background="#C0C0C0" Foreground="Red"
                        Command="{Binding IzlazCommand}"/>

                <StackPanel>
                    <!-- Totals -->
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="DUGUJE" FontFamily="Arial" FontSize="12" FontWeight="Bold"
                               Foreground="#000080" Background="#80FFFF" BorderThickness="1" BorderBrush="Gray" Padding="2"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TxtDug}" IsReadOnly="True"
                                 FontFamily="Arial" FontSize="12" Background="#80FFFF"
                                 TextAlignment="Right" Padding="2" BorderThickness="1"/>
                        <Label Grid.Row="1" Grid.Column="0" Content="POTRAŽUJE" FontFamily="Arial" FontSize="12" FontWeight="Bold"
                               Foreground="Green" Background="White" BorderThickness="1" BorderBrush="Gray" Padding="2"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TxtPot}" IsReadOnly="True"
                                 FontFamily="Arial" FontSize="12" Background="White"
                                 TextAlignment="Right" Padding="2" BorderThickness="1"/>
                        <Label x:Name="LblSaldo" Grid.Row="2" Grid.Column="0" Content="SALDO" FontFamily="Arial" FontSize="12" FontWeight="Bold"
                               Foreground="#800000" Background="#A8FFA8" BorderThickness="1" BorderBrush="Gray" Padding="2"/>
                        <TextBox x:Name="TxtSaldo" Grid.Row="2" Grid.Column="1" Text="{Binding TxtSaldo}" IsReadOnly="True"
                                 FontFamily="Arial" FontSize="12" Background="#A8FFA8"
                                 TextAlignment="Right" Padding="2" BorderThickness="1"/>
                    </Grid>

                    <!-- Action buttons -->
                    <Button Content="KONTNI PLAN F4"      Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#F3FA63" Command="{Binding KontniPlanCommand}"/>
                    <Button Content="KNJIZI F5"           Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#F3FA63" Command="{Binding KnjiziF5Command}"/>
                    <Button Content="TRAŽENJE NALOGA F9"  Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#F3FA63" Command="{Binding TraziNalogF9Command}"/>
                    <Button Content="NALOG F10"           Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#F3FA63" Command="{Binding NalogF10Command}"/>
                    <Button Content="TRAŽENJE KONTA F7"   Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#F3FA63" Command="{Binding TraziKontoF7Command}"/>
                    <Button Content="KONTO F6"            Height="32" Margin="4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#F3FA63" Command="{Binding KontoF6Command}"/>
                    <Button Content="ZAKLJUČNI LIST"      Height="32" Margin="4,8,4,2" FontFamily="Tahoma" FontSize="11"
                            Background="#D6D6D6" Foreground="#800000"
                            Command="{Binding ZakljucniListCommand}"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
