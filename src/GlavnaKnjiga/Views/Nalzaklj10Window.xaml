<Window x:Class="GlavnaKnjiga.Views.Nalzaklj10Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OSNOVNI ZAKLJUČNI LIST"
        Height="240" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Konto -->
        <Label Grid.Row="0" Grid.Column="0" Content="Konto"
               FontFamily="Tahoma" FontSize="11" Foreground="#BE0000" Background="#80FF80" Padding="2"/>
        <TextBox x:Name="TxtKonp" Grid.Row="0" Grid.Column="1" MaxLength="10"
                 FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Početni datum -->
        <Label Grid.Row="1" Grid.Column="0" Content="Početni datum"
               FontFamily="Tahoma" FontSize="11" Foreground="#BE0000" Background="#80FFFF" Padding="2"/>
        <DatePicker x:Name="TxtDat0" Grid.Row="1" Grid.Column="1"
                    FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Zadnji datum -->
        <Label Grid.Row="2" Grid.Column="0" Content="Zadnji datum"
               FontFamily="Tahoma" FontSize="11" Foreground="#BE0000" Background="#80FFFF" Padding="2"/>
        <DatePicker x:Name="TxtDat1" Grid.Row="2" Grid.Column="1"
                    FontFamily="Tahoma" FontSize="11" Margin="0,2"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button x:Name="BtnPregled" Content="PREGLED" Width="120" Height="36"
                    FontFamily="Tahoma" FontSize="11" Background="#C0C0C0"
                    Click="BtnPregled_Click"/>
            <Button Content="Izlaz" Width="80" Height="36" Margin="12,0,0,0"
                    FontFamily="Tahoma" FontSize="11" Background="#C0C0C0" Foreground="Red"
                    Click="BtnIzlaz_Click"/>
        </StackPanel>
    </Grid>
</Window>
