<Window x:Class="GlavnaKnjiga.Views.NalzamenakontaZamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PREKNJIŻAVANJE KONTA"
        Height="500" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#D8E0D0"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Buttons -->
        <WrapPanel DockPanel.Dock="Bottom" Margin="6,4" HorizontalAlignment="Center">
            <Button Content="DODAJ"          Width="90"  Margin="4,2" Background="#C0C0C0"
                    Command="{Binding DodajCommand}"/>
            <Button Content="BRISANJE REDA"  Width="110" Margin="4,2" Background="#C0C0C0"
                    Command="{Binding BrisanjeRedaCommand}"/>
            <Button Content="BRISANJE TABELE" Width="120" Margin="4,2" Background="#E09090"
                    Command="{Binding BrisanjeTabeleCommand}"/>
            <Button Content="ZAMENI"         Width="80"  Margin="4,2" Background="#90C090"
                    Command="{Binding ZameniCommand}"/>
            <Button Content="KOPIRAJ U GK"   Width="110" Margin="4,2" Background="#9090C0"
                    Command="{Binding KopirajUGlavnuKnjiguCommand}"/>
            <Button Content="PRVI"           Width="50"  Margin="4,2"
                    Command="{Binding IdiNaVrhCommand}"/>
            <Button Content="GORE"           Width="50"  Margin="4,2"
                    Command="{Binding IdiGoreCommand}"/>
            <Button Content="DOLE"           Width="50"  Margin="4,2"
                    Command="{Binding IdiDoleCommand}"/>
            <Button Content="ZADNJI"         Width="55"  Margin="4,2"
                    Command="{Binding IdiNaDnoCommand}"/>
            <Button Content="Izlaz"          Width="75"  Margin="4,2" Background="#C0C0C0"
                    Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid x:Name="Grd0"
                  ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelektovaniRed}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="10"
                  SelectionMode="Single"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Staro konto (SKONTO)" Binding="{Binding Skonto, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                <DataGridTextColumn Header="Deo"                  Binding="{Binding Deo,    UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                <DataGridTextColumn Header="Novo konto (KONTO)"  Binding="{Binding Konto,  UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                <DataGridTextColumn Header="Naziv"               Binding="{Binding Naziv,  UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                <DataGridTextColumn Header="Nazkto1"             Binding="{Binding Nazkto1,UpdateSourceTrigger=PropertyChanged}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
