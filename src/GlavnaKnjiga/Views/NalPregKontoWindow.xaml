<Window x:Class="GlavnaKnjiga.Views.NalPregKontoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PREGLED KONTA"
        Width="650" Height="690"
        WindowStartupLocation="CenterOwner"
        Background="#ECE9D8"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="18">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontFamily" Value="Tahoma"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#8B0000"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Height" Value="28"/>
                <Setter Property="Margin" Value="0,3"/>
                <Setter Property="FontFamily" Value="Tahoma"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Konto" Background="#80FF80" Padding="5"/>
        <TextBox Grid.Row="0" Grid.Column="1" MaxLength="10"
                 Text="{Binding Konto, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Text="Početni datum" Background="#80FFFF" Padding="5"/>
        <DatePicker Grid.Row="1" Grid.Column="1" Height="28" Margin="0,3"
                    SelectedDate="{Binding DatumOd}"/>

        <TextBlock Grid.Row="2" Text="Zadnji datum" Background="#80FFFF" Padding="5"/>
        <DatePicker Grid.Row="2" Grid.Column="1" Height="28" Margin="0,3"
                    SelectedDate="{Binding DatumDo}"/>

        <TextBlock Grid.Row="3" Text="Objekat" Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="3" Grid.Column="1" MaxLength="3" Width="70"
                 HorizontalAlignment="Left"
                 Text="{Binding Dok, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="4" Text="Mesto-grad" Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="4" Grid.Column="1" MaxLength="2" Width="60"
                 HorizontalAlignment="Left"
                 Text="{Binding Mp, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="5" Text="Mesto troškova" Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="5" Grid.Column="1" MaxLength="5" Width="85"
                 HorizontalAlignment="Left"
                 Text="{Binding Mtr, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="6" Text="Saldo po danima DA/NE" Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="6" Grid.Column="1" MaxLength="1" Width="45"
                 HorizontalAlignment="Left"
                 Text="{Binding SaldoPoDanima, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="7" Text="Padajući saldo DA/NE" Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="7" Grid.Column="1" MaxLength="1" Width="45"
                 HorizontalAlignment="Left"
                 Text="{Binding PadajuciSaldo, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="8" Text="Saldo po mesecima DA/NE" Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="8" Grid.Column="1" MaxLength="1" Width="45"
                 HorizontalAlignment="Left"
                 Text="{Binding SaldoPoMesecima, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="9" Text="Sve / duguje / potražuje = S/D/P"
                   Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="9" Grid.Column="1" MaxLength="1" Width="45"
                 HorizontalAlignment="Left"
                 Text="{Binding DugPotSve, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="10" Text="Sortirano po vrednosti DA/NE"
                   Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="10" Grid.Column="1" MaxLength="1" Width="45"
                 HorizontalAlignment="Left"
                 Text="{Binding SortiranoPoVrednosti, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="11" Text="Izbaci slične stavke DA/NE"
                   Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="11" Grid.Column="1" MaxLength="1" Width="45"
                 HorizontalAlignment="Left"
                 Text="{Binding IzbaciSlicne, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="12" Text="Svedi sličnost na dinara"
                   Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="12" Grid.Column="1" Width="110" HorizontalAlignment="Left"
                 Text="{Binding Tolerancija, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="13" Text="Opis (početak teksta)"
                   Background="#FFFF80" Padding="5"/>
        <TextBox Grid.Row="13" Grid.Column="1" MaxLength="30"
                 Text="{Binding Opis, UpdateSourceTrigger=PropertyChanged}"/>

        <Border Grid.Row="15" Grid.ColumnSpan="2" Margin="0,10,0,0"
                Padding="10" Background="#F7F7F7" BorderBrush="#B0B0B0" BorderThickness="1">
            <TextBlock Foreground="#444" TextWrapping="Wrap"
                       Text="D = da, N = ne. Konto kraće od 10 cifara obuhvata sva analitička konta koja počinju tim brojem."/>
        </Border>

        <StackPanel Grid.Row="16" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="PREGLED" Width="150" Height="40" Margin="4"
                    FontWeight="Bold" Command="{Binding PregledCommand}"/>
            <Button Content="IZLAZ" Width="100" Height="40" Margin="4"
                    Foreground="#B00000" Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
