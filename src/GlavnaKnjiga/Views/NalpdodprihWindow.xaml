<Window x:Class="GlavnaKnjiga.Views.NalpdodprihWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Height="170" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECE9D8"
        KeyDown="Window_KeyDown">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="KNJIŽENJE DODATNIH PRIHODA I RASHODA"
                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"
                   Background="#F1D1AD" Padding="8,4"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="DODATNI IZNOS" Foreground="#BE0000"
                       TextDecorations="Underline" FontSize="11" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" FontSize="11"
                     Text="{Binding Iznos, StringFormat={}{0:F2}, UpdateSourceTrigger=LostFocus}"
                     HorizontalAlignment="Stretch"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Potvrda" Width="100" Margin="8,0" Background="#C0C0C0"
                    Command="{Binding KnjiziCommand}"/>
            <Button Content="IZLAZ"     Width="80"  Margin="8,0" Background="#C0C0C0" Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>
    </Grid>
</Window>
