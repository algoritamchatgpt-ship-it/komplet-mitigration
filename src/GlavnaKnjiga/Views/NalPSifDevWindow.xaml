<Window x:Class="GlavnaKnjiga.Views.NalPSifDevWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIFARNIK DEVIZA"
        Height="450" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2B2B8C" Padding="8,4">
            <TextBlock Text="SIFARNIK DEVIZA" Foreground="White" FontSize="11" FontWeight="Bold"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4">
            <Button Content="DODAJ NOV" Width="100" Margin="2" Background="#C0C0C0"
                    Command="{Binding DodajNovCommand}"/>
            <Button Content="Izlaz"     Width="80"  Margin="2" Background="#C0C0C0" Foreground="Red"
                    Command="{Binding IzlazCommand}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  FontSize="11"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Dev"    Binding="{Binding Dev}"    Width="60"/>
                <DataGridTextColumn Header="Datdok" Binding="{Binding Datdok, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Kurs"   Binding="{Binding Kurs,   StringFormat={}{0:F6}}" Width="110"/>
                <DataGridTextColumn Header="Skurs"  Binding="{Binding Skurs,  StringFormat={}{0:F6}}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
