<Window x:Class="GlavnaKnjiga.Views.NalvrstaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VRSTE NALOGA ZA KNJIŽENJE"
        Height="560" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#B7BCF9"
        KeyDown="Window_KeyDown">

    <DockPanel>
        <!-- Info label -->
        <Border DockPanel.Dock="Top" Background="#E2FE DA" BorderBrush="#B7BCF9" BorderThickness="0,0,0,1" Height="26">
            <TextBlock Text="{Binding LabelInfo}" FontFamily="Tahoma" FontSize="11"
                       VerticalAlignment="Center" Margin="4,0"/>
        </Border>

        <!-- Dugmad dno -->
        <WrapPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4">
            <Button Content="PRVI"         Width="55"  Margin="2" Command="{Binding IdiNaVrhCommand}"   Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Button Content="GORE"         Width="55"  Margin="2" Command="{Binding IdiGoreCommand}"    Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Button Content="DOLE"         Width="55"  Margin="2" Command="{Binding IdiDoleCommand}"    Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Button Content="ZADNJI"       Width="55"  Margin="2" Command="{Binding IdiNaDnoCommand}"   Background="#C0C0C0" FontFamily="Tahoma" FontSize="9"/>
            <Button Content="DODAJ"        Width="75"  Margin="2" Command="{Binding DodajCommand}"      Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="KARTICA F7"   Width="90"  Margin="2" Command="{Binding KarticaF7Command}"  Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="BRISANJE S+F10" Width="110" Margin="2" Command="{Binding BrisanjeF10Command}" Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="ŠABLONI F8"   Width="90"  Margin="2" Command="{Binding SabloniF8Command}"  Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="DOPUNI KONTO" Width="110" Margin="2" Command="{Binding DopuniKontoCommand}" Background="#C0C0C0" FontFamily="Tahoma" FontSize="11"/>
            <Button Content="Izlaz"        Width="70"  Margin="2" Command="{Binding IzlazCommand}"      Background="#C0C0C0" FontFamily="Tahoma" FontSize="11" Foreground="Red"/>
        </WrapPanel>

        <!-- Grid -->
        <DataGrid ItemsSource="{Binding Redovi}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  FontFamily="Tahoma" FontSize="11"
                  Background="#F5F5F5"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#B7BCF9"
                  VerticalGridLinesBrush="#B7BCF9"
                  SelectionMode="Single"
                  Margin="2"
                  MouseDoubleClick="Grid_DoubleClick">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontFamily" Value="Tahoma"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Background" Value="#B7BCF9"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vrnal"   Binding="{Binding Vrnal}"   Width="45"/>
                <DataGridTextColumn Header="Naziv"   Binding="{Binding Naziv}"   Width="200"/>
                <DataGridTextColumn Header="Dok"     Binding="{Binding Dok}"     Width="35"/>
                <DataGridTextColumn Header="Mp"      Binding="{Binding Mp}"      Width="30"/>
                <DataGridTextColumn Header="Obl"     Binding="{Binding Obl}"     Width="30"/>
                <DataGridTextColumn Header="Period"  Binding="{Binding Period}"  Width="45"/>
                <DataGridTextColumn Header="Naldok"  Binding="{Binding Naldok}"  Width="50"/>
                <DataGridTextColumn Header="Znakovi" Binding="{Binding Znakovi}" Width="55"/>
                <DataGridTextColumn Header="Pocsif"  Binding="{Binding Pocsif}"  Width="45"/>
                <DataGridTextColumn Header="Nauto"   Binding="{Binding Nauto}"   Width="40"/>
                <DataGridTextColumn Header="Konto"   Binding="{Binding Konto}"   Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
