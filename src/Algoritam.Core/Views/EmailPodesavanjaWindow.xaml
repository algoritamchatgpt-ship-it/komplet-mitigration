<Window x:Class="Algoritam.Core.Views.EmailPodesavanjaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SMTP Podesavanja"
        Width="480" Height="410"
        MinWidth="400" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F8" FontFamily="Segoe UI">
    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="SMTP Podesavanja e-maila"
                   FontSize="15" FontWeight="SemiBold" Foreground="#1A237E"
                   Margin="0,0,0,14"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="SMTP Server:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SmtpServer, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5" Padding="4,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,5"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                         Width="70" Padding="4,3"/>
                <CheckBox Content="Koristi TLS (port 587)" IsChecked="{Binding KoristiTls}"
                          VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Korisnicko ime:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding KorisnickoIme, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5" Padding="4,3"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Lozinka:" VerticalAlignment="Center" Margin="0,5"/>
            <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="LozinkaBox"
                         Margin="0,5" Padding="4,3"
                         PasswordChanged="OnLozinkaChanged"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="E-mail posiljaoca:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PosiljaoceEmail, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5" Padding="4,3"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Ime posiljaoca:" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding PosiljaoceIme, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5" Padding="4,3"/>
        </Grid>

        <Border Grid.Row="2" Background="#FFF8E1" CornerRadius="4"
                BorderBrush="#FFE082" BorderThickness="1" Padding="8,6" Margin="0,8,0,4">
            <TextBlock Text="{Binding Poruka}" Foreground="#5D4037" FontSize="11"
                       TextWrapping="Wrap" MinHeight="16"/>
        </Border>

        <Border Grid.Row="3" Background="#D8E4F0" Padding="10,7"
                BorderBrush="#B8CCE4" BorderThickness="0,1,0,0" Margin="-20,4,-20,-16">
            <DockPanel>
                <Button Content="Zatvori" DockPanel.Dock="Right"
                        Width="84" Height="28"
                        Background="#607D8B" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        IsCancel="True" Click="OnZatvoriClick"/>
                <Button Content="Sacuvaj" DockPanel.Dock="Right" Margin="0,0,6,0"
                        Width="84" Height="28"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding SacuvajCommand}"/>
                <Button Content="Testiraj vezu" Height="28" HorizontalAlignment="Left"
                        Padding="14,0"
                        Background="#2E7D32" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding TestirajCommand}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
