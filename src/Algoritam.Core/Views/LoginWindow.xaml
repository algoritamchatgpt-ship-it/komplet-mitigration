<Window x:Class="Algoritam.Core.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PRIJAVA — OSNOVNA SREDSTVA"
        Width="520" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#E3F2FD">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="FIN OSNOVNA SREDSTVA"
                           FontFamily="Tahoma" FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Određivanje korisnika i prava pristupa"
                           FontFamily="Tahoma" FontSize="11"
                           Foreground="#BBDEFB" HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ FORMA ═══ -->
        <Grid Grid.Row="1" Margin="48,24,48,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Korisnik -->
            <TextBlock Grid.Row="0" Text="Korisnik"
                       Style="{StaticResource LabelStyle}"
                       Foreground="#0D47A1"/>

            <TextBox Grid.Row="2"
                     Style="{StaticResource InputStyle}"
                     Text="{Binding KorisnikIme, UpdateSourceTrigger=PropertyChanged}"
                     x:Name="TxtKorisnik"/>

            <!-- Lozinka -->
            <TextBlock Grid.Row="4" Text="Lozinka"
                       Style="{StaticResource LabelStyle}"
                       Foreground="#0D47A1"/>

            <PasswordBox Grid.Row="6"
                         x:Name="TxtLozinka"
                         FontFamily="Tahoma" FontSize="13"
                         Height="30" Padding="6,4"
                         BorderBrush="#888" BorderThickness="1"
                         Background="White"
                         PasswordChanged="TxtLozinka_PasswordChanged"/>

            <!-- Lokalni mod hint -->
            <TextBlock Grid.Row="7"
                       Margin="0,8,0,0"
                       Text="Lokalni mod: lozinka nije obavezna."
                       FontFamily="Tahoma" FontSize="10"
                       Foreground="#1565C0"
                       Visibility="{Binding LozinkaNijeObavezna,
                           Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Poruka o grešci -->
            <Border Grid.Row="8" Margin="0,10,0,0"
                    Background="#E3F2FD" CornerRadius="3"
                    BorderBrush="#1565C0" BorderThickness="1"
                    Visibility="{Binding Poruka, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding Poruka}"
                           FontFamily="Tahoma" FontSize="12"
                           Foreground="#C62828"
                           Padding="10,8"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </Border>
        </Grid>

        <!-- ═══ FOOTER / DUGMAD ═══ -->
        <Grid Grid.Row="2" Margin="48,0,48,16" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="ULAZ"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#1565C0" Foreground="White" BorderBrush="#0D47A1"
                    Command="{Binding PrijavaCommand}"
                    IsDefault="True"/>

            <Button Grid.Column="2"
                    Content="IZLAZ"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#E53935" Foreground="White" BorderBrush="#C62828"
                    x:Name="BtnIzlaz"/>
        </Grid>

        <!-- Dijagnostika link -->
        <TextBlock Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Margin="48,0,0,6"
                   Text="dijagnostika DBF"
                   FontFamily="Tahoma" FontSize="10"
                   Foreground="#78909C"
                   TextDecorations="Underline" Cursor="Hand">
            <TextBlock.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding PrikaziDijagnostikuCommand}"/>
            </TextBlock.InputBindings>
        </TextBlock>
    </Grid>
</Window>
