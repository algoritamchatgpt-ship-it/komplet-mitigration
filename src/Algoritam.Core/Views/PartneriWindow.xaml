<Window x:Class="Algoritam.Core.Views.PartneriWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIFARNIK POSLOVNIH PARTNERA"
        Width="900" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="720" MinHeight="440"
        Background="#EEF2FF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#1565C0">
            <Grid Margin="16,0">
                <TextBlock Text="SIFARNIK POSLOVNIH PARTNERA"
                           FontFamily="Tahoma" FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <ProgressBar HorizontalAlignment="Right" Width="180" Height="4"
                             IsIndeterminate="True" Foreground="#90CAF9" Background="#0D47A1"
                             BorderThickness="0" VerticalAlignment="Center"
                             Visibility="{Binding Ucitava, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ═══ PRETRAGA ═══ -->
        <Grid Grid.Row="1" Margin="12,8,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Pretraga:" FontFamily="Tahoma" FontSize="11"
                       VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#37474F"/>
            <TextBox Grid.Column="1" Text="{Binding Pretraga, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Tahoma" FontSize="12"
                     Padding="6,4" BorderBrush="#90CAF9" BorderThickness="1"/>
            <Button Grid.Column="2" Content="Traži šifru" Margin="6,0,0,0"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#0288D1" Foreground="White" BorderBrush="#01579B"
                    Width="90" Command="{Binding TraziSifruCommand}"/>
            <Button Grid.Column="4" Content="Traži naziv"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#0288D1" Foreground="White" BorderBrush="#01579B"
                    Width="90" Command="{Binding TraziNazivCommand}"/>
        </Grid>

        <!-- ═══ TABELA ═══ -->
        <DataGrid Grid.Row="2" Margin="12,0,12,0"
                  ItemsSource="{Binding Stavke}"
                  SelectedItem="{Binding Selektovani}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  FontFamily="Tahoma" FontSize="11"
                  Background="White"
                  BorderBrush="#90CAF9" BorderThickness="1"
                  RowBackground="White"
                  AlternatingRowBackground="#F8F9FF"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Šifra" Binding="{Binding Sifra}" Width="60"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="220"/>
                <DataGridTextColumn Header="Pošta" Binding="{Binding Posta}" Width="60"/>
                <DataGridTextColumn Header="Mesto" Binding="{Binding Mesto}" Width="140"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="110"/>
                <DataGridTextColumn Header="PIB" Binding="{Binding Pib}" Width="90"/>
                <DataGridTextColumn Header="Matični" Binding="{Binding Maticni}" Width="90"/>
                <DataGridTextColumn Header="Žiro račun" Binding="{Binding ZiroRac}" Width="160"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#BBDEFB"/>
                            <Setter Property="Foreground" Value="#0D47A1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- ═══ PORUKA ═══ -->
        <Border Grid.Row="3" Background="#E8EAF6" Padding="12,6"
                Visibility="{Binding Poruka, Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding Poruka}" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
        </Border>

        <!-- ═══ DUGMAD ═══ -->
        <Grid Grid.Row="4" Margin="12,0,12,12" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Dodaj"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#388E3C" Foreground="White" BorderBrush="#2E7D32"
                    Width="80" Command="{Binding DodajCommand}"/>

            <Button Grid.Column="2" Content="Izmeni"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#F57C00" Foreground="White" BorderBrush="#E65100"
                    Width="80" Command="{Binding IzmeniCommand}"/>

            <Button Grid.Column="4" Content="Obriši"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#D32F2F" Foreground="White" BorderBrush="#B71C1C"
                    Width="80" Command="{Binding ObrisiCommand}"/>

            <Button Grid.Column="6" Content="Kopiraj"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#7B1FA2" Foreground="White" BorderBrush="#6A1B9A"
                    Width="80" Command="{Binding KopirajRedCommand}"/>

            <Button Grid.Column="8" Content="SAČUVAJ"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#1565C0" Foreground="White" BorderBrush="#0D47A1"
                    Width="90" IsDefault="True"
                    Command="{Binding SacuvajCommand}"/>

            <Button Grid.Column="10" Content="Osveži"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#546E7A" Foreground="White" BorderBrush="#37474F"
                    Width="80" Command="{Binding UcitajCommand}"/>
        </Grid>
    </Grid>
</Window>
