<Window x:Class="Algoritam.Core.Views.PartnerKarticaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Naslov}"
        Width="560" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2FF"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1565C0">
            <TextBlock Text="{Binding Naslov}"
                       FontFamily="Tahoma" FontSize="14" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center" Margin="16,0"/>
        </Border>

        <!-- FORMA -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0">
            <Grid Margin="20,16,20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Šifra *:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Stavka.Sifra, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Naziv *:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Stavka.Naziv, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="40"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Naziv 2:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Stavka.Naziv2, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="40"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Pošta:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Stavka.Posta, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="10"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Mesto:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Stavka.Mesto, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="30"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Ulica:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <Grid Grid.Row="10" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Stavka.Ulica, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="30"/>
                    <TextBox Grid.Column="2" Text="{Binding Stavka.Ulbroj, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="6"/>
                </Grid>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="Telefon:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding Stavka.Telefon, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="20"/>

                <TextBlock Grid.Row="14" Grid.Column="0" Text="PIB:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding Stavka.Pib, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="15"/>

                <TextBlock Grid.Row="16" Grid.Column="0" Text="Matični:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="16" Grid.Column="1" Text="{Binding Stavka.Maticni, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="15"/>

                <TextBlock Grid.Row="18" Grid.Column="0" Text="Žiro račun:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="18" Grid.Column="1" Text="{Binding Stavka.ZiroRac, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="30"/>

                <TextBlock Grid.Row="20" Grid.Column="0" Text="Email:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="20" Grid.Column="1" Text="{Binding Stavka.Email, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="60"/>

                <TextBlock Grid.Row="22" Grid.Column="0" Text="Kontakt lice:" VerticalAlignment="Center" FontFamily="Tahoma" FontSize="11" Foreground="#37474F"/>
                <TextBox Grid.Row="22" Grid.Column="1" Text="{Binding Stavka.Lice1, UpdateSourceTrigger=PropertyChanged}" FontFamily="Tahoma" FontSize="12" Padding="5,3" BorderBrush="#90CAF9" BorderThickness="1" MaxLength="30"/>
            </Grid>
        </ScrollViewer>

        <!-- DUGMAD -->
        <Grid Grid.Row="2" Margin="20,0,20,16" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="POTVRDI"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#1565C0" Foreground="White" BorderBrush="#0D47A1"
                    Width="100" IsDefault="True"
                    Command="{Binding PotvrdiCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Grid.Column="3" Content="Otkaži"
                    Style="{StaticResource OsDugmeStyle}"
                    Background="#546E7A" Foreground="White" BorderBrush="#37474F"
                    Width="90" IsCancel="True"
                    Command="{Binding OtkaziCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>
    </Grid>
</Window>
